---
import SEOHead from '../components/SEOHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { hasNoTrackCookie } from '../lib/no-track';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  ogType?: string;
  publishDate?: Date;
  updateDate?: Date;
  schema?: Record<string, unknown> | Record<string, unknown>[];
  noindex?: boolean;
}

// Routes privées : zéro tracking (GA4, tarteaucitron, attribution cookie)
// + noindex forcé pour défense en profondeur.
const isAdminRoute = Astro.url.pathname.startsWith('/admin/');

// Opt-out admin via cookie `lga_no_track` (cf. /admin/no-track) — bloque
// tarteaucitron + gtag delegate AVANT chargement du tag Google.
const isOptedOut = hasNoTrackCookie(Astro.cookies);
const skipTracking = isAdminRoute || isOptedOut;

const props = { ...Astro.props, noindex: Astro.props.noindex ?? isAdminRoute };
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Merriweather:wght@400;700&display=swap"
      rel="stylesheet"
    />
    <SEOHead {...props} />
    <slot name="head" />
    {!skipTracking && (
      <>
        <!-- Tarteaucitron CMP (CNIL-compliant, self-hosted) + GA4 conditionnel -->
        <link rel="stylesheet" href="/tarteaucitron-custom.css" />
        <script is:inline src="/tarteaucitron/tarteaucitron.min.js"></script>
        <script is:inline define:vars={{ measurementId: 'G-1GHQCKDVPM' }}>
          window.tarteaucitronForceLanguage = 'fr';
          tarteaucitron.init({
            privacyUrl: '/politique-confidentialite/',
            bodyPosition: 'top',
            hashtag: '#tarteaucitron',
            cookieName: 'tarteaucitron',
            orientation: 'bottom',
            groupServices: true,
            showDetailsOnClick: true,
            serviceDefaultState: 'wait',
            showAlertSmall: false,
            cookieslist: false,
            closePopup: true,
            showIcon: true,
            iconPosition: 'BottomLeft',
            DenyAllCta: true,
            AcceptAllCta: true,
            highPrivacy: true,
            mandatory: true,
            mandatoryCta: true,
            googleConsentMode: false,
            bingConsentMode: false,
          });
          tarteaucitron.user.gtagUa = measurementId;
          (tarteaucitron.job = tarteaucitron.job || []).push('gtag');
        </script>
      </>
    )}
    {!isAdminRoute && (
      <!-- Attribution first-touch (UTM, gclid, referrer) — cookie first-party CNIL-exempt.
           Reste actif même en opt-out admin (volontaire, ne touche pas GA4). -->
      <script>
        import { captureAttribution } from '../lib/tracking';
        captureAttribution();
      </script>
    )}
  </head>
  <body>
    <a href="#main-content" class="skip-to-content">Aller au contenu principal</a>
    {isOptedOut && (
      <a
        href="/admin/no-track/"
        class="lga-no-track-badge"
        title="Tracking GA4 désactivé sur ce navigateur — cliquer pour gérer"
      >
        Tracking OFF
      </a>
    )}
    <Header />
    <main id="main-content">
      <slot />
    </main>
    <Footer />
    {!skipTracking && (
      <script>
        // Tracking clics liens affilies
        document.addEventListener('click', (e) => {
          const link = (e.target as Element).closest('a[rel*="sponsored"]');
          if (link && typeof window.gtag === 'function') {
            window.gtag('event', 'click_affiliate', {
              event_category: 'conversion',
              event_label: link.getAttribute('href'),
              link_text: link.textContent?.trim().slice(0, 50),
            });
          }
        });
      </script>
    )}
    <style>
      .lga-no-track-badge {
        position: fixed;
        bottom: 1rem;
        left: 1rem;
        z-index: 9999;
        background: #D97B3D;
        color: white;
        padding: 0.4rem 0.8rem;
        border-radius: 0.5rem;
        font-size: 0.75rem;
        font-weight: 600;
        letter-spacing: 0.05em;
        text-decoration: none;
        opacity: 0.85;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
        transition: opacity 0.2s;
      }
      .lga-no-track-badge:hover {
        opacity: 1;
      }
    </style>
    <script>
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.15 }
      );
      document.querySelectorAll('[data-animate]').forEach((el) => observer.observe(el));
    </script>
  </body>
</html>
