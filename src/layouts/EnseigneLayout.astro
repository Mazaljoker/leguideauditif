---
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import AuthorBox from '../components/AuthorBox.astro';
import HealthDisclaimer from '../components/HealthDisclaimer.astro';

interface Props {
  title: string;
  metaTitle?: string;
  metaDescription: string;
  enseigne: string;
  author: string;
  authorTitle: string;
  publishDate: Date;
  updateDate?: Date;
  headings: { depth: number; slug: string; text: string }[];
  faq?: { question: string; answer: string }[];
  image?: string;
  ogImage?: string;
  centresCount?: number;
}

const {
  title,
  metaTitle,
  metaDescription,
  enseigne,
  author,
  authorTitle,
  publishDate,
  updateDate,
  headings,
  faq,
  image,
  ogImage,
  centresCount,
} = Astro.props;

const breadcrumbs = [
  { label: 'Accueil', href: '/' },
  { label: 'Enseignes', href: '/enseignes/' },
  { label: enseigne },
];

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description: metaDescription,
  ...(ogImage && { image: new URL(ogImage, Astro.site).href }),
  author: {
    '@type': 'Person',
    '@id': 'https://leguideauditif.fr/#author',
    name: author,
    jobTitle: authorTitle,
    description: "Audioprothésiste DE, 28 ans d'expérience — Amplifon, Audika, 18 centres Afflelou, 5 ans Auzen.com, 3 000+ patients.",
    url: 'https://leguideauditif.fr/auteur/franck-olivier/',
    sameAs: ['https://www.linkedin.com/in/franck-olivier-chabbat-/'],
    hasCredential: [
      {
        '@type': 'EducationalOccupationalCredential',
        credentialCategory: 'degree',
        name: "Diplôme d'État d'audioprothésiste",
        recognizedBy: { '@type': 'Organization', name: 'Ministère de la Santé' },
      },
    ],
    identifier: {
      '@type': 'PropertyValue',
      propertyID: 'ADELI',
      value: '692606494',
      description: 'Numéro ADELI — Répertoire national des professionnels de santé',
    },
  },
  datePublished: publishDate.toISOString(),
  ...(updateDate && { dateModified: updateDate.toISOString() }),
  publisher: {
    '@type': 'Organization',
    name: 'LeGuideAuditif.fr',
    url: 'https://leguideauditif.fr',
  },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: breadcrumbs.map((item, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: item.label,
    ...(item.href && { item: new URL(item.href, Astro.site).href }),
  })),
};

const schemas: Record<string, unknown>[] = [articleSchema, breadcrumbSchema];

if (faq && faq.length > 0) {
  schemas.push({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faq.map((f) => ({
      '@type': 'Question',
      name: f.question,
      acceptedAnswer: { '@type': 'Answer', text: f.answer },
    })),
  });
}

const formattedDate = publishDate.toLocaleDateString('fr-FR', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const formattedUpdate = updateDate?.toLocaleDateString('fr-FR', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout
  title={metaTitle || title}
  description={metaDescription}
  ogImage={ogImage}
  ogType="article"
  publishDate={publishDate}
  updateDate={updateDate}
  schema={schemas}
>
  <div class="bg-creme">
    <div class="max-w-[780px] mx-auto px-5 py-4">
      <Breadcrumbs items={breadcrumbs} includeSchema={false} />
    </div>
  </div>

  <article class="bg-creme pb-16">
    <div class="max-w-[780px] mx-auto px-5">
      {image && (
        <img
          src={image}
          alt={title}
          class="w-full rounded-2xl mb-8"
          width="780"
          height="440"
          loading="eager"
        />
      )}

      <header class="mb-8">
        <h1 class="font-sans text-[32px] lg:text-[38px] font-extrabold text-marine leading-tight mb-4">{title}</h1>
        <div class="flex flex-wrap items-center gap-4 text-sm font-sans text-gris-texte">
          <span>Par <strong class="text-marine">{author}</strong>, {authorTitle}</span>
          <span>|</span>
          <time datetime={publishDate.toISOString()}>Publié le {formattedDate}</time>
          {formattedUpdate && (
            <>
              <span>|</span>
              <time datetime={updateDate!.toISOString()}>Mis à jour le {formattedUpdate}</time>
            </>
          )}
        </div>
        {centresCount !== undefined && centresCount > 0 && (
          <p class="mt-3 text-sm font-sans text-orange font-semibold">
            {centresCount} centres {enseigne} référencés en France
          </p>
        )}
      </header>

      <div class="bg-[#fef9f0] border border-[#f0dcc4] rounded-xl px-5 py-4 mb-8 text-sm text-gris-texte font-sans">
        <strong class="text-marine">Information santé :</strong> Ce contenu est informatif et ne remplace pas une consultation avec un professionnel de santé. Dernière revue : avril 2026.
      </div>

      <div class="prose prose-lg max-w-none
        prose-headings:font-sans prose-headings:text-marine prose-headings:font-bold
        prose-h2:text-2xl prose-h2:mt-12 prose-h2:mb-4
        prose-h3:text-xl prose-h3:mt-8 prose-h3:mb-3
        prose-p:text-marine prose-p:leading-relaxed
        prose-a:text-orange prose-a:font-medium hover:prose-a:underline
        prose-strong:text-marine
        prose-li:text-marine
      ">
        <slot />
      </div>

      {faq && faq.length > 0 && (
        <section class="mt-12">
          <h2 class="font-sans text-2xl font-bold text-marine mb-6">Questions fréquentes</h2>
          {faq.map((f) => (
            <details class="bg-blanc rounded-xl mb-3 shadow-[0_1px_4px_rgba(27,46,74,0.05)] group">
              <summary class="px-6 py-5 font-sans text-[17px] font-semibold text-marine cursor-pointer list-none flex justify-between items-center">
                <span>{f.question}</span>
                <span class="text-xl transition-transform group-open:rotate-45">+</span>
              </summary>
              <div class="px-6 pb-5 text-gris-texte text-base leading-relaxed">{f.answer}</div>
            </details>
          ))}
        </section>
      )}

      <AuthorBox />
      <HealthDisclaimer />
    </div>
  </article>
</BaseLayout>
