---
import BaseLayout from './BaseLayout.astro';
import AuthorBox from '../components/AuthorBox.astro';
import HealthDisclaimer from '../components/HealthDisclaimer.astro';
import AffiliateDisclosure from '../components/AffiliateDisclosure.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  author?: string;
  image?: string;
  imageAlt?: string;
  productsCompared?: number;
  category?: string;
}

const {
  title,
  description,
  pubDate,
  updatedDate,
  author = 'Franck-Olivier, Audioprothésiste DE',
  image,
  imageAlt,
  productsCompared,
  category,
} = Astro.props;

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  image: image ? new URL(image, Astro.site).href : undefined,
  datePublished: pubDate.toISOString(),
  dateModified: (updatedDate || pubDate).toISOString(),
  author: {
    '@type': 'Person',
    name: 'Franck-Olivier',
    jobTitle: 'Audioprothésiste DE',
    url: new URL('/auteur/franck-olivier/', Astro.site).href,
  },
  publisher: {
    '@type': 'Organization',
    name: 'LeGuideAuditif.fr',
  },
};

const formattedPubDate = pubDate.toLocaleDateString('fr-FR', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={title} description={description} image={image} schema={schema}>
  <article class="mx-auto max-w-[var(--max-width-wide)] px-6 py-12">
    <header class="mb-10">
      {category && (
        <a
          href={`/comparatifs/categorie/${category}/`}
          class="inline-block rounded-full bg-orange/10 px-3 py-1 text-sm font-medium text-orange no-underline hover:bg-orange/20 transition-colors mb-4"
        >
          {category}
        </a>
      )}
      <h1 class="font-serif text-3xl font-bold text-marine leading-tight md:text-4xl">
        {title}
      </h1>
      <div class="mt-4 flex flex-wrap items-center gap-4 text-sm text-gris">
        <span>Par <strong>{author}</strong></span>
        <span>·</span>
        <time datetime={pubDate.toISOString()}>Publié le {formattedPubDate}</time>
        {productsCompared && (
          <>
            <span>·</span>
            <span>{productsCompared} produits comparés</span>
          </>
        )}
      </div>
      {image && (
        <img
          src={image}
          alt={imageAlt || title}
          class="mt-6 w-full rounded-lg object-cover"
          loading="eager"
          width="1200"
          height="630"
        />
      )}
    </header>

    <AffiliateDisclosure />
    <HealthDisclaimer />

    <div class="prose mx-auto">
      <slot />
    </div>

    <AuthorBox />
  </article>
</BaseLayout>