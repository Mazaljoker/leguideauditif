---
export const prerender = false;

import AudioproLayout from '../../layouts/AudioproLayout.astro';
import DashboardRevendicateur from '../../components/audiopro/revendicateur/DashboardRevendicateur.astro';
import DashboardPremiumSolo from '../../components/audiopro/premium/DashboardPremiumSolo.astro';
import DashboardReseau from '../../components/audiopro/reseau/DashboardReseau.astro';
import { createServerClient } from '../../lib/supabase';
import {
  ACTIVE_CENTRE_COOKIE,
  computeCompleteness,
  getActiveCentreFull,
  getUserCentres,
  resolveActiveCentre,
  resolveDashboardState,
  type UserCentre,
} from '../../lib/audiopro';
import { makeMockCentre, mockReseauRows } from '../../lib/audiopro-mock';
import type {
  ActionPrioritaireInfo,
  CentreTableRow,
  DashboardState,
} from '../../types/audiopro';
import type { CentreData } from '../../types/centre';

const user = Astro.locals.user;
if (!user || !user.email) return Astro.redirect('/connexion-pro/');

const supabase = createServerClient();
const centres = await getUserCentres(supabase, user.email);
if (centres.length === 0) return Astro.redirect('/audioprothesiste-pro/bienvenue/');

const cookieSlug = Astro.cookies.get(ACTIVE_CENTRE_COOKIE)?.value;
const active = resolveActiveCentre(centres, cookieSlug);
if (!active) return Astro.redirect('/trouver-audioprothesiste/');

const centre = await getActiveCentreFull(supabase, active.slug, user.email);
if (!centre) return Astro.redirect('/trouver-audioprothesiste/');

// ------------------------------------------------------------
// Résolution de l'état de dashboard (+ preview query param en dev)
// ------------------------------------------------------------
const previewParam = Astro.url.searchParams.get('preview');
const allowedPreviews: DashboardState[] = ['revendicateur', 'premium_solo', 'reseau'];
const previewState: DashboardState | null =
  import.meta.env.DEV && previewParam && (allowedPreviews as string[]).includes(previewParam)
    ? (previewParam as DashboardState)
    : null;

const resolvedState = resolveDashboardState(centres);
const state: DashboardState = previewState ?? resolvedState;
const isPreview = previewState !== null;

// ------------------------------------------------------------
// Prénom affiché — cascade user_metadata → claim → email
// ------------------------------------------------------------
const metadata = (user as { user_metadata?: Record<string, unknown> }).user_metadata ?? {};
const metaGivenName = typeof metadata.given_name === 'string' ? metadata.given_name.trim() : '';
const metaFullName = typeof metadata.full_name === 'string' ? metadata.full_name.trim() : '';
const metaName = typeof metadata.name === 'string' ? metadata.name.trim() : '';
const claimedFirstName = centre.claimed_by_name?.split(' ')[0]?.trim() ?? '';
const emailLocal = (user.email ?? '').split('@')[0]?.trim() ?? '';

const prenom =
  metaGivenName ||
  metaFullName.split(' ')[0] ||
  metaName.split(' ')[0] ||
  claimedFirstName ||
  (emailLocal ? emailLocal.charAt(0).toUpperCase() + emailLocal.slice(1) : '') ||
  'Docteur';

// ------------------------------------------------------------
// Stats centre actif (vues 30j + leads 30j) — utilisées par les 3 states
// ------------------------------------------------------------
let viewCountActive = 0;
const { data: viewStats } = await supabase.rpc('centre_view_stats', { p_centre_id: centre.id });
if (viewStats && viewStats.length > 0) viewCountActive = Number(viewStats[0].views_30d) || 0;

const thirtyDaysAgo = new Date(Date.now() - 30 * 24 * 3600 * 1000).toISOString();
const { count: leadCountActive } = await supabase
  .from('leads')
  .select('*', { count: 'exact', head: true })
  .eq('source', `centre/${centre.slug}`)
  .gte('created_at', thirtyDaysAgo);

// ------------------------------------------------------------
// Aggregates Réseau : somme vues + leads + zone chalandise sur tous
// les centres du pro. En preview on utilise les valeurs du mockup.
// ------------------------------------------------------------
async function computeReseauAggregates(
  allCentres: UserCentre[],
): Promise<{ vuesCumulees: number; leadsCumules: number; rows: CentreTableRow[] }> {
  const statsPromises = allCentres.map(async (c) => {
    const [{ data: vStats }, { count: leadCount }] = await Promise.all([
      supabase.rpc('centre_view_stats', { p_centre_id: c.id }),
      supabase
        .from('leads')
        .select('*', { count: 'exact', head: true })
        .eq('source', `centre/${c.slug}`)
        .gte('created_at', thirtyDaysAgo),
    ]);
    const vues = vStats && vStats.length > 0 ? Number(vStats[0].views_30d) || 0 : 0;
    return { c, vues, leads: leadCount ?? 0 };
  });

  const results = await Promise.all(statsPromises);

  const rows: CentreTableRow[] = results.map(({ c, vues }) => ({
    slug: c.slug,
    nom: c.nom,
    adresse: c.ville ?? '',
    cp: c.cp ?? '',
    adsStatus: 'inactive',
    adsLabel: 'Non activé',
    positionRank: null,
    positionTotal: null,
    vues30j: vues,
    reviewScore: null,
    reviewCount: null,
    completeness: 0,
  }));

  return {
    vuesCumulees: results.reduce((acc, r) => acc + r.vues, 0),
    leadsCumules: results.reduce((acc, r) => acc + r.leads, 0),
    rows,
  };
}

// ------------------------------------------------------------
// Heuristique zone de chalandise (Phase 1 : estimation grossière)
// 12 000 adultes appareillables / CP urbain moyen, 6 000 / CP rural.
// À remplacer par un vrai appel INSEE dans une RPC dédiée Phase 2+.
// ------------------------------------------------------------
function estimateZoneChalandise(cp: string | null): number {
  if (!cp) return 0;
  const isParisOrUrban = /^(75|92|93|94|13|69|33|59|31|44|67)/.test(cp);
  return isParisOrUrban ? 12400 : 6200;
}

// ------------------------------------------------------------
// Revendicateur : nb jours depuis claim
// ------------------------------------------------------------
const claimedDaysAgo = centre.claimed_at
  ? Math.max(
      0,
      Math.floor((Date.now() - new Date(centre.claimed_at).getTime()) / (24 * 3600 * 1000)),
    )
  : 0;

// ------------------------------------------------------------
// Action prioritaire (Premium + Réseau) — priorité décroissante :
//   1. complétude fiche < 80%
//   2. centre claimed encore dans le portefeuille (landing à livrer)
//   3. rien d'urgent → pas d'alerte rendue
// ------------------------------------------------------------
function computeActionPremium(c: CentreData, comp: number): ActionPrioritaireInfo | undefined {
  if (comp < 80) {
    return {
      label: 'Action prioritaire',
      title: `Votre fiche n'est complète qu'à ${comp}%`,
      desc: 'Les fiches complètes remontent mieux dans les recherches Google.',
      ctaLabel: 'Compléter ma fiche',
      ctaHref: '/audioprothesiste-pro/fiche/',
    };
  }
  return undefined;
}

function computeActionReseau(
  allCentres: UserCentre[],
): ActionPrioritaireInfo | undefined {
  const pending = allCentres.filter((c) => c.plan === 'claimed');
  if (pending.length > 0) {
    return {
      label: 'Action prioritaire · Réseau',
      title: `${pending.length} de vos ${allCentres.length} centres n'ont pas encore leurs landing pages livrées`,
      desc: `${pending.map((c) => c.nom).join(', ')} en attente de validation.`,
      ctaLabel: 'Voir les livrables',
      ctaHref: '/audioprothesiste-pro/fiche/',
    };
  }
  return undefined;
}

// ------------------------------------------------------------
// Préparation des props par état
// ------------------------------------------------------------
const completeness = computeCompleteness(centre);

let reseauData: { vuesCumulees: number; leadsCumules: number; rows: CentreTableRow[] } = {
  vuesCumulees: 0,
  leadsCumules: 0,
  rows: [],
};

if (state === 'reseau' && !isPreview) {
  reseauData = await computeReseauAggregates(centres);
}

// En preview reseau : données du mockup v3 (Anthony 3 centres)
const mockPrenom = isPreview ? 'Sophie' : prenom;
const previewRevendicateurCentre = makeMockCentre();
---

<AudioproLayout
  title="Tableau de bord — Espace pro LeGuideAuditif"
  pageLabel="Tableau de bord"
>
  {isPreview && (
    <div class="mb-4 rounded-lg border-2 border-dashed border-orange bg-orange/10 px-4 py-3 font-sans text-sm text-marine">
      <strong>Mode preview :</strong> dashboard <code class="font-mono font-bold">{state}</code> rendu avec des données mock.
      Retirez <code class="font-mono">?preview=…</code> de l'URL pour revenir à la vue réelle.
    </div>
  )}

  {state === 'revendicateur' && (
    <DashboardRevendicateur
      prenom={isPreview ? 'Sophie' : prenom}
      centre={isPreview ? previewRevendicateurCentre : centre}
      viewCount30j={isPreview ? 12 : viewCountActive}
      leadCount30j={isPreview ? 0 : (leadCountActive ?? 0)}
      claimedDaysAgo={isPreview ? 3 : claimedDaysAgo}
    />
  )}

  {state === 'premium_solo' && (
    <DashboardPremiumSolo
      prenom={prenom}
      centre={centre}
      viewCount30j={isPreview ? 28 : viewCountActive}
      leadCount30j={isPreview ? 4 : (leadCountActive ?? 0)}
      zoneChalandise={estimateZoneChalandise(centre.cp)}
      completeness={completeness}
      action={computeActionPremium(centre, completeness)}
    />
  )}

  {state === 'reseau' && (
    <DashboardReseau
      prenom={isPreview ? 'Anthony' : prenom}
      nbCentres={isPreview ? 3 : centres.length}
      villesLabel={
        isPreview
          ? 'Paris 8e, 15e et 16e'
          : centres.map((c) => c.ville ?? c.cp).filter(Boolean).join(', ')
      }
      zoneChalandise={
        isPreview
          ? 37200
          : centres.reduce((acc, c) => acc + estimateZoneChalandise(c.cp), 0)
      }
      zoneLabel={
        isPreview
          ? 'Paris 8e + 15e + 16e'
          : centres.map((c) => c.ville ?? c.cp).filter(Boolean).slice(0, 3).join(' + ')
      }
      leadsCumules={isPreview ? 0 : reseauData.leadsCumules}
      vuesCumulees={isPreview ? 7 : reseauData.vuesCumulees}
      rows={isPreview ? mockReseauRows : reseauData.rows}
      action={
        isPreview
          ? {
              label: 'Action prioritaire · Réseau',
              title: "2 de vos 3 centres n'ont pas encore leurs landing pages livrées",
              desc: 'Parc Monceau et Commerce en attente de validation. Trocadéro actif depuis le 18 avril.',
              ctaLabel: 'Voir les livrables',
              ctaHref: '/audioprothesiste-pro/fiche/',
            }
          : computeActionReseau(centres)
      }
      nbAdsActives={isPreview ? 1 : 0}
      codePostauxLabel={
        isPreview
          ? '75008 · 75015 · 75016'
          : centres.map((c) => c.cp).filter(Boolean).join(' · ')
      }
    />
  )}
</AudioproLayout>
