---
export const prerender = false;

import { Icon } from 'astro-icon/components';
import AudioproLayout from '../../layouts/AudioproLayout.astro';
import PremiumLockedBanner from '../../components/audiopro/shared/PremiumLockedBanner.astro';
import { createServerClient } from '../../lib/supabase';
import {
  ACTIVE_CENTRE_COOKIE,
  getActiveCentreFull,
  getUserCentres,
  resolveActiveCentre,
  resolveProName,
} from '../../lib/audiopro';
import { TEMPLATES, TEMPLATE_ORDER } from '../../lib/actualites-templates';

const user = Astro.locals.user;
if (!user || !user.email) return Astro.redirect('/connexion-pro/');

const supabase = createServerClient();
const centres = await getUserCentres(supabase, user.email);
if (centres.length === 0) return Astro.redirect('/audioprothesiste-pro/bienvenue/');

const cookieSlug = Astro.cookies.get(ACTIVE_CENTRE_COOKIE)?.value;
const active = resolveActiveCentre(centres, cookieSlug);
if (!active) return Astro.redirect('/trouver-audioprothesiste/');

const centre = await getActiveCentreFull(supabase, active.slug, user.email);
if (!centre) return Astro.redirect('/trouver-audioprothesiste/');

const isPremium = centre.plan === 'premium';
const proName = resolveProName(user, centre.claimed_by_name ?? null);

interface ActualiteRow {
  id: string;
  template: string;
  title: string;
  body: string;
  variables: Record<string, string>;
  published_at: string;
}

let actualites: ActualiteRow[] = [];
if (isPremium) {
  const { data } = await supabase
    .from('centre_actualites')
    .select('id, template, title, body, variables, published_at')
    .eq('centre_id', centre.id)
    .order('published_at', { ascending: false });
  actualites = (data ?? []) as ActualiteRow[];
}

function formatFr(iso: string): string {
  return new Date(iso).toLocaleDateString('fr-FR', {
    day: '2-digit',
    month: 'long',
    year: 'numeric',
  });
}
---

<AudioproLayout
  title="Actualités — Espace pro LeGuideAuditif"
  pageLabel="Actualités"
>
  <header class="mb-6">
    <h1 class="font-sans text-2xl sm:text-3xl font-bold text-marine">Actualités de mon centre</h1>
    <p class="text-sm text-gris-texte font-sans mt-1">
      Publiez des annonces régulières (nouvelle marque, portes ouvertes, formation…) pour enrichir votre fiche publique et garder Google intéressé.
    </p>
  </header>

  {!isPremium && (
    <PremiumLockedBanner
      title="Feature réservée aux centres Premium"
      body="Les actualités du centre sont une feature Premium : elles apparaissent sur votre fiche publique et envoient un signal de fraîcheur à Google."
      centreSlug={centre.slug}
      lockedSource="locked-actualites"
      prefillName={proName.fullName}
      prefillEmail={user.email}
      centreId={centre.id}
    />
  )}

  {isPremium && (
    <>
      <div class="rounded-lg border border-marine/20 bg-marine/5 px-4 py-3 mb-6 flex items-start gap-2">
        <Icon name="lucide:info" class="w-4 h-4 text-marine mt-0.5 shrink-0" />
        <p class="text-xs text-marine/80 font-sans">
          <strong>Règles YMYL :</strong> pas de promesse thérapeutique ("guérir", "miracle"), pas de prix exact
          (utilisez "Classe 1" / "Classe 2" / "reste à charge 0€"). Publications instantanées.
        </p>
      </div>

      {/* Liste */}
      <section class="space-y-4 mb-8" id="actu-list">
        {actualites.map((a) => (
          <article class="rounded-xl border border-gris-clair bg-blanc p-5" data-id={a.id}>
            <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-3 mb-2">
              <div class="flex-1 min-w-0">
                <div class="flex flex-wrap items-center gap-2 mb-1">
                  <span class="inline-flex items-center gap-1 rounded-full bg-marine/10 text-marine px-2.5 py-0.5 text-[11px] font-sans font-bold uppercase tracking-wide">
                    {TEMPLATES[a.template as keyof typeof TEMPLATES]?.label ?? a.template}
                  </span>
                  <span class="text-[11px] text-gris-texte font-sans">
                    Publié le {formatFr(a.published_at)}
                  </span>
                </div>
                <h3 class="font-sans text-base sm:text-lg font-bold text-marine">{a.title}</h3>
                <p class="text-sm font-serif text-marine leading-relaxed mt-1">{a.body}</p>
              </div>
              <div class="flex gap-2 shrink-0">
                <button
                  type="button"
                  class="actu-delete inline-flex items-center justify-center gap-1.5 rounded-lg border border-red-200 bg-blanc px-4 py-2 text-sm font-sans font-medium text-red-600 hover:bg-red-50 transition-colors"
                  style="min-height: 44px;"
                  data-id={a.id}
                >
                  <Icon name="lucide:trash-2" class="w-4 h-4" />
                  Retirer
                </button>
              </div>
            </div>
          </article>
        ))}

        {actualites.length === 0 && (
          <div class="rounded-xl border-2 border-dashed border-gris-clair bg-creme/40 p-10 text-center">
            <Icon name="lucide:megaphone" class="w-10 h-10 text-gris-texte mx-auto mb-3" />
            <p class="font-sans text-marine font-semibold mb-1">Aucune actualité publiée pour le moment</p>
            <p class="text-sm font-sans text-gris-texte">Utilisez les templates ci-dessous pour publier votre première actualité.</p>
          </div>
        )}
      </section>

      {/* Sélecteur de template + formulaire dynamique */}
      <section class="rounded-xl bg-blanc border border-gris-clair p-5 sm:p-7">
        <h2 class="font-sans text-lg font-bold text-marine mb-1">Publier une nouvelle actualité</h2>
        <p class="text-sm text-gris-texte font-sans mb-5">Choisissez un template adapté à votre annonce.</p>

        <div class="grid grid-cols-2 sm:grid-cols-4 gap-2 mb-6" id="template-picker" role="radiogroup">
          {TEMPLATE_ORDER.map((key, idx) => {
            const def = TEMPLATES[key];
            return (
              <button
                type="button"
                class:list={[
                  'template-btn flex flex-col items-center gap-2 rounded-lg border-2 border-gris-clair bg-blanc p-3 text-center transition-colors hover:border-orange/40',
                  idx === 0 ? 'template-btn--active' : '',
                ]}
                data-template={key}
                style="min-height: 88px;"
              >
                <Icon name={def.icon} class="w-5 h-5 text-marine" />
                <span class="text-xs sm:text-sm font-sans font-semibold text-marine leading-tight">{def.label}</span>
              </button>
            );
          })}
        </div>

        <form id="actu-form" class="space-y-5">
          <input type="hidden" name="id" id="form-id" value="" />
          <input type="hidden" name="template" id="form-template" value={TEMPLATE_ORDER[0]} />

          <div id="template-description" class="rounded-lg bg-creme/60 p-3 text-sm text-marine font-sans">
            {TEMPLATES[TEMPLATE_ORDER[0]].description}
          </div>

          <div id="template-fields" class="space-y-4">
            {/* Rendu dynamique côté client selon template choisi */}
          </div>

          <div id="actu-error" class="hidden rounded-lg border border-red-300 bg-red-50 p-3 text-sm text-red-600 font-sans"></div>
          <div id="actu-success" class="hidden rounded-lg border border-green-300 bg-green-50 p-3 text-sm text-green-700 font-sans"></div>

          <div class="flex flex-col sm:flex-row gap-3 pt-2">
            <button
              type="submit"
              id="actu-submit"
              class="inline-flex items-center justify-center gap-2 rounded-lg bg-orange px-6 py-3 text-base font-semibold text-blanc font-sans hover:bg-orange-hover transition-colors disabled:opacity-60"
              style="min-height: 48px;"
            >
              <Icon name="lucide:send" class="w-4 h-4" />
              Publier
            </button>
          </div>
        </form>
      </section>
    </>
  )}

  <script define:vars={{
    centreSlug: centre.slug,
    templates: TEMPLATES,
    order: TEMPLATE_ORDER,
  }}>
    if (!document.getElementById('actu-form')) {
      // Pas Premium, skip script
    } else {
      let activeTemplate = order[0];
      const buttons = document.querySelectorAll('.template-btn');
      const desc = document.getElementById('template-description');
      const fieldsContainer = document.getElementById('template-fields');
      const templateInput = document.getElementById('form-template');
      const errorDiv = document.getElementById('actu-error');
      const successDiv = document.getElementById('actu-success');
      const submit = document.getElementById('actu-submit');

      function renderFields() {
        const def = templates[activeTemplate];
        desc.textContent = def.description;
        templateInput.value = activeTemplate;
        fieldsContainer.innerHTML = '';

        def.fields.forEach((f) => {
          const wrapper = document.createElement('div');
          const id = `field-${f.key}`;
          const label = document.createElement('label');
          label.htmlFor = id;
          label.className = 'block text-sm font-medium text-marine font-sans mb-1';
          label.textContent = f.label + (f.required ? ' *' : '');
          wrapper.appendChild(label);

          let el;
          if (f.type === 'textarea') {
            el = document.createElement('textarea');
            el.rows = 3;
          } else if (f.type === 'select') {
            el = document.createElement('select');
            el.className = 'bg-blanc';
            const empty = document.createElement('option');
            empty.value = '';
            empty.textContent = '—';
            el.appendChild(empty);
            (f.options || []).forEach((o) => {
              const opt = document.createElement('option');
              opt.value = o;
              opt.textContent = o;
              el.appendChild(opt);
            });
          } else {
            el = document.createElement('input');
            el.type = f.type;
          }
          el.id = id;
          el.name = f.key;
          el.required = !!f.required;
          if (f.placeholder) el.placeholder = f.placeholder;
          if (f.maxlength) el.maxLength = f.maxlength;
          el.className = (el.className || '') + ' w-full rounded-lg border border-gris-clair px-4 py-3 text-base font-sans focus:border-orange focus:outline-none focus:ring-2 focus:ring-orange/20';
          el.style.minHeight = '44px';
          wrapper.appendChild(el);
          fieldsContainer.appendChild(wrapper);
        });
      }

      buttons.forEach((btn) => {
        btn.addEventListener('click', () => {
          buttons.forEach((b) => b.classList.remove('template-btn--active'));
          btn.classList.add('template-btn--active');
          activeTemplate = btn.dataset.template;
          renderFields();
          errorDiv.classList.add('hidden');
          successDiv.classList.add('hidden');
        });
      });

      renderFields();

      // Delete
      document.querySelectorAll('.actu-delete').forEach((btn) => {
        btn.addEventListener('click', async () => {
          const id = btn.dataset.id;
          if (!confirm('Retirer cette actualité ? Elle disparaîtra de votre fiche publique.')) return;
          btn.disabled = true;
          try {
            const res = await fetch('/api/audiopro/actualite', {
              method: 'DELETE',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ id, centreSlug }),
            });
            const data = await res.json();
            if (!res.ok) throw new Error(data.error || 'Erreur');
            window.location.reload();
          } catch (err) {
            alert(err.message || 'Erreur lors de la suppression.');
            btn.disabled = false;
          }
        });
      });

      // Submit
      const form = document.getElementById('actu-form');
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        errorDiv.classList.add('hidden');
        successDiv.classList.add('hidden');
        submit.disabled = true;

        const fd = new FormData(form);
        const variables = {};
        const def = templates[activeTemplate];
        def.fields.forEach((f) => {
          const val = fd.get(f.key);
          if (val !== null && val !== '') variables[f.key] = String(val);
        });

        try {
          const res = await fetch('/api/audiopro/actualite', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              centreSlug,
              template: activeTemplate,
              variables,
            }),
          });
          const data = await res.json();
          if (!res.ok) throw new Error(data.error || 'Erreur');
          successDiv.textContent = 'Actualité publiée.';
          successDiv.classList.remove('hidden');
          setTimeout(() => window.location.reload(), 800);
        } catch (err) {
          errorDiv.textContent = err.message || 'Erreur inattendue.';
          errorDiv.classList.remove('hidden');
          submit.disabled = false;
        }
      });
    }
  </script>

  <style>
    .template-btn--active {
      border-color: var(--color-orange);
      background-color: color-mix(in srgb, var(--color-orange) 8%, white);
    }
  </style>
</AudioproLayout>
