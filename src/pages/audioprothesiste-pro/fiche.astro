---
export const prerender = false;

import { Icon } from 'astro-icon/components';
import AudioproLayout from '../../layouts/AudioproLayout.astro';
import { createServerClient } from '../../lib/supabase';
import {
  ACTIVE_CENTRE_COOKIE,
  getActiveCentreFull,
  getUserCentres,
  resolveActiveCentre,
} from '../../lib/audiopro';

const user = Astro.locals.user;
if (!user || !user.email) return Astro.redirect('/connexion-pro/');

const supabase = createServerClient();
const centres = await getUserCentres(supabase, user.email);
if (centres.length === 0) return Astro.redirect('/audioprothesiste-pro/bienvenue/');

const cookieSlug = Astro.cookies.get(ACTIVE_CENTRE_COOKIE)?.value;
const active = resolveActiveCentre(centres, cookieSlug);
if (!active) return Astro.redirect('/trouver-audioprothesiste/');

const centre = await getActiveCentreFull(supabase, active.slug, user.email);
if (!centre) return Astro.redirect('/trouver-audioprothesiste/');

const specialitesList = [
  'Acouphènes', 'Pédiatrie', 'Implants cochléaires',
  '100% Santé', 'Bilan auditif gratuit', 'Appareillage première fois',
  'Surdité sévère/profonde', 'Protection auditive', 'Audiométrie',
];
const marquesList = [
  'Phonak', 'Oticon', 'Signia', 'ReSound', 'Starkey',
  'Widex', 'Bernafon', 'Unitron', 'Audioservice',
];

const associationsList = [
  { code: 'UNSAF', label: 'UNSAF' },
  { code: 'CNA', label: 'Collège National d\'Audioprothèse' },
  { code: 'SFA', label: 'Société Française d\'Audiologie' },
  { code: 'AFREPA', label: 'AFREPA (acouphènes)' },
  { code: 'AES', label: 'AES' },
];

const languesList = [
  { code: 'FR', label: 'Français' },
  { code: 'EN', label: 'Anglais' },
  { code: 'ES', label: 'Espagnol' },
  { code: 'LSF', label: 'Langue des signes' },
  { code: 'IT', label: 'Italien' },
  { code: 'DE', label: 'Allemand' },
  { code: 'AR', label: 'Arabe' },
  { code: 'PT', label: 'Portugais' },
];

const isPremium = centre.plan === 'premium';
const currentYear = new Date().getFullYear();
const servicesInclus = (centre.services_inclus ?? {}) as Record<string, boolean>;
const equipement = (centre.equipement_cabine ?? {}) as Record<string, boolean | number>;
const accessibilite = (centre.accessibilite ?? {}) as Record<string, boolean | string>;

// Partenaires — 5 slots fixes (vides si non renseignés)
const partenairesInit = centre.partenaires_locaux ?? [];
const partenairesSlots = Array.from({ length: 5 }, (_, i) => partenairesInit[i] ?? { nom: '', role: 'orl', ville: '', tel: '', url: '' });
---

<AudioproLayout
  title={`Modifier ${centre.nom} — Espace pro LeGuideAuditif`}
  pageLabel="Ma fiche"
>
  <header class="mb-6">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
      <div>
        <h1 class="font-sans text-2xl sm:text-3xl font-bold text-marine">Ma fiche</h1>
        <p class="text-sm text-gris-texte font-sans mt-1">
          {centre.adresse}, {centre.cp} {centre.ville ?? ''}
        </p>
      </div>
      <a
        href={`/centre/${centre.slug}/`}
        target="_blank"
        rel="noopener"
        class="inline-flex items-center gap-2 rounded-lg border border-gris-clair px-4 py-2.5 text-sm font-medium text-marine font-sans hover:bg-blanc transition-colors shrink-0"
        style="min-height: 44px;"
      >
        <Icon name="lucide:external-link" class="w-4 h-4" />
        Voir ma fiche publique
      </a>
    </div>
  </header>

  {/* Onglets */}
  <div class="mb-6" role="tablist" aria-label="Sections de la fiche">
    <div class="flex gap-1 overflow-x-auto -mx-4 px-4 sm:mx-0 sm:px-0 border-b border-gris-clair">
      <button
        type="button"
        class="tab-btn tab-btn--active"
        data-tab="identite"
        role="tab"
        aria-selected="true"
        aria-controls="tab-identite"
        id="tab-label-identite"
      >
        <Icon name="lucide:id-card" class="w-4 h-4" />
        Identité
      </button>
      <button
        type="button"
        class="tab-btn"
        data-tab="offre"
        role="tab"
        aria-selected="false"
        aria-controls="tab-offre"
        id="tab-label-offre"
      >
        <Icon name="lucide:sparkles" class="w-4 h-4" />
        Offre
      </button>
      {isPremium && (
        <button
          type="button"
          class="tab-btn"
          data-tab="expertise"
          role="tab"
          aria-selected="false"
          aria-controls="tab-expertise"
          id="tab-label-expertise"
        >
          <Icon name="lucide:award" class="w-4 h-4" />
          Expertise
        </button>
      )}
      {isPremium && (
        <button
          type="button"
          class="tab-btn"
          data-tab="acces"
          role="tab"
          aria-selected="false"
          aria-controls="tab-acces"
          id="tab-label-acces"
        >
          <Icon name="lucide:map-pin" class="w-4 h-4" />
          Accès & équipement
        </button>
      )}
      {isPremium && (
        <button
          type="button"
          class="tab-btn"
          data-tab="reseaux"
          role="tab"
          aria-selected="false"
          aria-controls="tab-reseaux"
          id="tab-label-reseaux"
        >
          <Icon name="lucide:share-2" class="w-4 h-4" />
          Réseaux sociaux
        </button>
      )}
    </div>
  </div>

  <form id="fiche-form" class="rounded-xl border border-gris-clair bg-blanc p-6 sm:p-8">
    <input type="hidden" name="centreSlug" value={centre.slug} />

    {/* ================== Onglet Identité ================== */}
    <section
      id="tab-identite"
      class="tab-panel"
      role="tabpanel"
      aria-labelledby="tab-label-identite"
    >
      <div class="grid gap-5 sm:grid-cols-2">
        {/* ============ Section Photos ============
            - Gratuit (claimed) : 1 photo du centre (slot 0), pas d'avatar audio
            - Premium : avatar audioprothésiste + 4 photos cabine */}
        <div class="sm:col-span-2">
          <div class="flex items-center justify-between mb-3">
            <label class="block text-sm font-medium text-marine font-sans">
              Photos de votre fiche
            </label>
          </div>

          <div class="space-y-5">
            {/* --- Avatar (Premium uniquement) --- */}
            {isPremium ? (
              <div>
                <p class="text-xs font-sans font-semibold uppercase tracking-wide text-marine/70 mb-2">
                  Photo de l'audioprothésiste (avatar)
                </p>
                <div class="flex flex-col sm:flex-row sm:items-center gap-4 rounded-lg border border-gris-clair bg-creme/40 p-4">
                  <div
                    class="w-20 h-20 rounded-full bg-marine text-blanc flex items-center justify-center font-sans font-bold text-xl overflow-hidden shrink-0 border-2 border-gris-clair"
                    aria-hidden="true"
                  >
                    {centre.audio_photo_url ? (
                      <img src={centre.audio_photo_url} alt="" class="w-full h-full object-cover" />
                    ) : (
                      <span>
                        {(centre.audio_prenom?.[0] ?? centre.claimed_by_name?.[0] ?? 'A').toUpperCase()}
                        {(centre.audio_nom?.[0] ?? centre.claimed_by_name?.split(' ')[1]?.[0] ?? '').toUpperCase()}
                      </span>
                    )}
                  </div>
                  <div class="flex-1 min-w-0">
                    <p class="text-sm font-sans font-semibold text-marine mb-1">Votre portrait professionnel</p>
                    <p class="text-xs text-gris-texte font-sans mb-3">
                      Visible en haut de votre fiche publique et de votre dashboard. Cadrage portrait conseillé.
                    </p>
                    <input type="file" id="photo-input-avatar" accept="image/jpeg,image/png,image/webp" class="hidden" data-kind="avatar" />
                    <div class="flex flex-wrap gap-2">
                      <button
                        type="button"
                        class="photo-trigger inline-flex items-center justify-center gap-2 rounded-lg border border-gris-clair bg-blanc px-4 py-2.5 text-sm font-sans font-semibold text-marine hover:border-orange/40 transition-colors"
                        style="min-height: 44px;"
                        data-kind="avatar"
                      >
                        <Icon name="lucide:upload" class="w-4 h-4" />
                        {centre.audio_photo_url ? 'Changer' : 'Ajouter l\'avatar'}
                      </button>
                      {centre.audio_photo_url && (
                        <button
                          type="button"
                          class="photo-remove inline-flex items-center justify-center gap-2 rounded-lg border border-gris-clair bg-blanc px-4 py-2.5 text-sm font-sans font-medium text-gris-texte hover:text-marine transition-colors"
                          style="min-height: 44px;"
                          data-kind="avatar"
                        >
                          Retirer
                        </button>
                      )}
                    </div>
                  </div>
                </div>
              </div>
            ) : (
              <div class="rounded-lg border-2 border-dashed border-orange/30 bg-orange/5 p-4 flex items-start gap-3">
                <Icon name="lucide:crown" class="w-5 h-5 text-orange shrink-0 mt-0.5" />
                <div class="flex-1 text-sm font-sans">
                  <p class="text-marine font-semibold">Avatar audioprothésiste — réservé au Premium</p>
                  <p class="text-gris-texte mt-1">Ajoutez votre portrait professionnel avec un compte Premium. <a href={`/revendiquer/?centre=${centre.slug}`} class="text-orange font-semibold hover:underline">Passer Premium →</a></p>
                </div>
              </div>
            )}

            {/* --- Photos cabine ---
                Claimed : 1 slot (slot 0)
                Premium : 4 slots */}
            <div>
              <p class="text-xs font-sans font-semibold uppercase tracking-wide text-marine/70 mb-2">
                {isPremium
                  ? 'Photos du centre (4 max : cabine, accueil, équipement, équipe)'
                  : 'Photo du centre (1 photo autorisée en gratuit)'}
              </p>
              <div class:list={[
                'grid gap-3',
                isPremium ? 'grid-cols-2 sm:grid-cols-4' : 'grid-cols-1 sm:grid-cols-2',
              ]}>
                {(isPremium ? [0, 1, 2, 3] : [0]).map((slot) => {
                  const url = centre.photos_cabine?.[slot];
                  return (
                    <div class="rounded-lg border border-gris-clair bg-creme/40 p-3" data-photo-slot={slot}>
                      <div class="aspect-square rounded-lg bg-blanc border border-gris-clair overflow-hidden mb-2 flex items-center justify-center">
                        {url ? (
                          <img src={url} alt={`Photo ${slot + 1}`} class="w-full h-full object-cover" />
                        ) : (
                          <div class="text-center p-3">
                            <Icon name="lucide:image" class="w-6 h-6 text-gris-texte mx-auto mb-1" />
                            <p class="text-[10px] font-sans text-gris-texte uppercase tracking-wide">
                              {isPremium ? `Photo ${slot + 1}` : 'Photo du centre'}
                            </p>
                          </div>
                        )}
                      </div>
                      <input
                        type="file"
                        id={`photo-input-cabine-${slot}`}
                        accept="image/jpeg,image/png,image/webp"
                        class="hidden"
                        data-kind="cabine"
                        data-slot={slot}
                      />
                      <div class="flex gap-1">
                        <button
                          type="button"
                          class="photo-trigger flex-1 inline-flex items-center justify-center gap-1 rounded-md border border-gris-clair bg-blanc px-2 py-2 text-xs font-sans font-semibold text-marine hover:border-orange/40 transition-colors"
                          style="min-height: 40px;"
                          data-kind="cabine"
                          data-slot={slot}
                        >
                          <Icon name="lucide:upload" class="w-3.5 h-3.5" />
                          {url ? 'Changer' : 'Ajouter'}
                        </button>
                        {url && (
                          <button
                            type="button"
                            class="photo-remove inline-flex items-center justify-center rounded-md border border-red-200 bg-blanc px-2 py-2 text-xs font-sans font-medium text-red-600 hover:bg-red-50 transition-colors"
                            style="min-height: 40px;"
                            data-kind="cabine"
                            data-slot={slot}
                            aria-label={`Retirer la photo ${slot + 1}`}
                          >
                            <Icon name="lucide:trash-2" class="w-3.5 h-3.5" />
                          </button>
                        )}
                      </div>
                    </div>
                  );
                })}
              </div>
              {!isPremium && (
                <p class="text-xs text-gris-texte font-sans mt-2">
                  <Icon name="lucide:crown" class="inline w-3 h-3 text-orange" /> Passez en Premium pour 3 photos supplémentaires + avatar audioprothésiste.
                </p>
              )}
            </div>

            <p class="text-xs text-gris-texte font-sans">
              JPG, PNG ou WebP · 4 Mo max par photo. Uploads instantanés.
            </p>
            <div id="photo-status" class="hidden text-xs font-sans"></div>
          </div>
        </div>

        <div class="sm:col-span-2">
          <label for="edit-nom" class="block text-sm font-medium text-marine font-sans mb-1">
            Nom du centre
          </label>
          <input
            id="edit-nom"
            name="nom"
            type="text"
            value={centre.nom}
            required
            class="w-full rounded-lg border border-gris-clair px-4 py-3 text-base font-sans focus:border-orange focus:outline-none focus:ring-2 focus:ring-orange/20"
          />
        </div>

        <div>
          <label for="edit-tel" class="block text-sm font-medium text-marine font-sans mb-1">
            Téléphone
          </label>
          <input
            id="edit-tel"
            name="tel"
            type="tel"
            value={centre.tel || ''}
            class="w-full rounded-lg border border-gris-clair px-4 py-3 text-base font-sans focus:border-orange focus:outline-none focus:ring-2 focus:ring-orange/20"
          />
        </div>

        <div>
          <label for="edit-rpps" class="block text-sm font-medium text-marine font-sans mb-1">
            N° RPPS
          </label>
          <input
            id="edit-rpps"
            name="rpps"
            type="text"
            value={centre.rpps || ''}
            placeholder="Ex : 10001234567"
            class="w-full rounded-lg border border-gris-clair px-4 py-3 text-base font-sans focus:border-orange focus:outline-none focus:ring-2 focus:ring-orange/20"
          />
          <p class="text-xs text-gris-texte font-sans mt-1">Répertoire Partagé des Professionnels de Santé (11 chiffres)</p>
        </div>

        <div class="sm:col-span-2">
          <label for="edit-site-web" class="block text-sm font-medium text-marine font-sans mb-1">
            Site web
          </label>
          <input
            id="edit-site-web"
            name="site_web"
            type="url"
            value={centre.site_web || ''}
            placeholder="https://www.mon-centre.fr"
            class="w-full rounded-lg border border-gris-clair px-4 py-3 text-base font-sans focus:border-orange focus:outline-none focus:ring-2 focus:ring-orange/20"
          />
        </div>

        <div class="sm:col-span-2">
          <label class="block text-sm font-medium text-marine font-sans mb-2">
            Horaires d'ouverture
          </label>
          <input type="hidden" id="edit-horaires" name="horaires" value={centre.horaires || ''} />

          {/* Mode simple : 3 selects (la majorité des cas) — empilés sur mobile pour lisibilité */}
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-3" id="horaires-simple">
            <div>
              <label for="h-ouverture" class="block text-xs text-gris-texte font-sans mb-1">Ouverture</label>
              <select id="h-ouverture" class="w-full rounded-lg border border-gris-clair px-3 py-3 text-base font-sans focus:border-orange focus:outline-none focus:ring-2 focus:ring-orange/20 bg-blanc" style="min-height: 44px;">
                <option value="">--</option>
                <option value="8h">8h</option>
                <option value="8h30">8h30</option>
                <option value="9h">9h</option>
                <option value="9h30">9h30</option>
                <option value="10h">10h</option>
              </select>
            </div>
            <div>
              <label for="h-fermeture" class="block text-xs text-gris-texte font-sans mb-1">Fermeture</label>
              <select id="h-fermeture" class="w-full rounded-lg border border-gris-clair px-3 py-3 text-base font-sans focus:border-orange focus:outline-none focus:ring-2 focus:ring-orange/20 bg-blanc" style="min-height: 44px;">
                <option value="">--</option>
                <option value="17h">17h</option>
                <option value="17h30">17h30</option>
                <option value="18h">18h</option>
                <option value="18h30">18h30</option>
                <option value="19h">19h</option>
              </select>
            </div>
            <div>
              <label for="h-samedi" class="block text-xs text-gris-texte font-sans mb-1">Samedi</label>
              <select id="h-samedi" class="w-full rounded-lg border border-gris-clair px-3 py-3 text-base font-sans focus:border-orange focus:outline-none focus:ring-2 focus:ring-orange/20 bg-blanc" style="min-height: 44px;">
                <option value="">--</option>
                <option value="Fermé">Fermé</option>
                <option value="9h-12h">9h-12h</option>
                <option value="9h-13h">9h-13h</option>
                <option value="10h-12h">10h-12h</option>
                <option value="Sur RDV">Sur RDV</option>
              </select>
            </div>
          </div>

          {/* Mode avancé : textarea libre pour horaires détaillés + présence audio */}
          <details id="horaires-avance-details" class="mt-3 rounded-lg border border-gris-clair bg-creme/50 group">
            <summary class="cursor-pointer px-4 py-3 text-sm font-sans font-medium text-marine flex items-center gap-2 list-none [&::-webkit-details-marker]:hidden">
              <Icon name="lucide:chevron-right" class="w-4 h-4 transition-transform group-open:rotate-90" />
              <Icon name="lucide:pen-line" class="w-4 h-4 text-orange" />
              <span>Préciser mes horaires en texte libre</span>
              <span class="text-xs font-normal text-gris-texte ml-auto">optionnel</span>
            </summary>
            <div class="px-4 pb-4 pt-1">
              <textarea
                id="edit-horaires-libre"
                rows="3"
                maxlength="300"
                placeholder="Ex : Lun-Ven 9h-13h / 14h-18h30, fermé jeudi après-midi. Audioprothésiste DE présent mardi et vendredi uniquement. Sur RDV le samedi matin."
                class="w-full rounded-lg border border-gris-clair px-4 py-3 text-base font-sans focus:border-orange focus:outline-none focus:ring-2 focus:ring-orange/20 resize-y"
              ></textarea>
              <p class="text-xs text-gris-texte font-sans mt-2 flex items-start gap-1.5">
                <Icon name="lucide:info" class="w-3.5 h-3.5 mt-0.5 shrink-0 text-marine" />
                <span>Si ce champ est rempli, il remplace les horaires simples ci-dessus sur votre fiche publique. Parfait pour préciser les jours de présence de l'audioprothésiste, les pauses déjeuner ou les fermetures spéciales.</span>
              </p>
            </div>
          </details>
        </div>
      </div>
    </section>

    {/* ================== Onglet Offre ================== */}
    <section
      id="tab-offre"
      class="tab-panel hidden"
      role="tabpanel"
      aria-labelledby="tab-label-offre"
    >
      <div class="mb-5">
        <label class="block text-sm font-medium text-marine font-sans mb-2">
          Spécialités (3 max)
        </label>
        <div class="flex flex-wrap gap-2" id="specialites-container">
          {specialitesList.map((s) => (
            <label class="inline-flex items-center gap-1.5 rounded-full border border-gris-clair bg-blanc px-3 py-1.5 text-sm font-sans cursor-pointer hover:border-orange/50 transition-colors has-[:checked]:bg-[#E6F1FB] has-[:checked]:border-[#0C447C]/30 has-[:checked]:text-[#0C447C]">
              <input
                type="checkbox"
                name="specialites"
                value={s}
                checked={centre.specialites?.includes(s)}
                class="sr-only peer"
              />
              {s}
            </label>
          ))}
        </div>
      </div>

      <div class="mb-5">
        <label class="block text-sm font-medium text-marine font-sans mb-2">
          Marques proposées (3 max)
        </label>
        <div class="flex flex-wrap gap-2" id="marques-container">
          {marquesList.map((m) => (
            <label class="inline-flex items-center gap-1.5 rounded-full border border-gris-clair bg-blanc px-3 py-1.5 text-sm font-sans cursor-pointer hover:border-orange/50 transition-colors has-[:checked]:bg-[#E6F1FB] has-[:checked]:border-[#0C447C]/30 has-[:checked]:text-[#0C447C]">
              <input
                type="checkbox"
                name="marques"
                value={m}
                checked={centre.marques?.includes(m)}
                class="sr-only peer"
              />
              {m}
            </label>
          ))}
        </div>
      </div>

      <div>
        <label for="edit-apropos" class="block text-sm font-medium text-marine font-sans mb-1">
          À propos de votre centre
        </label>
        <textarea
          id="edit-apropos"
          name="a_propos"
          rows="5"
          maxlength="500"
          class="w-full rounded-lg border border-gris-clair px-4 py-3 text-base font-sans focus:border-orange focus:outline-none focus:ring-2 focus:ring-orange/20 resize-y"
        >{centre.a_propos || ''}</textarea>
        <p class="text-xs text-gris-texte font-sans mt-1">500 caractères max — décrivez votre approche, votre équipe, votre philosophie.</p>
      </div>
    </section>

    {/* ================== Onglet Expertise (premium only) ================== */}
    {isPremium && (
      <section
        id="tab-expertise"
        class="tab-panel hidden"
        role="tabpanel"
        aria-labelledby="tab-label-expertise"
      >
        <p class="text-sm text-gris-texte font-sans mb-5">
          Ces informations renforcent votre crédibilité professionnelle. Plus la page est complète, mieux elle remonte dans Google sur votre zone (signaux E-E-A-T pour les contenus santé).
        </p>

        <div class="grid gap-5 sm:grid-cols-2">
          <div class="sm:col-span-2">
            <label for="edit-audio-bio" class="block text-sm font-medium text-marine font-sans mb-1">
              Biographie professionnelle
            </label>
            <textarea
              id="edit-audio-bio"
              name="audio_bio"
              rows="5"
              maxlength="800"
              placeholder="Parcours (DE d'audioprothèse, stages, expériences), votre approche patient, vos domaines d'intérêt (acouphènes, pédiatrie, presbyacousie…)."
              class="w-full rounded-lg border border-gris-clair px-4 py-3 text-base font-sans focus:border-orange focus:outline-none focus:ring-2 focus:ring-orange/20 resize-y"
            >{centre.audio_bio ?? ''}</textarea>
            <p class="text-xs text-gris-texte font-sans mt-1">
              800 caractères max · affichée en haut de votre fiche publique.
            </p>
          </div>

          <div>
            <label for="edit-audio-annee-dip" class="block text-sm font-medium text-marine font-sans mb-1">
              Année d'obtention du D.E.
            </label>
            <input
              id="edit-audio-annee-dip"
              name="audio_annee_dip"
              type="number"
              min="1960"
              max={currentYear}
              value={centre.audio_annee_dip ?? ''}
              placeholder="Ex : 2005"
