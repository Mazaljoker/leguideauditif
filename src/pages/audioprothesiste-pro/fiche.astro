  <script define:vars={{ centreSlug: centre.slug }}>
    // --- Upload photos (avatar + 4 slots cabine) ---
    // Endpoint unifié /api/audiopro/upload-photo avec kind + slot
    const photoStatus = document.getElementById('photo-status');

    function showPhotoStatus(kind, message) {
      if (!photoStatus) return;
      photoStatus.className = 'text-xs font-sans ' + (kind === 'error' ? 'text-red-600' : 'text-[#639922]');
      photoStatus.textContent = message;
      photoStatus.classList.remove('hidden');
    }

    // Tous les boutons "Ajouter / Changer" (avatar + 4 cabine slots)
    document.querySelectorAll('.photo-trigger').forEach((btn) => {
      btn.addEventListener('click', () => {
        const kind = btn.dataset.kind;
        const slot = btn.dataset.slot;
        const inputId = kind === 'avatar' ? 'photo-input-avatar' : `photo-input-cabine-${slot}`;
        const input = document.getElementById(inputId);
        input?.click();
      });
    });

    // Tous les <input type=file> déclenchent l'upload sur change
    document.querySelectorAll('input[type=file][data-kind]').forEach((input) => {
      input.addEventListener('change', async () => {
        const file = input.files?.[0];
        if (!file) return;
        const kind = input.dataset.kind;
        const slot = input.dataset.slot;

        if (file.size > 4 * 1024 * 1024) {
          showPhotoStatus('error', 'Image trop lourde (max 4 Mo).');
          return;
        }
        if (!['image/jpeg', 'image/png', 'image/webp'].includes(file.type)) {
          showPhotoStatus('error', 'Format non supporté (JPG, PNG ou WebP).');
          return;
        }

        showPhotoStatus('success', 'Upload en cours…');
        const fd = new FormData();
        fd.append('centreSlug', centreSlug);
        fd.append('kind', kind);
        if (kind === 'cabine') fd.append('slot', slot);
        fd.append('file', file);

        try {
          const res = await fetch('/api/audiopro/upload-photo', {
            method: 'POST',
            body: fd,
          });
          const data = await res.json();
          if (!res.ok || !data.url) throw new Error(data.error || 'Upload impossible.');
          showPhotoStatus('success', 'Photo mise à jour. Rechargement…');
          setTimeout(() => window.location.reload(), 600);
        } catch (err) {
          showPhotoStatus('error', err.message || 'Erreur d\'upload.');
        }
      });
    });

    // Boutons Retirer
    document.querySelectorAll('.photo-remove').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const kind = btn.dataset.kind;
        const slot = btn.dataset.slot;
        const confirmMsg = kind === 'avatar'
          ? 'Retirer votre avatar ? Les initiales seront affichées à la place.'
          : `Retirer la photo ${Number(slot) + 1} ?`;
        if (!confirm(confirmMsg)) return;
        btn.disabled = true;
        try {
          const res = await fetch('/api/audiopro/upload-photo', {
            method: 'DELETE',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              centreSlug,
              kind,
              ...(kind === 'cabine' ? { slot: Number(slot) } : {}),
            }),
          });
          const data = await res.json();
          if (!res.ok) throw new Error(data.error || 'Erreur.');
          window.location.reload();
        } catch (err) {
          showPhotoStatus('error', err.message || 'Erreur lors du retrait.');
          btn.disabled = false;
        }
      });
    });
  </script>

  <script define:vars={{ currentHoraires: centre.horaires || '' }}>
    // --- Onglets ---
    const tabBtns = document.querySelectorAll('.tab-btn');
    const tabPanels = document.querySelectorAll('.tab-panel');

    tabBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        const target = btn.getAttribute('data-tab');
        tabBtns.forEach((b) => {
          b.classList.remove('tab-btn--active');
          b.setAttribute('aria-selected', 'false');
        });
        btn.classList.add('tab-btn--active');
        btn.setAttribute('aria-selected', 'true');
        tabPanels.forEach((panel) => {
          const panelId = panel.id.replace('tab-', '');
          if (panelId === target) {
            panel.classList.remove('hidden');
          } else {
            panel.classList.add('hidden');
          }
        });
      });
    });

    // --- Horaires ---
    const hOuverture = document.getElementById('h-ouverture');
    const hFermeture = document.getElementById('h-fermeture');
    const hSamedi = document.getElementById('h-samedi');
    const hHidden = document.getElementById('edit-horaires');
    const hLibre = document.getElementById('edit-horaires-libre');
    const hAvanceDetails = document.getElementById('horaires-avance-details');

    // Tente de parser les horaires au format généré par les selects.
    // Retourne true si le format match, false sinon (→ le textarea libre
    // prend le relais en pré-remplissant avec la valeur brute).
    function tryPreFillSelects(value) {
      let parsed = false;
      const match = value.match(/Lun-Ven\s+(\d+h\d*)-(\d+h\d*)/);
      if (match) {
        const openVals = Array.from(hOuverture.options).map((o) => o.value);
        const closeVals = Array.from(hFermeture.options).map((o) => o.value);
        if (openVals.includes(match[1]) && closeVals.includes(match[2])) {
          hOuverture.value = match[1];
          hFermeture.value = match[2];
          parsed = true;
        }
      }
      const samMatch = value.match(/Sam\s+(.+)/);
      if (samMatch) {
        const samVals = Array.from(hSamedi.options).map((o) => o.value);
        const samValue = samMatch[1].trim();
        if (samVals.includes(samValue)) {
          hSamedi.value = samValue;
          parsed = true;
        }
      }
      return parsed;
    }

    if (currentHoraires) {
      const parsedByselects = tryPreFillSelects(currentHoraires);
      // Si le format existant n'est pas parsable par les selects (pause
      // déjeuner, jours spécifiques, etc.), on met la valeur dans le
      // textarea libre et on ouvre la section avancée automatiquement.
      if (!parsedByselects) {
        hLibre.value = currentHoraires;
        if (hAvanceDetails) hAvanceDetails.open = true;
      }
    }

    function updateHoraires() {
      // Priorité : si le textarea libre est rempli, il remplace les selects.
      const libre = (hLibre.value || '').trim();
      if (libre) {
        hHidden.value = libre;
        return;
      }
      const ouv = hOuverture.value;
      const fer = hFermeture.value;
      const sam = hSamedi.value;
      const parts = [];
      if (ouv && fer) parts.push('Lun-Ven ' + ouv + '-' + fer);
      if (sam) parts.push('Sam ' + sam);
      hHidden.value = parts.join(' | ');
    }
    hOuverture.addEventListener('change', updateHoraires);
    hFermeture.addEventListener('change', updateHoraires);
    hSamedi.addEventListener('change', updateHoraires);
    hLibre.addEventListener('input', updateHoraires);

    // --- Limiter checkboxes à 3 ---
    function limitCheckboxes(containerId, max) {
      const container = document.getElementById(containerId);
      if (!container) return;
      container.addEventListener('change', function () {
        const checked = container.querySelectorAll('input[type="checkbox"]:checked');
        const unchecked = container.querySelectorAll('input[type="checkbox"]:not(:checked)');
        if (checked.length >= max) {
          unchecked.forEach((cb) => { cb.disabled = true; });
        } else {
          unchecked.forEach((cb) => { cb.disabled = false; });
        }
      });
      const initChecked = container.querySelectorAll('input[type="checkbox"]:checked');
      if (initChecked.length >= max) {
        container.querySelectorAll('input[type="checkbox"]:not(:checked)').forEach((cb) => { cb.disabled = true; });
      }
    }
    limitCheckboxes('specialites-container', 3);
    limitCheckboxes('marques-container', 3);

    // --- Submit ---
    const form = document.getElementById('fiche-form');
    const submitBtn = document.getElementById('edit-submit');
    const errorDiv = document.getElementById('edit-error');
    const successDiv = document.getElementById('edit-success');

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      submitBtn.disabled = true;
      const originalLabel = submitBtn.innerHTML;
      submitBtn.textContent = 'Enregistrement…';
      errorDiv.classList.add('hidden');
      successDiv.classList.add('hidden');

      updateHoraires();

      const formData = new FormData(form);
      const centreSlug = formData.get('centreSlug');
      const specialites = formData.getAll('specialites');
      const marques = formData.getAll('marques');

      const reseaux = {};
      const rsFb = formData.get('rs_facebook');
      const rsIg = formData.get('rs_instagram');
      const rsGo = formData.get('rs_google');
      const rsLi = formData.get('rs_linkedin');
      if (rsFb) reseaux.facebook = rsFb;
      if (rsIg) reseaux.instagram = rsIg;
      if (rsGo) reseaux.google = rsGo;
      if (rsLi) reseaux.linkedin = rsLi;

      // Expertise Premium
      const audioAssociations = formData.getAll('audio_associations');
      const langues = formData.getAll('langues');
      const anneeDipRaw = formData.get('audio_annee_dip');
      const anneeDip = anneeDipRaw ? parseInt(String(anneeDipRaw), 10) : null;
      const servicesInclus = {
        essai_30j: formData.get('services_essai_30j') === 'on',
        livraison_domicile: formData.get('services_livraison_domicile') === 'on',
        teleconsultation: formData.get('services_teleconsultation') === 'on',
        urgences: formData.get('services_urgences') === 'on',
      };

      // Accès & équipement Premium
      const essaiJoursRaw = formData.get('eq_essai_jours');
      const garantieAnneesRaw = formData.get('eq_garantie_annees');
      const essaiJours = essaiJoursRaw ? parseInt(String(essaiJoursRaw), 10) : null;
      const garantieAnnees = garantieAnneesRaw ? parseInt(String(garantieAnneesRaw), 10) : null;
      const equipementCabine = {
        cabine_insonorisee: formData.get('eq_cabine_insonorisee') === 'on',
        rem: formData.get('eq_rem') === 'on',
        anc: formData.get('eq_anc') === 'on',
        audiometre_num: formData.get('eq_audiometre_num') === 'on',
        cabine_pediatrique: formData.get('eq_cabine_pediatrique') === 'on',
      };
      if (essaiJours !== null && !isNaN(essaiJours)) equipementCabine.essai_jours = essaiJours;
      if (garantieAnnees !== null && !isNaN(garantieAnnees)) equipementCabine.garantie_annees = garantieAnnees;

      const accessibiliteData = {
        pmr: formData.get('acc_pmr') === 'on',
        ascenseur: formData.get('acc_ascenseur') === 'on',
        rdc: formData.get('acc_rdc') === 'on',
        parking: formData.get('acc_parking') === 'on',
      };
      const transports = (formData.get('acc_transports_en_commun') || '').toString().trim();
      if (transports) accessibiliteData.transports_en_commun = transports;

      // Partenaires : 5 slots, on ne garde que ceux avec un nom
      const partenaires = [];
      for (let i = 0; i < 5; i++) {
        const nom = (formData.get(`partner_${i}_nom`) || '').toString().trim();
        if (!nom) continue;
        const entry = {
          nom,
          role: formData.get(`partner_${i}_role`) || 'autre',
        };
        const ville = (formData.get(`partner_${i}_ville`) || '').toString().trim();
        const tel = (formData.get(`partner_${i}_tel`) || '').toString().trim();
        const url = (formData.get(`partner_${i}_url`) || '').toString().trim();
        if (ville) entry.ville = ville;
        if (tel) entry.tel = tel;
        if (url) entry.url = url;
        partenaires.push(entry);
      }

      const payload = {
        centreSlug,
        nom: formData.get('nom'),
        tel: formData.get('tel') || null,
        rpps: formData.get('rpps') || null,
        site_web: formData.get('site_web') || null,
        horaires: formData.get('horaires') || null,
        a_propos: formData.get('a_propos') || null,
        specialites,
        marques,
        audio_bio: formData.get('audio_bio') || null,
        audio_annee_dip: anneeDip && !isNaN(anneeDip) ? anneeDip : null,
        audio_associations: audioAssociations,
        langues: langues,
        services_inclus: servicesInclus,
        equipement_cabine: equipementCabine,
        accessibilite: accessibiliteData,
        partenaires_locaux: partenaires,
      };
      if (Object.keys(reseaux).length > 0) payload.reseaux_sociaux = reseaux;

      try {
        const res = await fetch('/api/centre-update', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });

        const data = await res.json();

        if (!res.ok) {
          throw new Error(data.error || 'Erreur lors de la sauvegarde.');
        }

        successDiv.textContent = 'Modifications enregistrées avec succès.';
        successDiv.classList.remove('hidden');
        submitBtn.disabled = false;
        submitBtn.innerHTML = originalLabel;
        successDiv.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      } catch (err) {
        errorDiv.textContent = err.message || 'Une erreur est survenue.';
        errorDiv.classList.remove('hidden');
        submitBtn.disabled = false;
        submitBtn.innerHTML = originalLabel;
      }
    });
  </script>
</AudioproLayout>
