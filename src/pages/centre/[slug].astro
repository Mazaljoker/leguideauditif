---
export const prerender = false;

import { Icon } from 'astro-icon/components';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import HealthDisclaimer from '../../components/HealthDisclaimer.astro';
import LeadForm from '../../components/LeadForm.tsx';
import ClaimBanner from '../../components/centre/ClaimBanner.astro';
import VerifiedBadge from '../../components/centre/VerifiedBadge.astro';
import UpsellBanner from '../../components/centre/UpsellBanner.astro';
import { supabase } from '../../lib/supabase';

const { slug } = Astro.params;

const { data: centre, error } = await supabase
  .from('centres_auditifs')
  .select('*')
  .eq('slug', slug)
  .single();

if (error || !centre) {
  return Astro.redirect('/trouver-audioprothesiste/');
}

const displayVille = centre.ville || centre.cp;

const isRpps = centre.plan === 'rpps';
const isClaimed = centre.plan === 'claimed';
const isPremium = centre.plan === 'premium';

const pageTitle = `${centre.nom} — Audioprothesiste ${displayVille}`;
const pageDescription = isRpps
  ? `${centre.nom}, audioprothesiste a ${displayVille}. Demandez un bilan auditif gratuit pres de chez vous.`
  : `${centre.nom}, audioprothesiste a ${displayVille}. Coordonnees, horaires et prise de rendez-vous.`;

const breadcrumbs = [
  { label: 'Accueil', href: '/' },
  { label: 'Trouver un audioprothesiste', href: '/trouver-audioprothesiste/' },
  { label: `${centre.nom}, ${displayVille}` },
];

// Schema.org — enrichi selon le niveau
const schema: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  '@id': `https://leguideauditif.fr/centre/${centre.slug}/`,
  name: centre.nom,
  address: {
    '@type': 'PostalAddress',
    streetAddress: centre.adresse,
    postalCode: centre.cp,
    addressLocality: centre.ville || undefined,
    addressCountry: 'FR',
  },
  medicalSpecialty: 'Audioprothese',
};

if (centre.lat && centre.lng) {
  schema.geo = { '@type': 'GeoCoordinates', latitude: centre.lat, longitude: centre.lng };
}
if (!isRpps && centre.tel) schema.telephone = centre.tel;
if (!isRpps && centre.site_web) schema.url = centre.site_web;
if (!isRpps && centre.email) schema.email = centre.email;
if (!isRpps && centre.horaires) schema.openingHours = centre.horaires;
if (centre.photo_url) schema.image = centre.photo_url;
if (centre.specialites?.length > 0) schema.knowsAbout = centre.specialites;
if (centre.marques?.length > 0) {
  schema.brand = centre.marques.map((m: string) => ({ '@type': 'Brand', name: m }));
}
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonical={`https://leguideauditif.fr/centre/${centre.slug}/`}
  schema={schema}
>
  <div class="bg-creme">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <Breadcrumbs items={breadcrumbs} />
    </div>
  </div>

  <article class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

    {/* ================================================================
        EN-TETE — commun aux 3 niveaux
        ================================================================ */}
    <header class="mb-8">
      <div class="flex flex-wrap items-center gap-3 mb-4">
        <h1 class="font-sans text-2xl sm:text-3xl font-bold text-marine leading-tight">
          {centre.nom}
        </h1>
        {isPremium && <VerifiedBadge />}
      </div>
      <div class="flex items-start gap-2 text-gris-texte font-sans">
        <Icon name="lucide:map-pin" class="w-5 h-5 mt-0.5 shrink-0 text-marine" />
        <p>
          {centre.adresse}<br />
          {centre.cp} {centre.ville}
          {centre.departement && <span class="text-gris-clair"> — Dept. {centre.departement}</span>}
        </p>
      </div>
    </header>

    {/* ================================================================
        NIVEAU 1 — Fiche RPPS (non revendiquee)
        Page courte : bandeau + carte + formulaire generique
        ================================================================ */}
    {isRpps && (
      <>
        <ClaimBanner slug={centre.slug} />

        {/* Carte si GPS dispo */}
        {centre.lat && centre.lng && (
          <section class="rounded-xl border border-gris-clair bg-blanc p-4 mb-8" aria-label="Localisation du centre">
            <h2 class="font-sans text-lg font-bold text-marine mb-3">Localisation</h2>
            <div class="rounded-lg overflow-hidden" style="height: 300px;">
              <iframe
                title={`Carte de ${centre.nom}`}
                width="100%"
                height="300"
                style="border: 0;"
                loading="lazy"
                src={`https://www.openstreetmap.org/export/embed.html?bbox=${centre.lng - 0.01},${centre.lat - 0.008},${centre.lng + 0.01},${centre.lat + 0.008}&layer=mapnik&marker=${centre.lat},${centre.lng}`}
              ></iframe>
            </div>
            <p class="text-sm text-gris-texte font-sans mt-2">
              {centre.adresse}, {centre.cp} {centre.ville}
            </p>
          </section>
        )}

        {/* Formulaire patient generique */}
        <section class="mb-8" aria-label="Demande de bilan auditif">
          <LeadForm client:visible centreSlug={centre.slug} />
        </section>
      </>
    )}

    {/* ================================================================
        NIVEAU 2 — Fiche revendiquee (gratuit)
        Fiche complete : coordonnees, photo, specialites, marques, a propos
        ================================================================ */}
    {isClaimed && (
      <>
        {/* Coordonnees */}
        <section class="rounded-xl border border-gris-clair bg-blanc p-6 sm:p-8 mb-8" aria-label="Coordonnees du centre">
          <h2 class="font-sans text-xl font-bold text-marine mb-6">Coordonnees</h2>
          <div class="grid gap-5 sm:grid-cols-2">
            {centre.tel && (
              <div class="flex items-center gap-3">
                <div class="flex items-center justify-center w-11 h-11 rounded-full bg-marine/10">
                  <Icon name="lucide:phone" class="w-5 h-5 text-marine" />
                </div>
                <div>
                  <p class="text-sm text-gris-texte font-sans">Telephone</p>
                  <a href={`tel:${centre.tel.replace(/\s/g, '')}`} class="text-lg font-semibold text-marine font-sans hover:text-orange transition-colors">
                    {centre.tel}
                  </a>
                </div>
              </div>
            )}

            {centre.site_web && (
              <div class="flex items-center gap-3">
                <div class="flex items-center justify-center w-11 h-11 rounded-full bg-marine/10">
                  <Icon name="lucide:globe" class="w-5 h-5 text-marine" />
                </div>
                <div>
                  <p class="text-sm text-gris-texte font-sans">Site web</p>
                  <a href={centre.site_web} target="_blank" rel="noopener" class="text-marine font-semibold font-sans hover:text-orange transition-colors">
                    Visiter le site
                  </a>
                </div>
              </div>
            )}

            {centre.email && (
              <div class="flex items-center gap-3">
                <div class="flex items-center justify-center w-11 h-11 rounded-full bg-marine/10">
                  <Icon name="lucide:mail" class="w-5 h-5 text-marine" />
                </div>
                <div>
                  <p class="text-sm text-gris-texte font-sans">Email</p>
                  <a href={`mailto:${centre.email}`} class="text-marine font-semibold font-sans hover:text-orange transition-colors">
                    {centre.email}
                  </a>
                </div>
              </div>
            )}

            {centre.horaires && (
              <div class="flex items-center gap-3 sm:col-span-2">
                <div class="flex items-center justify-center w-11 h-11 rounded-full bg-marine/10">
                  <Icon name="lucide:clock" class="w-5 h-5 text-marine" />
                </div>
                <div>
                  <p class="text-sm text-gris-texte font-sans">Horaires</p>
                  <p class="font-semibold text-marine font-sans">{centre.horaires}</p>
                </div>
              </div>
            )}
          </div>
        </section>

        {/* Photo */}
        {centre.photo_url && (
          <section class="mb-8">
            <img
              src={centre.photo_url}
              alt={`Photo du centre ${centre.nom}`}
              class="w-full rounded-xl object-cover"
              style="max-height: 400px;"
              loading="lazy"
            />
          </section>
        )}

        {/* Specialites */}
        {centre.specialites?.length > 0 && (
          <section class="rounded-xl border border-gris-clair bg-blanc p-6 mb-8" aria-label="Specialites">
            <h2 class="font-sans text-lg font-bold text-marine mb-4">Specialites</h2>
            <div class="flex flex-wrap gap-2">
              {centre.specialites.map((s: string) => (
                <span class="rounded-full bg-marine/5 border border-marine/10 px-3 py-1 text-sm font-medium text-marine font-sans">
                  {s}
                </span>
              ))}
            </div>
          </section>
        )}

        {/* Marques */}
        {centre.marques?.length > 0 && (
          <section class="rounded-xl border border-gris-clair bg-blanc p-6 mb-8" aria-label="Marques proposees">
            <h2 class="font-sans text-lg font-bold text-marine mb-4">Marques proposees</h2>
            <div class="flex flex-wrap gap-2">
              {centre.marques.map((m: string) => (
                <span class="rounded-full bg-marine/5 border border-marine/10 px-3 py-1 text-sm font-medium text-marine font-sans">
                  {m}
                </span>
              ))}
            </div>
          </section>
        )}

        {/* A propos */}
        {centre.a_propos && (
          <section class="rounded-xl border border-gris-clair bg-blanc p-6 mb-8" aria-label="A propos du centre">
            <h2 class="font-sans text-lg font-bold text-marine mb-4">A propos</h2>
            <p class="text-gris-texte font-sans leading-relaxed">{centre.a_propos}</p>
          </section>
        )}

        {/* Carte */}
        {centre.lat && centre.lng && (
          <section class="rounded-xl border border-gris-clair bg-blanc p-4 mb-8" aria-label="Localisation du centre">
            <h2 class="font-sans text-lg font-bold text-marine mb-3">Localisation</h2>
            <div class="rounded-lg overflow-hidden" style="height: 300px;">
              <iframe
                title={`Carte de ${centre.nom}`}
                width="100%"
                height="300"
                style="border: 0;"
                loading="lazy"
                src={`https://www.openstreetmap.org/export/embed.html?bbox=${centre.lng - 0.01},${centre.lat - 0.008},${centre.lng + 0.01},${centre.lat + 0.008}&layer=mapnik&marker=${centre.lat},${centre.lng}`}
              ></iframe>
            </div>
            <p class="text-sm text-gris-texte font-sans mt-2">
              {centre.adresse}, {centre.cp} {centre.ville}
            </p>
          </section>
        )}

        {/* Formulaire patient personnalise */}
        <section class="mb-8" aria-label="Demande de bilan auditif">
          <LeadForm client:visible centreSlug={centre.slug} centreName={centre.nom} />
        </section>

        {/* Upsell discret en bas */}
        <UpsellBanner />
      </>
    )}

    {/* ================================================================
        NIVEAU 3 — Fiche premium
        Tout du niveau 2 + badge verifie, reseaux sociaux, avis
        ================================================================ */}
    {isPremium && (
      <>
        {/* Coordonnees */}
        <section class="rounded-xl border-2 border-orange/20 bg-blanc p-6 sm:p-8 mb-8" aria-label="Coordonnees du centre">
          <h2 class="font-sans text-xl font-bold text-marine mb-6">Coordonnees</h2>
          <div class="grid gap-5 sm:grid-cols-2">
            {centre.tel && (
              <div class="flex items-center gap-3">
                <div class="flex items-center justify-center w-11 h-11 rounded-full bg-orange/10">
                  <Icon name="lucide:phone" class="w-5 h-5 text-orange" />
                </div>
                <div>
                  <p class="text-sm text-gris-texte font-sans">Telephone</p>
                  <a href={`tel:${centre.tel.replace(/\s/g, '')}`} class="text-lg font-semibold text-marine font-sans hover:text-orange transition-colors">
                    {centre.tel}
                  </a>
                </div>
              </div>
            )}

            {centre.site_web && (
              <div class="flex items-center gap-3">
                <div class="flex items-center justify-center w-11 h-11 rounded-full bg-orange/10">
                  <Icon name="lucide:globe" class="w-5 h-5 text-orange" />
                </div>
                <div>
                  <p class="text-sm text-gris-texte font-sans">Site web</p>
                  <a href={centre.site_web} target="_blank" rel="noopener" class="text-marine font-semibold font-sans hover:text-orange transition-colors">
                    Visiter le site
                  </a>
                </div>
              </div>
            )}

            {centre.email && (
              <div class="flex items-center gap-3">
                <div class="flex items-center justify-center w-11 h-11 rounded-full bg-orange/10">
                  <Icon name="lucide:mail" class="w-5 h-5 text-orange" />
                </div>
                <div>
                  <p class="text-sm text-gris-texte font-sans">Email</p>
                  <a href={`mailto:${centre.email}`} class="text-marine font-semibold font-sans hover:text-orange transition-colors">
                    {centre.email}
                  </a>
                </div>
              </div>
            )}

            {centre.horaires && (
              <div class="flex items-center gap-3 sm:col-span-2">
                <div class="flex items-center justify-center w-11 h-11 rounded-full bg-orange/10">
                  <Icon name="lucide:clock" class="w-5 h-5 text-orange" />
                </div>
                <div>
                  <p class="text-sm text-gris-texte font-sans">Horaires</p>
                  <p class="font-semibold text-marine font-sans">{centre.horaires}</p>
                </div>
              </div>
            )}
          </div>
        </section>

        {/* Photo */}
        {centre.photo_url && (
          <section class="mb-8">
            <img
              src={centre.photo_url}
              alt={`Photo du centre ${centre.nom}`}
              class="w-full rounded-xl object-cover"
              style="max-height: 400px;"
              loading="lazy"
            />
          </section>
        )}

        {/* Specialites */}
        {centre.specialites?.length > 0 && (
          <section class="rounded-xl border border-gris-clair bg-blanc p-6 mb-8" aria-label="Specialites">
            <h2 class="font-sans text-lg font-bold text-marine mb-4">Specialites</h2>
            <div class="flex flex-wrap gap-2">
              {centre.specialites.map((s: string) => (
                <span class="rounded-full bg-orange/10 border border-orange/20 px-3 py-1 text-sm font-medium text-marine font-sans">
                  {s}
                </span>
              ))}
            </div>
          </section>
        )}

        {/* Marques */}
        {centre.marques?.length > 0 && (
          <section class="rounded-xl border border-gris-clair bg-blanc p-6 mb-8" aria-label="Marques proposees">
            <h2 class="font-sans text-lg font-bold text-marine mb-4">Marques proposees</h2>
            <div class="flex flex-wrap gap-2">
              {centre.marques.map((m: string) => (
                <span class="rounded-full bg-marine/5 border border-marine/10 px-3 py-1 text-sm font-medium text-marine font-sans">
                  {m}
                </span>
              ))}
            </div>
          </section>
        )}

        {/* A propos */}
        {centre.a_propos && (
          <section class="rounded-xl border border-gris-clair bg-blanc p-6 mb-8" aria-label="A propos du centre">
            <h2 class="font-sans text-lg font-bold text-marine mb-4">A propos</h2>
            <p class="text-gris-texte font-sans leading-relaxed">{centre.a_propos}</p>
          </section>
        )}

        {/* Reseaux sociaux */}
        {centre.reseaux_sociaux && Object.keys(centre.reseaux_sociaux).length > 0 && (
          <section class="rounded-xl border border-gris-clair bg-blanc p-6 mb-8" aria-label="Reseaux sociaux">
            <h2 class="font-sans text-lg font-bold text-marine mb-4">Retrouvez-nous</h2>
            <div class="flex gap-3">
              {Object.entries(centre.reseaux_sociaux).map(([network, url]) => (
                <a
                  href={url as string}
                  target="_blank"
                  rel="noopener"
                  class="flex items-center justify-center w-11 h-11 rounded-full bg-marine/5 text-marine hover:bg-orange/10 hover:text-orange transition-colors"
                  aria-label={network}
                >
                  <Icon name={`lucide:${network === 'google' ? 'search' : network}`} class="w-5 h-5" />
                </a>
              ))}
            </div>
          </section>
        )}

        {/* Avis patients (placeholder pour l'instant) */}
        <section class="rounded-xl border border-gris-clair bg-blanc p-6 mb-8" aria-label="Avis patients">
          <h2 class="font-sans text-lg font-bold text-marine mb-3">Avis patients</h2>
          <p class="text-gris-texte font-sans text-sm">
            La section avis sera bientot disponible. Les patients pourront partager leur experience.
          </p>
        </section>

        {/* Carte */}
        {centre.lat && centre.lng && (
          <section class="rounded-xl border border-gris-clair bg-blanc p-4 mb-8" aria-label="Localisation du centre">
            <h2 class="font-sans text-lg font-bold text-marine mb-3">Localisation</h2>
            <div class="rounded-lg overflow-hidden" style="height: 300px;">
              <iframe
                title={`Carte de ${centre.nom}`}
                width="100%"
                height="300"
                style="border: 0;"
                loading="lazy"
                src={`https://www.openstreetmap.org/export/embed.html?bbox=${centre.lng - 0.01},${centre.lat - 0.008},${centre.lng + 0.01},${centre.lat + 0.008}&layer=mapnik&marker=${centre.lat},${centre.lng}`}
              ></iframe>
            </div>
            <p class="text-sm text-gris-texte font-sans mt-2">
              {centre.adresse}, {centre.cp} {centre.ville}
            </p>
          </section>
        )}

        {/* Formulaire patient personnalise */}
        <section class="mb-8" aria-label="Demande de bilan auditif">
          <LeadForm client:visible centreSlug={centre.slug} centreName={centre.nom} />
        </section>
      </>
    )}

    {/* Lien retour annuaire — commun */}
    <nav class="font-sans text-center py-4">
      <a
        href="/trouver-audioprothesiste/"
        class="inline-flex items-center gap-2 text-orange font-semibold hover:underline"
      >
        <Icon name="lucide:arrow-left" class="w-5 h-5" />
        Retour a l'annuaire
      </a>
    </nav>
  </article>

  <HealthDisclaimer />
</BaseLayout>
