---
export const prerender = false;

import { Icon } from 'astro-icon/components';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import HealthDisclaimer from '../../components/HealthDisclaimer.astro';
import LeadForm from '../../components/LeadForm.tsx';

// Composants centre
import CentreAlertBanner from '../../components/centre/CentreAlertBanner.astro';
import CentreHeader from '../../components/centre/CentreHeader.astro';
import CentreInfoGrid from '../../components/centre/CentreInfoGrid.astro';
import CentreSpecialties from '../../components/centre/CentreSpecialties.astro';
import CentreBrands from '../../components/centre/CentreBrands.astro';
import CentreCompleteness from '../../components/centre/CentreCompleteness.astro';
import CentreClaimCTA from '../../components/centre/CentreClaimCTA.astro';
import CentreUpgradeCard from '../../components/centre/CentreUpgradeCard.astro';
import CentreCompetitors from '../../components/centre/CentreCompetitors.astro';
import CentreStats from '../../components/centre/CentreStats.astro';
import CentreMap from '../../components/centre/CentreMap.astro';

// Blocs Premium enrichissement SEO/YMYL
import PremiumExpertiseBlock from '../../components/centre/premium/PremiumExpertiseBlock.astro';
import PremiumEquipementBlock from '../../components/centre/premium/PremiumEquipementBlock.astro';
import PremiumParcoursBlock from '../../components/centre/premium/PremiumParcoursBlock.astro';
import PremiumArticlesBlock from '../../components/centre/premium/PremiumArticlesBlock.astro';
import PremiumAccessibiliteBlock from '../../components/centre/premium/PremiumAccessibiliteBlock.astro';
import PremiumPartenairesBlock from '../../components/centre/premium/PremiumPartenairesBlock.astro';
import PremiumFaqBlock from '../../components/centre/premium/PremiumFaqBlock.astro';

import { supabase } from '../../lib/supabase';
import { getDepartementByCode, slugifyVille } from '../../lib/departements';
import type { CentreData } from '../../types/centre';

const { slug } = Astro.params;

const { data: centre, error } = await supabase
  .from('centres_auditifs')
  .select('*')
  .eq('slug', slug)
  .single();

if (error || !centre) {
  // Lookup centre_redirects avant 404 : le ré-import FINESS/INSEE 2026-04 a
  // modifié ~3 700 slugs. On émet un 301 propre plutôt que de crasher.
  // Le top 1000 des redirects est aussi dans vercel.json (edge), ce bloc
  // couvre les 2 719 restants via Supabase.
  const { data: redirect } = await supabase
    .from('centre_redirects')
    .select('new_slug')
    .eq('old_slug', slug)
    .maybeSingle();
  if (redirect?.new_slug) {
    return Astro.redirect(`/centre/${redirect.new_slug}/`, 301);
  }
  return new Response(null, { status: 404 });
}

const typedCentre = centre as unknown as CentreData;
const displayVille = typedCentre.ville || typedCentre.cp;

const isRpps = typedCentre.plan === 'rpps';
const isClaimed = typedCentre.plan === 'claimed';
const isPremium = typedCentre.plan === 'premium';
const isPendingClaim = isRpps && typedCentre.claim_status === 'pending';

// Indexation : noindex sur fiches RPPS non revendiquées (thin content — FINESS brut).
// Les fiches claimed/premium portent `a_propos` + données enrichies = indexables.
// Les fiches is_demo sont également noindex (démos ne doivent pas polluer l'index Google).
const isThin = isRpps || typedCentre.is_demo === true;

// Verifier si le visiteur est le proprietaire de cette fiche
const user = Astro.locals.user;
const isOwner = user?.email === typedCentre.claimed_by_email && typedCentre.claim_status === 'approved';

// --- Données conditionnelles ---

// Centres concurrents (État 1 uniquement)
let competitors: CentreData[] = [];
if (isRpps && typedCentre.lat && typedCentre.lng) {
  const { data } = await supabase.rpc('nearby_claimed_centres', {
    p_lat: typedCentre.lat,
    p_lng: typedCentre.lng,
    p_exclude_id: typedCentre.id,
  });
  if (data) competitors = data as unknown as CentreData[];
}

// Stats de vues
let viewCount = 0;
const { data: stats } = await supabase.rpc('centre_view_stats', {
  p_centre_id: typedCentre.id,
});
if (stats && stats.length > 0) viewCount = Number(stats[0].views_30d) || 0;

// Nombre de leads (pour les compteurs)
let leadCount = 0;
const { count } = await supabase
  .from('leads')
  .select('*', { count: 'exact', head: true })
  .eq('source', `centre/${slug}`);
if (count) leadCount = count;

// --- SEO ---
const pageTitle = `${typedCentre.nom} — Audioprothésiste ${displayVille}`;
const pageDescription = isRpps
  ? `${typedCentre.nom}, audioprothésiste à ${displayVille}. Demandez un bilan auditif gratuit près de chez vous.`
  : `${typedCentre.nom}, audioprothésiste à ${displayVille}. Coordonnées, horaires et prise de rendez-vous.`;

// Maillage silo : Audioprothésistes → Département → Ville → Centre
const centreCp = typedCentre.cp || '';
const centreDepCode = centreCp.substring(0, 2) === '97' ? centreCp.substring(0, 3) : centreCp.substring(0, 2);
const centreDepInfo = getDepartementByCode(centreDepCode);
const centreVilleSlug = typedCentre.ville ? slugifyVille(typedCentre.ville) : '';

const breadcrumbs = [
  { label: 'Accueil', href: '/' },
  { label: 'Audioprothésistes', href: '/audioprothesiste/' },
  ...(centreDepInfo ? [{ label: centreDepInfo.nom, href: `/audioprothesiste/departement/${centreDepInfo.slug}/` }] : []),
  ...(centreVilleSlug ? [{ label: displayVille, href: `/audioprothesiste/${centreVilleSlug}/` }] : []),
  { label: typedCentre.nom },
];

const schema: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': ['LocalBusiness', 'MedicalBusiness'],
  '@id': `https://leguideauditif.fr/centre/${typedCentre.slug}/`,
  name: typedCentre.nom,
  address: {
    '@type': 'PostalAddress',
    streetAddress: typedCentre.adresse,
    postalCode: typedCentre.cp,
    addressLocality: typedCentre.ville || undefined,
    addressCountry: 'FR',
  },
  medicalSpecialty: 'Audioprothèse',
};

if (typedCentre.lat && typedCentre.lng) {
  schema.geo = { '@type': 'GeoCoordinates', latitude: typedCentre.lat, longitude: typedCentre.lng };
}
if (!isRpps && typedCentre.rpps) {
  schema.identifier = {
    '@type': 'PropertyValue',
    name: 'RPPS',
    value: typedCentre.rpps,
    description: 'Répertoire Partagé des Professionnels de Santé',
  };
}
if (!isRpps && typedCentre.tel) schema.telephone = typedCentre.tel;
if (!isRpps && typedCentre.site_web) schema.url = typedCentre.site_web;
if (!isRpps && typedCentre.email) schema.email = typedCentre.email;
if (!isRpps && typedCentre.horaires) schema.openingHours = typedCentre.horaires;
if (typedCentre.photo_url) schema.image = typedCentre.photo_url;
if (typedCentre.specialites?.length > 0) schema.knowsAbout = typedCentre.specialites;
if (typedCentre.marques?.length > 0) {
  schema.brand = typedCentre.marques.map((m: string) => ({ '@type': 'Brand', name: m }));
}
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonical={`https://leguideauditif.fr/centre/${typedCentre.slug}/`}
  schema={schema}
  noindex={isThin}
>
  <div class="bg-creme">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <Breadcrumbs items={breadcrumbs} />
    </div>
  </div>

  <article class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

    {/* ================================================================
        ÉTAT 1 — Non revendiquée (RPPS)
        ================================================================ */}
    {isRpps && (
      <>
        <CentreAlertBanner />
        <CentreHeader centre={typedCentre} />
        <CentreInfoGrid centre={typedCentre} />
        <CentreSpecialties centre={typedCentre} />
        <CentreBrands centre={typedCentre} />
        <CentreCompleteness centre={typedCentre} />

        {/* Encadre alerte rouge */}
        <div class="rounded-lg bg-[#FCEBEB] px-4 py-3 mb-6 flex items-start gap-2">
          <Icon name="lucide:alert-triangle" class="w-4 h-4 text-[#A32D2D] shrink-0 mt-0.5" />
          <p class="text-xs text-[#791F1F] font-sans">
            Sans fiche complète, les demandes de devis de cette zone sont envoyées aux centres voisins qui ont complété leur fiche.
          </p>
        </div>

        {isPendingClaim ? (
          <div class="rounded-xl bg-[#FAEEDA] border border-[#EFD5A0] p-5 mb-6 flex items-start gap-3">
            <Icon name="lucide:clock" class="w-5 h-5 text-[#854F0B] shrink-0 mt-0.5" />
            <div>
              <p class="text-sm font-medium text-[#633806] font-sans">Vérification en cours</p>
              <p class="text-xs text-[#854F0B] font-sans mt-1">
                Une demande de revendication a été soumise pour ce centre. La vérification est en cours et sera finalisée sous 24h.
              </p>
            </div>
          </div>
        ) : (
          <CentreClaimCTA slug={typedCentre.slug} audioPrenom={typedCentre.audio_prenom} />
        )}
        <CentreCompetitors competitors={competitors} />
        <CentreStats plan="rpps" viewCount={viewCount} leadCount={leadCount} />
        <CentreMap centre={typedCentre} />

        <section class="mb-6" aria-label="Demande de bilan auditif">
          <LeadForm client:visible centreSlug={typedCentre.slug} variant="rpps" />
        </section>

        {/* Footer source RPPS */}
        <p class="text-[11px] text-[#B4B2A9] font-sans text-center mb-4">
          Source : Annuaire RPPS (data.gouv.fr) — Mise à jour périodique
        </p>
      </>
    )}

    {/* ================================================================
        ÉTAT 2 — Revendiquée gratuite
        ================================================================ */}
    {isClaimed && (
      <>
        {isOwner && (
          <a
            href="/audioprothesiste-pro/"
            class="flex items-center justify-center gap-2 w-full rounded-lg bg-marine px-5 py-3 text-sm font-medium text-blanc font-sans mb-4 hover:bg-marine/90 transition-colors"
            style="min-height: 44px;"
          >
            <Icon name="lucide:layout-dashboard" class="w-4 h-4" />
            Accéder à mon espace pro
          </a>
        )}
        <CentreHeader centre={typedCentre} />
        <CentreInfoGrid centre={typedCentre} />

        <CentreSpecialties centre={typedCentre} />
        <CentreBrands centre={typedCentre} />
        <CentreCompleteness centre={typedCentre} />

        {typedCentre.a_propos && (
          <section class="rounded-xl border border-gris-clair bg-blanc p-6 mb-6" aria-label="À propos du centre">
            <h2 class="font-sans text-lg font-bold text-marine mb-4">À propos</h2>
            <p class="text-gris-texte font-sans leading-relaxed">{typedCentre.a_propos}</p>
          </section>
        )}

        <CentreUpgradeCard slug={typedCentre.slug} />
        <CentreStats plan="claimed" viewCount={viewCount} />
        <CentreMap centre={typedCentre} />

        <section class="mb-6" aria-label="Demande de bilan auditif">
          <LeadForm client:visible centreSlug={typedCentre.slug} centreName={typedCentre.nom} variant="claimed" />
        </section>
      </>
    )}

    {/* ================================================================
        ÉTAT 3 — Premium (fiche enrichie E-E-A-T + YMYL + local SEO)
        ================================================================ */}
    {isPremium && (
      <>
        {isOwner && (
          <a
            href="/audioprothesiste-pro/"
            class="flex items-center justify-center gap-2 w-full rounded-lg bg-marine px-5 py-3 text-sm font-medium text-blanc font-sans mb-4 hover:bg-marine/90 transition-colors"
            style="min-height: 44px;"
          >
            <Icon name="lucide:layout-dashboard" class="w-4 h-4" />
            Accéder à mon espace pro
          </a>
        )}
        <CentreHeader centre={typedCentre} />
        <CentreInfoGrid centre={typedCentre} />
        <CentreSpecialties centre={typedCentre} />
        <CentreBrands centre={typedCentre} />

        {/* E-E-A-T : audio + diplôme + asso + bio (remplace l'ancien "à propos"
            qui était pauvre — on intègre a_propos comme fallback bio dans le bloc) */}
        <PremiumExpertiseBlock centre={typedCentre} />

        {/* Équipement technique : cabine, REM, essai, garantie */}
        <PremiumEquipementBlock centre={typedCentre} />

        {/* Parcours patient 4 étapes + HowTo JSON-LD */}
        <PremiumParcoursBlock centre={typedCentre} />

        {/* Articles contextualisés — maillage interne SEO */}
        <PremiumArticlesBlock centre={typedCentre} />

        {/* Accessibilité + schema Place amenityFeature (Google Local Pack) */}
        <PremiumAccessibiliteBlock centre={typedCentre} />

        {/* Partenaires de soin locaux — E-A-T réseau */}
        <PremiumPartenairesBlock centre={typedCentre} />

        <CentreStats plan="premium" viewCount={viewCount} leadCount={leadCount} />
        <CentreMap centre={typedCentre} />

        {/* FAQ locale schema.org — rich results */}
        <PremiumFaqBlock centre={typedCentre} />

        <section class="mb-6" aria-label="Demande de bilan auditif">
          <LeadForm client:visible centreSlug={typedCentre.slug} centreName={typedCentre.nom} variant="premium" />
        </section>
      </>
    )}

    {/* Lien retour annuaire */}
    <nav class="font-sans text-center py-4">
      <a
        href="/trouver-audioprothesiste/"
        class="inline-flex items-center gap-2 text-orange font-semibold hover:underline"
      >
        <Icon name="lucide:arrow-left" class="w-5 h-5" />
        Retour à l'annuaire
      </a>
    </nav>
  </article>

  <HealthDisclaimer />

  {/* Tracking page view */}
  <script define:vars={{ centreId: typedCentre.id }}>
    fetch('/api/page-view', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ centreId }),
    }).catch(() => {});
  </script>
</BaseLayout>
