---
export const prerender = false;

import { Icon } from 'astro-icon/components';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import HealthDisclaimer from '../../components/HealthDisclaimer.astro';
import LeadForm from '../../components/LeadForm.tsx';

// Composants centre
import CentreAlertBanner from '../../components/centre/CentreAlertBanner.astro';
import CentreHeader from '../../components/centre/CentreHeader.astro';
import CentreInfoGrid from '../../components/centre/CentreInfoGrid.astro';
import CentreSpecialties from '../../components/centre/CentreSpecialties.astro';
import CentreBrands from '../../components/centre/CentreBrands.astro';
import CentreCompleteness from '../../components/centre/CentreCompleteness.astro';
import CentreClaimCTA from '../../components/centre/CentreClaimCTA.astro';
import CentreUpgradeCard from '../../components/centre/CentreUpgradeCard.astro';
import CentreCompetitors from '../../components/centre/CentreCompetitors.astro';
import CentreStats from '../../components/centre/CentreStats.astro';
import CentreMap from '../../components/centre/CentreMap.astro';

import { supabase } from '../../lib/supabase';
import type { CentreData } from '../../types/centre';

const { slug } = Astro.params;

const { data: centre, error } = await supabase
  .from('centres_auditifs')
  .select('*')
  .eq('slug', slug)
  .single();

if (error || !centre) {
  return Astro.redirect('/trouver-audioprothesiste/');
}

const typedCentre = centre as unknown as CentreData;
const displayVille = typedCentre.ville || typedCentre.cp;

const isRpps = typedCentre.plan === 'rpps';
const isClaimed = typedCentre.plan === 'claimed';
const isPremium = typedCentre.plan === 'premium';
const isPendingClaim = isRpps && typedCentre.claim_status === 'pending';

// --- Donnees conditionnelles ---

// Centres concurrents (Etat 1 uniquement)
let competitors: CentreData[] = [];
if (isRpps && typedCentre.lat && typedCentre.lng) {
  const { data } = await supabase.rpc('nearby_claimed_centres', {
    p_lat: typedCentre.lat,
    p_lng: typedCentre.lng,
    p_exclude_id: typedCentre.id,
  });
  if (data) competitors = data as unknown as CentreData[];
}

// Stats de vues
let viewCount = 0;
const { data: stats } = await supabase.rpc('centre_view_stats', {
  p_centre_id: typedCentre.id,
});
if (stats && stats.length > 0) viewCount = Number(stats[0].views_30d) || 0;

// Nombre de leads (pour les compteurs)
let leadCount = 0;
const { count } = await supabase
  .from('leads')
  .select('*', { count: 'exact', head: true })
  .eq('source', `centre/${slug}`);
if (count) leadCount = count;

// --- SEO ---
const pageTitle = `${typedCentre.nom} — Audioprothesiste ${displayVille}`;
const pageDescription = isRpps
  ? `${typedCentre.nom}, audioprothesiste a ${displayVille}. Demandez un bilan auditif gratuit pres de chez vous.`
  : `${typedCentre.nom}, audioprothesiste a ${displayVille}. Coordonnees, horaires et prise de rendez-vous.`;

const breadcrumbs = [
  { label: 'Accueil', href: '/' },
  { label: 'Trouver un audioprothesiste', href: '/trouver-audioprothesiste/' },
  { label: `${typedCentre.nom}, ${displayVille}` },
];

const schema: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  '@id': `https://leguideauditif.fr/centre/${typedCentre.slug}/`,
  name: typedCentre.nom,
  address: {
    '@type': 'PostalAddress',
    streetAddress: typedCentre.adresse,
    postalCode: typedCentre.cp,
    addressLocality: typedCentre.ville || undefined,
    addressCountry: 'FR',
  },
  medicalSpecialty: 'Audioprothese',
};

if (typedCentre.lat && typedCentre.lng) {
  schema.geo = { '@type': 'GeoCoordinates', latitude: typedCentre.lat, longitude: typedCentre.lng };
}
if (!isRpps && typedCentre.tel) schema.telephone = typedCentre.tel;
if (!isRpps && typedCentre.site_web) schema.url = typedCentre.site_web;
if (!isRpps && typedCentre.email) schema.email = typedCentre.email;
if (!isRpps && typedCentre.horaires) schema.openingHours = typedCentre.horaires;
if (typedCentre.photo_url) schema.image = typedCentre.photo_url;
if (typedCentre.specialites?.length > 0) schema.knowsAbout = typedCentre.specialites;
if (typedCentre.marques?.length > 0) {
  schema.brand = typedCentre.marques.map((m: string) => ({ '@type': 'Brand', name: m }));
}
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonical={`https://leguideauditif.fr/centre/${typedCentre.slug}/`}
  schema={schema}
>
  <div class="bg-creme">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <Breadcrumbs items={breadcrumbs} />
    </div>
  </div>

  <article class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

    {/* ================================================================
        ETAT 1 — Non revendiquee (RPPS)
        ================================================================ */}
    {isRpps && (
      <>
        <CentreAlertBanner />
        <CentreHeader centre={typedCentre} />
        <CentreInfoGrid centre={typedCentre} />
        <CentreSpecialties centre={typedCentre} />
        <CentreBrands centre={typedCentre} />
        <CentreCompleteness centre={typedCentre} />

        {/* Encadre alerte rouge */}
        <div class="rounded-lg bg-[#FCEBEB] px-4 py-3 mb-6 flex items-start gap-2">
          <Icon name="lucide:alert-triangle" class="w-4 h-4 text-[#A32D2D] shrink-0 mt-0.5" />
          <p class="text-xs text-[#791F1F] font-sans">
            Sans fiche complete, les demandes de devis de cette zone sont envoyees aux centres voisins qui ont complete leur fiche.
          </p>
        </div>

        {isPendingClaim ? (
          <div class="rounded-xl bg-[#FAEEDA] border border-[#EFD5A0] p-5 mb-6 flex items-start gap-3">
            <Icon name="lucide:clock" class="w-5 h-5 text-[#854F0B] shrink-0 mt-0.5" />
            <div>
              <p class="text-sm font-medium text-[#633806] font-sans">Verification en cours</p>
              <p class="text-xs text-[#854F0B] font-sans mt-1">
                Une demande de revendication a ete soumise pour ce centre. La verification est en cours et sera finalisee sous 24h.
              </p>
            </div>
          </div>
        ) : (
          <CentreClaimCTA slug={typedCentre.slug} audioPrenom={typedCentre.audio_prenom} />
        )}
        <CentreCompetitors competitors={competitors} />
        <CentreStats plan="rpps" viewCount={viewCount} leadCount={leadCount} />
        <CentreMap centre={typedCentre} />

        <section class="mb-6" aria-label="Demande de bilan auditif">
          <LeadForm client:visible centreSlug={typedCentre.slug} variant="rpps" />
        </section>

        {/* Footer source RPPS */}
        <p class="text-[11px] text-[#B4B2A9] font-sans text-center mb-4">
          Source : Annuaire RPPS (data.gouv.fr) — Mise a jour periodique
        </p>
      </>
    )}

    {/* ================================================================
        ETAT 2 — Revendiquee gratuite
        ================================================================ */}
    {isClaimed && (
      <>
        <CentreHeader centre={typedCentre} />
        <CentreInfoGrid centre={typedCentre} />

        {typedCentre.photo_url && (
          <section class="mb-6">
            <img
              src={typedCentre.photo_url}
              alt={`Photo du centre ${typedCentre.nom}`}
              class="w-full rounded-xl object-cover"
              style="max-height: 400px;"
              loading="lazy"
            />
          </section>
        )}

        <CentreSpecialties centre={typedCentre} />
        <CentreBrands centre={typedCentre} />
        <CentreCompleteness centre={typedCentre} />

        {typedCentre.a_propos && (
          <section class="rounded-xl border border-gris-clair bg-blanc p-6 mb-6" aria-label="A propos du centre">
            <h2 class="font-sans text-lg font-bold text-marine mb-4">A propos</h2>
            <p class="text-gris-texte font-sans leading-relaxed">{typedCentre.a_propos}</p>
          </section>
        )}

        <CentreUpgradeCard slug={typedCentre.slug} />
        <CentreStats plan="claimed" viewCount={viewCount} />
        <CentreMap centre={typedCentre} />

        <section class="mb-6" aria-label="Demande de bilan auditif">
          <LeadForm client:visible centreSlug={typedCentre.slug} centreName={typedCentre.nom} variant="claimed" />
        </section>
      </>
    )}

    {/* ================================================================
        ETAT 3 — Premium
        ================================================================ */}
    {isPremium && (
      <>
        <CentreHeader centre={typedCentre} />
        <CentreInfoGrid centre={typedCentre} />

        {typedCentre.photo_url && (
          <section class="mb-6">
            <img
              src={typedCentre.photo_url}
              alt={`Photo du centre ${typedCentre.nom}`}
              class="w-full rounded-xl object-cover"
              style="max-height: 400px;"
              loading="lazy"
            />
          </section>
        )}

        <CentreSpecialties centre={typedCentre} />
        <CentreBrands centre={typedCentre} />
        <CentreCompleteness centre={typedCentre} />

        {typedCentre.a_propos && (
          <section class="rounded-xl border border-gris-clair bg-blanc p-6 mb-6" aria-label="A propos du centre">
            <h2 class="font-sans text-lg font-bold text-marine mb-4">A propos</h2>
            <p class="text-gris-texte font-sans leading-relaxed">{typedCentre.a_propos}</p>
          </section>
        )}

        <CentreStats plan="premium" viewCount={viewCount} leadCount={leadCount} />
        <CentreMap centre={typedCentre} />

        <section class="mb-6" aria-label="Demande de bilan auditif">
          <LeadForm client:visible centreSlug={typedCentre.slug} centreName={typedCentre.nom} variant="premium" />
        </section>
      </>
    )}

    {/* Lien retour annuaire */}
    <nav class="font-sans text-center py-4">
      <a
        href="/trouver-audioprothesiste/"
        class="inline-flex items-center gap-2 text-orange font-semibold hover:underline"
      >
        <Icon name="lucide:arrow-left" class="w-5 h-5" />
        Retour a l'annuaire
      </a>
    </nav>
  </article>

  <HealthDisclaimer />

  {/* Tracking page view */}
  <script define:vars={{ centreId: typedCentre.id }}>
    fetch('/api/page-view', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ centreId }),
    }).catch(() => {});
  </script>
</BaseLayout>
