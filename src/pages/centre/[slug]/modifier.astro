---
export const prerender = false;

import { Icon } from 'astro-icon/components';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import { supabase } from '../../../lib/supabase';
import type { CentreData } from '../../../types/centre';

const { slug } = Astro.params;
const user = Astro.locals.user;

// Rediriger si non connecte
if (!user) {
  return Astro.redirect('/connexion-pro');
}

const { data: centre, error } = await supabase
  .from('centres_auditifs')
  .select('*')
  .eq('slug', slug)
  .single();

if (error || !centre) {
  return Astro.redirect('/trouver-audioprothesiste/');
}

// Verifier que l'utilisateur est bien le proprietaire
if (user.email !== centre.claimed_by_email || centre.claim_status !== 'approved') {
  return Astro.redirect(`/centre/${slug}/`);
}

const typedCentre = centre as unknown as CentreData;

const breadcrumbs = [
  { label: 'Accueil', href: '/' },
  { label: typedCentre.nom, href: `/centre/${typedCentre.slug}/` },
  { label: 'Modifier' },
];
---

<BaseLayout
  title={`Modifier ${typedCentre.nom} — LeGuideAuditif`}
  description="Modifiez les informations de votre fiche audioproth\u00e9siste."
>
  <meta slot="head" name="robots" content="noindex" />

  <div class="bg-creme">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <Breadcrumbs items={breadcrumbs} />
    </div>
  </div>

  <section class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="flex items-center gap-3 mb-6">
      <div class="w-10 h-10 rounded-full bg-orange/10 flex items-center justify-center">
        <Icon name="lucide:pen-line" class="w-5 h-5 text-orange" />
      </div>
      <div>
        <h1 class="font-sans text-xl font-bold text-marine">Modifier votre fiche</h1>
        <p class="text-sm text-gris-texte font-sans">{typedCentre.adresse}, {typedCentre.cp} {typedCentre.ville}</p>
      </div>
    </div>

    <form id="edit-form" class="rounded-xl border border-gris-clair bg-blanc p-6 sm:p-8">
      <input type="hidden" name="centreSlug" value={typedCentre.slug} />

      <div class="grid gap-5 sm:grid-cols-2">
        <div class="sm:col-span-2">
          <label for="edit-nom" class="block text-sm font-medium text-marine font-sans mb-1">
            Nom du centre
          </label>
          <input
            id="edit-nom"
            name="nom"
            type="text"
            value={typedCentre.nom}
            required
            class="w-full rounded-lg border border-gris-clair px-4 py-3 text-base font-sans focus:border-orange focus:outline-none focus:ring-2 focus:ring-orange/20"
          />
        </div>

        <div>
          <label for="edit-tel" class="block text-sm font-medium text-marine font-sans mb-1">
            T&eacute;l&eacute;phone
          </label>
          <input
            id="edit-tel"
            name="tel"
            type="tel"
            value={typedCentre.tel || ''}
            class="w-full rounded-lg border border-gris-clair px-4 py-3 text-base font-sans focus:border-orange focus:outline-none focus:ring-2 focus:ring-orange/20"
          />
        </div>

        <div>
          <label for="edit-site-web" class="block text-sm font-medium text-marine font-sans mb-1">
            Site web
          </label>
          <input
            id="edit-site-web"
            name="site_web"
            type="url"
            value={typedCentre.site_web || ''}
            placeholder="https://www.mon-centre.fr"
            class="w-full rounded-lg border border-gris-clair px-4 py-3 text-base font-sans focus:border-orange focus:outline-none focus:ring-2 focus:ring-orange/20"
          />
        </div>

        <div class="sm:col-span-2">
          <label class="block text-sm font-medium text-marine font-sans mb-2">
            Horaires d'ouverture
          </label>
          <input type="hidden" id="edit-horaires" name="horaires" value={typedCentre.horaires || ''} />
          <div class="grid grid-cols-3 gap-3">
            <div>
              <label for="h-ouverture" class="block text-xs text-gris-texte font-sans mb-1">Ouverture</label>
              <select id="h-ouverture" class="w-full rounded-lg border border-gris-clair px-3 py-3 text-base font-sans focus:border-orange focus:outline-none focus:ring-2 focus:ring-orange/20 bg-blanc">
                <option value="">--</option>
                <option value="8h">8h</option>
                <option value="8h30">8h30</option>
                <option value="9h">9h</option>
                <option value="9h30">9h30</option>
                <option value="10h">10h</option>
              </select>
            </div>
            <div>
              <label for="h-fermeture" class="block text-xs text-gris-texte font-sans mb-1">Fermeture</label>
              <select id="h-fermeture" class="w-full rounded-lg border border-gris-clair px-3 py-3 text-base font-sans focus:border-orange focus:outline-none focus:ring-2 focus:ring-orange/20 bg-blanc">
                <option value="">--</option>
                <option value="17h">17h</option>
                <option value="17h30">17h30</option>
                <option value="18h">18h</option>
                <option value="18h30">18h30</option>
                <option value="19h">19h</option>
              </select>
            </div>
            <div>
              <label for="h-samedi" class="block text-xs text-gris-texte font-sans mb-1">Samedi</label>
              <select id="h-samedi" class="w-full rounded-lg border border-gris-clair px-3 py-3 text-base font-sans focus:border-orange focus:outline-none focus:ring-2 focus:ring-orange/20 bg-blanc">
                <option value="">--</option>
                <option value="Ferm&eacute;">Ferm&eacute;</option>
                <option value="9h-12h">9h-12h</option>
                <option value="9h-13h">9h-13h</option>
                <option value="10h-12h">10h-12h</option>
                <option value="Sur RDV">Sur RDV</option>
              </select>
            </div>
          </div>
        </div>
      </div>

      <div class="mt-5">
        <label class="block text-sm font-medium text-marine font-sans mb-1">
          Sp&eacute;cialit&eacute;s (3 max)
        </label>
        <div class="flex flex-wrap gap-2" id="specialites-container">
          {[
            'Acouph\u00e8nes', 'P\u00e9diatrie', 'Implants cochl\u00e9aires',
            '100% Sant\u00e9', 'Bilan auditif gratuit', 'Appareillage premi\u00e8re fois',
            'Surdit\u00e9 s\u00e9v\u00e8re/profonde', 'Protection auditive', 'Audiom\u00e9trie',
          ].map((s) => (
            <label class="inline-flex items-center gap-1.5 rounded-full border border-gris-clair bg-blanc px-3 py-1.5 text-sm font-sans cursor-pointer hover:border-orange/50 transition-colors has-[:checked]:bg-[#E6F1FB] has-[:checked]:border-[#0C447C]/30 has-[:checked]:text-[#0C447C]">
              <input
                type="checkbox"
                name="specialites"
                value={s}
                checked={typedCentre.specialites?.includes(s)}
                class="sr-only peer"
              />
              {s}
            </label>
          ))}
        </div>
      </div>

      <div class="mt-5">
        <label class="block text-sm font-medium text-marine font-sans mb-1">
          Marques propos&eacute;es (3 max)
        </label>
        <div class="flex flex-wrap gap-2" id="marques-container">
          {[
            'Phonak', 'Oticon', 'Signia', 'ReSound', 'Starkey',
            'Widex', 'Bernafon', 'Unitron', 'Audioservice',
          ].map((m) => (
            <label class="inline-flex items-center gap-1.5 rounded-full border border-gris-clair bg-blanc px-3 py-1.5 text-sm font-sans cursor-pointer hover:border-orange/50 transition-colors has-[:checked]:bg-[#E6F1FB] has-[:checked]:border-[#0C447C]/30 has-[:checked]:text-[#0C447C]">
              <input
                type="checkbox"
                name="marques"
                value={m}
                checked={typedCentre.marques?.includes(m)}
                class="sr-only peer"
              />
              {m}
            </label>
          ))}
        </div>
      </div>

      <div class="mt-5">
        <label for="edit-apropos" class="block text-sm font-medium text-marine font-sans mb-1">
          &Agrave; propos de votre centre
        </label>
        <textarea
          id="edit-apropos"
          name="a_propos"
          rows="4"
          maxlength="500"
          class="w-full rounded-lg border border-gris-clair px-4 py-3 text-base font-sans focus:border-orange focus:outline-none focus:ring-2 focus:ring-orange/20 resize-y"
        >{typedCentre.a_propos || ''}</textarea>
        <p class="text-xs text-gris-texte font-sans mt-1">500 caract&egrave;res max</p>
      </div>

      {typedCentre.plan === 'premium' && (
        <div class="mt-5">
          <label class="block text-sm font-medium text-marine font-sans mb-2">
            R&eacute;seaux sociaux <span class="text-xs text-gris-texte font-normal">(Premium)</span>
          </label>
          <div class="grid gap-3 sm:grid-cols-2">
            <div>
              <label for="rs-facebook" class="block text-xs text-gris-texte font-sans mb-1">Facebook</label>
              <input
                id="rs-facebook"
                name="rs_facebook"
                type="url"
                value={typedCentre.reseaux_sociaux?.facebook || ''}
                placeholder="https://facebook.com/votre-page"
                class="w-full rounded-lg border border-gris-clair px-4 py-3 text-base font-sans focus:border-orange focus:outline-none focus:ring-2 focus:ring-orange/20"
              />
            </div>
            <div>
              <label for="rs-instagram" class="block text-xs text-gris-texte font-sans mb-1">Instagram</label>
              <input
                id="rs-instagram"
                name="rs_instagram"
                type="url"
                value={typedCentre.reseaux_sociaux?.instagram || ''}
                placeholder="https://instagram.com/votre-compte"
                class="w-full rounded-lg border border-gris-clair px-4 py-3 text-base font-sans focus:border-orange focus:outline-none focus:ring-2 focus:ring-orange/20"
              />
            </div>
            <div>
              <label for="rs-google" class="block text-xs text-gris-texte font-sans mb-1">Google Business</label>
              <input
                id="rs-google"
                name="rs_google"
                type="url"
                value={typedCentre.reseaux_sociaux?.google || ''}
                placeholder="https://g.page/votre-centre"
                class="w-full rounded-lg border border-gris-clair px-4 py-3 text-base font-sans focus:border-orange focus:outline-none focus:ring-2 focus:ring-orange/20"
              />
            </div>
            <div>
              <label for="rs-linkedin" class="block text-xs text-gris-texte font-sans mb-1">LinkedIn</label>
              <input
                id="rs-linkedin"
                name="rs_linkedin"
                type="url"
                value={typedCentre.reseaux_sociaux?.linkedin || ''}
                placeholder="https://linkedin.com/company/..."
                class="w-full rounded-lg border border-gris-clair px-4 py-3 text-base font-sans focus:border-orange focus:outline-none focus:ring-2 focus:ring-orange/20"
              />
            </div>
          </div>
        </div>
      )}

      <div id="edit-error" class="hidden mt-4 rounded-lg border border-red-300 bg-red-50 p-3 text-sm text-red-600 font-sans"></div>
      <div id="edit-success" class="hidden mt-4 rounded-lg border border-green-300 bg-green-50 p-3 text-sm text-green-700 font-sans"></div>

      <div class="mt-6 flex gap-3">
        <button
          type="submit"
          id="edit-submit"
          class="rounded-lg bg-orange px-8 py-3 text-base font-semibold text-blanc font-sans transition-colors hover:bg-orange-hover focus:outline-none focus:ring-2 focus:ring-orange/50 cursor-pointer disabled:opacity-60"
          style="min-height: 48px;"
        >
          Enregistrer
        </button>
        <a
          href={`/centre/${typedCentre.slug}/`}
          class="rounded-lg border border-gris-clair px-6 py-3 text-base font-medium text-gris-texte font-sans hover:bg-creme transition-colors"
          style="min-height: 48px; display: flex; align-items: center;"
        >
          Voir ma fiche
        </a>
      </div>
    </form>
  </section>

  <script define:vars={{ currentHoraires: typedCentre.horaires || '' }}>
    // --- Parser les horaires existants pour pre-remplir les selects ---
    const hOuverture = document.getElementById('h-ouverture');
    const hFermeture = document.getElementById('h-fermeture');
    const hSamedi = document.getElementById('h-samedi');
    const hHidden = document.getElementById('edit-horaires');

    if (currentHoraires) {
      const match = currentHoraires.match(/Lun-Ven\s+(\d+h\d*)-(\d+h\d*)/);
      if (match) {
        hOuverture.value = match[1];
        hFermeture.value = match[2];
      }
      const samMatch = currentHoraires.match(/Sam\s+(.+)/);
      if (samMatch) {
        hSamedi.value = samMatch[1].trim();
      }
    }

    function updateHoraires() {
      const ouv = hOuverture.value;
      const fer = hFermeture.value;
      const sam = hSamedi.value;
      const parts = [];
      if (ouv && fer) parts.push('Lun-Ven ' + ouv + '-' + fer);
      if (sam) parts.push('Sam ' + sam);
      hHidden.value = parts.join(' | ');
    }
    hOuverture.addEventListener('change', updateHoraires);
    hFermeture.addEventListener('change', updateHoraires);
    hSamedi.addEventListener('change', updateHoraires);

    // --- Limiter a 3 max ---
    function limitCheckboxes(containerId, max) {
      const container = document.getElementById(containerId);
      if (!container) return;
      container.addEventListener('change', function() {
        const checked = container.querySelectorAll('input[type="checkbox"]:checked');
        const unchecked = container.querySelectorAll('input[type="checkbox"]:not(:checked)');
        if (checked.length >= max) {
          unchecked.forEach(function(cb) { cb.disabled = true; });
        } else {
          unchecked.forEach(function(cb) { cb.disabled = false; });
        }
      });
      // Init
      var initChecked = container.querySelectorAll('input[type="checkbox"]:checked');
      if (initChecked.length >= max) {
        container.querySelectorAll('input[type="checkbox"]:not(:checked)').forEach(function(cb) { cb.disabled = true; });
      }
    }
    limitCheckboxes('specialites-container', 3);
    limitCheckboxes('marques-container', 3);

    // --- Submit ---
    var form = document.getElementById('edit-form');
    var submitBtn = document.getElementById('edit-submit');
    var errorDiv = document.getElementById('edit-error');
    var successDiv = document.getElementById('edit-success');

    form.addEventListener('submit', async function(e) {
      e.preventDefault();
      submitBtn.disabled = true;
      submitBtn.textContent = 'Enregistrement...';
      errorDiv.classList.add('hidden');
      successDiv.classList.add('hidden');

      updateHoraires();

      var formData = new FormData(form);
      var centreSlug = formData.get('centreSlug');
      var specialites = formData.getAll('specialites');
      var marques = formData.getAll('marques');

      // Reseaux sociaux (seulement si les champs existent = premium)
      var reseaux = {};
      var rsFb = formData.get('rs_facebook');
      var rsIg = formData.get('rs_instagram');
      var rsGo = formData.get('rs_google');
      var rsLi = formData.get('rs_linkedin');
      if (rsFb) reseaux.facebook = rsFb;
      if (rsIg) reseaux.instagram = rsIg;
      if (rsGo) reseaux.google = rsGo;
      if (rsLi) reseaux.linkedin = rsLi;

      var payload = {
        centreSlug: centreSlug,
        nom: formData.get('nom'),
        tel: formData.get('tel') || null,
        site_web: formData.get('site_web') || null,
        horaires: formData.get('horaires') || null,
        a_propos: formData.get('a_propos') || null,
        specialites: specialites,
        marques: marques,
      };
      if (Object.keys(reseaux).length > 0) payload.reseaux_sociaux = reseaux;

      try {
        var res = await fetch('/api/centre-update', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });

        var data = await res.json();

        if (!res.ok) {
          throw new Error(data.error || 'Erreur lors de la sauvegarde.');
        }

        successDiv.textContent = 'Modifications enregistr\u00e9es avec succ\u00e8s.';
        successDiv.classList.remove('hidden');
        submitBtn.disabled = false;
        submitBtn.textContent = 'Enregistrer';
      } catch (err) {
        errorDiv.textContent = err.message || 'Une erreur est survenue.';
        errorDiv.classList.remove('hidden');
        submitBtn.disabled = false;
        submitBtn.textContent = 'Enregistrer';
      }
    });
  </script>
</BaseLayout>
