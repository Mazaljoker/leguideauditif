---
// Route historique /centre/[slug]/modifier — remplacée par /audioprothesiste-pro/fiche/
// depuis le 2026-04-23 (espace pro unifié).
//
// On conserve un 301 permanent pour ne pas casser :
//   - les emails de bienvenue déjà envoyés aux revendicateurs
//   - les bookmarks éventuels des pros
//   - les backlinks externes qui pointeraient sur cette URL
//
// Le layout /audioprothesiste-pro/fiche/ résout le centre actif via
// le cookie lga_centre_slug ou le centre is_primary, donc le slug
// de l'URL d'origine n'est plus nécessaire.

export const prerender = false;

return Astro.redirect('/audioprothesiste-pro/fiche/', 301);
---
