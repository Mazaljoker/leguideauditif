---
export const prerender = false;

import { Icon } from 'astro-icon/components';
import BaseLayout from '../layouts/BaseLayout.astro';

// Si déjà connecté → aller direct à l'espace pro (pas besoin de se reloguer).
const user = Astro.locals.user;
if (user && user.email) {
  return Astro.redirect('/audioprothesiste-pro/');
}

const error = Astro.url.searchParams.get('error');

// Google One Tap — activé uniquement si le Client ID est fourni.
// Fallback transparent : si absent, l'onglet Google reste disponible
// via OAuth redirect (signInWithOAuth).
const googleClientId = import.meta.env.PUBLIC_GOOGLE_CLIENT_ID || '';
const oneTapEnabled = googleClientId.length > 0;
---

<BaseLayout
  title="Espace professionnel — LeGuideAuditif"
  description="Connectez-vous à votre espace audioprothésiste pour gérer votre fiche, vos demandes et votre abonnement."
>
  <meta slot="head" name="robots" content="noindex" />

  <section class="max-w-md mx-auto px-4 py-12">
    <div class="rounded-xl border border-gris-clair bg-blanc p-6 sm:p-8 shadow-sm">
      <div class="text-center mb-6">
        <div class="w-14 h-14 rounded-full bg-marine/10 flex items-center justify-center mx-auto mb-4">
          <Icon name="lucide:user-check" class="w-7 h-7 text-marine" />
        </div>
        <h1 class="font-sans text-xl font-bold text-marine">Espace professionnel</h1>
        <p class="text-sm text-gris-texte font-sans mt-2">
          Connectez-vous pour gérer votre fiche audioprothésiste.
        </p>
      </div>

      {error && (
        <div class="mb-5 rounded-lg border border-red-300 bg-red-50 p-3 text-sm text-red-600 font-sans">
          La connexion a échoué. Merci de réessayer.
        </div>
      )}

      {/* Google One Tap — connexion rapide sans quitter la page */}
      {oneTapEnabled && (
        <div class="mb-5">
          <p class="text-xs font-sans font-semibold uppercase tracking-wide text-marine/70 mb-2 text-center">
            Connexion rapide
          </p>
          <div class="flex justify-center mb-2" id="google-one-tap-btn">
            {/* Le bouton Google s'injecte ici via le script GSI */}
          </div>
          <div id="gsi-error" class="hidden rounded-lg border border-red-300 bg-red-50 p-2 text-xs text-red-600 font-sans mb-2"></div>
          <div class="flex items-center gap-3 my-4" aria-hidden="true">
            <span class="flex-1 h-px bg-gris-clair"></span>
            <span class="text-[11px] font-sans text-gris-texte uppercase tracking-wide">ou</span>
            <span class="flex-1 h-px bg-gris-clair"></span>
          </div>
        </div>
      )}

      {/* Onglets */}
      <div role="tablist" aria-label="Méthode de connexion" class="flex gap-1 mb-5 border-b border-gris-clair -mx-6 sm:-mx-8 px-6 sm:px-8 overflow-x-auto">
        <button
          type="button"
          class="auth-tab auth-tab--active"
          data-tab="magic"
          role="tab"
          aria-selected="true"
          aria-controls="panel-magic"
          id="tab-magic"
        >
          Lien par email
        </button>
        <button
          type="button"
          class="auth-tab"
          data-tab="password"
          role="tab"
          aria-selected="false"
          aria-controls="panel-password"
          id="tab-password"
        >
          Mot de passe
        </button>
      </div>

      {/* Panel Magic Link */}
      <section
        id="panel-magic"
        class="auth-panel"
        role="tabpanel"
        aria-labelledby="tab-magic"
      >
        <p class="text-sm text-gris-texte font-sans mb-4">
          Recevez un lien de connexion par email. Aucun mot de passe à retenir.
        </p>
        <form id="magic-form">
          <div class="mb-4">
            <label for="magic-email" class="block text-sm font-medium text-marine font-sans mb-1">
              Email professionnel
            </label>
            <input
              id="magic-email"
              name="email"
              type="email"
              required
              autocomplete="email"
              placeholder="votre@email.fr"
              class="w-full rounded-lg border border-gris-clair px-4 py-3 text-base font-sans focus:border-orange focus:outline-none focus:ring-2 focus:ring-orange/20"
            />
          </div>
          <div class="auth-error hidden mb-3 rounded-lg border border-red-300 bg-red-50 p-3 text-sm text-red-600 font-sans"></div>
          <div class="auth-success hidden mb-3 rounded-lg border border-green-300 bg-green-50 p-3 text-sm text-green-700 font-sans"></div>
          <button
            type="submit"
            class="w-full rounded-lg bg-orange px-6 py-3 text-base font-semibold text-blanc font-sans transition-colors hover:bg-orange-hover focus:outline-none focus:ring-2 focus:ring-orange/50 cursor-pointer disabled:opacity-60"
            style="min-height: 48px;"
          >
            Recevoir un lien de connexion
          </button>
        </form>
      </section>

      {/* Panel Password */}
      <section
        id="panel-password"
        class="auth-panel hidden"
        role="tabpanel"
        aria-labelledby="tab-password"
      >
        <p class="text-sm text-gris-texte font-sans mb-4">
          Entrez votre email et votre mot de passe.
        </p>
        <form id="password-form">
          <div class="mb-4">
            <label for="pwd-email" class="block text-sm font-medium text-marine font-sans mb-1">
              Email professionnel
            </label>
            <input
              id="pwd-email"
              name="email"
              type="email"
              required
              autocomplete="email"
              placeholder="votre@email.fr"
              class="w-full rounded-lg border border-gris-clair px-4 py-3 text-base font-sans focus:border-orange focus:outline-none focus:ring-2 focus:ring-orange/20"
            />
          </div>
          <div class="mb-4">
            <label for="pwd-password" class="block text-sm font-medium text-marine font-sans mb-1">
              Mot de passe
            </label>
            <input
              id="pwd-password"
              name="password"
              type="password"
              required
              autocomplete="current-password"
              minlength="8"
              class="w-full rounded-lg border border-gris-clair px-4 py-3 text-base font-sans focus:border-orange focus:outline-none focus:ring-2 focus:ring-orange/20"
            />
          </div>
          <div class="auth-error hidden mb-3 rounded-lg border border-red-300 bg-red-50 p-3 text-sm text-red-600 font-sans"></div>
          <button
            type="submit"
            class="w-full rounded-lg bg-orange px-6 py-3 text-base font-semibold text-blanc font-sans transition-colors hover:bg-orange-hover focus:outline-none focus:ring-2 focus:ring-orange/50 cursor-pointer disabled:opacity-60"
            style="min-height: 48px;"
          >
            Se connecter
          </button>
          <p class="text-xs text-gris-texte font-sans text-center mt-4">
            Pas encore de mot de passe ? Utilisez le lien par email puis définissez-le dans votre compte.
          </p>
        </form>
      </section>

      <p class="text-xs text-gris-texte font-sans text-center mt-6 pt-6 border-t border-gris-clair">
        Pas encore de fiche ? <a href="/trouver-audioprothesiste/" class="text-orange font-medium hover:underline">Trouvez votre centre</a> et revendiquez-le gratuitement.
      </p>
    </div>
  </section>

  <style>
    .auth-tab {
      flex: 1;
      min-width: max-content;
      padding: 0.75rem 1rem;
      font-family: var(--font-sans);
      font-size: 0.875rem;
      font-weight: 500;
      color: var(--color-gris-texte);
      border-bottom: 2px solid transparent;
      background: transparent;
      cursor: pointer;
      white-space: nowrap;
      transition: color 150ms, border-color 150ms;
      min-height: 44px;
    }
    .auth-tab:hover { color: var(--color-marine); }
    .auth-tab:focus-visible {
      outline: 2px solid var(--color-orange);
      outline-offset: -2px;
    }
    .auth-tab--active {
      color: var(--color-marine);
      font-weight: 600;
      border-bottom-color: var(--color-orange);
    }
  </style>

  {oneTapEnabled && (
    <script is:inline src="https://accounts.google.com/gsi/client" async></script>
  )}

  <script define:vars={{ googleClientId, oneTapEnabled }}>
    // Exposer la config Google aux scripts module ci-dessous.
    window.__lgaGoogleConfig = { googleClientId, oneTapEnabled };
  </script>

  <script>
    import {
      signInProWithMagicLink,
      signInProWithPassword,
      signInProWithGoogleIdToken,
      generateGoogleNonce,
    } from '../lib/auth';

    // --- Onglets ---
    const tabBtns = document.querySelectorAll<HTMLButtonElement>('.auth-tab');
    const panels = document.querySelectorAll<HTMLElement>('.auth-panel');

    tabBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        const target = btn.getAttribute('data-tab');
        tabBtns.forEach((b) => {
          b.classList.remove('auth-tab--active');
          b.setAttribute('aria-selected', 'false');
        });
        btn.classList.add('auth-tab--active');
        btn.setAttribute('aria-selected', 'true');
        panels.forEach((p) => {
          const panelId = p.id.replace('panel-', '');
          if (panelId === target) p.classList.remove('hidden');
          else p.classList.add('hidden');
        });
      });
    });

    // --- Helpers UI ---
    function showMsg(panel: HTMLElement, kind: 'error' | 'success', message: string) {
      const err = panel.querySelector('.auth-error') as HTMLElement | null;
      const ok = panel.querySelector('.auth-success') as HTMLElement | null;
      err?.classList.add('hidden');
      ok?.classList.add('hidden');
      const target = kind === 'error' ? err : ok;
      if (target) {
        target.textContent = message;
        target.classList.remove('hidden');
      }
    }

    // --- Magic link ---
    const magicForm = document.getElementById('magic-form') as HTMLFormElement;
    magicForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      const panel = document.getElementById('panel-magic')!;
      const btn = magicForm.querySelector('button[type="submit"]') as HTMLButtonElement;
      const email = (document.getElementById('magic-email') as HTMLInputElement).value.trim();

      btn.disabled = true;
      btn.textContent = 'Envoi en cours...';

      const { error } = await signInProWithMagicLink(email);

      if (error) {
        showMsg(panel, 'error', 'Impossible d’envoyer le lien. Vérifiez votre email.');
        btn.disabled = false;
        btn.textContent = 'Recevoir un lien de connexion';
      } else {
        showMsg(panel, 'success', `Un lien de connexion a été envoyé à ${email}. Vérifiez votre boîte de réception.`);
        btn.textContent = 'Email envoyé';
      }
    });

    // --- Password ---
    const passwordForm = document.getElementById('password-form') as HTMLFormElement;
    passwordForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      const panel = document.getElementById('panel-password')!;
      const btn = passwordForm.querySelector('button[type="submit"]') as HTMLButtonElement;
      const email = (document.getElementById('pwd-email') as HTMLInputElement).value.trim();
      const password = (document.getElementById('pwd-password') as HTMLInputElement).value;

      btn.disabled = true;
      btn.textContent = 'Connexion...';

      const { data, error } = await signInProWithPassword(email, password);

      if (error || !data.session) {
        showMsg(panel, 'error', 'Email ou mot de passe incorrect.');
        btn.disabled = false;
        btn.textContent = 'Se connecter';
        return;
      }

      // Stocker les tokens dans des cookies pour le middleware SSR
      document.cookie = `sb-access-token=${data.session.access_token}; path=/; max-age=${60 * 60 * 24 * 7}; SameSite=Lax; Secure`;
      document.cookie = `sb-refresh-token=${data.session.refresh_token}; path=/; max-age=${60 * 60 * 24 * 7}; SameSite=Lax; Secure`;
      window.location.href = '/audioprothesiste-pro/';
    });

    // --- Google One Tap + bouton Sign in with Google ---
    // Activé si PUBLIC_GOOGLE_CLIENT_ID est défini. Le script GSI est
    // chargé async ; on attend sa disponibilité puis on configure le
    // bouton officiel + on propose le One Tap popup.
    const cfg = (window as unknown as { __lgaGoogleConfig?: { googleClientId: string; oneTapEnabled: boolean } }).__lgaGoogleConfig;
    if (cfg?.oneTapEnabled && cfg.googleClientId) {
      initOneTap(cfg.googleClientId).catch((err) => {
        console.error('[gsi] init failed', err);
      });
    }

    async function initOneTap(clientId: string) {
      // Attendre que le script GSI ait défini window.google.accounts.id
      const gsi = await waitForGsi(5000);
      if (!gsi) {
        console.warn('[gsi] Script GSI indisponible après 5s — bouton One Tap désactivé');
        return;
      }

      const { nonce, hashedNonce } = await generateGoogleNonce();
      // Stocker le nonce en clair pour le callback (consommé une fois)
      (window as unknown as { __gsiNonce?: string }).__gsiNonce = nonce;

      const gsiError = document.getElementById('gsi-error') as HTMLElement | null;
      const btnContainer = document.getElementById('google-one-tap-btn');

      function showError(msg: string) {
        console.error('[gsi]', msg);
        if (gsiError) {
          gsiError.textContent = msg;
          gsiError.classList.remove('hidden');
        }
      }

      // Le callback de GSI n'est PAS async — on déclenche le flow asynchrone
      // via une fonction séparée pour que GSI reçoive une fonction synchrone
      // (certaines versions du SDK tolèrent mal les Promise retournées ici).
      function onGoogleCredential(response: { credential?: string }) {
        console.log('[gsi] credential received', { hasCredential: !!response?.credential });
        const credential = response?.credential;
        if (!credential) {
          showError('Réponse Google vide. Réessayez.');
          return;
        }
        void handleGoogleLogin(credential);
      }

      async function handleGoogleLogin(credential: string) {
        try {
          const n = (window as unknown as { __gsiNonce?: string }).__gsiNonce ?? '';
          const { data, error } = await signInProWithGoogleIdToken(credential, n);
          if (error) throw error;
          if (!data?.session) throw new Error('Session vide côté Supabase.');
          document.cookie = `sb-access-token=${data.session.access_token}; path=/; max-age=${60 * 60 * 24 * 7}; SameSite=Lax; Secure`;
          document.cookie = `sb-refresh-token=${data.session.refresh_token}; path=/; max-age=${60 * 60 * 24 * 7}; SameSite=Lax; Secure`;
          window.location.href = '/audioprothesiste-pro/';
        } catch (err: unknown) {
          const msg = err instanceof Error ? err.message : 'Connexion Google impossible.';
          showError(msg);
        }
      }

      gsi.initialize({
        client_id: clientId,
        callback: onGoogleCredential,
        nonce: hashedNonce,
        use_fedcm_for_prompt: true,
        itp_support: true,
        auto_select: false, // ne pas reconnecter automatiquement
        context: 'signin',
      });

      if (btnContainer) {
        try {
          gsi.renderButton(btnContainer, {
            theme: 'outline',
            size: 'large',
            text: 'continue_with',
            shape: 'rectangular',
            logo_alignment: 'left',
            width: 320,
          });
        } catch (err) {
          console.error('[gsi] renderButton failed', err);
        }
      }

      // Proposer le One Tap popup. Un listener affiche les raisons de skip
      // côté console si FedCM/cookies tiers bloquent le prompt.
      gsi.prompt((notification: unknown) => {
        const n = notification as {
          isNotDisplayed?: () => boolean;
          getNotDisplayedReason?: () => string;
          isSkippedMoment?: () => boolean;
          getSkippedReason?: () => string;
          isDismissedMoment?: () => boolean;
          getDismissedReason?: () => string;
        };
        if (n.isNotDisplayed?.()) {
          console.info('[gsi] One Tap non affiché :', n.getNotDisplayedReason?.());
        } else if (n.isSkippedMoment?.()) {
          console.info('[gsi] One Tap skippé :', n.getSkippedReason?.());
        } else if (n.isDismissedMoment?.()) {
          console.info('[gsi] One Tap fermé :', n.getDismissedReason?.());
        }
      });
    }

    interface GsiApi {
      initialize: (config: Record<string, unknown>) => void;
      renderButton: (el: HTMLElement, opts: Record<string, unknown>) => void;
      prompt: (listener?: (notification: unknown) => void) => void;
    }

    async function waitForGsi(timeoutMs: number): Promise<GsiApi | null> {
      const start = Date.now();
      return new Promise((resolve) => {
        const tick = () => {
          const gsi = (window as unknown as { google?: { accounts?: { id?: GsiApi } } }).google?.accounts?.id;
          if (gsi) return resolve(gsi);
          if (Date.now() - start > timeoutMs) return resolve(null);
          setTimeout(tick, 50);
        };
        tick();
      });
    }
  </script>
</BaseLayout>
