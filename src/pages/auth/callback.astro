---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Connexion en cours... | LeGuideAuditif"
  description="Redirection après connexion."
>
  <div class="max-w-[1140px] mx-auto px-5 py-16 text-center">
    <p class="text-lg text-gris-texte font-sans">Connexion en cours...</p>
  </div>
</BaseLayout>

<script>
  import { supabase } from '../../lib/supabase';

  // Supabase Auth traite automatiquement le hash fragment (#access_token=...)
  // après un magic link ou une confirmation email.
  const { data: { session } } = await supabase.auth.getSession();

  if (session) {
    // Stocker les tokens dans des cookies pour le middleware SSR
    document.cookie = `sb-access-token=${session.access_token}; path=/; max-age=${60 * 60 * 24 * 7}; SameSite=Lax; Secure`;
    document.cookie = `sb-refresh-token=${session.refresh_token}; path=/; max-age=${60 * 60 * 24 * 7}; SameSite=Lax; Secure`;

    // Vérifier si le profil existe
    const { data: profile } = await supabase
      .from('profiles')
      .select('id')
      .eq('id', session.user.id)
      .single();

    if (profile) {
      window.location.href = '/annonces/deposer/';
    } else {
      // Premier login — compléter le profil
      window.location.href = '/auth/profil/?first=1';
    }
  } else {
    window.location.href = '/auth/login/?error=callback';
  }
</script>
