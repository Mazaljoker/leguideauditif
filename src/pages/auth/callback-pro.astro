---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Connexion en cours... | LeGuideAuditif"
  description="Redirection après connexion professionnelle."
>
  <meta slot="head" name="robots" content="noindex" />
  <div class="max-w-[1140px] mx-auto px-5 py-16 text-center">
    <h1 class="sr-only">Connexion en cours</h1>
    <p class="text-lg text-gris-texte font-sans">Connexion en cours...</p>
  </div>
</BaseLayout>

<script>
  import { supabase } from '../../lib/supabase';

  const { data: { session } } = await supabase.auth.getSession();

  if (session) {
    // Stocker les tokens dans des cookies pour le middleware SSR
    document.cookie = `sb-access-token=${session.access_token}; path=/; max-age=${60 * 60 * 24 * 7}; SameSite=Lax; Secure`;
    document.cookie = `sb-refresh-token=${session.refresh_token}; path=/; max-age=${60 * 60 * 24 * 7}; SameSite=Lax; Secure`;

    // Redirection vers l'espace pro unifié. Le layout AudioproLayout
    // gère la résolution du centre actif (is_primary ou cookie) et
    // redirige vers /trouver-audioprothesiste/ si aucun centre claimed.
    window.location.href = '/audioprothesiste-pro/';
  } else {
    window.location.href = '/connexion-pro?error=1';
  }
</script>
