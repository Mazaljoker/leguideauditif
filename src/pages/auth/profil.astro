---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import ProfileForm from '../../components/auth/ProfileForm';

const isFirst = Astro.url.searchParams.get('first') === '1';

const breadcrumbs = [
  { label: 'Accueil', href: '/' },
  { label: 'Mon profil' },
];
---

<BaseLayout
  title="Mon profil — Espace professionnel | LeGuideAuditif"
  description="Complétez votre profil professionnel pour déposer vos annonces audioprothèse."
>
  <meta slot="head" name="robots" content="noindex" />
  <div class="max-w-[1140px] mx-auto px-5 py-8">
    <Breadcrumbs items={breadcrumbs} />

    <div class="py-8">
      <h1 class="font-sans text-3xl font-extrabold text-marine text-center mb-2">
        {isFirst ? 'Complétez votre profil' : 'Mon profil'}
      </h1>
      <p class="text-center text-gris-texte mb-8 font-sans">
        {isFirst
          ? 'Quelques informations pour personnaliser votre expérience et pré-remplir vos annonces.'
          : 'Modifiez vos informations professionnelles.'}
      </p>

      <ProfileForm
        client:load
        redirectTo={isFirst ? '/annonces/deposer/' : undefined}
      />
    </div>
  </div>
</BaseLayout>
