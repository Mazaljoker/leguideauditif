---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import RegisterForm from '../../components/auth/RegisterForm';

const breadcrumbs = [
  { label: 'Accueil', href: '/' },
  { label: 'Inscription' },
];
---

<BaseLayout
  title="Inscription — Espace professionnel | LeGuideAuditif"
  description="Creez votre compte professionnel pour deposer gratuitement vos annonces audioprothese."
>
  <div class="max-w-[1140px] mx-auto px-5 py-8">
    <Breadcrumbs items={breadcrumbs} />

    <div class="max-w-md mx-auto py-8">
      <h1 class="font-sans text-3xl font-extrabold text-marine text-center mb-2">Creer un compte</h1>
      <p class="text-center text-gris-texte mb-8 font-sans">
        Inscrivez-vous pour deposer gratuitement vos annonces et acceder a votre espace professionnel.
      </p>

      <RegisterForm client:load />
    </div>
  </div>
</BaseLayout>
