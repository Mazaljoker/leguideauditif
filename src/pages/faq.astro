---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import HealthDisclaimer from '../components/HealthDisclaimer.astro';

const breadcrumbs = [
  { label: 'Accueil', href: '/' },
  { label: 'FAQ' },
];

const faqSections = [
  {
    title: 'Perte auditive',
    faqs: [
      { question: "Comment savoir si j'ai une perte auditive ?", answer: "Les signes les plus courants sont : faire repeter, monter le volume de la TV, difficulte a suivre les conversations en groupe, fatigue auditive en fin de journee. Seul un <a href='/guides/audiogramme/' class='text-orange hover:underline'>audiogramme chez un ORL</a> permet un diagnostic precis." },
      { question: "La perte auditive est-elle reversible ?", answer: "La perte de perception (la plus frequente) est irreversible. Certaines surdites de transmission (bouchon, otite) sont traitables. <a href='/guides/perte-auditive/types/' class='text-orange hover:underline'>En savoir plus sur les types de perte</a>." },
      { question: "A partir de quel age risque-t-on une perte auditive ?", answer: "La <a href='/guides/perte-auditive/presbyacousie/' class='text-orange hover:underline'>presbyacousie</a> debute vers 50-55 ans. Elle touche 1 personne sur 3 apres 65 ans. Un depistage est recommande des 50 ans." },
      { question: "A quel age faut-il faire un bilan auditif ?", answer: "Des 50 ans, puis tous les 2 a 3 ans. Plus tot si exposition au bruit ou antecedents familiaux. Le bilan est <a href='/guides/prevention/bilan-auditif-gratuit/' class='text-orange hover:underline'>gratuit chez l'audioprothesiste</a>." },
    ],
  },
  {
    title: 'Appareils auditifs',
    faqs: [
      { question: "Quel est le meilleur appareil auditif en 2026 ?", answer: "Il n'y a pas de meilleur appareil universel. Le choix depend de votre perte, votre mode de vie et votre budget. <a href='/comparatifs/meilleur-appareil-auditif-2026/' class='text-orange hover:underline'>Voir notre classement 2026</a>." },
      { question: "Contour ou intra-auriculaire : comment choisir ?", answer: "Les contours (BTE/RIC) sont plus puissants et polyvalents (70% du marche). Les intra-auriculaires sont plus discrets mais limites en puissance. <a href='/guides/appareils-auditifs/types/' class='text-orange hover:underline'>Comparer tous les types</a>." },
      { question: "Quelle est la difference entre Classe 1 et Classe 2 ?", answer: "Classe 1 = 0 euro de reste a charge, technologies de base. Classe 2 = prix libre, Bluetooth, IA, plus de canaux. <a href='/guides/appareils-auditifs/classe-1-vs-classe-2/' class='text-orange hover:underline'>Comparer en detail</a>." },
      { question: "Peut-on essayer un appareil avant de l'acheter ?", answer: "Oui, l'essai de 30 jours est obligatoire. Vous pouvez retourner l'appareil sans frais. <a href='/guides/appareils-auditifs/premier-appareil/' class='text-orange hover:underline'>Guide premier appareil</a>." },
      { question: "Rechargeable ou a piles ?", answer: "80% des ventes sont rechargeables en 2026. Autonomie 18-30h, recharge USB. Les piles restent adaptees pour les intra-auriculaires profonds. <a href='/guides/appareils-auditifs/rechargeable-vs-piles/' class='text-orange hover:underline'>Comparatif complet</a>." },
      { question: "Les appareils auditifs ont-ils le Bluetooth ?", answer: "Les Classe 2 oui (streaming telephone, musique, TV). La plupart des Classe 1 non. <a href='/guides/appareils-auditifs/bluetooth/' class='text-orange hover:underline'>Guide connectivite</a>." },
    ],
  },
  {
    title: 'Prix et remboursement',
    faqs: [
      { question: "Combien coute un appareil auditif en 2026 ?", answer: "De 0 euro (Classe 1, 100% Sante) a 2 200 euros par oreille (Classe 2 premium). <a href='/guides/remboursement/prix-appareil-auditif/' class='text-orange hover:underline'>Voir tous les tarifs</a>." },
      { question: "C'est quoi le 100% Sante audition ?", answer: "Une reforme garantissant un reste a charge de 0 euro pour les appareils Classe 1 (plafonnes a 950 euros/oreille) si vous avez une mutuelle responsable. <a href='/guides/remboursement/100-sante-audition/' class='text-orange hover:underline'>Tout comprendre en 5 minutes</a>." },
      { question: "Quelle mutuelle pour les appareils auditifs ?", answer: "Toute mutuelle responsable couvre le Classe 1 a 100%. Pour le Classe 2, visez un contrat qui rembourse au minimum 500 euros/oreille en complement. <a href='/guides/remboursement/mutuelle/' class='text-orange hover:underline'>Guide mutuelles</a>." },
      { question: "Existe-t-il des aides financieres en plus ?", answer: "Oui : PCH (MDPH), AGEFIPH (travailleurs), CSS (ex-CMU-C), CCAS, caisses de retraite. <a href='/guides/remboursement/aides-financieres/' class='text-orange hover:underline'>Toutes les aides</a>." },
      { question: "Comment lire un devis audioprothesiste ?", answer: "Le devis normalise comporte une double colonne Classe 1 / Classe 2 avec le reste a charge pour chaque option. <a href='/guides/remboursement/devis/' class='text-orange hover:underline'>Guide devis</a>." },
    ],
  },
  {
    title: 'Acouphenes',
    faqs: [
      { question: "Les acouphenes peuvent-ils disparaitre ?", answer: "Certains acouphenes diminuent ou disparaissent (cause traitable). Pour les acouphenes chroniques, des strategies permettent de reduire significativement la gene. <a href='/guides/acouphenes/' class='text-orange hover:underline'>Guide complet acouphenes</a>." },
      { question: "Quel traitement pour les acouphenes en 2026 ?", answer: "Therapie sonore (TRT, 70-80% d'efficacite), TCC, appareils auditifs avec masqueurs. Il n'existe pas de medicament specifique valide. <a href='/guides/acouphenes/traitement/' class='text-orange hover:underline'>Les traitements qui marchent</a>." },
      { question: "Un appareil auditif aide-t-il contre les acouphenes ?", answer: "Oui, chez 60-70% des patients qui ont aussi une perte auditive. L'amplification masque partiellement les acouphenes. <a href='/guides/acouphenes/appareil-auditif/' class='text-orange hover:underline'>En savoir plus</a>." },
    ],
  },
  {
    title: "L'audioprothesiste",
    faqs: [
      { question: "Comment choisir un bon audioprothesiste ?", answer: "Verifiez le DE, la proximite, le nombre de marques proposees, la duree des RDV et la qualite du suivi sur 4 ans. <a href='/guides/audioprothesiste/choisir/' class='text-orange hover:underline'>Les criteres essentiels</a>." },
      { question: "Quelle difference entre ORL et audioprothesiste ?", answer: "L'ORL diagnostique et prescrit. L'audioprothesiste choisit, adapte et regle vos appareils. <a href='/guides/audioprothesiste/orl-vs-audio/' class='text-orange hover:underline'>Qui fait quoi</a>." },
      { question: "Le premier RDV est-il payant ?", answer: "Non, le bilan auditif chez l'audioprothesiste est gratuit et sans engagement. <a href='/guides/audioprothesiste/premier-rdv/' class='text-orange hover:underline'>Se preparer au premier RDV</a>." },
    ],
  },
];

const allFaqs = faqSections.flatMap((s) => s.faqs);
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: allFaqs.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: faq.answer.replace(/<[^>]*>/g, ''),
    },
  })),
};

const schemas = [
  faqSchema,
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: breadcrumbs.map((item, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      name: item.label,
      ...(item.href && { item: new URL(item.href, 'https://leguideauditif.fr').href }),
    })),
  },
];
---

<BaseLayout
  title="FAQ — Questions frequentes sur l'audition — LeGuideAuditif.fr"
  description="Reponses aux questions les plus frequentes sur la perte auditive, les appareils auditifs, le remboursement et les acouphenes."
  schema={schemas}
>
  <div class="bg-creme">
    <div class="max-w-[780px] mx-auto px-5">
      <Breadcrumbs items={breadcrumbs} />
    </div>
  </div>

  <section class="bg-creme pt-8 pb-16">
    <div class="max-w-[780px] mx-auto px-5">
      <h1 class="font-sans text-[32px] lg:text-[38px] font-extrabold text-marine leading-tight mb-4">Questions frequentes sur l'audition</h1>
      <p class="text-lg text-gris-texte mb-10">
        Retrouvez les reponses aux questions que nos lecteurs posent le plus souvent. Chaque reponse renvoie vers le guide detaille correspondant.
      </p>

      {faqSections.map((section) => (
        <div class="mb-10">
          <h2 class="font-sans text-xl font-bold text-marine mb-4">{section.title}</h2>
          {section.faqs.map((faq) => (
            <details class="bg-blanc rounded-xl mb-3 shadow-[0_1px_4px_rgba(27,46,74,0.05)] group">
              <summary class="px-6 py-5 font-sans text-[17px] font-semibold text-marine cursor-pointer list-none flex justify-between items-center">
                <span>{faq.question}</span>
                <span class="text-xl transition-transform group-open:rotate-45">+</span>
              </summary>
              <div class="px-6 pb-5 text-gris-texte text-base leading-relaxed" set:html={faq.answer} />
            </details>
          ))}
        </div>
      ))}
    </div>
  </section>

  <HealthDisclaimer />
</BaseLayout>
