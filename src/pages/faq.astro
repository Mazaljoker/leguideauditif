---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import HealthDisclaimer from '../components/HealthDisclaimer.astro';

const breadcrumbs = [
  { label: 'Accueil', href: '/' },
  { label: 'FAQ' },
];

const faqSections = [
  {
    title: 'Perte auditive',
    faqs: [
      { question: "Comment savoir si j'ai une perte auditive ?", answer: "Les signes les plus courants sont : faire répéter, monter le volume de la TV, difficulté à suivre les conversations en groupe, fatigue auditive en fin de journée. Seul un <a href='/guides/audiogramme/' class='text-orange hover:underline'>audiogramme chez un ORL</a> permet un diagnostic précis." },
      { question: "La perte auditive est-elle reversible ?", answer: "La perte de perception (la plus fréquente) est irréversible. Certaines surdités de transmission (bouchon, otite) sont traitables. <a href='/guides/perte-auditive/types/' class='text-orange hover:underline'>En savoir plus sur les types de perte</a>." },
      { question: "À partir de quel âge risque-t-on une perte auditive ?", answer: "La <a href='/guides/perte-auditive/presbyacousie/' class='text-orange hover:underline'>presbyacousie</a> débute vers 50-55 ans. Elle touche 1 personne sur 3 après 65 ans. Un dépistage est recommandé dès 50 ans." },
      { question: "À quel âge faut-il faire un bilan auditif ?", answer: "Dès 50 ans, puis tous les 2 à 3 ans. Plus tôt si exposition au bruit ou antécédents familiaux. Le bilan est <a href='/guides/prevention/bilan-auditif-gratuit/' class='text-orange hover:underline'>gratuit chez l'audioprothésiste</a>." },
    ],
  },
  {
    title: 'Appareils auditifs',
    faqs: [
      { question: "Quel est le meilleur appareil auditif en 2026 ?", answer: "Il n'y a pas de meilleur appareil universel. Le choix dépend de votre perte, votre mode de vie et votre budget. <a href='/comparatifs/meilleur-appareil-auditif-2026/' class='text-orange hover:underline'>Voir notre classement 2026</a>." },
      { question: "Contour ou intra-auriculaire : comment choisir ?", answer: "Les contours (BTE/RIC) sont plus puissants et polyvalents (70% du marché). Les intra-auriculaires sont plus discrets mais limités en puissance. <a href='/guides/appareils-auditifs/types/' class='text-orange hover:underline'>Comparer tous les types</a>." },
      { question: "Quelle est la différence entre Classe 1 et Classe 2 ?", answer: "Classe 1 = 0 euro de reste à charge, technologies de base. Classe 2 = prix libre, Bluetooth, IA, plus de canaux. <a href='/guides/appareils-auditifs/classe-1-vs-classe-2/' class='text-orange hover:underline'>Comparer en détail</a>." },
      { question: "Peut-on essayer un appareil avant de l'acheter ?", answer: "Oui, l'essai de 30 jours est obligatoire. Vous pouvez retourner l'appareil sans frais. <a href='/guides/appareils-auditifs/premier-appareil/' class='text-orange hover:underline'>Guide premier appareil</a>." },
      { question: "Rechargeable ou à piles ?", answer: "80% des ventes sont rechargeables en 2026. Autonomie 18-30h, recharge USB. Les piles restent adaptées pour les intra-auriculaires profonds. <a href='/guides/appareils-auditifs/rechargeable-vs-piles/' class='text-orange hover:underline'>Comparatif complet</a>." },
      { question: "Les appareils auditifs ont-ils le Bluetooth ?", answer: "Les Classe 2 oui (streaming téléphone, musique, TV). La plupart des Classe 1 non. <a href='/guides/appareils-auditifs/bluetooth/' class='text-orange hover:underline'>Guide connectivité</a>." },
    ],
  },
  {
    title: 'Prix et remboursement',
    faqs: [
      { question: "Combien coûte un appareil auditif en 2026 ?", answer: "De 0 euro (Classe 1, 100% Santé) à 2 200 euros par oreille (Classe 2 premium). <a href='/guides/remboursement/prix-appareil-auditif/' class='text-orange hover:underline'>Voir tous les tarifs</a>." },
      { question: "C'est quoi le 100% Santé audition ?", answer: "Une réforme garantissant un reste à charge de 0 euro pour les appareils Classe 1 (plafonnés à 950 euros/oreille) si vous avez une mutuelle responsable. <a href='/guides/remboursement/100-sante-audition/' class='text-orange hover:underline'>Tout comprendre en 5 minutes</a>." },
      { question: "Quelle mutuelle pour les appareils auditifs ?", answer: "Toute mutuelle responsable couvre le Classe 1 à 100%. Pour le Classe 2, visez un contrat qui rembourse au minimum 500 euros/oreille en complément. <a href='/guides/remboursement/mutuelle/' class='text-orange hover:underline'>Guide mutuelles</a>." },
      { question: "Existe-t-il des aides financières en plus ?", answer: "Oui : PCH (MDPH), AGEFIPH (travailleurs), CSS (ex-CMU-C), CCAS, caisses de retraite. <a href='/guides/remboursement/aides-financieres/' class='text-orange hover:underline'>Toutes les aides</a>." },
      { question: "Comment lire un devis audioprothésiste ?", answer: "Le devis normalisé comporte une double colonne Classe 1 / Classe 2 avec le reste à charge pour chaque option. <a href='/guides/remboursement/devis/' class='text-orange hover:underline'>Guide devis</a>." },
    ],
  },
  {
    title: 'Acouphènes',
    faqs: [
      { question: "Les acouphènes peuvent-ils disparaître ?", answer: "Certains acouphènes diminuent ou disparaissent (cause traitable). Pour les acouphènes chroniques, des stratégies permettent de réduire significativement la gêne. <a href='/guides/acouphenes/' class='text-orange hover:underline'>Guide complet acouphènes</a>." },
      { question: "Quel traitement pour les acouphènes en 2026 ?", answer: "Thérapie sonore (TRT, 70-80% d'efficacité), TCC, appareils auditifs avec masqueurs. Il n'existe pas de médicament spécifique validé. <a href='/guides/acouphenes/traitement/' class='text-orange hover:underline'>Les traitements qui marchent</a>." },
      { question: "Un appareil auditif aide-t-il contre les acouphènes ?", answer: "Oui, chez 60-70% des patients qui ont aussi une perte auditive. L'amplification masque partiellement les acouphènes. <a href='/guides/acouphenes/appareil-auditif/' class='text-orange hover:underline'>En savoir plus</a>." },
    ],
  },
  {
    title: "L'audioprothésiste",
    faqs: [
      { question: "Comment choisir un bon audioprothésiste ?", answer: "Vérifiez le DE, la proximité, le nombre de marques proposées, la durée des RDV et la qualité du suivi sur 4 ans. <a href='/guides/audioprothesiste/choisir/' class='text-orange hover:underline'>Les critères essentiels</a>." },
      { question: "Quelle différence entre ORL et audioprothésiste ?", answer: "L'ORL diagnostique et prescrit. L'audioprothésiste choisit, adapte et règle vos appareils. <a href='/guides/audioprothesiste/orl-vs-audio/' class='text-orange hover:underline'>Qui fait quoi</a>." },
      { question: "Le premier RDV est-il payant ?", answer: "Non, le bilan auditif chez l'audioprothésiste est gratuit et sans engagement. <a href='/guides/audioprothesiste/premier-rdv/' class='text-orange hover:underline'>Se préparer au premier RDV</a>." },
    ],
  },
];

const allFaqs = faqSections.flatMap((s) => s.faqs);
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: allFaqs.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: faq.answer.replace(/<[^>]*>/g, ''),
    },
  })),
};

const schemas = [
  faqSchema,
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: breadcrumbs.map((item, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      name: item.label,
      ...(item.href && { item: new URL(item.href, 'https://leguideauditif.fr').href }),
    })),
  },
];
---

<BaseLayout
  title="Questions fréquentes sur l'audition — LeGuideAuditif"
  description="Réponses aux questions les plus fréquentes sur la perte auditive, les appareils auditifs, le remboursement et les acouphènes."
  schema={schemas}
>
  <div class="bg-creme">
    <div class="max-w-[780px] mx-auto px-5">
      <Breadcrumbs items={breadcrumbs} />
    </div>
  </div>

  <section class="bg-creme pt-8 pb-16">
    <div class="max-w-[780px] mx-auto px-5">
      <h1 class="font-sans text-[32px] lg:text-[38px] font-extrabold text-marine leading-tight mb-4">Questions fréquentes sur l'audition</h1>
      <p class="text-lg text-gris-texte mb-10">
        Retrouvez les réponses aux questions que nos lecteurs posent le plus souvent. Chaque réponse renvoie vers le guide détaillé correspondant.
      </p>

      {faqSections.map((section) => (
        <div class="mb-10">
          <h2 class="font-sans text-xl font-bold text-marine mb-4">{section.title}</h2>
          {section.faqs.map((faq) => (
            <details class="bg-blanc rounded-xl mb-3 shadow-[0_1px_4px_rgba(27,46,74,0.05)] group">
              <summary class="px-6 py-5 font-sans text-[17px] font-semibold text-marine cursor-pointer list-none flex justify-between items-center">
                <span>{faq.question}</span>
                <span class="text-xl transition-transform group-open:rotate-45">+</span>
              </summary>
              <div class="px-6 pb-5 text-gris-texte text-base leading-relaxed" set:html={faq.answer} />
            </details>
          ))}
        </div>
      ))}
    </div>
  </section>

  <HealthDisclaimer />
</BaseLayout>
