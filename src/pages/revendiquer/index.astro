---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { supabase } from '../../lib/supabase';

const centreSlug = Astro.url.searchParams.get('centre');
const cancelled = Astro.url.searchParams.has('cancelled');

let centre = null;
if (centreSlug) {
  // Vue v_centres_auditifs_public : refuse la revendication d'une fiche etat_administratif=C
  // (cf. migration 033). Si pas trouvé → redirect 301 vers l'annuaire ci-dessous.
  const { data } = await supabase
    .from('v_centres_auditifs_public')
    .select('slug, nom, adresse, cp, ville, is_premium')
    .eq('slug', centreSlug)
    .single();
  centre = data;
}

if (!centre) {
  return Astro.redirect('/trouver-audioprothesiste/', 301);
}

if (centre.is_premium) {
  return Astro.redirect(`/centre/${centre.slug}/`, 301);
}

const displayVille = centre.ville || centre.cp;
const pageTitle = `Revendiquer la fiche de ${centre.nom} — LeGuideAuditif`;
const pageDescription = `Vous gérez ${centre.nom} à ${displayVille} ? Revendiquez votre fiche pour afficher vos coordonnées et gagner en visibilité.`;

const breadcrumbs = [
  { label: 'Accueil', href: '/' },
  { label: 'Trouver un audioprothésiste', href: '/trouver-audioprothesiste/' },
  { label: centre.nom, href: `/centre/${centre.slug}/` },
  { label: 'Revendiquer' },
];
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <meta slot="head" name="robots" content="noindex" />
  <div class="bg-creme">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <Breadcrumbs items={breadcrumbs} />
    </div>
  </div>

  <section class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

    <h1 class="font-sans text-2xl sm:text-3xl font-bold text-marine mb-2">
      Revendiquez votre fiche
    </h1>
    <p class="text-gris-texte font-sans mb-8">
      Complétez le formulaire ci-dessous pour revendiquer la fiche de
      <strong class="text-marine">{centre.nom}</strong> ({centre.adresse}, {centre.cp} {centre.ville}).
    </p>

    {cancelled && (
      <div class="rounded-lg border border-orange/30 bg-orange/5 p-4 mb-6 font-sans text-gris-texte">
        Le paiement a été annulé. Vous pouvez réessayer quand vous le souhaitez.
      </div>
    )}

    {/* === Avantages Premium enrichis === */}
    <div class="rounded-xl border border-gris-clair bg-blanc p-6 mb-8">
      <h2 class="font-sans text-lg font-bold text-marine mb-2">
        Une fiche Premium pensée pour vous faire remonter dans Google
      </h2>
      <p class="text-sm text-gris-texte font-sans mb-5">
        Bien plus qu'un numéro de téléphone en clair. Une page enrichie avec tous les signaux que Google apprécie sur les contenus santé (YMYL).
      </p>

      <div class="grid gap-5 sm:grid-cols-2">
        <div class="rounded-lg border border-gris-clair bg-creme/40 p-5">
          <h3 class="font-sans font-bold text-marine text-base mb-3 flex items-center gap-2">
            <svg class="w-5 h-5 text-orange shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2 15 8.5 22 9.5 17 14.5 18.5 22 12 18.5 5.5 22 7 14.5 2 9.5 9 8.5Z"/></svg>
            Expertise mise en avant
          </h3>
          <ul class="space-y-2 text-sm font-sans text-gris-texte">
            <li>Photo pro + bio de l'audioprothésiste</li>
            <li>N° RPPS vérifié, année du diplôme, expérience</li>
            <li>Associations professionnelles (UNSAF, CNA…)</li>
            <li>Langues parlées au centre</li>
          </ul>
        </div>

        <div class="rounded-lg border border-gris-clair bg-creme/40 p-5">
          <h3 class="font-sans font-bold text-marine text-base mb-3 flex items-center gap-2">
            <svg class="w-5 h-5 text-orange shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5Z"/></svg>
            Contenu SEO riche
          </h3>
          <ul class="space-y-2 text-sm font-sans text-gris-texte">
            <li>FAQ locale géolocalisée (ville, dép.) — éligible rich results Google</li>
            <li>Parcours patient détaillé 4 étapes (schéma HowTo)</li>
            <li>Articles contextualisés selon vos marques/spécialités</li>
            <li>Suggestions d'appareils phares à recommander</li>
          </ul>
        </div>

        <div class="rounded-lg border border-gris-clair bg-creme/40 p-5">
          <h3 class="font-sans font-bold text-marine text-base mb-3 flex items-center gap-2">
            <svg class="w-5 h-5 text-orange shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
            Visibilité maximale
          </h3>
          <ul class="space-y-2 text-sm font-sans text-gris-texte">
            <li>Téléphone en clair + site web cliquable</li>
            <li>Horaires affichés + liens réseaux sociaux</li>
            <li>Marqueur prioritaire sur la carte</li>
            <li>Badge « Centre vérifié »</li>
            <li>Services inclus (essai 30j, livraison, téléconsult.)</li>
          </ul>
        </div>

        <div class="rounded-lg border border-gris-clair bg-creme/40 p-5">
          <h3 class="font-sans font-bold text-marine text-base mb-3 flex items-center gap-2">
            <svg class="w-5 h-5 text-orange shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 3v18h18"/><path d="m7 17 4-4 4 4 5-5"/></svg>
            Espace pro dédié
          </h3>
          <ul class="space-y-2 text-sm font-sans text-gris-texte">
            <li>Dashboard avec KPIs, demandes patients, leads</li>
            <li>Édition en direct de votre fiche (publication instantanée)</li>
            <li>Accès aux leviers Ads + Leads + nPosts</li>
            <li>Support prioritaire</li>
            <li>Sans engagement · résiliable en 1 clic</li>
          </ul>
        </div>
      </div>

      <p class="text-xs text-gris-texte font-sans mt-5 pt-4 border-t border-gris-clair">
        <strong class="text-marine">YMYL santé :</strong> les moteurs de recherche pondèrent fortement l'expertise professionnelle pour les contenus santé. Une fiche enrichie = meilleur classement sur « audioprothésiste {displayVille} » et requêtes associées.
      </p>
    </div>

    {/* === Choix de la formule === */}
    <div class="rounded-xl border border-gris-clair bg-blanc p-6 mb-8">
      <h2 class="font-sans text-lg font-bold text-marine mb-4">
        Choisissez votre formule
      </h2>
      <div class="grid gap-4 sm:grid-cols-2" id="plan-selector">
        <label
          class="plan-card plan-card--selected flex flex-col rounded-xl border-2 border-orange p-5 cursor-pointer transition-all"
          data-plan="monthly"
        >
          <input type="radio" name="plan" value="monthly" checked class="sr-only" />
          <span class="font-sans text-sm font-semibold text-orange uppercase tracking-wide mb-1">Mensuel</span>
          <span class="font-sans text-2xl font-bold text-marine">39 &euro;<span class="text-base font-normal text-gris-texte">/mois</span></span>
          <span class="font-sans text-sm text-gris-texte mt-2">Sans engagement, résiliable à tout moment</span>
        </label>
        <label
          class="plan-card flex flex-col rounded-xl border-2 border-gris-clair p-5 cursor-pointer transition-all relative"
          data-plan="annual"
        >
          <input type="radio" name="plan" value="annual" class="sr-only" />
          <span class="absolute -top-3 right-4 rounded-full bg-orange px-3 py-0.5 text-xs font-bold text-blanc font-sans">-17%</span>
          <span class="font-sans text-sm font-semibold text-orange uppercase tracking-wide mb-1">Annuel</span>
          <span class="font-sans text-2xl font-bold text-marine">390 &euro;<span class="text-base font-normal text-gris-texte">/an</span></span>
          <span class="font-sans text-sm text-gris-texte mt-1">soit 32,50 &euro;/mois — <strong class="text-orange">2 mois offerts</strong></span>
        </label>
      </div>
    </div>

    {/* === Formulaire === */}
    <form
      id="claim-form"
      class="rounded-xl border-2 border-orange/20 bg-blanc p-6 sm:p-8"
    >
      <input type="hidden" name="centreSlug" value={centre.slug} />
      <input type="hidden" name="plan" id="hidden-plan" value="monthly" />

      <h2 class="font-sans text-lg font-bold text-marine mb-6">
        Vos informations professionnelles
      </h2>

      <div class="grid gap-5 sm:grid-cols-2">
        <div>
          <label for="claim-nom" class="block text-sm font-medium text-marine font-sans mb-1">
            Nom
          </label>
          <input
            id="claim-nom"
            name="nom"
            type="text"
            required
            autocomplete="family-name"
            class="w-full rounded-lg border border-gris-clair px-4 py-3 text-base font-sans focus:border-orange focus:outline-none focus:ring-2 focus:ring-orange/20"
          />
        </div>

        <div>
          <label for="claim-prenom" class="block text-sm font-medium text-marine font-sans mb-1">
            Prénom
          </label>
          <input
            id="claim-prenom"
            name="prenom"
            type="text"
            required
            autocomplete="given-name"
            class="w-full rounded-lg border border-gris-clair px-4 py-3 text-base font-sans focus:border-orange focus:outline-none focus:ring-2 focus:ring-orange/20"
          />
        </div>

        <div>
          <label for="claim-email" class="block text-sm font-medium text-marine font-sans mb-1">
            Email professionnel
          </label>
          <input
            id="claim-email"
            name="email"
            type="email"
            required
            autocomplete="email"
            class="w-full rounded-lg border border-gris-clair px-4 py-3 text-base font-sans focus:border-orange focus:outline-none focus:ring-2 focus:ring-orange/20"
          />
        </div>

        <div>
          <label for="claim-identifiant" class="block text-sm font-medium text-marine font-sans mb-1">
            N&deg; ADELI ou SIRET
          </label>
          <input
            id="claim-identifiant"
            name="identifiant"
            type="text"
            required
            placeholder="Ex : 01 93 12345 6 ou 123 456 789 00012"
            class="w-full rounded-lg border border-gris-clair px-4 py-3 text-base font-sans focus:border-orange focus:outline-none focus:ring-2 focus:ring-orange/20"
          />
        </div>
      </div>

      <div class="mt-6">
        <label class="flex items-start gap-2 text-sm text-gris-texte font-sans">
          <input type="checkbox" name="rgpd" required class="mt-1" />
          <span>
            J'atteste être le gérant ou un représentant autorisé de cet établissement.
            J'accepte les <a href="/mentions-legales/" class="text-orange underline">conditions générales</a> et la
            <a href="/politique-confidentialite/" class="text-orange underline">politique de confidentialité</a>.
          </span>
        </label>
      </div>

      <div id="claim-error" class="hidden mt-4 rounded-lg border border-red-300 bg-red-50 p-3 text-sm text-red-600 font-sans"></div>

      <div class="mt-6">
        <button
          type="submit"
          id="claim-submit"
          class="w-full sm:w-auto rounded-lg bg-orange px-8 py-3 text-lg font-semibold text-blanc font-sans transition-colors hover:bg-orange-hover focus:outline-none focus:ring-2 focus:ring-orange/50 cursor-pointer disabled:opacity-60"
          style="min-height: 48px;"
        >
          Passer au paiement (39 &euro;/mois)
        </button>
      </div>
    </form>
  </section>

  <script>
    const form = document.getElementById('claim-form') as HTMLFormElement;
    const submitBtn = document.getElementById('claim-submit') as HTMLButtonElement;
    const errorDiv = document.getElementById('claim-error') as HTMLDivElement;
    const hiddenPlan = document.getElementById('hidden-plan') as HTMLInputElement;
    const planCards = document.querySelectorAll<HTMLLabelElement>('.plan-card');
    const planRadios = document.querySelectorAll<HTMLInputElement>('input[name="plan"]');

    const labels: Record<string, string> = {
      monthly: 'Passer au paiement (39 \u20ac/mois)',
      annual: 'Passer au paiement (390 \u20ac/an)',
    };

    // Plan selection toggle
    planRadios.forEach((radio) => {
      radio.addEventListener('change', () => {
        planCards.forEach((card) => {
          const isSelected = card.dataset.plan === radio.value;
          card.classList.toggle('plan-card--selected', isSelected);
          card.classList.toggle('border-orange', isSelected);
          card.classList.toggle('border-gris-clair', !isSelected);
        });
        hiddenPlan.value = radio.value;
        submitBtn.textContent = labels[radio.value] || labels.monthly;
      });
    });

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      submitBtn.disabled = true;
      submitBtn.textContent = 'Redirection en cours...';
      errorDiv.classList.add('hidden');

      const formData = new FormData(form);
      const plan = formData.get('plan') as string;
      const body = {
        centreSlug: formData.get('centreSlug'),
        nom: formData.get('nom'),
        prenom: formData.get('prenom'),
        email: formData.get('email'),
        identifiant: formData.get('identifiant'),
        plan,
      };

      try {
        const res = await fetch('/api/checkout', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body),
        });

        const data = await res.json();

        if (!res.ok) {
          throw new Error(data.error || 'Une erreur est survenue.');
        }

        window.location.href = data.url;
      } catch (err: unknown) {
        const message = err instanceof Error ? err.message : 'Une erreur est survenue.';
        errorDiv.textContent = message;
        errorDiv.classList.remove('hidden');
        submitBtn.disabled = false;
        submitBtn.textContent = labels[hiddenPlan.value] || labels.monthly;
      }
    });
  </script>

  <style>
    .plan-card--selected {
      background-color: rgba(217, 123, 61, 0.04);
      box-shadow: 0 0 0 1px rgba(217, 123, 61, 0.3);
    }
  </style>
</BaseLayout>
