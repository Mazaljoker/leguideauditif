---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';

const breadcrumbs = [
  { label: 'Accueil', href: '/' },
  { label: 'Trouver un audioprothésiste', href: '/trouver-audioprothesiste/' },
  { label: 'Confirmation' },
];
---

<BaseLayout
  title="Fiche revendiquée avec succès — LeGuideAuditif"
  description="Votre fiche audioprothésiste premium a été revendiquée. Gérez vos informations et recevez des demandes de devis."
>
  <meta slot="head" name="robots" content="noindex" />
  <div class="bg-creme">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <Breadcrumbs items={breadcrumbs} />
    </div>
  </div>

  <section class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-16 text-center">

    <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-green-100 mb-6">
      <svg class="w-8 h-8 text-green-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M20 6 9 17l-5-5" />
      </svg>
    </div>

    <h1 class="font-sans text-2xl sm:text-3xl font-bold text-marine mb-4">
      Votre fiche a été revendiquée avec succès
    </h1>

    <p class="text-gris-texte font-sans text-lg mb-6 max-w-xl mx-auto">
      Votre paiement a bien été enregistré. Votre fiche est désormais en statut
      <strong class="text-orange">Premium</strong> : vos coordonnées, horaires et
      lien vers votre site web sont maintenant visibles par tous les visiteurs.
    </p>

    <div class="rounded-xl border border-gris-clair bg-blanc p-6 mb-8 text-left max-w-md mx-auto font-sans">
      <h2 class="font-bold text-marine mb-3">Prochaines étapes</h2>
      <ul class="space-y-2 text-gris-texte">
        <li class="flex items-start gap-2">
          <svg class="w-5 h-5 text-orange mt-0.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5" /></svg>
          Vérifiez que vos informations (téléphone, horaires, site web) sont à jour
        </li>
        <li class="flex items-start gap-2">
          <svg class="w-5 h-5 text-orange mt-0.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5" /></svg>
          Un email de confirmation a été envoyé à votre adresse
        </li>
        <li class="flex items-start gap-2">
          <svg class="w-5 h-5 text-orange mt-0.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5" /></svg>
          Pour toute modification, contactez-nous via la page <a href="/contact/" class="text-orange underline">Contact</a>
        </li>
      </ul>
    </div>

    <a
      href="/trouver-audioprothesiste/"
      class="inline-flex items-center gap-2 rounded-lg bg-marine px-6 py-3 font-semibold text-blanc font-sans transition-colors hover:bg-marine-light focus:outline-none focus:ring-2 focus:ring-marine/50"
      style="min-height: 48px;"
    >
      <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="19" y1="12" x2="5" y2="12" />
        <polyline points="12 19 5 12 12 5" />
      </svg>
      Retour à l'annuaire
    </a>
  </section>
</BaseLayout>
