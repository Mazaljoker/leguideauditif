---
/**
 * /catalogue/classe-1/ — Page Classe 1 (100% Santé)
 * Tous les appareils éligibles RAC 0€
 * Contenu éducatif sur le dispositif 100% Santé
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import AuthorBox from '../../components/AuthorBox.astro';
import HealthDisclaimer from '../../components/HealthDisclaimer.astro';
import ProductCard from '../../components/catalogue/ProductCard.astro';
import { getCollection } from 'astro:content';
import { formatPrice, getProductPrice, isClasse1, sortProducts } from '../../lib/catalogue-utils';

const allProducts = await getCollection('catalogueAppareils');
const allData = allProducts.map(p => p.data);
const classe1Products = sortProducts(
  allData.filter(p => isClasse1(p)),
  'price-asc'
);

const brands = new Set(classe1Products.map(p => p.marque)).size;
const prices = classe1Products.map(p => getProductPrice(p)).filter(Boolean) as number[];
const maxPrice = prices.length ? Math.max(...prices) : 950;

const title = 'Appareils auditifs Classe 1 — 100% Santé, reste à charge 0€';
const description = `${classe1Products.length} aides auditives Classe 1 éligibles au 100% Santé (reste à charge 0€). Comparez les modèles de ${brands} marques. Guide par un audioprothésiste DE.`;
---

<BaseLayout title={title} description={description} canonical="/catalogue/classe-1/">
  <Breadcrumbs items={[
    { label: 'Accueil', href: '/' },
    { label: 'Catalogue', href: '/catalogue/' },
    { label: 'Classe 1 — 100% Santé' }
  ]} />

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    {/* Hero */}
    <div class="bg-gradient-to-br from-emerald-700 to-emerald-900 text-blanc rounded-2xl p-8 sm:p-12 mb-8 relative overflow-hidden">
      <div class="absolute -right-10 -top-10 w-48 h-48 rounded-full bg-blanc/10" aria-hidden="true"></div>
      <span class="inline-block px-4 py-1.5 rounded-full bg-blanc/20 font-sans text-sm font-bold mb-4">
        ✓ 100% Santé — Reste à charge 0€
      </span>
      <h1 class="font-sans text-3xl sm:text-4xl font-extrabold mb-3">
        Appareils auditifs Classe 1
      </h1>
      <p class="text-lg opacity-90 max-w-2xl leading-relaxed">
        Depuis le 1er janvier 2021, la réforme 100% Santé vous permet d'obtenir
        des aides auditives de qualité sans aucun reste à charge, intégralement
        prises en charge par la Sécurité sociale et votre complémentaire santé.
      </p>
    </div>

    {/* Stats */}
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-8">
      <div class="bg-blanc rounded-xl p-5 text-center shadow-sm">
        <div class="font-sans text-3xl font-extrabold text-emerald-600">{classe1Products.length}</div>
        <div class="font-sans text-sm text-gris-texte mt-1">Appareils Classe 1</div>
      </div>
      <div class="bg-blanc rounded-xl p-5 text-center shadow-sm">
        <div class="font-sans text-3xl font-extrabold text-emerald-600">{brands}</div>
        <div class="font-sans text-sm text-gris-texte mt-1">Marques</div>
      </div>
      <div class="bg-blanc rounded-xl p-5 text-center shadow-sm">
        <div class="font-sans text-3xl font-extrabold text-emerald-600">0€</div>
        <div class="font-sans text-sm text-gris-texte mt-1">Reste à charge</div>
      </div>
      <div class="bg-blanc rounded-xl p-5 text-center shadow-sm">
        <div class="font-sans text-3xl font-extrabold text-emerald-600">≤ 950€</div>
        <div class="font-sans text-sm text-gris-texte mt-1">Prix max réglementé</div>
      </div>
    </div>

    {/* Contenu éducatif 100% Santé */}
    <div class="bg-blanc rounded-2xl p-6 sm:p-8 mb-8 shadow-sm">
      <h2 class="font-sans text-xl font-bold text-marine mb-4">
        Le 100% Santé en audiologie : comment ça marche ?
      </h2>
      <div class="space-y-4 font-sans text-gris-texte leading-relaxed">
        <p>
          La réforme <strong class="text-marine">100% Santé</strong> (anciennement « RAC 0 »)
          garantit un accès à des aides auditives de qualité sans reste à charge pour l'assuré.
          Elle concerne les appareils dits de <strong class="text-marine">Classe 1</strong>.
        </p>
        <p>
          Concrètement, le prix de vente des appareils Classe 1 est plafonné à
          <strong class="text-emerald-600">950 € par appareil</strong> (soit 1 900 € la paire).
          Ce montant est intégralement couvert par l'Assurance Maladie et votre complémentaire
          santé responsable.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 mt-6">
        <div class="bg-emerald-50 rounded-xl p-5">
          <h3 class="font-sans text-base font-bold text-emerald-700 mb-3">Ce que comprend la Classe 1</h3>
          <ul class="space-y-2">
            <li class="font-sans text-sm text-emerald-800 flex items-start gap-2">
              <span class="text-emerald-500 mt-0.5">✓</span> Au minimum 12 canaux de réglage
            </li>
            <li class="font-sans text-sm text-emerald-800 flex items-start gap-2">
              <span class="text-emerald-500 mt-0.5">✓</span> Système anti-larsen
            </li>
            <li class="font-sans text-sm text-emerald-800 flex items-start gap-2">
              <span class="text-emerald-500 mt-0.5">✓</span> Réduction de bruit (au moins 2 canaux)
            </li>
            <li class="font-sans text-sm text-emerald-800 flex items-start gap-2">
              <span class="text-emerald-500 mt-0.5">✓</span> 3 modes d'écoute minimum
            </li>
            <li class="font-sans text-sm text-emerald-800 flex items-start gap-2">
              <span class="text-emerald-500 mt-0.5">✓</span> Connectivité sans fil (Bluetooth sur la plupart)
            </li>
            <li class="font-sans text-sm text-emerald-800 flex items-start gap-2">
              <span class="text-emerald-500 mt-0.5">✓</span> 4 ans de garantie minimum
            </li>
            <li class="font-sans text-sm text-emerald-800 flex items-start gap-2">
              <span class="text-emerald-500 mt-0.5">✓</span> 30 jours d'essai minimum
            </li>
          </ul>
        </div>
        <div class="bg-blue-50 rounded-xl p-5">
          <h3 class="font-sans text-base font-bold text-marine mb-3">Classe 1 vs Classe 2</h3>
          <ul class="space-y-2">
            <li class="font-sans text-sm text-marine flex items-start gap-2">
              <span class="text-orange mt-0.5">→</span> <strong>Classe 1</strong> : prix plafonné, 0€ reste à charge
            </li>
            <li class="font-sans text-sm text-marine flex items-start gap-2">
              <span class="text-orange mt-0.5">→</span> <strong>Classe 2</strong> : prix libre, reste à charge variable
            </li>
            <li class="font-sans text-sm text-marine flex items-start gap-2">
              <span class="text-orange mt-0.5">→</span> La Classe 2 propose des technologies plus avancées (plus de canaux, IA, capteurs santé…)
            </li>
            <li class="font-sans text-sm text-marine flex items-start gap-2">
              <span class="text-orange mt-0.5">→</span> Un appareil Classe 1 suffit pour la majorité des pertes auditives légères à moyennes
            </li>
          </ul>
        </div>
      </div>
    </div>

    {/* Grille produits Classe 1 */}
    <h2 class="font-sans text-xl font-bold text-marine mb-4">
      Tous les appareils Classe 1 ({classe1Products.length})
    </h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 mb-8">
      {classe1Products.map(p => <ProductCard product={p} />)}
    </div>

    <p class="text-xs text-gris-texte text-center mb-8">
      * Le reste à charge 0€ s'applique avec une complémentaire santé responsable et une
      prescription médicale valide. Le prix comprend l'appareil, l'adaptation et le suivi sur 4 ans.
    </p>

    {/* Lead CTA */}
    <div class="bg-gradient-to-br from-emerald-700 to-emerald-900 text-blanc rounded-2xl p-8 text-center mb-8">
      <h2 class="font-sans text-2xl font-bold mb-2">Testez un appareil Classe 1 sans avancer 1€</h2>
      <p class="opacity-80 mb-5">30 jours d'essai gratuit chez un audioprothésiste près de chez vous</p>
      <a href="/devis/" class="inline-block bg-orange text-blanc px-8 py-3.5 rounded-xl font-sans text-lg font-bold no-underline hover:bg-orange-hover transition-colors">
        Demander un devis gratuit →
      </a>
    </div>

    <AuthorBox />
    <HealthDisclaimer />
  </div>
</BaseLayout>