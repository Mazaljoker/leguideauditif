---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import HealthDisclaimer from '../../components/HealthDisclaimer.astro';
import AudioMap from '../../components/AudioMap.tsx';
import '../../styles/audiomap.css';
import { supabase } from '../../lib/supabase';

// Fetch depuis Supabase — uniquement les centres avec GPS pour la carte
// Supabase limite à 1000 lignes par défaut, on pagine pour tout récupérer
const PAGE_SIZE = 1000;
let allCentres: Awaited<ReturnType<typeof supabase.from<'centres_auditifs'>>>['data'] = [];
let offset = 0;
let hasMore = true;

while (hasMore) {
  const { data: batch } = await supabase
    .from('centres_auditifs')
    .select('id, slug, nom, adresse, cp, ville, departement, lat, lng, tel, horaires, site_web, finess, source, is_premium, plan')
    .not('lat', 'is', null)
    .not('lng', 'is', null)
    .range(offset, offset + PAGE_SIZE - 1);

  if (batch && batch.length > 0) {
    allCentres = [...(allCentres ?? []), ...batch];
    offset += PAGE_SIZE;
    hasMore = batch.length === PAGE_SIZE;
  } else {
    hasMore = false;
  }
}

const centres = allCentres ?? [];

const title = 'Trouver un audioprothésiste près de chez vous | LeGuideAuditif';
const description =
  'Carte interactive des audioprothésistes en France. Recherchez par ville ou code postal, trouvez un professionnel qualifié près de chez vous.';

const breadcrumbs = [
  { label: 'Accueil', href: '/' },
  { label: 'Trouver un audioprothésiste' },
];

// Schema.org -- WebPage + SearchAction
const schemaWebPage = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: title,
  description,
  url: 'https://leguideauditif.fr/trouver-audioprothesiste/',
  isPartOf: {
    '@type': 'WebSite',
    name: 'LeGuideAuditif',
    url: 'https://leguideauditif.fr',
  },
  potentialAction: {
    '@type': 'SearchAction',
    target: {
      '@type': 'EntryPoint',
      urlTemplate:
        'https://leguideauditif.fr/trouver-audioprothesiste/?q={search_term_string}',
    },
    'query-input': 'required name=search_term_string',
  },
};

// Schema.org -- LocalBusiness pour chaque centre (max 50 pour le JSON-LD)
const schemaLocalBusinesses = centres.slice(0, 50).map((centre: {
  slug: string;
  nom: string;
  adresse: string;
  cp: string;
  ville: string;
  tel: string;
  horaires: string | null;
  site_web: string | null;
  lat: number;
  lng: number;
  is_premium: boolean;
}) => ({
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  '@id': `https://leguideauditif.fr/centre/${centre.slug}/`,
  name: centre.nom,
  address: {
    '@type': 'PostalAddress',
    streetAddress: centre.adresse,
    postalCode: centre.cp,
    addressLocality: centre.ville,
    addressCountry: 'FR',
  },
  telephone: centre.tel || undefined,
  openingHours: centre.horaires || undefined,
  url: centre.site_web || undefined,
  geo: {
    '@type': 'GeoCoordinates',
    latitude: centre.lat,
    longitude: centre.lng,
  },
  additionalType: 'https://schema.org/MedicalBusiness',
  medicalSpecialty: 'Audioprothèse',
}));

const allSchemas = [schemaWebPage, ...schemaLocalBusinesses];
---

<BaseLayout
  title={title}
  description={description}
  canonical="https://leguideauditif.fr/trouver-audioprothesiste/"
  ogImage="/og-trouver-audioprothesiste.jpg"
  ogType="website"
  schema={allSchemas}
>
  {/* Leaflet CSS -- loaded only on this page */}
  <link
    rel="stylesheet"
    href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
    integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
    crossorigin=""
    slot="head"
  />

  <section class="bg-creme pt-8 pb-16">
    <div class="max-w-[1200px] mx-auto px-4 sm:px-6">
      <Breadcrumbs items={breadcrumbs} />

      <header class="mb-8">
        <h1 class="font-sans text-[32px] sm:text-[38px] font-extrabold text-marine leading-tight mb-4">
          Trouver un audioprothésiste près de chez vous
        </h1>
        <p class="text-lg leading-relaxed max-w-[680px]">
          Utilisez notre carte interactive pour localiser un audioprothésiste
          diplômé d'État dans votre ville. Entrez votre ville ou code postal
          pour afficher les centres les plus proches.
        </p>
      </header>

      {/* Carte interactive -- React island, chargee cote client */}
      <AudioMap client:only="react" data={centres} />

      {/* Section informative sous la carte */}
      <div class="mt-12 max-w-[780px]">
        <h2 class="font-sans text-[26px] font-bold text-marine mb-4">
          Comment choisir votre audioprothésiste ?
        </h2>
        <p class="mb-4">
          Le choix de votre audioprothésiste est une étape cruciale dans votre
          parcours de soin auditif. Ce professionnel de santé, titulaire du
          Diplôme d'État d'audioprothésiste (DE), vous accompagnera pendant
          toute la durée de vie de vos appareils auditifs -- en moyenne 4 à 5 ans.
        </p>
        <p class="mb-4">
          Lors de votre premier rendez-vous, l'audioprothésiste réalise un
          bilan auditif complet et gratuit. Ce bilan permet de déterminer
          votre degré de perte auditive et de vous orienter vers la solution
          la plus adaptée à vos besoins et à votre mode de vie.
        </p>

        <h3 class="font-sans text-[20px] font-bold text-marine mb-3 mt-8">
          Les critères essentiels
        </h3>
        <p class="mb-4">
          Privilégiez un centre offrant un suivi personnalisé sur la durée.
          Le nombre de rendez-vous de réglage après l'appareillage est un
          indicateur important de la qualité du suivi. Vérifiez également
          que le centre propose des appareils de classe 1 (100% Santé, reste
          à charge zéro) et de classe 2 pour avoir le choix.
        </p>

        <h3 class="font-sans text-[20px] font-bold text-marine mb-3 mt-8">
          Vos droits en tant que patient
        </h3>
        <p class="mb-6">
          Depuis la réforme 100% Santé, vous avez droit à un devis normalisé
          détaillant le prix des appareils, le coût du suivi et les
          remboursements. L'audioprothésiste est tenu de vous proposer au
          moins une offre de classe 1 entièrement prise en charge par
          l'Assurance Maladie et votre complémentaire santé.
        </p>

        {/* Liens internes vers les guides */}
        <div class="bg-blanc rounded-2xl p-6 shadow-[0_2px_12px_rgba(27,46,74,0.06)]">
          <h3 class="font-sans text-[18px] font-bold text-marine mb-3">
            Guides utiles pour votre parcours auditif
          </h3>
          <ul class="space-y-2">
            <li>
              <a href="/guides/audioprothesiste/choisir/" class="text-orange hover:underline font-medium">
                Comment choisir son audioprothésiste
              </a>
            </li>
            <li>
              <a href="/guides/audioprothesiste/premier-rdv/" class="text-orange hover:underline font-medium">
                Premier rendez-vous : a quoi vous attendre
              </a>
            </li>
            <li>
              <a href="/guides/remboursement/" class="text-orange hover:underline font-medium">
                Remboursement des appareils auditifs : le guide complet
              </a>
            </li>
            <li>
              <a href="/guides/remboursement/100-sante-audition/" class="text-orange hover:underline font-medium">
                100% Santé audition : ce que vous devez savoir
              </a>
            </li>
            <li>
              <a href="/guides/appareils-auditifs/classe-1-vs-classe-2/" class="text-orange hover:underline font-medium">
                Classe 1 vs Classe 2 : comparaison détaillée
              </a>
            </li>
            <li>
              <a href="/guides/perte-auditive/symptomes/" class="text-orange hover:underline font-medium">
                Les symptômes d'une perte auditive
              </a>
            </li>
          </ul>
        </div>
      </div>

      <HealthDisclaimer />
    </div>
  </section>
</BaseLayout>