---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import LeadForm from '../../components/LeadForm.tsx';
import MiniMap from '../../components/MiniMap.tsx';
import { supabase } from '../../lib/supabase';
import { getDepartementByCode, slugifyVille, formatVilleName, normalizeVilleBase, prepositionDepartement } from '../../lib/departements';

const { ville: villeSlug } = Astro.params;

if (!villeSlug) {
  return new Response(null, { status: 404 });
}

// Chercher les centres dont le slug ville correspond
// On reconstruit le nom de ville à partir des centres trouvés
const PAGE_SIZE = 1000;
let allCentres: any[] = [];
let offset = 0;
let hasMore = true;

// Première passe : chercher par slug de ville
while (hasMore) {
  const { data: batch } = await supabase
    .from('centres_auditifs')
    .select('id, slug, nom, adresse, cp, ville, departement, lat, lng, tel, horaires, site_web, is_premium, plan, finess')
    .not('lat', 'is', null)
    .not('lng', 'is', null)
    .range(offset, offset + PAGE_SIZE - 1);

  if (batch && batch.length > 0) {
    // Filtrer par slug de ville côté client (Supabase n'a pas de slugify)
    const matching = batch.filter((c) => c.ville && slugifyVille(c.ville) === villeSlug);
    allCentres = [...allCentres, ...matching];
    offset += PAGE_SIZE;
    hasMore = batch.length === PAGE_SIZE;
  } else {
    hasMore = false;
  }
}

// Si aucun centre trouvé, 404 propre (pas redirect — évite "Page avec redirection échec" en GSC)
if (allCentres.length === 0) {
  return new Response(null, { status: 404 });
}

// Extraire les infos de la ville (nom formaté, arrondissements regroupés en "Paris", "Lyon"...)
const villeName = formatVilleName(normalizeVilleBase(allCentres[0].ville || ''));
const cp = allCentres[0].cp || '';
const depCode = cp.substring(0, 2) === '97' ? cp.substring(0, 3) : cp.substring(0, 2);
const depInfo = getDepartementByCode(depCode);

const centresCount = allCentres.length;
const claimedCount = allCentres.filter((c) => c.plan === 'claimed' || c.plan === 'premium').length;

// Indexation : noindex si < 6 centres (thin content — signal qualité Google).
// Seuil validé pour limiter l'index aux métropoles et sous-préfectures denses.
const isThin = centresCount < 6;

// Trier : fiches vérifiées en premier, puis premium, puis alphabétique
allCentres.sort((a, b) => {
  const planOrder = { premium: 0, claimed: 1, rpps: 2 };
  const aOrder = planOrder[a.plan as keyof typeof planOrder] ?? 3;
  const bOrder = planOrder[b.plan as keyof typeof planOrder] ?? 3;
  if (aOrder !== bOrder) return aOrder - bOrder;
  return (a.nom || '').localeCompare(b.nom || '');
});

// Détecter si la ville a des arrondissements (Paris, Lyon, Marseille)
// Détection : au moins 2 formes distinctes de la même ville de base
const rawVilles = new Set(allCentres.map((c) => (c.ville || '').trim().toUpperCase()));
const hasArrondissements = rawVilles.size > 1;

// Helpers pour extraire le numéro d'arrondissement depuis le CP
// Paris 75001-75020, Lyon 69001-69009, Marseille 13001-13016
function extractArrondissementFromCp(cp: string): string | null {
  if (!cp) return null;
  const match = cp.match(/^(75|69|13)0?(\d{1,2})$/);
  if (!match) return null;
  const num = parseInt(match[2], 10);
  if (num < 1 || num > 20) return null;
  const prefix = match[1];
  if (prefix === '75') return `${num}${num === 1 ? 'er' : 'e'} arrondissement`;
  if (prefix === '69') return `Lyon ${num}${num === 1 ? 'er' : 'e'}`;
  if (prefix === '13') return `Marseille ${num}${num === 1 ? 'er' : 'e'}`;
  return null;
}

// Grouper les centres par arrondissement si applicable
type ArrondissementGroup = { label: string; cp: string; centres: any[] };
const arrondissements: ArrondissementGroup[] = [];
if (hasArrondissements) {
  const groups = new Map<string, ArrondissementGroup>();
  for (const c of allCentres) {
    const label = extractArrondissementFromCp(c.cp) || 'Non précisé';
    const key = c.cp || 'unknown';
    if (!groups.has(key)) {
      groups.set(key, { label, cp: c.cp || '', centres: [] });
    }
    groups.get(key)!.centres.push(c);
  }
  // Trier par numéro d'arrondissement (via CP)
  arrondissements.push(
    ...Array.from(groups.values()).sort((a, b) => (a.cp || '').localeCompare(b.cp || ''))
  );
}

// Préparer les centres pour la mini-carte (tous)
const centresForMap = allCentres.map((c) => ({
  id: c.id,
  slug: c.slug,
  nom: c.nom,
  adresse: c.adresse,
  cp: c.cp,
  ville: formatVilleName(c.ville || ''),
  lat: c.lat,
  lng: c.lng,
  tel: c.tel,
  plan: c.plan,
}));

const title = `Audioprothésiste à ${villeName}${depInfo ? ` (${depInfo.code})` : ''}`;
const description = `Trouvez un audioprothésiste à ${villeName}${depInfo ? `, ${depInfo.nom}` : ''}. Comparez les prix, vérifiez les diplômes, prenez rendez-vous. Annuaire indépendant rédigé par un audioprothésiste DE.`;

// OG image dynamique — générée via /api/og/silo (Edge function, cachée par Vercel)
const ogSubtitle = depInfo ? `${depInfo.nom} · ${depInfo.code}` : '';
const ogImage = `/api/og/silo?type=ville&title=${encodeURIComponent(`Audioprothésiste à ${villeName}`)}&subtitle=${encodeURIComponent(ogSubtitle)}`;

const breadcrumbs = [
  { label: 'Accueil', href: '/' },
  { label: 'Audioprothésistes', href: '/audioprothesiste/' },
  ...(depInfo ? [{ label: `${depInfo.nom} (${depInfo.code})`, href: `/audioprothesiste/departement/${depInfo.slug}/` }] : []),
  { label: villeName },
];

// FAQ dynamique
const faq = [
  {
    question: `Comment trouver un audioprothésiste à ${villeName} ?`,
    answer: `Consultez la liste ci-dessous pour voir les centres auditifs à ${villeName}. Cliquez sur une fiche pour obtenir les coordonnées et horaires. Vous pouvez aussi utiliser notre formulaire de devis gratuit : un audioprothésiste diplômé d'État proche de ${villeName} vous rappelle sous 48 heures.`
  },
  {
    question: `Quel est le prix d'un appareil auditif à ${villeName} ?`,
    answer: `Les prix sont identiques partout en France. En classe 1 (100 % Santé), le reste à charge est de 0 euro. En classe 2, comptez de 850 à 2 400 euros par oreille selon la gamme, avant remboursement par la Sécurité sociale et votre mutuelle.`
  },
  {
    question: `Quelles sont les obligations d'un audioprothésiste à ${villeName} ?`,
    answer: `Un audioprothésiste exerçant à ${villeName} doit être diplômé d'État (numéro ADELI ou RPPS vérifiable), remettre un devis normalisé avant toute vente, et assurer un suivi sur 4 ans minimum. L'essai gratuit de 30 jours est obligatoire avant achat.`
  },
];

// Schema.org
const schemas = [
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: title,
    description,
    url: `https://leguideauditif.fr/audioprothesiste/${villeSlug}/`,
    isPartOf: {
      '@type': 'WebSite',
      name: 'LeGuideAuditif.fr',
      url: 'https://leguideauditif.fr',
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: breadcrumbs.map((item, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      name: item.label,
      ...(item.href && { item: new URL(item.href, 'https://leguideauditif.fr').href }),
    })),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faq.map((f) => ({
      '@type': 'Question',
      name: f.question,
      acceptedAnswer: { '@type': 'Answer', text: f.answer },
    })),
  },
];
---

<BaseLayout title={title} description={description} ogImage={ogImage} schema={schemas} noindex={isThin}>
  {/* Leaflet CSS — loaded only on this page */}
  <link
    rel="stylesheet"
    href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
    integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
    crossorigin=""
    slot="head"
  />

  <div class="bg-creme">
    <div class="max-w-[1140px] mx-auto px-5 py-4">
      <Breadcrumbs items={breadcrumbs} includeSchema={false} />
    </div>
  </div>

  <section class="bg-creme py-12">
    <div class="max-w-[1140px] mx-auto px-5">
      <!-- Header -->
      <header class="mb-10">
        <h1 class="font-sans text-[32px] lg:text-[38px] font-extrabold text-marine leading-tight mb-3">
          Audioprothésiste à {villeName}
        </h1>
        <p class="text-gris-texte text-lg max-w-[700px]">
          Centres auditifs à {villeName}{depInfo && villeName !== depInfo.nom ? ` (${depInfo.nom}, ${depInfo.code})` : depInfo ? ` (${depInfo.code})` : ''}, référencés à partir du RPPS (Répertoire Partagé des Professionnels de Santé) et de l'INSEE/SIRENE.
          {depInfo && villeName !== depInfo.nom && (
            <>
              {' '}Voir aussi <a href={`/audioprothesiste/departement/${depInfo.slug}/`} class="text-orange hover:underline">tous les audioprothésistes {prepositionDepartement(depInfo.nom).de}</a>.
            </>
          )}
        </p>
      </header>

      <!-- Mini-carte Leaflet -->
      <div class="mb-10">
        <MiniMap client:only="react" centres={centresForMap} label={`Carte des audioprothésistes à ${villeName}`} />
      </div>

      <!-- Conseil expert contextuel -->
      <div class="bg-blanc rounded-xl p-6 mb-10 shadow-[0_1px_4px_rgba(27,46,74,0.05)]">
        <h2 class="font-sans text-xl font-bold text-marine mb-3">Bien choisir son audioprothésiste à {villeName}</h2>
        <p class="text-gris-texte leading-relaxed mb-3">
          Quel que soit le nombre de centres à {villeName}, ce qui compte vraiment, c'est la qualité de l'audioprothésiste
          qui vous suivra pendant 4 ans. Les écarts de prix en classe 2 peuvent atteindre 200 à 400 euros par oreille
          pour le même appareil — d'où l'intérêt de comparer plusieurs <a href="/devis/" class="text-orange hover:underline">devis gratuits</a>
          avant de vous engager.
        </p>
        <p class="text-gris-texte leading-relaxed">
          Trois vérifications avant de signer : le diplôme d'État (ADELI ou RPPS), la présence régulière
          de l'audioprothésiste au centre (le suivi dure 4 ans), et le
          <a href="/guides/remboursement/devis/" class="text-orange hover:underline">devis normalisé</a> obligatoire (arrêté du 14 novembre 2018).
        </p>
      </div>

      <!-- Liste des centres : groupée par arrondissement si applicable, sinon liste simple -->
      <div class="mb-10">
        <h2 class="font-sans text-xl font-bold text-marine mb-4">
          Centres auditifs à {villeName}
        </h2>

        {hasArrondissements ? (
          <!-- Groupée par arrondissement -->
          <div class="space-y-8">
            {arrondissements.map((arr) => (
              <div>
                <h3 class="font-sans text-lg font-semibold text-marine mb-3 border-b border-gris-clair pb-2">
                  {arr.label} <span class="text-sm text-gris-texte font-normal">({arr.cp})</span>
                </h3>
                <div class="space-y-3">
                  {arr.centres.map((c) => (
                    <a
                      href={`/centre/${c.slug}/`}
                      class="block bg-blanc rounded-xl p-4 shadow-[0_1px_4px_rgba(27,46,74,0.05)] hover:shadow-md transition-shadow no-underline hover:no-underline"
                    >
                      <div class="flex justify-between items-start">
                        <div>
                          <h4 class="font-sans text-base font-semibold text-marine">{c.nom}</h4>
                          <p class="text-sm text-gris-texte">{c.adresse} — {c.cp}</p>
                          {c.tel && <p class="text-sm text-orange mt-1">{c.tel}</p>}
                        </div>
                        <div class="flex flex-col items-end gap-1 shrink-0">
                          {c.plan === 'premium' && (
                            <span class="text-xs bg-orange/10 text-orange px-2 py-1 rounded-full font-sans font-medium">Premium</span>
                          )}
                          {c.plan === 'claimed' && (
                            <span class="text-xs bg-green-50 text-green-700 px-2 py-1 rounded-full font-sans font-medium">Fiche vérifiée</span>
                          )}
                        </div>
                      </div>
                    </a>
                  ))}
                </div>
              </div>
            ))}
          </div>
        ) : (
          <!-- Liste simple -->
          <div class="space-y-3">
            {allCentres.map((c) => (
              <a
                href={`/centre/${c.slug}/`}
                class="block bg-blanc rounded-xl p-4 shadow-[0_1px_4px_rgba(27,46,74,0.05)] hover:shadow-md transition-shadow no-underline hover:no-underline"
              >
                <div class="flex justify-between items-start">
                  <div>
                    <h3 class="font-sans text-base font-semibold text-marine">{c.nom}</h3>
                    <p class="text-sm text-gris-texte">{c.adresse} — {c.cp} {formatVilleName(c.ville || '')}</p>
                    {c.tel && <p class="text-sm text-orange mt-1">{c.tel}</p>}
                  </div>
                  <div class="flex flex-col items-end gap-1 shrink-0">
                    {c.plan === 'premium' && (
                      <span class="text-xs bg-orange/10 text-orange px-2 py-1 rounded-full font-sans font-medium">Premium</span>
                    )}
                    {c.plan === 'claimed' && (
                      <span class="text-xs bg-green-50 text-green-700 px-2 py-1 rounded-full font-sans font-medium">Fiche vérifiée</span>
                    )}
                  </div>
                </div>
              </a>
            ))}
          </div>
        )}
      </div>

      <!-- FAQ -->
      <div class="mb-10">
        <h2 class="font-sans text-xl font-bold text-marine mb-4">Questions fréquentes</h2>
        {faq.map((f) => (
          <details class="bg-blanc rounded-xl mb-3 shadow-[0_1px_4px_rgba(27,46,74,0.05)] group">
            <summary class="px-6 py-5 font-sans text-[17px] font-semibold text-marine cursor-pointer list-none flex justify-between items-center">
              <span>{f.question}</span>
              <span class="text-xl transition-transform group-open:rotate-45">+</span>
            </summary>
            <div class="px-6 pb-5 text-gris-texte text-base leading-relaxed">{f.answer}</div>
          </details>
        ))}
      </div>

      <!-- LeadForm -->
      <div class="bg-blanc rounded-2xl p-8 shadow-[0_2px_12px_rgba(27,46,74,0.06)] mb-10">
        <h2 class="font-sans text-2xl font-bold text-marine mb-4">Devis gratuit à {villeName}</h2>
        <p class="text-gris-texte mb-6">Un audioprothésiste qualifié proche de {villeName} vous rappelle sous 48 heures.</p>
        <LeadForm client:visible />
      </div>

      <!-- Maillage silo -->
      <div class="text-sm text-gris-texte space-y-2">
        {depInfo && (
          <p>
            Voir aussi :
            <a href={`/audioprothesiste/departement/${depInfo.slug}/`} class="text-orange hover:underline">
              Tous les audioprothésistes du {depInfo.nom} ({depInfo.code})
            </a>
          </p>
        )}
        <p>Guides connexes :</p>
        <ul class="flex flex-wrap gap-x-4 gap-y-1">
          <li><a href="/guides/audioprothesiste/choisir/" class="text-orange hover:underline">Comment choisir son audioprothésiste</a></li>
          <li><a href="/guides/remboursement/prix-appareil-auditif/" class="text-orange hover:underline">Prix des appareils auditifs</a></li>
          <li><a href="/guides/remboursement/100-sante-audition/" class="text-orange hover:underline">100 % Santé Audition</a></li>
        </ul>
      </div>
    </div>
  </section>
</BaseLayout>
