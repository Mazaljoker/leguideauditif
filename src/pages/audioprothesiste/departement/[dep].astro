---
export const prerender = false;

import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import LeadForm from '../../../components/LeadForm.tsx';
import MiniMap from '../../../components/MiniMap.tsx';
import { supabase } from '../../../lib/supabase';
import { DEPARTEMENTS, getDepartementBySlug, slugifyVille, formatVilleName, normalizeVilleBase, prepositionDepartement } from '../../../lib/departements';
import type { DepartementInfo } from '../../../lib/departements';

const { dep } = Astro.params;
const depInfo = getDepartementBySlug(dep || '');

if (!depInfo) {
  return Astro.redirect('/trouver-audioprothesiste/');
}

// Récupérer les centres du département (par code postal)
const cpPrefix = depInfo.code.length === 3 ? depInfo.code : depInfo.code.padStart(2, '0');
const PAGE_SIZE = 1000;
let allCentres: any[] = [];
let offset = 0;
let hasMore = true;

while (hasMore) {
  const { data: batch } = await supabase
    .from('centres_auditifs')
    .select('id, slug, nom, adresse, cp, ville, departement, lat, lng, tel, is_premium, plan')
    .like('cp', `${cpPrefix}%`)
    .not('lat', 'is', null)
    .not('lng', 'is', null)
    .range(offset, offset + PAGE_SIZE - 1);

  if (batch && batch.length > 0) {
    allCentres = [...allCentres, ...batch];
    offset += PAGE_SIZE;
    hasMore = batch.length === PAGE_SIZE;
  } else {
    hasMore = false;
  }
}

// Grouper par ville (en regroupant les arrondissements : Paris 15e → Paris)
const villeMap = new Map<string, { count: number; ville: string; slug: string }>();
for (const c of allCentres) {
  if (!c.ville) continue;
  const baseVille = normalizeVilleBase(c.ville);
  const slug = slugifyVille(baseVille);
  if (!villeMap.has(slug)) {
    villeMap.set(slug, { count: 0, ville: formatVilleName(baseVille), slug });
  }
  villeMap.get(slug)!.count++;
}
const villes = Array.from(villeMap.values()).sort((a, b) => b.count - a.count);
const topVilles = villes.slice(0, 30);

const centresCount = allCentres.length;
const villesCount = villes.length;
const claimedCount = allCentres.filter((c) => c.plan === 'claimed' || c.plan === 'premium').length;

// Centres pour la mini-carte département (échantillon si >500 pour les perfs)
const centresForMap = (centresCount > 500 ? allCentres.slice(0, 500) : allCentres).map((c) => ({
  id: c.id,
  slug: c.slug,
  nom: c.nom,
  adresse: c.adresse,
  cp: c.cp,
  ville: formatVilleName(c.ville || ''),
  lat: c.lat,
  lng: c.lng,
  tel: c.tel,
  plan: c.plan,
}));

const prep = prepositionDepartement(depInfo.nom);
const title = `Audioprothésiste ${prep.de} (${depInfo.code})`;
const description = `Trouvez un audioprothésiste ${prep.dans} (${depInfo.code}). Annuaire indépendant rédigé par un audioprothésiste DE, basé sur les données publiques FINESS.`;

// OG image dynamique — générée via /api/og/silo (Edge function, cachée par Vercel)
const ogImage = `/api/og/silo?type=departement&title=${encodeURIComponent(`Audioprothésiste ${prep.de}`)}&subtitle=${encodeURIComponent(`${depInfo.region} · ${depInfo.code}`)}`;

const breadcrumbs = [
  { label: 'Accueil', href: '/' },
  { label: 'Audioprothésistes', href: '/audioprothesiste/' },
  { label: `${depInfo.nom} (${depInfo.code})` },
];

// FAQ dynamique
const faq = [
  {
    question: `Comment trouver un audioprothésiste ${prep.dans} ?`,
    answer: `Consultez la liste des villes ci-dessous ou directement la liste des centres du département ${depInfo.nom} (${depInfo.code}). Les données proviennent du fichier FINESS (source publique) mis à jour régulièrement. Vous pouvez aussi utiliser notre formulaire de devis gratuit : un audioprothésiste qualifié vous rappelle sous 48 heures.`
  },
  {
    question: `Comment choisir un audioprothésiste ${prep.dans} ?`,
    answer: `Vérifiez d'abord que le professionnel est diplômé d'État (numéro ADELI ou RPPS). Demandez la durée de présence de l'audioprothésiste dans le centre — le suivi dure 4 ans minimum. Comparez toujours au moins deux devis. Le devis normalisé est obligatoire (arrêté du 14 novembre 2018).`
  },
  {
    question: `Les appareils auditifs sont-ils remboursés ${prep.dans} ?`,
    answer: `Oui, le remboursement est identique partout en France. Les appareils de classe 1 (100 % Santé) sont intégralement remboursés : reste à charge zéro. Pour la classe 2, le remboursement dépend de votre mutuelle. Le département n'a aucun impact sur le tarif ou le remboursement.`
  },
];

// Schema.org
const schemas = [
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: title,
    description,
    url: `https://leguideauditif.fr/audioprothesiste/departement/${dep}/`,
    isPartOf: {
      '@type': 'WebSite',
      name: 'LeGuideAuditif.fr',
      url: 'https://leguideauditif.fr',
    },
    about: {
      '@type': 'MedicalSpecialty',
      name: 'Audioprothèse',
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: breadcrumbs.map((item, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      name: item.label,
      ...(item.href && { item: new URL(item.href, 'https://leguideauditif.fr').href }),
    })),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faq.map((f) => ({
      '@type': 'Question',
      name: f.question,
      acceptedAnswer: { '@type': 'Answer', text: f.answer },
    })),
  },
];
---

<BaseLayout title={title} description={description} ogImage={ogImage} schema={schemas}>
  {/* Leaflet CSS — loaded only on this page */}
  <link
    rel="stylesheet"
    href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
    integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
    crossorigin=""
    slot="head"
  />

  <div class="bg-creme">
    <div class="max-w-[1140px] mx-auto px-5 py-4">
      <Breadcrumbs items={breadcrumbs} includeSchema={false} />
    </div>
  </div>

  <section class="bg-creme py-12">
    <div class="max-w-[1140px] mx-auto px-5">
      <!-- Header -->
      <header class="mb-10">
        <h1 class="font-sans text-[32px] lg:text-[38px] font-extrabold text-marine leading-tight mb-3">
          Audioprothésiste {prep.dans} ({depInfo.code})
        </h1>
        <p class="text-gris-texte text-lg max-w-[700px]">
          Centres auditifs du département {depInfo.nom}, région {depInfo.region}.
          Annuaire indépendant basé sur les données publiques FINESS.
        </p>
      </header>

      <!-- Mini-carte Leaflet -->
      {centresForMap.length > 0 && (
        <div class="mb-10">
          <MiniMap client:only="react" centres={centresForMap} label={`Carte des audioprothésistes ${prep.dans}`} />
        </div>
      )}

      <!-- Contenu expert contextuel -->
      <div class="bg-blanc rounded-xl p-6 mb-10 shadow-[0_1px_4px_rgba(27,46,74,0.05)]">
        <h2 class="font-sans text-xl font-bold text-marine mb-3">Trouver un audioprothésiste {prep.dans}</h2>
        <p class="text-gris-texte leading-relaxed mb-3">
          Le choix d'un audioprothésiste {prep.dans} mérite la même attention que partout ailleurs en France.
          L'enjeu n'est pas le nombre de centres dans votre département, mais la qualité de l'audioprothésiste qui
          vous accompagnera sur les quatre années de suivi. Si vous habitez en zone rurale ou dans une commune peu
          dotée, pensez à élargir votre recherche aux villes voisines ou à consulter un audioprothésiste en
          <a href="/guides/audioprothesiste/teleaudiologie/" class="text-orange hover:underline"> téléaudiologie</a> pour un premier avis.
        </p>
        <p class="text-gris-texte leading-relaxed">
          Mon conseil : quel que soit le département, la qualité de votre appareillage dépend du professionnel qui vous suit.
          Vérifiez son diplôme d'État (numéro ADELI ou RPPS), sa présence régulière au centre, et demandez le
          <a href="/guides/remboursement/devis/" class="text-orange hover:underline"> devis normalisé</a> (c'est obligatoire, arrêté du 14 novembre 2018).
        </p>
      </div>

      <!-- Villes du département (maillage silo) -->
      {topVilles.length > 0 && (
        <div class="mb-10">
          <h2 class="font-sans text-xl font-bold text-marine mb-4">
            Principales villes {prep.de}
          </h2>
          <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3">
            {topVilles.map((v) => (
              <a
                href={`/audioprothesiste/${v.slug}/`}
                class="bg-blanc rounded-lg px-4 py-3 shadow-[0_1px_4px_rgba(27,46,74,0.05)] hover:shadow-md hover:-translate-y-0.5 transition-all no-underline hover:no-underline"
              >
                <span class="font-sans text-sm font-medium text-marine">{v.ville}</span>
              </a>
            ))}
          </div>
          {villes.length > 30 && (
            <p class="text-sm text-gris-texte mt-3">
              <a href="/trouver-audioprothesiste/" class="text-orange hover:underline">Voir la carte complète de tous les centres</a>
            </p>
          )}
        </div>
      )}

      <!-- Liste des centres (top 20) -->
      {allCentres.length > 0 && (
        <div class="mb-10">
          <h2 class="font-sans text-xl font-bold text-marine mb-4">
            Centres auditifs {prep.dans}
          </h2>
          <div class="space-y-3">
            {allCentres.slice(0, 20).map((c) => (
              <a
                href={`/centre/${c.slug}/`}
                class="block bg-blanc rounded-xl p-4 shadow-[0_1px_4px_rgba(27,46,74,0.05)] hover:shadow-md transition-shadow no-underline hover:no-underline"
              >
                <div class="flex justify-between items-start">
                  <div>
                    <h3 class="font-sans text-base font-semibold text-marine">{c.nom}</h3>
                    <p class="text-sm text-gris-texte">{c.adresse} — {c.cp} {formatVilleName(c.ville || '')}</p>
                    {c.tel && <p class="text-sm text-orange mt-1">{c.tel}</p>}
                  </div>
                  {(c.plan === 'claimed' || c.plan === 'premium') && (
                    <span class="text-xs bg-green-50 text-green-700 px-2 py-1 rounded-full font-sans font-medium shrink-0">
                      Fiche vérifiée
                    </span>
                  )}
                </div>
              </a>
            ))}
          </div>
          {allCentres.length > 20 && (
            <p class="text-sm text-gris-texte mt-4 text-center">
              <a href="/trouver-audioprothesiste/" class="text-orange hover:underline">Voir tous les centres sur la carte interactive</a>
            </p>
          )}
        </div>
      )}

      <!-- FAQ -->
      <div class="mb-10">
        <h2 class="font-sans text-xl font-bold text-marine mb-4">Questions fréquentes</h2>
        {faq.map((f) => (
          <details class="bg-blanc rounded-xl mb-3 shadow-[0_1px_4px_rgba(27,46,74,0.05)] group">
            <summary class="px-6 py-5 font-sans text-[17px] font-semibold text-marine cursor-pointer list-none flex justify-between items-center">
              <span>{f.question}</span>
              <span class="text-xl transition-transform group-open:rotate-45">+</span>
            </summary>
            <div class="px-6 pb-5 text-gris-texte text-base leading-relaxed">{f.answer}</div>
          </details>
        ))}
      </div>

      <!-- LeadForm -->
      <div class="bg-blanc rounded-2xl p-8 shadow-[0_2px_12px_rgba(27,46,74,0.06)] mb-10">
        <h2 class="font-sans text-2xl font-bold text-marine mb-4">Demandez un devis gratuit {prep.dans}</h2>
        <p class="text-gris-texte mb-6">Comparez les offres de plusieurs audioprothésistes près de chez vous, en toute indépendance.</p>
        <LeadForm client:visible />
      </div>

      <!-- Maillage vers guides -->
      <div class="text-sm text-gris-texte space-y-1">
        <p>Guides connexes :</p>
        <ul class="flex flex-wrap gap-x-4 gap-y-1">
          <li><a href="/guides/audioprothesiste/choisir/" class="text-orange hover:underline">Comment choisir son audioprothésiste</a></li>
          <li><a href="/guides/remboursement/prix-appareil-auditif/" class="text-orange hover:underline">Prix des appareils auditifs</a></li>
          <li><a href="/guides/remboursement/100-sante-audition/" class="text-orange hover:underline">100 % Santé Audition</a></li>
          <li><a href="/guides/audioprothesiste/premier-rdv/" class="text-orange hover:underline">Premier rendez-vous</a></li>
        </ul>
      </div>
    </div>
  </section>
</BaseLayout>
