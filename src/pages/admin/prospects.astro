---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import { createServerClient } from '../../lib/supabase';
import { getProspects } from '../../lib/prospects';
import { getAdminNavCounts } from '../../lib/adminNav';
import AdminNav from '../../components/admin/AdminNav.astro';
import ProspectsPage from '../../components/admin/prospects/ProspectsPage.tsx';

// Protection admin (pattern admin/index.astro)
const ADMIN_EMAIL = 'franckolivier@leguideauditif.fr';
const user = Astro.locals.user;

if (!user || user.email !== ADMIN_EMAIL) {
  return Astro.redirect('/auth/login/');
}

const supabase = createServerClient();
const [prospects, navCounts] = await Promise.all([
  getProspects(supabase),
  getAdminNavCounts(supabase),
]);
---

<BaseLayout title="Prospects — Admin LGA" description="Pipeline commercial LeGuideAuditif">
  <meta slot="head" name="robots" content="noindex" />

  <AdminNav counts={navCounts} currentPath="/admin/prospects" />

  <main class="min-h-screen bg-creme">
    <section class="max-w-6xl mx-auto px-5 py-6">
      <ProspectsPage client:load initialProspects={prospects} />
    </section>
  </main>
</BaseLayout>
