---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import { createServerClient } from '../../lib/supabase';
import { getProspects } from '../../lib/prospects';
import ProspectsHeader from '../../components/admin/prospects/ProspectsHeader.astro';
import ProspectsStats from '../../components/admin/prospects/ProspectsStats.astro';
import ProspectsList from '../../components/admin/prospects/ProspectsList.tsx';
import Chip from '../../components/admin/ui/Chip.astro';
import type { ProspectStatus } from '../../types/prospect';

// Protection admin (pattern admin/index.astro)
const ADMIN_EMAIL = 'franckolivier@leguideauditif.fr';
const user = Astro.locals.user;

if (!user || user.email !== ADMIN_EMAIL) {
  return Astro.redirect('/auth/login/');
}

const supabase = createServerClient();
const prospects = await getProspects(supabase);

// Counts statiques pour les chips (Phase 4 activera l'interactivité)
const countByStatus = (s: ProspectStatus) => prospects.filter((p) => p.status === s).length;
---

<BaseLayout title="Prospects — Admin LGA" description="Pipeline commercial LeGuideAuditif">
  <meta slot="head" name="robots" content="noindex" />

  <main class="min-h-screen bg-creme">
    <section class="max-w-6xl mx-auto px-5 py-6">
      <ProspectsHeader />
      <ProspectsStats prospects={prospects} />

      {/* Filtres actifs en Phase 4 */}
      <div class="bg-blanc border border-[#E4DED3] rounded-xl p-3 mb-4 flex gap-2 flex-wrap items-center">
        <Chip label="Tous" count={prospects.length} active={true} data-filter="all" />
        <Chip label="Prospect" count={countByStatus('prospect')} data-filter="prospect" />
        <Chip label="Contacté" count={countByStatus('contacte')} data-filter="contacte" />
        <Chip label="RDV" count={countByStatus('rdv')} data-filter="rdv" />
        <Chip label="Proposition" count={countByStatus('proposition')} data-filter="proposition" />
        <Chip label="Signé" count={countByStatus('signe')} data-filter="signe" />
        <div class="w-px h-5 bg-[#E4DED3] mx-1" aria-hidden="true"></div>
        <Chip label="À faire" data-filter="todo" />
        <Chip label="Fondateur" data-filter="fondateur" />
        <input
          type="search"
          placeholder="Rechercher nom, centre, ville…"
          class="flex-1 min-w-[200px] border border-[#E4DED3] bg-creme px-3 py-2 rounded-lg text-[13px] font-sans text-marine focus:outline-2 focus:outline-orange"
          disabled
          aria-label="Recherche (activée en Phase 4)"
        />
      </div>

      <ProspectsList client:load prospects={prospects} />
    </section>
  </main>
</BaseLayout>
