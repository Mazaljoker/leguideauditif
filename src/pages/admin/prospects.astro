---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import { createServerClient } from '../../lib/supabase';
import { getProspects } from '../../lib/prospects';
import { getAdminNavCounts } from '../../lib/adminNav';
import AdminNav from '../../components/admin/AdminNav.astro';
import AdminTasksDrawerProvider from '../../components/admin/AdminTasksDrawerProvider.tsx';
import ProspectsPage from '../../components/admin/prospects/ProspectsPage.tsx';
import type { Task } from '../../types/task';

// Protection admin (pattern admin/index.astro)
const ADMIN_EMAIL = 'franckolivier@leguideauditif.fr';
const user = Astro.locals.user;

if (!user || user.email !== ADMIN_EMAIL) {
  return Astro.redirect('/auth/login/');
}

const supabase = createServerClient();
const [prospects, navCounts] = await Promise.all([
  getProspects(supabase),
  getAdminNavCounts(supabase),
]);

// Prochaine tâche open par prospect (ordre par due_at, première = plus imminente)
const prospectIds = prospects.map((p) => p.id);
const { data: nextTasksRaw } = prospectIds.length
  ? await supabase
      .from('tasks')
      .select('*')
      .eq('owner_type', 'prospect')
      .eq('status', 'open')
      .in('owner_id', prospectIds)
      .order('due_at', { ascending: true, nullsFirst: false })
  : { data: [] as Task[] };

const initialTasksByProspect: Record<string, Task> = {};
for (const t of (nextTasksRaw ?? []) as Task[]) {
  if (t.owner_id && !initialTasksByProspect[t.owner_id]) {
    initialTasksByProspect[t.owner_id] = t;
  }
}

// Search blobs : par prospect_id, concatène noms centres + téléphones liés.
// Permet la recherche côté client par "centre", "téléphone", etc.
const { data: centresForSearchRaw } = prospectIds.length
  ? await supabase
      .from('prospect_centres')
      .select('prospect_id, centre:centres_auditifs(nom, tel)')
      .in('prospect_id', prospectIds)
  : { data: [] as Array<{ prospect_id: string; centre: { nom: string | null; tel: string | null } | { nom: string | null; tel: string | null }[] | null }> };

const initialSearchBlobs: Record<string, string> = {};
for (const row of centresForSearchRaw ?? []) {
  const centre = Array.isArray(row.centre) ? row.centre[0] : row.centre;
  if (!centre) continue;
  const telDigits = centre.tel ? centre.tel.replace(/\D/g, '') : '';
  const parts = [centre.nom, centre.tel, telDigits].filter(Boolean) as string[];
  const prev = initialSearchBlobs[row.prospect_id] ?? '';
  initialSearchBlobs[row.prospect_id] = (prev + ' ' + parts.join(' ')).trim();
}
---

<BaseLayout title="Prospects — Admin LGA" description="Pipeline commercial LeGuideAuditif">
  <meta slot="head" name="robots" content="noindex" />

  <AdminNav counts={navCounts} currentPath="/admin/prospects" />

  <main class="min-h-screen bg-creme">
    <section class="max-w-6xl mx-auto px-5 py-6">
      <ProspectsPage
        client:load
        initialProspects={prospects}
        initialTasksByProspect={initialTasksByProspect}
        initialSearchBlobs={initialSearchBlobs}
      />
    </section>
  </main>

  <AdminTasksDrawerProvider
    client:load
    urgentCount={navCounts.tasksUrgent}
    currentPath="/admin/prospects"
  />
</BaseLayout>
