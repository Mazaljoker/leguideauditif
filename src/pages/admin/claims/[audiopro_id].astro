---
export const prerender = false;

import BaseLayout from '../../../layouts/BaseLayout.astro';
import { Icon } from 'astro-icon/components';
import { supabase, createServerClient } from '../../../lib/supabase';
import { getAdminNavCounts } from '../../../lib/adminNav';
import AdminNav from '../../../components/admin/AdminNav.astro';
import AdminTasksDrawerProvider from '../../../components/admin/AdminTasksDrawerProvider.tsx';
import AudioproStageBadge from '../../../components/admin/AudioproStageBadge.astro';
import EmailEventsTimeline from '../../../components/admin/EmailEventsTimeline.astro';
import LifecycleEventsTimeline from '../../../components/admin/LifecycleEventsTimeline.astro';
import RelanceEmailDropdown from '../../../components/admin/RelanceEmailDropdown.tsx';
import PromoteProspectButton from '../../../components/admin/PromoteProspectButton.tsx';
import {
  COMPLETENESS_FIELD_LABELS,
  type AudioproLifecycle,
  type AudioproLifecycleEvent,
  type EmailEvent,
  type AudioproMissingField,
} from '../../../types/audiopro-lifecycle';

// --- Auth admin (Pattern B) ---
const ADMIN_EMAIL = 'franckolivier@leguideauditif.fr';
const user = Astro.locals.user;
if (!user || user.email !== ADMIN_EMAIL) {
  return Astro.redirect('/auth/login/');
}

const { audiopro_id } = Astro.params;
if (!audiopro_id) {
  return Astro.redirect('/admin/claims');
}

const serverClient = createServerClient();

// --- Fetch audio ---
const { data: audiopro } = await serverClient
  .from('audiopro_lifecycle')
  .select('*')
  .eq('id', audiopro_id)
  .maybeSingle<AudioproLifecycle>();

if (!audiopro) {
  return Astro.redirect('/admin/claims?error=notfound');
}

// --- Fetch centres liés, missing_fields, events, emails, prospect, interactions, attributions ---
const [
  linkedCentresRes,
  missingFieldsRes,
  lifecycleEventsRes,
  emailEventsRes,
  prospectRes,
  navCounts,
] = await Promise.all([
  serverClient
    .from('audiopro_centres')
    .select(`
      centre_id,
      linked_via,
      linked_at,
      centres_auditifs (
        id, slug, nom, ville, cp, plan, claim_status,
        tel, site_web, email, a_propos, photo_url, specialites, marques,
        claimed_at, premium_since
      )
    `)
    .eq('audiopro_id', audiopro_id),
  serverClient.rpc('audiopro_missing_fields', { p_audiopro_id: audiopro_id }),
  serverClient
    .from('audiopro_lifecycle_events')
    .select('*')
    .eq('audiopro_id', audiopro_id)
    .order('occurred_at', { ascending: false }),
  serverClient
    .from('email_events')
    .select('*')
    .eq('audiopro_id', audiopro_id)
    .order('sent_at', { ascending: false }),
  audiopro.prospect_id
    ? serverClient
        .from('prospects')
        .select('*')
        .eq('id', audiopro.prospect_id)
        .maybeSingle()
    : Promise.resolve({ data: null }),
  getAdminNavCounts(supabase),
]);

type LinkedCentreRow = {
  centre_id: string;
  linked_via: string;
  linked_at: string;
  centres_auditifs: {
    id: string;
    slug: string;
    nom: string;
    ville: string | null;
    cp: string | null;
    plan: string;
    claim_status: string;
    tel: string | null;
    site_web: string | null;
    email: string | null;
    a_propos: string | null;
    photo_url: string | null;
    specialites: string[] | null;
    marques: string[] | null;
    claimed_at: string | null;
    premium_since: string | null;
  };
};

const linkedCentres: LinkedCentreRow[] = (linkedCentresRes.data ?? []) as LinkedCentreRow[];
const missing: AudioproMissingField[] = (missingFieldsRes.data ?? []) as AudioproMissingField[];
const lifecycleEvents: AudioproLifecycleEvent[] = (lifecycleEventsRes.data ?? []) as AudioproLifecycleEvent[];
const emailEvents: EmailEvent[] = (emailEventsRes.data ?? []) as EmailEvent[];
const prospect = prospectRes.data;

// Attribution : 1 requête après coup (centreIds connus)
const centreIds = linkedCentres.map((lc) => lc.centre_id);
const { data: attributionsData } = centreIds.length > 0
  ? await serverClient
      .from('claim_attributions')
      .select('*')
      .in('centre_id', centreIds)
      .order('created_at', { ascending: false })
      .limit(10)
  : { data: [] };
const attributions = (attributionsData ?? []) as Array<{
  created_at: string;
  centre_slug: string | null;
  utm_source: string | null;
  utm_medium: string | null;
  utm_campaign: string | null;
  gclid: string | null;
  fbclid: string | null;
  referrer: string | null;
  landing_page: string | null;
}>;

// Prospect interactions (si prospect lié)
const { data: interactionsData } = audiopro.prospect_id
  ? await serverClient
      .from('prospect_interactions')
      .select('id, kind, content, occurred_at')
      .eq('prospect_id', audiopro.prospect_id)
      .order('occurred_at', { ascending: false })
      .limit(20)
  : { data: [] };
const interactions = (interactionsData ?? []) as Array<{
  id: string;
  kind: string;
  content: string;
  occurred_at: string;
}>;

const fullName = [audiopro.prenom, audiopro.nom]
  .filter((s): s is string => typeof s === 'string' && s.trim().length > 0)
  .join(' ')
  .trim() || audiopro.email;
---

<BaseLayout title={`Admin — ${fullName}`} description="Fiche audio revendicateur">
  <meta slot="head" name="robots" content="noindex" />

  <AdminNav counts={navCounts} currentPath="/admin/claims" />

  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-8 space-y-6 font-sans">

    <a
      href="/admin/claims"
      class="inline-flex items-center gap-1 text-sm text-gris-texte hover:text-orange"
      style="min-height: 44px;"
    >
      <Icon name="lucide:arrow-left" class="w-4 h-4" />
      Retour aux revendications
    </a>

    {/* ─── Bloc 1 — Header (identité + badges + actions globales) ─── */}
    <header class="bg-white border border-[#E4DED3] rounded-lg p-5">
      <div class="flex items-start justify-between gap-4 flex-wrap">
        <div>
          <h1 class="text-2xl font-bold text-marine">{fullName}</h1>
          <div class="mt-1 text-sm text-gris-texte font-mono break-all">{audiopro.email}</div>
          <div class="mt-3 flex items-center gap-2 flex-wrap">
            <AudioproStageBadge stage={audiopro.lifecycle_stage} size="md" />
            <span class="text-xs text-gris-texte">
              depuis le {new Date(audiopro.stage_changed_at).toLocaleDateString('fr-FR')}
            </span>
            {audiopro.email_unsubscribed_at && (
              <span class="text-xs px-2 py-0.5 rounded bg-[#FAEEDA] text-[#854F0B] font-medium">
                Désabonné
              </span>
            )}
            {audiopro.hard_bounced_at && (
              <span class="text-xs px-2 py-0.5 rounded bg-[#FCEBEB] text-[#A32D2D] font-medium">
                Bounce permanent
              </span>
            )}
          </div>
        </div>
        <div class="flex gap-2 flex-wrap">
          <RelanceEmailDropdown
            client:load
            audioproId={audiopro.id}
            audioproEmail={audiopro.email}
            isUnsubscribed={!!audiopro.email_unsubscribed_at}
          />
          {!audiopro.prospect_id && (
            <PromoteProspectButton
              client:load
              audioproId={audiopro.id}
              audioproName={fullName}
            />
          )}
        </div>
      </div>

      <dl class="grid grid-cols-2 lg:grid-cols-4 gap-4 mt-5 text-sm">
        <div>
          <dt class="text-xs text-gris-texte">ADELI</dt>
          <dd class="text-marine font-medium">{audiopro.adeli ?? '—'}</dd>
        </div>
        <div>
          <dt class="text-xs text-gris-texte">RPPS</dt>
          <dd class="text-marine font-medium">{audiopro.rpps ?? '—'}</dd>
        </div>
        <div>
          <dt class="text-xs text-gris-texte">1re revendication</dt>
          <dd class="text-marine">
            {audiopro.first_claim_at
              ? new Date(audiopro.first_claim_at).toLocaleDateString('fr-FR')
              : '—'}
          </dd>
        </div>
        <div>
          <dt class="text-xs text-gris-texte">Dernière connexion</dt>
          <dd class="text-marine">
            {audiopro.last_login_at
              ? new Date(audiopro.last_login_at).toLocaleDateString('fr-FR')
              : '—'}
          </dd>
        </div>
      </dl>
    </header>

    {/* ─── Bloc 2 — Centres liés avec actions par-centre ─── */}
    <section class="bg-white border border-[#E4DED3] rounded-lg p-5">
      <h2 class="text-lg font-bold text-marine mb-4">
        Centres liés ({linkedCentres.length})
      </h2>
      {linkedCentres.length === 0 ? (
        <p class="text-sm text-gris-texte italic">Aucun centre lié.</p>
      ) : (
        <div class="space-y-4">
          {linkedCentres.map((lc) => {
            const c = lc.centres_auditifs;
            const mf = missing.find((m) => m.centre_id === c.id);
            return (
              <div class="border border-[#E4DED3] rounded p-4" id={`centre-${c.slug}`}>
                <div class="flex items-start justify-between gap-3 flex-wrap mb-3">
                  <div>
                    <a
                      href={`/centre/${c.slug}/`}
                      target="_blank"
                      rel="noopener"
                      class="font-medium text-marine hover:text-orange"
                    >
                      {c.nom}
                    </a>
                    <div class="text-xs text-gris-texte">
                      {c.ville ?? ''} {c.cp ?? ''}
                    </div>
                    <div class="text-xs mt-1 flex items-center gap-2">
                      <span class="px-2 py-0.5 rounded bg-[#F8F5F0] text-marine font-medium">
                        plan: {c.plan}
                      </span>
                      <span class={
                        c.claim_status === 'approved'
                          ? 'px-2 py-0.5 rounded bg-[#E1F5EE] text-[#0F6E56] font-medium'
                          : c.claim_status === 'pending'
                            ? 'px-2 py-0.5 rounded bg-[#FAEEDA] text-[#854F0B] font-medium'
                            : c.claim_status === 'rejected'
                              ? 'px-2 py-0.5 rounded bg-[#FCEBEB] text-[#A32D2D] font-medium'
                              : 'px-2 py-0.5 rounded bg-[#F8F5F0] text-gris-texte'
                      }>
                        {c.claim_status}
                      </span>
                    </div>
                  </div>
                  <div class="text-right">
                    <div class="text-lg font-bold text-marine">
                      {mf?.completeness_pct ?? 0}%
                    </div>
                    <div class="text-xs text-gris-texte">complétude</div>
                  </div>
                </div>

                {mf && mf.missing_fields.length > 0 && (
                  <div class="mb-3 text-xs text-gris-texte">
                    <strong>Il manque :</strong>{' '}
                    {mf.missing_fields.map((f) => COMPLETENESS_FIELD_LABELS[f]).join(', ')}
                  </div>
                )}

                {/* Toolbar actions par centre — préserve le workflow legacy */}
                <div class="flex flex-wrap items-center gap-2 pt-3 border-t border-[#E4DED3]">
                  {c.claim_status === 'pending' && (
                    <>
                      <button
                        type="button"
                        class="centre-action rounded bg-[#0F6E56] px-4 py-2 text-sm font-medium text-white hover:bg-[#0A5843]"
                        style="min-height: 44px;"
                        data-action="approve"
                        data-slug={c.slug}
                      >
                        Approuver
                      </button>
                      <button
                        type="button"
                        class="centre-action rounded bg-white border border-[#A32D2D] px-4 py-2 text-sm font-medium text-[#A32D2D] hover:bg-[#FCEBEB]"
                        style="min-height: 44px;"
                        data-action="reject"
                        data-slug={c.slug}
                      >
                        Rejeter
                      </button>
                    </>
                  )}
                  {c.claim_status === 'approved' && c.plan !== 'premium' && (
                    <>
                      <button
                        type="button"
                        class="centre-premium rounded bg-orange px-3 py-1.5 text-xs font-medium text-white hover:opacity-90"
                        style="min-height: 44px;"
                        data-slug={c.slug}
                      >
                        Offrir Premium
                      </button>
                      <button
                        type="button"
                        class="centre-revoke text-xs font-medium text-[#A32D2D] hover:underline px-2 py-1"
                        style="min-height: 44px;"
                        data-slug={c.slug}
                      >
                        Revoquer
                      </button>
                    </>
                  )}
                  {c.plan === 'premium' && (
                    <span class="text-xs text-[#0F6E56] font-medium">Premium actif</span>
                  )}
                  <a
                    href={`/centre/${c.slug}/`}
                    target="_blank"
                    rel="noopener"
                    class="text-xs text-orange font-medium hover:underline ml-auto"
                    style="min-height: 44px; display: inline-flex; align-items: center;"
                  >
                    Voir la fiche publique
                  </a>
                </div>

                <div id={`premium-link-${c.slug}`} class="hidden mt-3">
                  <div class="flex gap-2">
                    <input
                      type="text"
                      readonly
                      class="flex-1 rounded border border-[#E4DED3] px-2 py-1 text-xs font-mono bg-[#F8F5F0]"
                    />
                    <button
                      type="button"
                      class="copy-premium-link rounded px-3 py-1 text-xs bg-marine text-white hover:opacity-90"
                      style="min-height: 44px;"
                    >
                      Copier
                    </button>
                  </div>
                  <p class="text-[10px] text-gris-texte mt-1">
                    Envoyer au client — 1 clic = Premium activé.
                  </p>
                </div>
              </div>
            );
          })}
        </div>
      )}
    </section>

    {/* ─── Bloc 3 — Prospect CRM (si lié) ─── */}
    {prospect && (
      <section class="bg-white border border-[#E4DED3] rounded-lg p-5">
        <div class="flex items-start justify-between flex-wrap gap-3 mb-4">
          <h2 class="text-lg font-bold text-marine">Prospect CRM</h2>
          <a
            href={`/admin/prospects/${prospect.id}`}
            class="inline-flex items-center gap-1 text-sm text-orange hover:underline"
          >
            Voir la fiche prospect
            <Icon name="lucide:arrow-right" class="w-3 h-3" />
          </a>
        </div>
        <dl class="grid grid-cols-2 lg:grid-cols-4 gap-4 text-sm mb-4">
          <div>
            <dt class="text-xs text-gris-texte">Statut</dt>
            <dd class="font-medium text-marine">{prospect.status}</dd>
          </div>
          <div>
            <dt class="text-xs text-gris-texte">Next action</dt>
            <dd class="text-marine">{prospect.next_action ?? '—'}</dd>
          </div>
          <div>
            <dt class="text-xs text-gris-texte">MRR potentiel</dt>
            <dd class="text-marine">
              {prospect.mrr_potentiel ? `${prospect.mrr_potentiel} €` : '—'}
            </dd>
          </div>
          <div>
            <dt class="text-xs text-gris-texte">Fondateur</dt>
            <dd class="text-marine">{prospect.is_fondateur ? 'Oui' : 'Non'}</dd>
          </div>
        </dl>
        {interactions.length > 0 && (
          <div class="border-t border-[#E4DED3] pt-3">
            <h3 class="text-sm font-semibold text-marine mb-2">
              Dernières interactions ({interactions.length})
            </h3>
            <ol class="space-y-2">
              {interactions.slice(0, 5).map((i) => (
                <li class="text-xs border-l-2 border-[#E4DED3] pl-3">
                  <div class="text-gris-texte">
                    {new Date(i.occurred_at).toLocaleString('fr-FR', { day: '2-digit', month: '2-digit', year: 'numeric', hour: '2-digit', minute: '2-digit' })}
                    {' · '}
                    <span class="font-medium">{i.kind}</span>
                  </div>
                  <div class="text-marine mt-0.5">{i.content}</div>
                </li>
              ))}
            </ol>
          </div>
        )}
      </section>
    )}

    {/* ─── Bloc 4 — Timeline emails ─── */}
    <section class="bg-white border border-[#E4DED3] rounded-lg p-5">
      <h2 class="text-lg font-bold text-marine mb-3">
        Historique emails ({emailEvents.length})
      </h2>
      <EmailEventsTimeline events={emailEvents} />
    </section>

    {/* ─── Bloc 5 — Timeline lifecycle ─── */}
    <section class="bg-white border border-[#E4DED3] rounded-lg p-5">
      <h2 class="text-lg font-bold text-marine mb-3">
        Historique lifecycle ({lifecycleEvents.length})
      </h2>
      <LifecycleEventsTimeline events={lifecycleEvents} />
    </section>

    {/* ─── Bloc 6 — Attribution (moins utile au quotidien, en bas) ─── */}
    <details class="bg-white border border-[#E4DED3] rounded-lg overflow-hidden">
      <summary class="px-5 py-4 cursor-pointer hover:bg-[#FDFBF7] font-medium text-marine">
        Attribution ({attributions.length})
      </summary>
      <div class="px-5 pb-5 pt-2 border-t border-[#E4DED3]">
        {attributions.length === 0 ? (
          <p class="text-sm text-gris-texte italic">Aucune attribution tracée.</p>
        ) : (
          <div class="space-y-3">
            {attributions.map((a) => (
              <div class="border-b border-[#F0EAE0] pb-2 last:border-b-0 text-xs">
                <div class="text-gris-texte">
                  {new Date(a.created_at).toLocaleDateString('fr-FR')}
                  {a.centre_slug && (<> · <span class="text-marine">{a.centre_slug}</span></>)}
                </div>
                {a.utm_source && (
                  <div class="text-marine">
                    UTM : {a.utm_source} / {a.utm_medium ?? '—'} / {a.utm_campaign ?? '—'}
                  </div>
                )}
                {a.gclid && <div class="text-marine">GClid : oui</div>}
                {a.fbclid && <div class="text-marine">FBClid : oui</div>}
                {a.referrer && (
                  <div class="text-gris-texte truncate">Referrer : {a.referrer}</div>
                )}
                {a.landing_page && (
                  <div class="text-gris-texte truncate">Landing : {a.landing_page}</div>
                )}
              </div>
            ))}
          </div>
        )}
      </div>
    </details>
  </section>

  <script>
    // --- Approve/Reject pending pour chaque centre ---
    document.querySelectorAll<HTMLButtonElement>('.centre-action').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const action = btn.getAttribute('data-action');
        const slug = btn.getAttribute('data-slug');
        const endpoint = action === 'approve' ? '/api/admin/approve-claim' : '/api/admin/reject-claim';

        btn.textContent = 'En cours...';
        btn.setAttribute('disabled', 'true');

        try {
          const res = await fetch(endpoint, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ centreSlug: slug }),
          });
          const data = await res.json();
          if (!res.ok) throw new Error(data.error ?? 'Erreur');
          window.location.reload();
        } catch (err) {
          alert(err instanceof Error ? err.message : 'Erreur');
          btn.textContent = action === 'approve' ? 'Approuver' : 'Rejeter';
          btn.removeAttribute('disabled');
        }
      });
    });

    // --- Offrir Premium ---
    document.querySelectorAll<HTMLButtonElement>('.centre-premium').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const slug = btn.getAttribute('data-slug');
        if (!slug) return;
        btn.textContent = 'Génération...';
        btn.setAttribute('disabled', 'true');

        try {
          const res = await fetch('/api/admin/generate-premium-link', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ centreSlug: slug }),
          });
          const data = await res.json();
          if (!res.ok) throw new Error(data.error ?? 'Erreur');

          const container = document.getElementById('premium-link-' + slug);
          if (container) {
            const input = container.querySelector<HTMLInputElement>('input');
            if (input) input.value = data.link;
            container.classList.remove('hidden');
          }
          btn.textContent = 'Lien généré';
        } catch (err) {
          alert(err instanceof Error ? err.message : 'Erreur');
          btn.textContent = 'Offrir Premium';
          btn.removeAttribute('disabled');
        }
      });
    });

    // --- Copier lien premium ---
    document.querySelectorAll<HTMLButtonElement>('.copy-premium-link').forEach((btn) => {
      btn.addEventListener('click', () => {
        const input = btn.parentElement?.querySelector<HTMLInputElement>('input');
        if (input && input.value) {
          navigator.clipboard.writeText(input.value);
          const orig = btn.textContent;
          btn.textContent = 'Copié';
          setTimeout(() => { btn.textContent = orig ?? 'Copier'; }, 2000);
        }
      });
    });

    // --- Revoquer un claim approuve ---
    document.querySelectorAll<HTMLButtonElement>('.centre-revoke').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const slug = btn.getAttribute('data-slug');
        if (!slug) return;
        if (!confirm('Revoquer cette revendication ? Le centre repassera en mode ghost.')) return;

        btn.textContent = 'En cours...';
        btn.setAttribute('disabled', 'true');

        try {
          const res = await fetch('/api/admin/reject-claim', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ centreSlug: slug }),
          });
          const data = await res.json();
          if (!res.ok) throw new Error(data.error ?? 'Erreur');
          window.location.reload();
        } catch (err) {
          alert(err instanceof Error ? err.message : 'Erreur');
          btn.textContent = 'Revoquer';
          btn.removeAttribute('disabled');
        }
      });
    });
  </script>

  <AdminTasksDrawerProvider
    client:load
    urgentCount={navCounts.tasksUrgent}
    currentPath="/admin/claims"
  />
</BaseLayout>
