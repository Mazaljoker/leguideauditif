---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import AdminNav from '../../components/admin/AdminNav.astro';
import AdminTasksDrawerProvider from '../../components/admin/AdminTasksDrawerProvider.tsx';
import { createServerClient } from '../../lib/supabase';
import { getAdminNavCounts } from '../../lib/adminNav';
import { fetchInitialTasks } from '../../lib/tasks';
import TasksPage from '../../components/admin/tasks/TasksPage.tsx';

const ADMIN_EMAIL = 'franckolivier@leguideauditif.fr';
const user = Astro.locals.user;

if (!user || user.email !== ADMIN_EMAIL) {
  return Astro.redirect('/auth/login/');
}

const supabase = createServerClient();
const [navCounts, initialTasks] = await Promise.all([
  getAdminNavCounts(supabase),
  fetchInitialTasks(supabase),
]);
---

<BaseLayout title="Tâches — Admin LGA" description="Task manager admin">
  <meta slot="head" name="robots" content="noindex" />

  <AdminNav counts={navCounts} currentPath="/admin/tasks" />

  <main class="min-h-screen bg-creme">
    <section class="max-w-6xl mx-auto px-5 py-6">
      <TasksPage client:load initialTasks={initialTasks} />
    </section>
  </main>

  <AdminTasksDrawerProvider
    client:load
    urgentCount={navCounts.tasksUrgent}
    currentPath="/admin/tasks"
  />
</BaseLayout>
