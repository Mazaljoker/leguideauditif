---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import { Icon } from 'astro-icon/components';
import { supabase } from '../../lib/supabase';

// Protection par token dans l'URL
const token = Astro.url.searchParams.get('token');
const adminSecret = import.meta.env.ADMIN_SECRET || process.env.ADMIN_SECRET;

if (!adminSecret || token !== adminSecret) {
  return Astro.redirect('/');
}

// Recuperer les claims en attente
const { data: pendingClaims } = await supabase
  .from('centres_auditifs')
  .select('slug, nom, adresse, cp, ville, claimed_by_name, claimed_by_email, claimed_by_adeli, claimed_at, tel, horaires, specialites, marques, a_propos, photo_url')
  .eq('claim_status', 'pending')
  .order('claimed_at', { ascending: false });

// Recuperer les claims recemment traites
const { data: recentClaims } = await supabase
  .from('centres_auditifs')
  .select('slug, nom, claimed_by_name, claim_status, claimed_at')
  .in('claim_status', ['approved', 'rejected'])
  .order('claimed_at', { ascending: false })
  .limit(10);
---

<BaseLayout title="Admin — Claims en attente" description="Administration des revendications">
  <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

    <h1 class="font-sans text-2xl font-bold text-marine mb-2">Revendications en attente</h1>
    <p class="text-sm text-gris-texte font-sans mb-8">{pendingClaims?.length || 0} demande(s) a verifier</p>

    {(!pendingClaims || pendingClaims.length === 0) ? (
      <div class="rounded-xl bg-[#E1F5EE] p-6 text-center">
        <Icon name="lucide:check-circle" class="w-8 h-8 text-[#0F6E56] mx-auto mb-2" />
        <p class="text-sm font-medium text-[#04342C] font-sans">Aucune demande en attente</p>
      </div>
    ) : (
      <div class="space-y-4 mb-12">
        {pendingClaims.map((claim) => (
          <div class="rounded-xl border border-gris-clair bg-blanc p-6" id={`claim-${claim.slug}`}>
            <div class="flex flex-wrap items-start justify-between gap-4 mb-4">
              <div>
                <h2 class="font-sans text-lg font-bold text-marine">{claim.nom}</h2>
                <p class="text-sm text-gris-texte font-sans">{claim.adresse}, {claim.cp} {claim.ville}</p>
                <a href={`/centre/${claim.slug}/`} class="text-xs text-orange font-sans hover:underline" target="_blank">
                  Voir la fiche
                </a>
              </div>
              <span class="rounded-full bg-[#FAEEDA] px-3 py-1 text-xs font-medium text-[#854F0B] font-sans">
                En attente
              </span>
            </div>

            <div class="grid gap-3 sm:grid-cols-2 text-sm font-sans mb-4">
              <div>
                <span class="text-gris-texte">Demandeur :</span>
                <span class="text-marine font-medium ml-1">{claim.claimed_by_name}</span>
              </div>
              <div>
                <span class="text-gris-texte">Email :</span>
                <span class="text-marine font-medium ml-1">{claim.claimed_by_email}</span>
              </div>
              <div>
                <span class="text-gris-texte">ADELI/SIRET :</span>
                <span class="text-marine font-medium ml-1">{claim.claimed_by_adeli}</span>
              </div>
              <div>
                <span class="text-gris-texte">Date :</span>
                <span class="text-marine font-medium ml-1">
                  {claim.claimed_at ? new Date(claim.claimed_at).toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric', hour: '2-digit', minute: '2-digit' }) : '—'}
                </span>
              </div>
              {claim.tel && (
                <div>
                  <span class="text-gris-texte">Telephone :</span>
                  <span class="text-marine font-medium ml-1">{claim.tel}</span>
                </div>
              )}
              {claim.horaires && (
                <div>
                  <span class="text-gris-texte">Horaires :</span>
                  <span class="text-marine font-medium ml-1">{claim.horaires}</span>
                </div>
              )}
            </div>

            {claim.specialites && claim.specialites.length > 0 && (
              <div class="mb-3">
                <span class="text-xs text-gris-texte font-sans">Specialites : </span>
                {claim.specialites.map((s: string) => (
                  <span class="inline-block rounded-full bg-[#E6F1FB] px-2 py-0.5 text-xs text-[#0C447C] font-sans mr-1">{s}</span>
                ))}
              </div>
            )}

            {claim.marques && claim.marques.length > 0 && (
              <div class="mb-3">
                <span class="text-xs text-gris-texte font-sans">Marques : </span>
                {claim.marques.map((m: string) => (
                  <span class="inline-block rounded-full bg-[#F8F5F0] px-2 py-0.5 text-xs text-marine font-sans mr-1">{m}</span>
                ))}
              </div>
            )}

            {claim.a_propos && (
              <div class="mb-3">
                <span class="text-xs text-gris-texte font-sans">Description : </span>
                <p class="text-sm text-marine font-sans mt-1">{claim.a_propos}</p>
              </div>
            )}

            {claim.photo_url && (
              <div class="mb-4">
                <img src={claim.photo_url} alt="Photo du centre" class="w-32 h-24 rounded-lg object-cover" />
              </div>
            )}

            <div class="flex gap-3 pt-4 border-t border-gris-clair">
              <button
                type="button"
                class="admin-action rounded-lg bg-[#0F6E56] px-5 py-2.5 text-sm font-medium text-blanc font-sans hover:bg-[#0A5843] transition-colors cursor-pointer"
                style="min-height: 44px;"
                data-action="approve"
                data-slug={claim.slug}
              >
                Approuver
              </button>
              <button
                type="button"
                class="admin-action rounded-lg bg-blanc border border-[#A32D2D] px-5 py-2.5 text-sm font-medium text-[#A32D2D] font-sans hover:bg-[#FCEBEB] transition-colors cursor-pointer"
                style="min-height: 44px;"
                data-action="reject"
                data-slug={claim.slug}
              >
                Rejeter
              </button>
            </div>
          </div>
        ))}
      </div>
    )}

    {recentClaims && recentClaims.length > 0 && (
      <>
        <h2 class="font-sans text-lg font-bold text-marine mb-4">Recemment traites</h2>
        <div class="rounded-xl border border-gris-clair bg-blanc overflow-hidden">
          <table class="w-full text-sm font-sans">
            <thead class="bg-creme">
              <tr>
                <th class="text-left px-4 py-3 text-gris-texte font-medium">Centre</th>
                <th class="text-left px-4 py-3 text-gris-texte font-medium">Demandeur</th>
                <th class="text-left px-4 py-3 text-gris-texte font-medium">Statut</th>
              </tr>
            </thead>
            <tbody>
              {recentClaims.map((c) => (
                <tr class="border-t border-gris-clair">
                  <td class="px-4 py-3 text-marine">{c.nom}</td>
                  <td class="px-4 py-3 text-gris-texte">{c.claimed_by_name || '—'}</td>
                  <td class="px-4 py-3">
                    {c.claim_status === 'approved' ? (
                      <span class="rounded-full bg-[#E1F5EE] px-2 py-0.5 text-xs font-medium text-[#0F6E56]">Approuve</span>
                    ) : (
                      <span class="rounded-full bg-[#FCEBEB] px-2 py-0.5 text-xs font-medium text-[#A32D2D]">Rejete</span>
                    )}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </>
    )}
  </section>

  <script define:vars={{ adminSecret }}>
    document.querySelectorAll('.admin-action').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const action = btn.getAttribute('data-action');
        const slug = btn.getAttribute('data-slug');
        const endpoint = action === 'approve' ? '/api/admin/approve-claim' : '/api/admin/reject-claim';

        btn.textContent = 'En cours...';
        btn.setAttribute('disabled', 'true');

        try {
          const res = await fetch(endpoint, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ centreSlug: slug, token: adminSecret }),
          });

          const data = await res.json();
          if (!res.ok) throw new Error(data.error);

          const card = document.getElementById(`claim-${slug}`);
          if (card) {
            card.style.opacity = '0.5';
            card.innerHTML = `<p class="text-sm font-medium font-sans text-center py-4">${action === 'approve' ? 'Approuve' : 'Rejete'} avec succes</p>`;
          }
        } catch (err) {
          alert(err instanceof Error ? err.message : 'Erreur');
          btn.textContent = action === 'approve' ? 'Approuver' : 'Rejeter';
          btn.removeAttribute('disabled');
        }
      });
    });
  </script>
</BaseLayout>
