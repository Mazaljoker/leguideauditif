---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import { Icon } from 'astro-icon/components';
import { supabase, createServerClient } from '../../lib/supabase';
import { getAdminNavCounts } from '../../lib/adminNav';
import AdminNav from '../../components/admin/AdminNav.astro';
import AdminTasksDrawerProvider from '../../components/admin/AdminTasksDrawerProvider.tsx';
import AudioproStageBadge from '../../components/admin/AudioproStageBadge.astro';
import AudioproListFilters from '../../components/admin/AudioproListFilters.tsx';
import RelanceEmailDropdown from '../../components/admin/RelanceEmailDropdown.tsx';
import { getAudioproList } from '../../lib/audiopro-lifecycle';
import {
  EMAIL_TEMPLATE_LABELS,
  LIFECYCLE_STAGES,
  LIFECYCLE_STAGE_LABELS,
  type LifecycleStage,
  type AudioproListRow,
} from '../../types/audiopro-lifecycle';
import { requireAdmin } from '../../lib/admin-guard';

// Auth admin — pattern partagé (preserve redirect + distinction need-login/need-admin)
const guard = requireAdmin(Astro);
if (guard) return guard;

// --- Parse query params ---
const url = Astro.url;
const stageParam = url.searchParams.getAll('stage') as LifecycleStage[];
const validStages = stageParam.filter((s): s is LifecycleStage =>
  (LIFECYCLE_STAGES as readonly string[]).includes(s),
);
const hasProspectParam = url.searchParams.get('has_prospect');
const hasProspect: boolean | null =
  hasProspectParam === 'true' ? true : hasProspectParam === 'false' ? false : null;
const compMin = Math.max(0, Math.min(100, Number(url.searchParams.get('comp_min') ?? 0) || 0));
const compMax = Math.max(compMin, Math.min(100, Number(url.searchParams.get('comp_max') ?? 100) || 100));
const search = (url.searchParams.get('q') ?? '').trim();

// --- Fetch ---
// createServerClient pour lire les tables Phase 1 (RLS bloque anon).
// supabase (anon) reste pour les reads publics (adminNav counts + centres).
const serverClient = createServerClient();

const [rows, navCounts, stageDistributionRes, bouncedRes] = await Promise.all([
  getAudioproList(serverClient, {
    stage_filter: validStages.length > 0 ? validStages : undefined,
    has_prospect: hasProspect,
    completeness_range: [compMin, compMax],
    search: search || undefined,
    limit: 200,
  }),
  getAdminNavCounts(supabase),
  serverClient
    .from('audiopro_lifecycle')
    .select('lifecycle_stage'),
  serverClient
    .from('audiopro_lifecycle')
    .select('id', { count: 'exact', head: true })
    .not('hard_bounced_at', 'is', null),
]);

// Distribution par stage pour la barre stats en haut
const statsByStage: Record<LifecycleStage, number> = {
  revendique: 0, approuve: 0, active: 0, engage: 0, premium: 0, churned: 0,
};
for (const r of stageDistributionRes.data ?? []) {
  const s = r.lifecycle_stage as LifecycleStage;
  if (s in statsByStage) statsByStage[s]++;
}

const hardBouncedCount = bouncedRes.count ?? 0;
const listRows = rows as AudioproListRow[];
---

<BaseLayout title="Admin — Revendications" description="Pipeline email revendicateurs">
  <meta slot="head" name="robots" content="noindex" />

  <AdminNav counts={navCounts} currentPath="/admin/claims" />

  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 space-y-6 font-sans">

    <header class="flex items-start justify-between gap-4 flex-wrap">
      <div>
        <h1 class="text-2xl font-bold text-marine">Revendications</h1>
        <p class="text-sm text-gris-texte mt-1">Vue audio-centric du pipeline lifecycle</p>
      </div>
      <div class="flex gap-2 flex-wrap">
        {LIFECYCLE_STAGES.map((stage) => (
          <span class="inline-flex items-center gap-1 px-3 py-1 rounded-full bg-[#F8F5F0] text-xs">
            <strong class="text-marine">{statsByStage[stage]}</strong>
            <span class="text-gris-texte">{LIFECYCLE_STAGE_LABELS[stage]}</span>
          </span>
        ))}
      </div>
    </header>

    {hardBouncedCount > 0 && (
      <div class="bg-[#FCEBEB] border-l-4 border-[#A32D2D] p-3 text-sm text-[#A32D2D]">
        <strong>{hardBouncedCount} email(s) en bounce permanent.</strong> Ces audios ne reçoivent plus de relance automatique.
      </div>
    )}

    <AudioproListFilters
      client:load
      initialStageFilter={validStages}
      initialHasProspect={hasProspect}
      initialCompletenessMin={compMin}
      initialCompletenessMax={compMax}
      initialSearch={search}
    />

    <div class="overflow-x-auto rounded-lg border border-[#E4DED3] bg-white">
      <table class="w-full text-sm">
        <thead class="bg-[#F8F5F0] text-left text-xs uppercase text-gris-texte">
          <tr>
            <th class="px-4 py-3">Date claim</th>
            <th class="px-4 py-3">Audio</th>
            <th class="px-4 py-3">Email</th>
            <th class="px-4 py-3 text-center">Centres</th>
            <th class="px-4 py-3">Statuts claims</th>
            <th class="px-4 py-3">Lifecycle</th>
            <th class="px-4 py-3 text-center">Complétude</th>
            <th class="px-4 py-3">Dernier email</th>
            <th class="px-4 py-3 text-center">30j</th>
            <th class="px-4 py-3">Prospect</th>
            <th class="px-4 py-3 text-right">Actions</th>
          </tr>
        </thead>
        <tbody>
          {listRows.length === 0 ? (
            <tr>
              <td colspan="11" class="px-4 py-8 text-center text-gris-texte italic">
                Aucun audio ne correspond à ces filtres.
              </td>
            </tr>
          ) : (
            listRows.map((row) => {
              const fullName = [row.prenom, row.nom].filter(Boolean).join(' ').trim() || '(sans nom)';
              return (
                <tr class="border-t border-[#F0EAE0] hover:bg-[#FDFBF7]">
                  <td class="px-4 py-3 whitespace-nowrap text-xs text-gris-texte">
                    {row.first_claim_at
                      ? new Date(row.first_claim_at).toLocaleDateString('fr-FR')
                      : '—'}
                  </td>
                  <td class="px-4 py-3">
                    <a
                      href={`/admin/claims/${row.audiopro_id}/`}
                      class="font-medium text-marine hover:text-orange"
                    >
                      {fullName}
                    </a>
                  </td>
                  <td class="px-4 py-3 text-xs text-gris-texte break-all">{row.email}</td>
                  <td class="px-4 py-3 text-center font-semibold text-marine">{row.nb_centres}</td>
                  <td class="px-4 py-3 text-xs text-gris-texte">
                    {row.claim_status_summary ?? '—'}
                  </td>
                  <td class="px-4 py-3">
                    <AudioproStageBadge stage={row.lifecycle_stage} />
                  </td>
                  <td class="px-4 py-3">
                    <div class="inline-flex items-center gap-2">
                      <div class="w-16 bg-[#F0EAE0] rounded-full h-2 overflow-hidden">
                        <div
                          class="h-full bg-orange rounded-full"
                          style={`width: ${row.completeness_avg}%`}
                        />
                      </div>
                      <span class="text-xs font-semibold text-marine">{row.completeness_avg}%</span>
                    </div>
                  </td>
                  <td class="px-4 py-3 text-xs text-gris-texte">
                    {row.last_email_template ? (
                      <div>
                        <div class="font-medium text-marine truncate max-w-[180px]">
                          {EMAIL_TEMPLATE_LABELS[row.last_email_template] ?? row.last_email_template}
                        </div>
                        <div>
                          {row.last_email_sent_at
                            ? new Date(row.last_email_sent_at).toLocaleDateString('fr-FR')
                            : '—'}
                        </div>
                        {row.last_email_clicked_at && (
                          <div class="text-[#0F6E56] font-medium">Cliqué</div>
                        )}
                      </div>
                    ) : '—'}
                  </td>
                  <td class="px-4 py-3 text-center text-marine">{row.emails_sent_30d}</td>
                  <td class="px-4 py-3">
                    {row.prospect_id ? (
                      <a
                        href={`/admin/prospects/${row.prospect_id}`}
                        class="inline-flex px-2 py-1 text-xs rounded bg-[#D97B3D] bg-opacity-10 text-orange font-medium hover:underline"
                      >
                        {row.prospect_status ?? 'Prospect'}
                      </a>
                    ) : (
                      <span class="text-xs text-gris-texte">—</span>
                    )}
                  </td>
                  <td class="px-4 py-3 text-right">
                    <div class="flex justify-end gap-1 items-center">
                      <a
                        href={`/admin/claims/${row.audiopro_id}/`}
                        class="p-2 rounded hover:bg-[#F8F5F0]"
                        aria-label={`Voir la fiche de ${fullName}`}
                        style="min-height: 44px; min-width: 44px; display: inline-flex; align-items: center; justify-content: center;"
                      >
                        <Icon name="lucide:eye" class="w-4 h-4 text-marine" />
                      </a>
                      <RelanceEmailDropdown
                        client:load
                        audioproId={row.audiopro_id}
                        audioproEmail={row.email}
                        isUnsubscribed={!!row.email_unsubscribed_at}
                      />
                    </div>
                  </td>
                </tr>
              );
            })
          )}
        </tbody>
      </table>
    </div>

    <p class="text-xs text-gris-texte">
      {listRows.length} audio(s) affiché(s). Limite 200 — affinez les filtres si la liste est tronquée.
    </p>
  </section>

  <AdminTasksDrawerProvider
    client:load
    urgentCount={navCounts.tasksUrgent}
    currentPath="/admin/claims"
  />
</BaseLayout>
