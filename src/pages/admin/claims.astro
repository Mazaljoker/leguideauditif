---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import { Icon } from 'astro-icon/components';
import { supabase } from '../../lib/supabase';
import { getAdminNavCounts } from '../../lib/adminNav';
import AdminNav from '../../components/admin/AdminNav.astro';
import AdminTasksDrawerProvider from '../../components/admin/AdminTasksDrawerProvider.tsx';

// Protection par session admin
const ADMIN_EMAIL = 'franckolivier@leguideauditif.fr';
const user = Astro.locals.user;

if (!user || user.email !== ADMIN_EMAIL) {
  return Astro.redirect('/auth/login/');
}

// Recuperer les claims + counts nav en parallele
const [pendingRes, recentRes, navCounts] = await Promise.all([
  supabase
    .from('centres_auditifs')
    .select('slug, nom, adresse, cp, ville, claimed_by_name, claimed_by_email, claimed_by_adeli, claimed_at, tel, site_web, horaires, specialites, marques, a_propos, photo_url')
    .eq('claim_status', 'pending')
    .order('claimed_at', { ascending: false }),
  supabase
    .from('centres_auditifs')
    .select('slug, nom, cp, ville, claimed_by_name, claimed_by_email, claimed_by_adeli, claim_status, claimed_at, plan, tel, site_web, horaires, specialites, marques, a_propos, photo_url')
    .in('claim_status', ['approved', 'rejected'])
    .order('claimed_at', { ascending: false })
    .limit(20),
  getAdminNavCounts(supabase),
]);

const pendingClaims = pendingRes.data;
const recentClaims = recentRes.data;
---

<BaseLayout title="Admin — Claims en attente" description="Administration des revendications">
  <meta slot="head" name="robots" content="noindex" />

  <AdminNav counts={navCounts} currentPath="/admin/claims" />

  <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

    <h1 class="font-sans text-2xl font-bold text-marine mb-2">Revendications en attente</h1>
    <p class="text-sm text-gris-texte font-sans mb-8">{pendingClaims?.length || 0} demande(s) a verifier</p>

    {(!pendingClaims || pendingClaims.length === 0) ? (
      <div class="rounded-xl bg-[#E1F5EE] p-6 text-center">
        <Icon name="lucide:check-circle" class="w-8 h-8 text-[#0F6E56] mx-auto mb-2" />
        <p class="text-sm font-medium text-[#04342C] font-sans">Aucune demande en attente</p>
      </div>
    ) : (
      <div class="space-y-4 mb-12">
        {pendingClaims.map((claim) => (
          <div class="rounded-xl border border-gris-clair bg-blanc p-6" id={`claim-${claim.slug}`}>
            <div class="flex flex-wrap items-start justify-between gap-4 mb-4">
              <div>
                <h2 class="font-sans text-lg font-bold text-marine">{claim.nom}</h2>
                <p class="text-sm text-gris-texte font-sans">{claim.adresse}, {claim.cp} {claim.ville}</p>
                <a href={`/centre/${claim.slug}/`} class="text-xs text-orange font-sans hover:underline" target="_blank">
                  Voir la fiche
                </a>
              </div>
              <span class="rounded-full bg-[#FAEEDA] px-3 py-1 text-xs font-medium text-[#854F0B] font-sans">
                En attente
              </span>
            </div>

            <div class="grid gap-3 sm:grid-cols-2 text-sm font-sans mb-4">
              <div>
                <span class="text-gris-texte">Demandeur :</span>
                <span class="text-marine font-medium ml-1">{claim.claimed_by_name}</span>
              </div>
              <div>
                <span class="text-gris-texte">Email :</span>
                <span class="text-marine font-medium ml-1">{claim.claimed_by_email}</span>
              </div>
              <div>
                <span class="text-gris-texte">ADELI/SIRET :</span>
                <span class="text-marine font-medium ml-1">{claim.claimed_by_adeli}</span>
              </div>
              <div>
                <span class="text-gris-texte">Date :</span>
                <span class="text-marine font-medium ml-1">
                  {claim.claimed_at ? new Date(claim.claimed_at).toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric', hour: '2-digit', minute: '2-digit' }) : '—'}
                </span>
              </div>
              <div>
                <span class="text-gris-texte">Telephone :</span>
                {claim.tel ? <span class="text-marine font-medium ml-1">{claim.tel}</span> : <span class="text-gris-texte italic ml-1">Non renseigné</span>}
              </div>
              <div>
                <span class="text-gris-texte">Horaires :</span>
                {claim.horaires ? <span class="text-marine font-medium ml-1">{claim.horaires}</span> : <span class="text-gris-texte italic ml-1">Non renseigné</span>}
              </div>
              <div>
                <span class="text-gris-texte">Site web :</span>
                {claim.site_web ? <a href={claim.site_web} target="_blank" rel="noopener" class="text-orange font-medium ml-1 hover:underline">{claim.site_web}</a> : <span class="text-gris-texte italic ml-1">Non renseigné</span>}
              </div>
            </div>

            <div class="mb-3">
              <span class="text-xs text-gris-texte font-sans">Specialites : </span>
              {claim.specialites && claim.specialites.length > 0 ? (
                claim.specialites.map((s: string) => (
                  <span class="inline-block rounded-full bg-[#E6F1FB] px-2 py-0.5 text-xs text-[#0C447C] font-sans mr-1">{s}</span>
                ))
              ) : (
                <span class="text-xs text-gris-texte italic font-sans">Non renseigné</span>
              )}
            </div>

            <div class="mb-3">
              <span class="text-xs text-gris-texte font-sans">Marques : </span>
              {claim.marques && claim.marques.length > 0 ? (
                claim.marques.map((m: string) => (
                  <span class="inline-block rounded-full bg-[#F8F5F0] px-2 py-0.5 text-xs text-marine font-sans mr-1">{m}</span>
                ))
              ) : (
                <span class="text-xs text-gris-texte italic font-sans">Non renseigné</span>
              )}
            </div>

            <div class="mb-3">
              <span class="text-xs text-gris-texte font-sans">Description : </span>
              {claim.a_propos ? (
                <p class="text-sm text-marine font-sans mt-1">{claim.a_propos}</p>
              ) : (
                <span class="text-xs text-gris-texte italic font-sans">Non renseigné</span>
              )}
            </div>

            <div class="mb-4">
              <span class="text-xs text-gris-texte font-sans">Photo : </span>
              {claim.photo_url ? (
                <img src={claim.photo_url} alt="Photo du centre" class="mt-1 w-32 h-24 rounded-lg object-cover" />
              ) : (
                <span class="text-xs text-gris-texte italic font-sans">Non renseigné</span>
              )}
            </div>

            <div class="flex gap-3 pt-4 border-t border-gris-clair">
              <button
                type="button"
                class="admin-action rounded-lg bg-[#0F6E56] px-5 py-2.5 text-sm font-medium text-blanc font-sans hover:bg-[#0A5843] transition-colors cursor-pointer"
                style="min-height: 44px;"
                data-action="approve"
                data-slug={claim.slug}
              >
                Approuver
              </button>
              <button
                type="button"
                class="admin-action rounded-lg bg-blanc border border-[#A32D2D] px-5 py-2.5 text-sm font-medium text-[#A32D2D] font-sans hover:bg-[#FCEBEB] transition-colors cursor-pointer"
                style="min-height: 44px;"
                data-action="reject"
                data-slug={claim.slug}
              >
                Rejeter
              </button>
            </div>
          </div>
        ))}
      </div>
    )}

    {recentClaims && recentClaims.length > 0 && (
      <>
        <h2 class="font-sans text-lg font-bold text-marine mb-4">Recemment traites</h2>
        <div class="space-y-3">
          {recentClaims.map((c) => (
            <details class="rounded-xl border border-gris-clair bg-blanc overflow-hidden group">
              <summary class="flex items-center justify-between px-5 py-4 cursor-pointer hover:bg-creme/50 transition-colors">
                <div class="flex items-center gap-4">
                  <div>
                    <span class="text-sm font-bold text-marine font-sans">{c.nom}</span>
                    <span class="text-xs text-gris-texte font-sans ml-2">{c.cp} {c.ville}</span>
                  </div>
                </div>
                <div class="flex items-center gap-3">
                  <span class="text-xs text-gris-texte font-sans">{c.claimed_by_name}</span>
                  {c.claim_status === 'approved' ? (
                    <span class="rounded-full bg-[#E1F5EE] px-2 py-0.5 text-xs font-medium text-[#0F6E56]">Approuve</span>
                  ) : (
                    <span class="rounded-full bg-[#FCEBEB] px-2 py-0.5 text-xs font-medium text-[#A32D2D]">Rejete</span>
                  )}
                  <Icon name="lucide:chevron-down" class="w-4 h-4 text-gris-texte group-open:rotate-180 transition-transform" />
                </div>
              </summary>
              <div class="px-5 pb-5 border-t border-gris-clair pt-4">
                <div class="grid gap-2 sm:grid-cols-2 text-sm font-sans mb-4">
                  <div><span class="text-gris-texte">Email :</span> <a href={`mailto:${c.claimed_by_email}`} class="text-orange hover:underline">{c.claimed_by_email}</a></div>
                  <div><span class="text-gris-texte">RPPS/SIRET :</span> <span class="text-marine">{c.claimed_by_adeli}</span></div>
                  <div><span class="text-gris-texte">Tel :</span> {c.tel ? <span class="text-marine">{c.tel}</span> : <span class="text-gris-texte italic">Non renseigné</span>}</div>
                  <div><span class="text-gris-texte">Site :</span> {c.site_web ? <a href={c.site_web} target="_blank" rel="noopener" class="text-orange hover:underline">{c.site_web}</a> : <span class="text-gris-texte italic">Non renseigné</span>}</div>
                  <div><span class="text-gris-texte">Horaires :</span> {c.horaires ? <span class="text-marine">{c.horaires}</span> : <span class="text-gris-texte italic">Non renseigné</span>}</div>
                  <div><span class="text-gris-texte">Date :</span> <span class="text-marine">{c.claimed_at ? new Date(c.claimed_at).toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' }) : '—'}</span></div>
                </div>
                <div class="mb-2">
                  <span class="text-xs text-gris-texte font-sans">Specialites : </span>
                  {c.specialites && c.specialites.length > 0 ? (
                    c.specialites.map((s: string) => (
                      <span class="inline-block rounded-full bg-[#E6F1FB] px-2 py-0.5 text-xs text-[#0C447C] font-sans mr-1">{s}</span>
                    ))
                  ) : (
                    <span class="text-xs text-gris-texte italic font-sans">Non renseigné</span>
                  )}
                </div>
                <div class="mb-3">
                  <span class="text-xs text-gris-texte font-sans">Marques : </span>
                  {c.marques && c.marques.length > 0 ? (
                    c.marques.map((m: string) => (
                      <span class="inline-block rounded-full bg-[#F8F5F0] px-2 py-0.5 text-xs text-marine font-sans mr-1">{m}</span>
                    ))
                  ) : (
                    <span class="text-xs text-gris-texte italic font-sans">Non renseigné</span>
                  )}
                </div>
                <div class="mb-3">
                  <span class="text-xs text-gris-texte font-sans">Description : </span>
                  {c.a_propos ? (
                    <p class="text-xs text-gris-texte font-sans mt-1">{c.a_propos}</p>
                  ) : (
                    <span class="text-xs text-gris-texte italic font-sans">Non renseigné</span>
                  )}
                </div>
                <div class="mb-3">
                  <span class="text-xs text-gris-texte font-sans">Photo : </span>
                  {c.photo_url ? (
                    <img src={c.photo_url} alt={`Photo ${c.nom}`} class="mt-1 rounded max-w-[200px] max-h-[120px] object-cover" />
                  ) : (
                    <span class="text-xs text-gris-texte italic font-sans">Non renseigné</span>
                  )}
                </div>
                <div class="flex flex-wrap items-center gap-3 pt-3 border-t border-gris-clair">
                  <a href={`/centre/${c.slug}/`} target="_blank" class="text-xs text-orange font-sans font-medium hover:underline">Voir la fiche</a>
                  {c.claim_status === 'approved' && c.plan !== 'premium' && (
                    <button
                      type="button"
                      class="admin-premium rounded px-2 py-1 text-xs bg-orange text-blanc font-sans font-medium hover:bg-orange-hover cursor-pointer"
                      data-slug={c.slug}
                    >
                      Offrir Premium
                    </button>
                  )}
                  {c.plan === 'premium' && (
                    <span class="text-xs text-[#0F6E56] font-sans font-medium">Premium actif</span>
                  )}
                  <div id={`premium-link-${c.slug}`} class="hidden w-full mt-2">
                    <div class="flex gap-2">
                      <input type="text" readonly class="flex-1 rounded border border-gris-clair px-2 py-1 text-xs font-mono bg-creme" />
                      <button type="button" class="copy-link rounded px-2 py-1 text-xs bg-marine text-blanc font-sans cursor-pointer hover:bg-marine/80">Copier</button>
                    </div>
                    <p class="text-[10px] text-gris-texte font-sans mt-1">Envoyez ce lien au client — 1 clic = Premium active</p>
                  </div>
                  {c.claim_status === 'approved' && (
                    <button
                      type="button"
                      class="admin-revoke text-xs text-[#A32D2D] font-sans font-medium hover:underline cursor-pointer"
                      data-slug={c.slug}
                    >
                      Revoquer
                    </button>
                  )}
                </div>
              </div>
            </details>
          ))}
        </div>
      </>
    )}
  </section>

  <script>
    // --- Offrir Premium ---
    document.querySelectorAll('.admin-premium').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const slug = btn.getAttribute('data-slug');
        btn.textContent = 'Generation...';

        try {
          const res = await fetch('/api/admin/generate-premium-link', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ centreSlug: slug }),
          });
          const data = await res.json();
          if (!res.ok) throw new Error(data.error);

          const container = document.getElementById('premium-link-' + slug);
          if (container) {
            const input = container.querySelector('input');
            if (input) input.value = data.link;
            container.classList.remove('hidden');
          }
          btn.textContent = 'Lien genere';
          btn.setAttribute('disabled', 'true');
        } catch (err) {
          alert(err instanceof Error ? err.message : 'Erreur');
          btn.textContent = 'Offrir Premium';
        }
      });
    });

    // --- Copier le lien premium ---
    document.querySelectorAll('.copy-link').forEach((btn) => {
      btn.addEventListener('click', () => {
        const input = btn.parentElement?.querySelector('input');
        if (input) {
          navigator.clipboard.writeText(input.value);
          btn.textContent = 'Copie !';
          setTimeout(() => { btn.textContent = 'Copier'; }, 2000);
        }
      });
    });

    // --- Revoquer un claim approuve ---
    document.querySelectorAll('.admin-revoke').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const slug = btn.getAttribute('data-slug');
        if (!confirm('Revoquer cette revendication ? Le centre repassera en mode ghost.')) return;

        btn.textContent = 'En cours...';

        try {
          const res = await fetch('/api/admin/reject-claim', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ centreSlug: slug }),
          });
          const data = await res.json();
          if (!res.ok) throw new Error(data.error);
          window.location.reload();
        } catch (err) {
          alert(err instanceof Error ? err.message : 'Erreur');
          btn.textContent = 'Revoquer';
        }
      });
    });

    // --- Approuver / Rejeter un claim pending ---
    document.querySelectorAll('.admin-action').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const action = btn.getAttribute('data-action');
        const slug = btn.getAttribute('data-slug');
        const endpoint = action === 'approve' ? '/api/admin/approve-claim' : '/api/admin/reject-claim';

        btn.textContent = 'En cours...';
        btn.setAttribute('disabled', 'true');

        try {
          const res = await fetch(endpoint, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ centreSlug: slug }),
          });

          const data = await res.json();
          if (!res.ok) throw new Error(data.error);

          const card = document.getElementById(`claim-${slug}`);
          if (card) {
            card.style.opacity = '0.5';
            card.innerHTML = `<p class="text-sm font-medium font-sans text-center py-4">${action === 'approve' ? 'Approuve' : 'Rejete'} avec succes</p>`;
          }
        } catch (err) {
          alert(err instanceof Error ? err.message : 'Erreur');
          btn.textContent = action === 'approve' ? 'Approuver' : 'Rejeter';
          btn.removeAttribute('disabled');
        }
      });
    });
  </script>

  <AdminTasksDrawerProvider
    client:load
    urgentCount={navCounts.tasksUrgent}
    currentPath="/admin/claims"
  />
</BaseLayout>
