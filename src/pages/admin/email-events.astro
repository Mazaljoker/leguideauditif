---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import { Icon } from 'astro-icon/components';
import { supabase, createServerClient } from '../../lib/supabase';
import { getAdminNavCounts } from '../../lib/adminNav';
import AdminNav from '../../components/admin/AdminNav.astro';
import { EMAIL_TEMPLATE_LABELS, type EmailTemplateKey } from '../../types/audiopro-lifecycle';
import { requireAdmin } from '../../lib/admin-guard';

const guard = requireAdmin(Astro);
if (guard) return guard;

const serverClient = createServerClient();

// Filtre période — défaut 7 jours, query param ?days=N
const daysParam = Number(Astro.url.searchParams.get('days') ?? 7);
const days = Number.isFinite(daysParam) && daysParam > 0 && daysParam <= 90 ? daysParam : 7;
const since = new Date(Date.now() - days * 86400000).toISOString();

const [eventsRes, navCounts] = await Promise.all([
  serverClient
    .from('email_events')
    .select('id, sent_at, recipient_email, template_key, trigger, resend_message_id, delivered_at, opened_at, clicked_at, bounced_at, complaint_at, audiopro_id')
    .gte('sent_at', since)
    .order('sent_at', { ascending: false })
    .limit(500),
  getAdminNavCounts(supabase),
]);

const events = eventsRes.data ?? [];

// Stats agrégées (par template_key)
interface StatRow {
  template_key: EmailTemplateKey;
  sent: number;
  delivered: number;
  opened: number;
  clicked: number;
  bounced: number;
  complained: number;
}

const statsMap = new Map<EmailTemplateKey, StatRow>();
for (const ev of events) {
  const key = ev.template_key as EmailTemplateKey;
  if (!statsMap.has(key)) {
    statsMap.set(key, {
      template_key: key,
      sent: 0,
      delivered: 0,
      opened: 0,
      clicked: 0,
      bounced: 0,
      complained: 0,
    });
  }
  const s = statsMap.get(key)!;
  s.sent++;
  if (ev.delivered_at) s.delivered++;
  if (ev.opened_at) s.opened++;
  if (ev.clicked_at) s.clicked++;
  if (ev.bounced_at) s.bounced++;
  if (ev.complaint_at) s.complained++;
}
const stats = Array.from(statsMap.values()).sort((a, b) => b.sent - a.sent);

const totalSent = events.length;
const totalDelivered = events.filter(e => e.delivered_at).length;
const totalOpened = events.filter(e => e.opened_at).length;
const totalClicked = events.filter(e => e.clicked_at).length;
const totalBounced = events.filter(e => e.bounced_at).length;
const totalComplained = events.filter(e => e.complaint_at).length;

const pct = (n: number, total: number): string => total === 0 ? '—' : `${Math.round((n / total) * 100)}%`;

const fmtDate = (iso: string | null): string => {
  if (!iso) return '—';
  const d = new Date(iso);
  return d.toLocaleString('fr-FR', { dateStyle: 'short', timeStyle: 'short' });
};

const truncate = (s: string, n: number): string => s.length > n ? s.slice(0, n - 1) + '…' : s;
---

<BaseLayout title="Email events — Admin LeGuideAuditif" description="Tracking livraison/ouverture/clic des emails">
  <meta slot="head" name="robots" content="noindex" />

  <div class="min-h-screen bg-creme">
    <AdminNav counts={navCounts} currentPath={Astro.url.pathname} />

    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 font-sans">

      <header class="mb-8">
        <h1 class="text-3xl font-bold text-marine mb-2">Email events</h1>
        <p class="text-sm text-gris-texte">
          Tracking en temps réel via webhook Resend — derniers <strong>{days}</strong> jour{days > 1 ? 's' : ''}.
          <span class="ml-2 text-xs">
            <a href="?days=1" class="underline hover:text-orange">24h</a>
            <span class="mx-1">·</span>
            <a href="?days=7" class="underline hover:text-orange">7j</a>
            <span class="mx-1">·</span>
            <a href="?days=30" class="underline hover:text-orange">30j</a>
            <span class="mx-1">·</span>
            <a href="?days=90" class="underline hover:text-orange">90j</a>
          </span>
        </p>
      </header>

      {/* Cartes globales */}
      <section class="grid grid-cols-2 md:grid-cols-6 gap-3 mb-8">
        <div class="bg-white p-4 rounded-lg border border-[#E4DED3]">
          <p class="text-xs text-gris-texte mb-1">Envoyés</p>
          <p class="text-2xl font-bold text-marine">{totalSent}</p>
        </div>
        <div class="bg-white p-4 rounded-lg border border-[#E4DED3]">
          <p class="text-xs text-gris-texte mb-1">Délivrés</p>
          <p class="text-2xl font-bold text-marine">{totalDelivered}</p>
          <p class="text-xs text-gris-texte">{pct(totalDelivered, totalSent)}</p>
        </div>
        <div class="bg-white p-4 rounded-lg border border-[#E4DED3]">
          <p class="text-xs text-gris-texte mb-1">Ouverts</p>
          <p class="text-2xl font-bold text-marine">{totalOpened}</p>
          <p class="text-xs text-gris-texte">{pct(totalOpened, totalDelivered)}</p>
        </div>
        <div class="bg-white p-4 rounded-lg border border-[#E4DED3]">
          <p class="text-xs text-gris-texte mb-1">Cliqués</p>
          <p class="text-2xl font-bold text-marine">{totalClicked}</p>
          <p class="text-xs text-gris-texte">{pct(totalClicked, totalOpened)} CTR</p>
        </div>
        <div class="bg-white p-4 rounded-lg border border-[#E4DED3]">
          <p class="text-xs text-gris-texte mb-1">Bounce</p>
          <p class={`text-2xl font-bold ${totalBounced > 0 ? 'text-[#A32D2D]' : 'text-marine'}`}>{totalBounced}</p>
          <p class="text-xs text-gris-texte">{pct(totalBounced, totalSent)}</p>
        </div>
        <div class="bg-white p-4 rounded-lg border border-[#E4DED3]">
          <p class="text-xs text-gris-texte mb-1">Spam complaint</p>
          <p class={`text-2xl font-bold ${totalComplained > 0 ? 'text-[#A32D2D]' : 'text-marine'}`}>{totalComplained}</p>
          <p class="text-xs text-gris-texte">{pct(totalComplained, totalSent)}</p>
        </div>
      </section>

      {/* Stats par template */}
      {stats.length > 0 && (
        <section class="bg-white rounded-lg border border-[#E4DED3] overflow-hidden mb-8">
          <header class="px-4 py-3 border-b border-[#E4DED3] bg-[#F8F5F0]">
            <h2 class="text-base font-bold text-marine">Performance par template</h2>
          </header>
          <div class="overflow-x-auto">
            <table class="w-full text-sm">
              <thead class="bg-[#FDFBF7] text-xs text-gris-texte">
                <tr>
                  <th class="px-3 py-2 text-left font-medium">Template</th>
                  <th class="px-3 py-2 text-right font-medium">Envoyés</th>
                  <th class="px-3 py-2 text-right font-medium">Délivrés</th>
                  <th class="px-3 py-2 text-right font-medium">Ouverts</th>
                  <th class="px-3 py-2 text-right font-medium">Cliqués</th>
                  <th class="px-3 py-2 text-right font-medium">Bounce</th>
                  <th class="px-3 py-2 text-right font-medium">Spam</th>
                  <th class="px-3 py-2 text-right font-medium">Open rate</th>
                  <th class="px-3 py-2 text-right font-medium">CTR</th>
                </tr>
              </thead>
              <tbody>
                {stats.map(s => (
                  <tr class="border-t border-[#E4DED3]">
                    <td class="px-3 py-2 text-marine font-medium">{EMAIL_TEMPLATE_LABELS[s.template_key] ?? s.template_key}</td>
                    <td class="px-3 py-2 text-right">{s.sent}</td>
                    <td class="px-3 py-2 text-right">{s.delivered}</td>
                    <td class="px-3 py-2 text-right">{s.opened}</td>
                    <td class="px-3 py-2 text-right">{s.clicked}</td>
                    <td class={`px-3 py-2 text-right ${s.bounced > 0 ? 'text-[#A32D2D] font-medium' : ''}`}>{s.bounced}</td>
                    <td class={`px-3 py-2 text-right ${s.complained > 0 ? 'text-[#A32D2D] font-medium' : ''}`}>{s.complained}</td>
                    <td class="px-3 py-2 text-right font-mono text-xs">{pct(s.opened, s.delivered)}</td>
                    <td class="px-3 py-2 text-right font-mono text-xs">{pct(s.clicked, s.opened)}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </section>
      )}

      {/* Liste détaillée */}
      <section class="bg-white rounded-lg border border-[#E4DED3] overflow-hidden">
        <header class="px-4 py-3 border-b border-[#E4DED3] bg-[#F8F5F0]">
          <h2 class="text-base font-bold text-marine">Derniers envois ({events.length})</h2>
        </header>

        {events.length === 0 ? (
          <p class="px-4 py-8 text-center text-gris-texte text-sm">
            Aucun email envoyé sur la période.
          </p>
        ) : (
          <div class="overflow-x-auto">
            <table class="w-full text-xs font-mono">
              <thead class="bg-[#FDFBF7] text-gris-texte">
                <tr>
                  <th class="px-3 py-2 text-left font-medium">Sent</th>
                  <th class="px-3 py-2 text-left font-medium">Destinataire</th>
                  <th class="px-3 py-2 text-left font-medium">Template</th>
                  <th class="px-3 py-2 text-left font-medium">Trigger</th>
                  <th class="px-3 py-2 text-center font-medium" title="Délivré">D</th>
                  <th class="px-3 py-2 text-center font-medium" title="Ouvert">O</th>
                  <th class="px-3 py-2 text-center font-medium" title="Cliqué">C</th>
                  <th class="px-3 py-2 text-center font-medium" title="Bounce">B</th>
                  <th class="px-3 py-2 text-center font-medium" title="Spam complaint">S</th>
                </tr>
              </thead>
              <tbody>
                {events.map(ev => (
                  <tr class="border-t border-[#E4DED3] hover:bg-[#FDFBF7]">
                    <td class="px-3 py-2 whitespace-nowrap">{fmtDate(ev.sent_at)}</td>
                    <td class="px-3 py-2 truncate max-w-[18rem]" title={ev.recipient_email}>{truncate(ev.recipient_email, 35)}</td>
                    <td class="px-3 py-2 text-marine">{ev.template_key}</td>
                    <td class="px-3 py-2 text-gris-texte">{ev.trigger}</td>
                    <td class={`px-3 py-2 text-center ${ev.delivered_at ? 'text-[#0F6E56]' : 'text-[#C4BEB1]'}`}>{ev.delivered_at ? '✓' : '·'}</td>
                    <td class={`px-3 py-2 text-center ${ev.opened_at ? 'text-[#0F6E56]' : 'text-[#C4BEB1]'}`}>{ev.opened_at ? '✓' : '·'}</td>
                    <td class={`px-3 py-2 text-center ${ev.clicked_at ? 'text-[#0F6E56] font-bold' : 'text-[#C4BEB1]'}`}>{ev.clicked_at ? '✓' : '·'}</td>
                    <td class={`px-3 py-2 text-center ${ev.bounced_at ? 'text-[#A32D2D] font-bold' : 'text-[#C4BEB1]'}`}>{ev.bounced_at ? '✗' : '·'}</td>
                    <td class={`px-3 py-2 text-center ${ev.complaint_at ? 'text-[#A32D2D] font-bold' : 'text-[#C4BEB1]'}`}>{ev.complaint_at ? '!' : '·'}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        )}
      </section>

      <p class="text-xs text-gris-texte mt-6">
        Légende : <strong>D</strong>élivré · <strong>O</strong>uvert · <strong>C</strong>liqué · <strong>B</strong>ounce · <strong>S</strong>pam complaint.
        Les colonnes O/C ne se remplissent que si le webhook Resend est configuré et que le destinataire ouvre/clique réellement (les ouvertures sont trackées via pixel 1×1, les clics via wrapper d'URL).
      </p>

    </main>
  </div>
</BaseLayout>
