---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import { Icon } from 'astro-icon/components';
import AdminNav from '../../components/admin/AdminNav.astro';
import { createServerClient } from '../../lib/supabase';
import { getAdminNavCounts } from '../../lib/adminNav';
import { requireAdmin } from '../../lib/admin-guard';

const guard = requireAdmin(Astro);
if (guard) return guard;

const supabase = createServerClient();
const navCounts = await getAdminNavCounts(supabase);

// 12 derniers runs
const { data: runs } = await supabase
  .from('rpps_sync_runs')
  .select('*')
  .order('started_at', { ascending: false })
  .limit(12);

interface SyncRun {
  id: string;
  started_at: string;
  completed_at: string | null;
  status: 'running' | 'success' | 'failed';
  trigger_source: 'manual' | 'cron';
  rpps_count_before: number | null;
  rpps_count_after: number | null;
  rpps_inserted: number;
  rpps_updated: number;
  rpps_marked_inactive: number;
  new_centres_detected: Array<{
    rpps: string;
    nom: string | null;
    prenom: string | null;
    raison_sociale: string | null;
    enseigne: string | null;
    code_postal: string | null;
    commune: string | null;
  }>;
  error_message: string | null;
  duration_seconds: number | null;
}

const typedRuns: SyncRun[] = (runs ?? []) as SyncRun[];
const lastRun = typedRuns[0];

// Bandeau fraîcheur : vert ≤ 16 j, orange 17–32 j, rouge > 32 j (1 sync /15 j attendue)
function daysSince(iso: string | null): number | null {
  if (!iso) return null;
  return Math.floor((Date.now() - new Date(iso).getTime()) / 86400000);
}
const daysSinceLast = lastRun ? daysSince(lastRun.started_at) : null;
const freshnessClass =
  daysSinceLast === null
    ? 'bg-gray-100 text-gray-700'
    : daysSinceLast <= 16
    ? 'bg-green-50 text-green-700 border-green-200'
    : daysSinceLast <= 32
    ? 'bg-orange-50 text-orange-700 border-orange-200'
    : 'bg-red-50 text-red-700 border-red-200';

const newCentresSinceLast = lastRun?.new_centres_detected?.length ?? 0;

function formatDate(iso: string | null): string {
  if (!iso) return '—';
  return new Date(iso).toLocaleString('fr-FR', {
    day: '2-digit',
    month: '2-digit',
    year: 'numeric',
    hour: '2-digit',
    minute: '2-digit',
  });
}

function formatDuration(s: number | null): string {
  if (s === null) return '—';
  if (s < 60) return `${s} s`;
  const min = Math.floor(s / 60);
  const sec = s % 60;
  return `${min} min ${sec}s`;
}
---

<BaseLayout title="Sync RPPS — Admin LGA" description="Tableau de bord des synchronisations RPPS bi-mensuelles." noindex>
  <meta slot="head" name="robots" content="noindex" />

  <div class="bg-creme min-h-screen">
    <AdminNav counts={navCounts} currentPath={Astro.url.pathname} />

    <main class="max-w-[1140px] mx-auto px-5 py-8">
      <header class="flex items-start justify-between gap-4 mb-6">
        <div>
          <h1 class="font-sans text-[28px] font-extrabold text-marine mb-1">Sync RPPS</h1>
          <p class="text-gris-texte text-sm">
            Synchronisation bi-mensuelle (1er + 15) du Répertoire Partagé des Professionnels de Santé via FHIR.
          </p>
        </div>

        <button
          id="manual-sync-btn"
          type="button"
          class="rounded-lg bg-orange px-5 py-2.5 text-sm font-semibold text-blanc font-sans hover:bg-orange-hover transition-colors disabled:opacity-60 disabled:cursor-not-allowed"
        >
          <Icon name="lucide:refresh-cw" class="inline w-4 h-4 mr-1 align-text-bottom" />
          Lancer une sync manuelle
        </button>
      </header>

      <div id="sync-status" class="hidden mb-4 rounded-lg border p-4 font-sans text-sm"></div>

      <!-- Bandeau fraicheur -->
      <div class={`rounded-xl border p-4 mb-6 ${freshnessClass}`}>
        <div class="flex items-center justify-between gap-4 flex-wrap">
          <div>
            <p class="font-sans font-semibold text-base">
              {daysSinceLast === null
                ? 'Aucune sync exécutée pour l\'instant'
                : daysSinceLast === 0
                ? 'Dernière sync : aujourd\'hui'
                : `Dernière sync : il y a ${daysSinceLast} jour${daysSinceLast > 1 ? 's' : ''}`}
            </p>
            {lastRun && (
              <p class="text-xs mt-1 opacity-80">
                {formatDate(lastRun.started_at)} · trigger {lastRun.trigger_source} · {formatDuration(lastRun.duration_seconds)}
              </p>
            )}
          </div>
          {newCentresSinceLast > 0 && (
            <div class="text-right">
              <p class="text-2xl font-bold font-sans">{newCentresSinceLast}</p>
              <p class="text-xs">nouvelle{newCentresSinceLast > 1 ? 's' : ''} ouverture{newCentresSinceLast > 1 ? 's' : ''}</p>
            </div>
          )}
        </div>
      </div>

      <!-- Liste des runs -->
      <div class="bg-blanc rounded-xl shadow-[0_1px_4px_rgba(27,46,74,0.05)] overflow-hidden">
        <table class="w-full text-sm font-sans">
          <thead class="bg-creme">
            <tr class="text-left text-gris-texte text-xs uppercase tracking-wide">
              <th class="px-4 py-3">Date</th>
              <th class="px-4 py-3">Trigger</th>
              <th class="px-4 py-3">Statut</th>
              <th class="px-4 py-3">Durée</th>
              <th class="px-4 py-3 text-right">Insérés</th>
              <th class="px-4 py-3 text-right">Mis à jour</th>
              <th class="px-4 py-3 text-right">Inactivés</th>
              <th class="px-4 py-3 text-right">Détail</th>
            </tr>
          </thead>
          <tbody>
            {typedRuns.length === 0 && (
              <tr><td colspan="8" class="px-4 py-12 text-center text-gris-texte">
                Aucune sync exécutée pour l'instant. Lancez la première via le bouton ci-dessus.
              </td></tr>
            )}
            {typedRuns.map((r) => (
              <tr class="border-t border-gris-clair">
                <td class="px-4 py-3">{formatDate(r.started_at)}</td>
                <td class="px-4 py-3">
                  <span class={`inline-block rounded-full px-2 py-0.5 text-xs font-medium ${
                    r.trigger_source === 'cron'
                      ? 'bg-blue-50 text-blue-700'
                      : 'bg-gray-100 text-gray-700'
                  }`}>
                    {r.trigger_source}
                  </span>
                </td>
                <td class="px-4 py-3">
                  <span class={`inline-block rounded-full px-2 py-0.5 text-xs font-medium ${
                    r.status === 'success'
                      ? 'bg-green-50 text-green-700'
                      : r.status === 'failed'
                      ? 'bg-red-50 text-red-700'
                      : 'bg-yellow-50 text-yellow-700'
                  }`}>
                    {r.status}
                  </span>
                </td>
                <td class="px-4 py-3 text-gris-texte">{formatDuration(r.duration_seconds)}</td>
                <td class="px-4 py-3 text-right font-medium text-green-700">+{r.rpps_inserted}</td>
                <td class="px-4 py-3 text-right text-gris-texte">{r.rpps_updated}</td>
                <td class="px-4 py-3 text-right text-gris-texte">{r.rpps_marked_inactive}</td>
                <td class="px-4 py-3 text-right">
                  {r.new_centres_detected && r.new_centres_detected.length > 0 ? (
                    <button
                      type="button"
                      class="text-orange hover:underline detail-btn font-medium"
                      data-run-id={r.id}
                    >
                      {r.new_centres_detected.length} ouverture{r.new_centres_detected.length > 1 ? 's' : ''}
                    </button>
                  ) : r.error_message ? (
                    <button
                      type="button"
                      class="text-red-700 hover:underline error-btn"
                      data-error={r.error_message}
                    >
                      Erreur
                    </button>
                  ) : (
                    <span class="text-gris-texte">—</span>
                  )}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <!-- Modale détail -->
      <div id="detail-modal" class="hidden fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4">
        <div class="bg-blanc rounded-xl max-w-2xl w-full max-h-[80vh] overflow-auto">
          <div class="px-6 py-4 border-b border-gris-clair flex items-center justify-between">
            <h2 id="detail-modal-title" class="font-sans font-bold text-marine">Nouvelles ouvertures</h2>
            <button id="detail-modal-close" type="button" class="text-gris-texte hover:text-marine">
              <Icon name="lucide:x" class="w-5 h-5" />
            </button>
          </div>
          <div id="detail-modal-body" class="px-6 py-4 font-sans text-sm"></div>
        </div>
      </div>
    </main>
  </div>

  <script define:vars={{ runsJson: JSON.stringify(typedRuns) }}>
    interface SyncRun {
      id: string;
      new_centres_detected: Array<{
        rpps: string;
        nom: string | null;
        prenom: string | null;
        enseigne: string | null;
        raison_sociale: string | null;
        code_postal: string | null;
        commune: string | null;
      }>;
    }

    const runs: SyncRun[] = JSON.parse(runsJson);
    const runsById = new Map(runs.map((r) => [r.id, r]));

    function escapeHtml(s: string | null): string {
      if (!s) return '';
      return s.replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]!));
    }

    // ── Bouton "Lancer sync manuelle" ──
    const manualBtn = document.getElementById('manual-sync-btn') as HTMLButtonElement;
    const statusBox = document.getElementById('sync-status') as HTMLDivElement;

    manualBtn.addEventListener('click', async () => {
      manualBtn.disabled = true;
      manualBtn.textContent = 'Sync en cours…';
      statusBox.className = 'mb-4 rounded-lg border p-4 font-sans text-sm bg-blue-50 border-blue-200 text-blue-800';
      statusBox.classList.remove('hidden');
      statusBox.textContent = 'Sync RPPS lancée. La sync FHIR peut prendre 30–60 secondes…';

      try {
        const res = await fetch('/api/admin/sync-rpps', { method: 'POST' });
        const data = await res.json();
        if (!res.ok || data.status === 'failed') {
          throw new Error(data.error_message || data.error || 'Erreur sync');
        }
        statusBox.className = 'mb-4 rounded-lg border p-4 font-sans text-sm bg-green-50 border-green-200 text-green-800';
        statusBox.textContent = `Sync OK : +${data.inserted} insérés, ${data.updated} mis à jour, ${data.marked_inactive} inactivés, ${data.new_centres_count} nouvelle(s) ouverture(s) détectée(s). Rechargement…`;
        setTimeout(() => window.location.reload(), 2000);
      } catch (err) {
        const msg = err instanceof Error ? err.message : String(err);
        statusBox.className = 'mb-4 rounded-lg border p-4 font-sans text-sm bg-red-50 border-red-200 text-red-800';
        statusBox.textContent = `Erreur : ${msg}`;
        manualBtn.disabled = false;
        manualBtn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="inline w-4 h-4 mr-1 align-text-bottom"><path d="M3 12a9 9 0 0 1 9-9 9.75 9.75 0 0 1 6.74 2.74L21 8"/><path d="M21 3v5h-5"/><path d="M21 12a9 9 0 0 1-9 9 9.75 9.75 0 0 1-6.74-2.74L3 16"/><path d="M3 21v-5h5"/></svg> Réessayer';
      }
    });

    // ── Modale détail ──
    const modal = document.getElementById('detail-modal') as HTMLDivElement;
    const modalTitle = document.getElementById('detail-modal-title') as HTMLHeadingElement;
    const modalBody = document.getElementById('detail-modal-body') as HTMLDivElement;
    const modalClose = document.getElementById('detail-modal-close') as HTMLButtonElement;

    function closeModal(): void { modal.classList.add('hidden'); }
    modalClose.addEventListener('click', closeModal);
    modal.addEventListener('click', (e) => { if (e.target === modal) closeModal(); });

    document.querySelectorAll<HTMLButtonElement>('.detail-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const runId = btn.dataset.runId;
        const run = runId ? runsById.get(runId) : undefined;
        if (!run) return;
        modalTitle.textContent = `Nouvelles ouvertures — ${run.new_centres_detected.length}`;
        modalBody.innerHTML = `
          <ul class="space-y-3">
            ${run.new_centres_detected.map((c) => `
              <li class="border-b border-gris-clair pb-3 last:border-0">
                <p class="font-semibold text-marine">${escapeHtml(c.prenom)} ${escapeHtml(c.nom)}</p>
                <p class="text-gris-texte text-xs">RPPS ${escapeHtml(c.rpps)}</p>
                <p class="text-sm">${escapeHtml(c.enseigne || c.raison_sociale || '—')}</p>
                <p class="text-xs text-gris-texte mt-1">${escapeHtml(c.commune || '')} ${escapeHtml(c.code_postal || '')}</p>
              </li>
            `).join('')}
          </ul>
        `;
        modal.classList.remove('hidden');
      });
    });

    document.querySelectorAll<HTMLButtonElement>('.error-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        modalTitle.textContent = 'Erreur de sync';
        const errorText = btn.dataset.error || 'Erreur inconnue';
        modalBody.innerHTML = `<pre class="bg-red-50 text-red-800 p-3 rounded text-xs overflow-auto whitespace-pre-wrap">${escapeHtml(errorText)}</pre>`;
        modal.classList.remove('hidden');
      });
    });
  </script>
</BaseLayout>
