---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';

const title = 'Études et données — LeGuideAuditif.fr';
const description = 'Études indépendantes sur la santé auditive en France : données RPPS, cartographies, analyses départementales.';

const breadcrumbs = [
  { label: 'Accueil', href: '/' },
  { label: 'Études' },
];
---

<BaseLayout title={title} description={description}>
  <section class="bg-creme pt-4 pb-16">
    <div class="max-w-[780px] mx-auto px-4 sm:px-6">
      <Breadcrumbs items={breadcrumbs} />

      <h1 class="font-sans text-[32px] lg:text-[38px] font-extrabold text-marine leading-tight mb-8">
        Études et données
      </h1>

      <div class="bg-white rounded-2xl p-6 shadow-[0_1px_4px_rgba(27,46,74,0.05)] border border-[#1B2E4A]/5">
        <h2 class="font-sans text-xl font-bold text-marine mb-2">
          <a href="/etudes/deserts-auditifs-france-2026" class="text-orange hover:underline">
            Carte des déserts auditifs en France (2026)
          </a>
        </h2>
        <p class="font-sans text-base text-gris-texte leading-relaxed mb-3">
          Première carte interactive des audioprothésistes par département.
          Où manque-t-il des professionnels de l'audition ? Données RPPS 2026 x INSEE 2025.
        </p>
        <time datetime="2026-04-20" class="font-sans text-sm text-gris-texte">
          20 avril 2026
        </time>
      </div>
    </div>
  </section>
</BaseLayout>
