---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import AuthorBox from '../../components/AuthorBox.astro';
import HealthDisclaimer from '../../components/HealthDisclaimer.astro';
import DesertsAuditifsIsland from '../../components/etudes/DesertsAuditifsIsland.tsx';
import DownloadLeadMagnet from '../../components/etudes/DownloadLeadMagnet.tsx';
import CiterEtude from '../../components/etudes/CiterEtude.tsx';
import desertsData from '../../data/deserts-auditifs-2026.json';

const title = 'Carte des déserts auditifs en France (2026)';
const fullTitle = `${title} — LeGuideAuditif.fr`;
const description = 'Première carte interactive des audioprothésistes par département. Où manque-t-il des professionnels de l\'audition ? Données RPPS 2026 x INSEE 2025.';

const publishDate = new Date('2026-04-20');

const breadcrumbs = [
  { label: 'Accueil', href: '/' },
  { label: 'Études', href: '/etudes/' },
  { label: 'Déserts auditifs France 2026' },
];

// --- Computed stats ---
const { metadata, departements } = desertsData;
const sorted = [...departements].sort((a, b) => a.ratio_100k - b.ratio_100k);
const pire = sorted[0];
const meilleur = sorted[sorted.length - 1];
const pireMet = sorted.find((d) => !['971', '972', '973', '974', '976'].includes(d.code));

// --- Schema.org ---
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  author: {
    '@type': 'Person',
    '@id': 'https://leguideauditif.fr/#author',
    name: 'Franck-Olivier Chabbat',
    jobTitle: 'Audioprothésiste DE',
    url: 'https://leguideauditif.fr/auteur/franck-olivier/',
  },
  datePublished: publishDate.toISOString(),
  publisher: {
    '@type': 'Organization',
    name: 'LeGuideAuditif.fr',
    url: 'https://leguideauditif.fr',
  },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: breadcrumbs.map((item, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: item.label,
    ...(item.href && { item: new URL(item.href, Astro.site).href }),
  })),
};

const datasetSchema = {
  '@context': 'https://schema.org',
  '@type': 'Dataset',
  name: 'Densité d\'audioprothésistes par département en France (2026)',
  description: 'Nombre d\'audioprothésistes pour 100 000 habitants, par département. Données RPPS avril 2026 x INSEE 2025.',
  creator: { '@type': 'Person', name: 'Franck-Olivier Chabbat' },
  datePublished: '2026-04-20',
  license: 'https://www.etalab.gouv.fr/licence-ouverte-open-licence/',
  distribution: {
    '@type': 'DataDownload',
    encodingFormat: 'application/json',
    contentUrl: 'https://leguideauditif.fr/data/deserts-auditifs-2026.json',
  },
};

const faqEntries = [
  {
    question: 'Qu\'est-ce qu\'un désert auditif ?',
    answer: 'On parle de désert auditif quand un département manque cruellement d\'audioprothésistes par rapport à la moyenne nationale (8,4 pour 100 000 habitants en 2026). En clair : si vous vivez dans l\'un de ces territoires, trouver un rendez-vous peut prendre des semaines. Voire des mois.',
  },
  {
    question: 'Quel département est le plus sous-doté en audioprothésistes ?',
    answer: `La Haute-Marne (52), et de loin. Avec seulement ${pireMet?.ratio_100k} audioprothésistes pour 100 000 habitants, c'est deux fois moins que la moyenne nationale. Pour un patient qui y vit, ça veut dire des trajets longs et des délais d'attente importants.`,
  },
  {
    question: 'Combien y a-t-il d\'audioprothésistes en France en 2026 ?',
    answer: `Le RPPS (le registre officiel des professionnels de santé) en recense ${metadata.total_audios_rpps.toLocaleString('fr-FR')} en avril 2026. Parmi eux, ${metadata.total_audios.toLocaleString('fr-FR')} ont une adresse qui permet de les localiser par département. Les autres sont souvent des salariés rattachés à plusieurs sites.`,
  },
  {
    question: 'Comment sont calculées les données de cette étude ?',
    answer: 'On divise le nombre d\'audioprothésistes géolocalisés dans chaque département par la population totale (INSEE 2025), puis on multiplie par 100 000. Ça donne un ratio comparable d\'un département à l\'autre, quelle que soit sa taille. Les seuils que j\'ai retenus : désert (moins de 5), sous-doté (5 à 7), correct (7 à 10) et bien doté (plus de 10).',
  },
  {
    question: 'Pourquoi la Seine-Saint-Denis est-elle sous-dotée malgré sa proximité avec Paris ?',
    answer: `Le 93 compte ${sorted.find(d => d.code === '93')?.ratio_100k} audioprothésistes pour 100 000 habitants — presque la moitié de la moyenne nationale. Et pourtant, c'est en Île-de-France. L'explication ? Avec 1,7 million d'habitants, la demande est énorme, mais les cabinets se concentrent dans Paris intra-muros. Les patients du 93 doivent souvent traverser le périphérique pour se faire appareiller.`,
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqEntries.map((f) => ({
    '@type': 'Question',
    name: f.question,
    acceptedAnswer: { '@type': 'Answer', text: f.answer },
  })),
};

const allSchemas = [articleSchema, breadcrumbSchema, datasetSchema, faqSchema];
---

<BaseLayout
  title={fullTitle}
  description={description}
  canonical="https://leguideauditif.fr/etudes/deserts-auditifs-france-2026/"
  ogImage="/images/etudes/og-deserts-auditifs-2026.jpg"
  ogType="article"
  publishDate={publishDate}
  schema={allSchemas}
>
  {/* Leaflet CSS */}
  <link
    rel="stylesheet"
    href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
    integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
    crossorigin=""
    slot="head"
  />
  <link
    rel="preload"
    as="fetch"
    href="/data/departements-france.geojson"
    crossorigin=""
    slot="head"
  />

  <section class="bg-creme pt-4 pb-16">
    {/* Breadcrumbs */}
    <div class="max-w-[1200px] mx-auto px-4 sm:px-6">
      <Breadcrumbs items={breadcrumbs} />
    </div>

    {/* Hero */}
    <header class="max-w-[780px] mx-auto px-4 sm:px-6 mb-10">
      <h1 class="font-serif text-[32px] lg:text-[48px] font-bold text-marine leading-tight mb-4">
        En Haute-Marne, il y a <span class="text-[#F44336]">2 fois moins</span> d'audioprothésistes par habitant que la moyenne française.
      </h1>
      <p class="font-sans text-lg text-gris-texte leading-relaxed">
        J'ai croisé les données officielles du RPPS (répertoire des professionnels de santé) et de l'INSEE pour dresser cet état des lieux.
        Après 28 ans de terrain, je constate chaque jour les conséquences de ces inégalités sur mes patients.
        — <strong class="text-marine">Franck-Olivier Chabbat</strong>, audioprothésiste DE.
      </p>
      <div class="flex flex-wrap items-center gap-3 mt-3">
        <span class="inline-block px-3 py-1 bg-[#1B2E4A] text-white font-sans text-xs font-bold rounded-full uppercase tracking-wide">
          Edition 2026
        </span>
        <div class="font-sans text-sm text-gris-texte">
          <time datetime="2026-04-20">Publié le 20 avril 2026</time>
          <span class="mx-1">|</span>
          <time datetime="2026-04-20">Mis à jour le 20 avril 2026</time>
        </div>
      </div>
    </header>

    {/* Health disclaimer inline */}
    <div class="max-w-[780px] mx-auto px-4 sm:px-6 mb-10">
      <div class="bg-[#fef9f0] border border-[#f0dcc4] rounded-xl px-5 py-4 text-sm text-gris-texte font-sans">
        <strong class="text-marine">Information santé :</strong> Ce contenu est informatif et ne remplace pas une consultation avec un professionnel de santé. Dernière revue : avril 2026.
      </div>
    </div>

    {/* Key stats bar */}
    <div class="max-w-[1200px] mx-auto px-4 sm:px-6 mb-10">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
        <div class="bg-white rounded-xl p-5 shadow-[0_1px_4px_rgba(27,46,74,0.05)] border border-[#1B2E4A]/5">
          <p class="font-sans text-sm text-gris-texte mb-1">Audioprothésistes géolocalisés</p>
          <p class="font-serif text-3xl font-bold text-marine">{metadata.total_audios.toLocaleString('fr-FR')}</p>
          <p class="font-sans text-xs text-gris-texte">sur {metadata.total_audios_rpps.toLocaleString('fr-FR')} au RPPS</p>
        </div>
        <div class="bg-white rounded-xl p-5 shadow-[0_1px_4px_rgba(27,46,74,0.05)] border border-[#1B2E4A]/5">
          <p class="font-sans text-sm text-gris-texte mb-1">Moyenne nationale</p>
          <p class="font-serif text-3xl font-bold text-marine">{metadata.moyenne_nationale}</p>
          <p class="font-sans text-xs text-gris-texte">pour 100 000 habitants</p>
        </div>
        <div class="bg-white rounded-xl p-5 shadow-[0_1px_4px_rgba(27,46,74,0.05)] border border-[#1B2E4A]/5">
          <p class="font-sans text-sm text-gris-texte mb-1">Département le plus sous-doté</p>
          <p class="font-serif text-3xl font-bold text-[#C62828]">{pireMet?.nom}</p>
          <p class="font-sans text-xs text-gris-texte">{pireMet?.ratio_100k} / 100k hab.</p>
        </div>
        <div class="bg-white rounded-xl p-5 shadow-[0_1px_4px_rgba(27,46,74,0.05)] border border-[#1B2E4A]/5">
          <p class="font-sans text-sm text-gris-texte mb-1">Département le mieux doté</p>
          <p class="font-serif text-3xl font-bold text-[#2E7D32]">{meilleur.nom}</p>
          <p class="font-sans text-xs text-gris-texte">{meilleur.ratio_100k} / 100k hab.</p>
        </div>
      </div>
    </div>

    {/* Lead magnet — download data */}
    <div class="max-w-[1200px] mx-auto px-4 sm:px-6 mb-10">
      <DownloadLeadMagnet client:only="react" />
    </div>

    {/* Interactive map + table (shared state via React island) */}
    <div class="max-w-[1200px] mx-auto px-4 sm:px-6 mb-12">
      <DesertsAuditifsIsland
        client:only="react"
        data={departements}
        metadata={{ moyenne_nationale: metadata.moyenne_nationale }}
      />
    </div>

    {/* Editorial analysis */}
    <div class="max-w-[780px] mx-auto px-4 sm:px-6 mb-12">
      <h2 id="analyse" class="font-sans text-2xl font-bold text-marine mb-8">
        Analyse : la fracture auditive territoriale
      </h2>

      {/* Intro — accroche en gras */}
      <p class="font-sans text-lg text-marine leading-relaxed mb-8">
        <strong class="text-xl">J'ai dirigé 18 centres dans des régions très différentes</strong> — de la banlieue parisienne à des villes moyennes. Je savais que l'accès aux soins auditifs n'était pas le même partout. Mais en croisant les données officielles du RPPS et de l'INSEE, l'ampleur du déséquilibre m'a frappé.
      </p>

      {/* Section 1 — Ecart 1 a 4 */}
      <div class="mb-10 pb-10 border-b border-[#1B2E4A]/10">
        <h3 class="font-sans text-xl font-bold text-marine mb-5">Un écart de 1 à 4 entre départements</h3>

        {/* Stat callout */}
        <div class="flex flex-col sm:flex-row gap-4 mb-6">
          <div class="flex-1 bg-[#FFEBEE] border-l-4 border-[#C62828] rounded-r-xl px-5 py-4">
            <p class="font-serif text-3xl font-bold text-[#C62828]">4,19</p>
            <p class="font-sans text-sm text-[#C62828]/70">Haute-Marne — pour 100k hab.</p>
          </div>
          <div class="flex-1 bg-[#E8F5E9] border-l-4 border-[#2E7D32] rounded-r-xl px-5 py-4">
            <p class="font-serif text-3xl font-bold text-[#2E7D32]">17,13</p>
            <p class="font-sans text-sm text-[#2E7D32]/70">Paris — pour 100k hab.</p>
          </div>
        </div>

        <p class="font-sans text-base text-marine leading-relaxed mb-3">
          Quatre fois plus. Ce n'est pas un léger déséquilibre. <strong>C'est un gouffre.</strong>
        </p>
        <p class="font-sans text-base text-marine leading-relaxed">
          La moyenne nationale se situe à 8,37 pour 100 000 habitants. Mais cette moyenne ne veut pas dire grand-chose. Tout dépend de l'endroit où vous vivez.
        </p>
      </div>

      {/* Section 2 — Diagonale */}
      <div class="mb-10 pb-10 border-b border-[#1B2E4A]/10">
        <h3 class="font-sans text-xl font-bold text-marine mb-5">La diagonale du vide auditif</h3>
        <p class="font-sans text-base text-marine leading-relaxed mb-4">
          Regardez la carte. Un couloir se dessine, du nord-est vers le centre de la France. La Haute-Marne (4,19), l'Eure-et-Loir (5,08), l'Orne (5,15), la Haute-Saône (5,17). Population vieillissante, bassins d'emploi fragiles, peu de jeunes diplômés qui s'y installent. Le résultat est là.
        </p>

        {/* Stat callout Creuse */}
        <div class="bg-[#FFF3E0] border-l-4 border-[#E65100] rounded-r-xl px-5 py-4">
          <p class="font-sans text-base text-[#E65100]">
            <strong class="font-serif text-2xl">5</strong> audioprothésistes pour <strong>114 000</strong> habitants en Creuse.
            <span class="block text-sm mt-1 text-[#E65100]/70">Pour couvrir un territoire plus grand que certains départements d'Île-de-France.</span>
          </p>
        </div>
      </div>

      {/* Section 3 — SSD */}
      <div class="mb-10 pb-10 border-b border-[#1B2E4A]/10">
        <h3 class="font-sans text-xl font-bold text-marine mb-5">Le paradoxe Seine-Saint-Denis</h3>
        <p class="font-sans text-base text-marine leading-relaxed mb-4">
          On pourrait penser que la proximité de Paris protège ses voisins. Pas du tout. La Seine-Saint-Denis compte 91 audioprothésistes pour 1,7 million d'habitants — un ratio de 5,32 pour 100 000. Presque la moitié de la moyenne nationale.
        </p>
        <p class="font-sans text-base text-marine leading-relaxed mb-6">
          L'explication tient en un mot : <strong>concentration</strong>. Les cabinets s'installent là où le pouvoir d'achat est élevé. À Paris intra-muros, vous avez l'embarras du choix. De l'autre côté du périphérique, vous attendez des semaines. Selon la DREES, les inégalités de répartition des professionnels de santé suivent les inégalités économiques des territoires.
        </p>

        {/* Anecdote blockquote */}
        <blockquote class="bg-[#F8F5F0] border-l-4 border-[#D97B3D] rounded-r-xl px-6 py-5 italic">
          <p class="font-sans text-base text-marine leading-relaxed">
            "Je me souviens d'une patiente de 74 ans qui venait de Montreuil. Elle mettait 1 h 15 en transports pour venir à mon cabinet parisien, parce qu'aucun audioprothésiste près de chez elle ne pouvait la recevoir avant deux mois."
          </p>
          <p class="font-sans text-sm text-[#D97B3D] mt-2 not-italic font-medium">
            Ca ne devrait pas exister en Ile-de-France.
          </p>
        </blockquote>
      </div>

      {/* Section 4 — Le sud */}
      <div class="mb-10 pb-10 border-b border-[#1B2E4A]/10">
        <h3 class="font-sans text-xl font-bold text-marine mb-5">Le sud, terre d'accueil des audioprothésistes</h3>
        <p class="font-sans text-base text-marine leading-relaxed mb-4">
          De l'autre côté du classement, certains départements du sud font bien mieux que la moyenne. L'Ariège (12,76) et le Lot (13,60) dépassent la plupart des grandes métropoles. La raison ? Le cadre de vie. Les jeunes diplômés choisissent de plus en plus leur lieu d'installation en fonction de la qualité de vie, pas seulement du volume de patients. C'est un phénomène documenté par les études de la DREES sur la démographie des professions de santé.
        </p>
        <p class="font-sans text-base text-marine leading-relaxed">
          Bonne nouvelle pour les retraités du sud-ouest. Moins bonne pour ceux du Grand Est.
        </p>
      </div>

      {/* Section 5 — Population agee */}
      <div class="mb-10 pb-10 border-b border-[#1B2E4A]/10">
        <h3 class="font-sans text-xl font-bold text-marine mb-5">L'angle qui change tout : la population âgée</h3>
        <p class="font-sans text-base text-marine leading-relaxed mb-4">
          Notre étude utilise la population totale comme dénominateur — pour rester comparable aux données publiées. Mais regardons les choses autrement.
        </p>
        <p class="font-sans text-base text-marine leading-relaxed mb-6">
          90 % des personnes appareillées ont plus de 60 ans, selon les données de l'Assurance maladie. Un même ratio d'audioprothésistes ne signifie donc pas du tout la même chose selon la structure d'âge du département.
        </p>

        {/* Comparaison visuelle */}
        <div class="flex flex-col sm:flex-row gap-4">
          <div class="flex-1 bg-[#FFF3E0] border-l-4 border-[#E65100] rounded-r-xl px-5 py-4">
            <p class="font-sans text-sm text-[#E65100]/70 mb-1">Creuse</p>
            <p class="font-serif text-2xl font-bold text-[#E65100]">40 %</p>
            <p class="font-sans text-xs text-[#E65100]/60">de la population a plus de 60 ans</p>
          </div>
          <div class="flex-1 bg-[#E3F2FD] border-l-4 border-[#1565C0] rounded-r-xl px-5 py-4">
            <p class="font-sans text-sm text-[#1565C0]/70 mb-1">Seine-Saint-Denis</p>
            <p class="font-serif text-2xl font-bold text-[#1565C0]">19 %</p>
            <p class="font-sans text-xs text-[#1565C0]/60">de la population a plus de 60 ans</p>
          </div>
        </div>
        <p class="font-sans text-base text-marine leading-relaxed mt-5">
          Les départements ruraux cumulent les handicaps : moins de professionnels <strong>et</strong> une population plus âgée.
        </p>
      </div>

      {/* Section 6 — Consequences : cards grid */}
      <div class="mb-8">
        <h3 class="font-sans text-xl font-bold text-marine mb-5">Ce que ça change pour vous, concrètement</h3>
        <p class="font-sans text-base text-marine leading-relaxed mb-6">
          Si vous habitez dans un département sous-doté, les conséquences sont directes.
        </p>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-8">
          <div class="bg-white rounded-xl border border-[#1B2E4A]/10 p-5 shadow-[0_1px_4px_rgba(27,46,74,0.05)]">
            <div class="flex items-center gap-2 mb-2">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#C62828" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              <h4 class="font-sans text-base font-bold text-marine">Des délais allongés</h4>
            </div>
            <p class="font-sans text-sm text-gris-texte leading-relaxed">Plusieurs semaines d'attente, parfois deux mois pour un premier bilan. Dans les zones les plus tendues, c'est la norme.</p>
          </div>
          <div class="bg-white rounded-xl border border-[#1B2E4A]/10 p-5 shadow-[0_1px_4px_rgba(27,46,74,0.05)]">
            <div class="flex items-center gap-2 mb-2">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#C62828" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
              <h4 class="font-sans text-base font-bold text-marine">Des trajets pénibles</h4>
            </div>
            <p class="font-sans text-sm text-gris-texte leading-relaxed">Le cabinet le plus proche peut se trouver à 45 minutes de route. Pour une personne âgée qui ne conduit plus, c'est un obstacle réel.</p>
          </div>
          <div class="bg-white rounded-xl border border-[#1B2E4A]/10 p-5 shadow-[0_1px_4px_rgba(27,46,74,0.05)]">
            <div class="flex items-center gap-2 mb-2">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#C62828" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
              <h4 class="font-sans text-base font-bold text-marine">Un suivi difficile</h4>
            </div>
            <p class="font-sans text-sm text-gris-texte leading-relaxed">L'adaptation demande 4 à 6 rendez-vous la première année (HAS). Quand chaque visite est une expédition, certains patients espacent — ou abandonnent.</p>
          </div>
          <div class="bg-white rounded-xl border border-[#1B2E4A]/10 p-5 shadow-[0_1px_4px_rgba(27,46,74,0.05)]">
            <div class="flex items-center gap-2 mb-2">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#C62828" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
              <h4 class="font-sans text-base font-bold text-marine">Risque d'abandon</h4>
            </div>
            <p class="font-sans text-sm text-gris-texte leading-relaxed">La DREES estime qu'un tiers des personnes appareillées n'utilisent pas régulièrement leurs aides auditives. La distance est l'un des facteurs identifiés.</p>
          </div>
        </div>

        <p class="font-sans text-base text-marine leading-relaxed">
          Ces données ne sont pas une fatalité. Elles dessinent une carte des priorités. Si vous êtes concerné, la première étape reste de <a href="/trouver-audioprothesiste" class="text-[#9A5515] underline hover:no-underline font-semibold">localiser les professionnels disponibles près de chez vous</a>.
        </p>
      </div>
    </div>

    {/* Methodology */}
    <div class="max-w-[780px] mx-auto px-4 sm:px-6 mb-12">
      <h2 id="methodologie" class="font-sans text-2xl font-bold text-marine mb-6">
        Méthodologie
      </h2>
