---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';

const breadcrumbs = [
  { label: 'Accueil', href: '/' },
  { label: 'Contact' },
];

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'ContactPage',
    name: 'Contactez LeGuideAuditif.fr',
    url: 'https://leguideauditif.fr/contact/',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: breadcrumbs.map((item, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      name: item.label,
      ...(item.href && { item: new URL(item.href, 'https://leguideauditif.fr').href }),
    })),
  },
];
---

<BaseLayout
  title="Contact — LeGuideAuditif.fr"
  description="Contactez l'équipe de LeGuideAuditif.fr pour toute question sur nos guides, partenariats ou demande de renseignements."
  schema={schema}
>
  <div class="bg-creme">
    <div class="max-w-[780px] mx-auto px-5">
      <Breadcrumbs items={breadcrumbs} />
    </div>
  </div>

  <section class="bg-creme pt-8 pb-16">
    <div class="max-w-[780px] mx-auto px-5">
      <h1 class="font-sans text-[32px] lg:text-[38px] font-extrabold text-marine leading-tight mb-4">Nous contacter</h1>
      <p class="text-lg leading-relaxed text-gris-texte mb-10">
        Une question sur nos guides ? Une demande de partenariat ? Remplissez le formulaire ci-dessous et nous vous répondrons dans les meilleurs délais.
      </p>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- Formulaire -->
        <div class="lg:col-span-2">
          <form id="contact-form" class="bg-blanc rounded-2xl p-6 sm:p-8 border border-gris-clair space-y-5">
            <div>
              <label for="contact-name" class="block font-sans text-sm font-semibold text-marine mb-2">Nom complet</label>
              <input
                type="text"
                id="contact-name"
                name="name"
                required
                autocomplete="name"
                class="w-full px-4 py-3 border border-gris-clair rounded-lg font-sans text-base text-marine focus:outline-none focus:ring-2 focus:ring-orange focus:border-orange"
                placeholder="Votre nom"
              />
            </div>
            <div>
              <label for="contact-email" class="block font-sans text-sm font-semibold text-marine mb-2">Adresse email</label>
              <input
                type="email"
                id="contact-email"
                name="email"
                required
                autocomplete="email"
                class="w-full px-4 py-3 border border-gris-clair rounded-lg font-sans text-base text-marine focus:outline-none focus:ring-2 focus:ring-orange focus:border-orange"
                placeholder="votre@email.fr"
              />
            </div>
            <div>
              <label for="contact-subject" class="block font-sans text-sm font-semibold text-marine mb-2">Sujet</label>
              <select
                id="contact-subject"
                name="subject"
                required
                class="w-full px-4 py-3 border border-gris-clair rounded-lg font-sans text-base text-marine focus:outline-none focus:ring-2 focus:ring-orange focus:border-orange bg-blanc"
              >
                <option value="">Sélectionnez un sujet</option>
                <option value="question-guide">Question sur un guide</option>
                <option value="partenariat">Proposition de partenariat</option>
                <option value="audioprothesiste">Je suis audioprothésiste</option>
                <option value="correction">Signaler une erreur</option>
                <option value="autre">Autre demande</option>
              </select>
            </div>
            <div>
              <label for="contact-message" class="block font-sans text-sm font-semibold text-marine mb-2">Message</label>
              <textarea
                id="contact-message"
                name="message"
                required
                rows="5"
                class="w-full px-4 py-3 border border-gris-clair rounded-lg font-sans text-base text-marine focus:outline-none focus:ring-2 focus:ring-orange focus:border-orange resize-y"
                placeholder="Décrivez votre demande..."
              ></textarea>
            </div>
            <div>
              <button
                type="submit"
                class="w-full sm:w-auto px-8 py-3 bg-orange text-white font-sans font-semibold rounded-lg hover:bg-orange-hover transition-colors cursor-pointer"
              >
                Envoyer le message
              </button>
            </div>
            <p id="contact-success" class="hidden text-sm font-sans text-green-700 bg-green-50 border border-green-200 rounded-lg px-4 py-3">
              Votre message a bien été envoyé. Nous vous répondrons dans les meilleurs délais.
            </p>
            <p id="contact-error" class="hidden text-sm font-sans text-red-700 bg-red-50 border border-red-200 rounded-lg px-4 py-3">
              Une erreur est survenue. Veuillez réessayer ou nous contacter directement par email.
            </p>
          </form>
        </div>

        <!-- Sidebar info -->
        <aside class="space-y-6">
          <div class="bg-blanc rounded-2xl p-6 border border-gris-clair">
            <h2 class="font-sans text-lg font-bold text-marine mb-3">Par email</h2>
            <a href="mailto:contact@leguideauditif.fr" class="text-orange font-semibold text-base hover:underline">contact@leguideauditif.fr</a>
          </div>
          <div class="bg-blanc rounded-2xl p-6 border border-gris-clair">
            <h2 class="font-sans text-lg font-bold text-marine mb-3">Délai de réponse</h2>
            <p class="text-base text-gris-texte">Nous répondons généralement sous 48 heures ouvrées.</p>
          </div>
          <div class="bg-blanc rounded-2xl p-6 border border-gris-clair">
            <h2 class="font-sans text-lg font-bold text-marine mb-3">Audioprothésistes</h2>
            <p class="text-base text-gris-texte">Vous souhaitez apparaître dans notre annuaire ? Sélectionnez "Je suis audioprothésiste" dans le formulaire.</p>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <script>
    const form = document.getElementById('contact-form') as HTMLFormElement;
    const successMsg = document.getElementById('contact-success');
    const errorMsg = document.getElementById('contact-error');

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      successMsg?.classList.add('hidden');
      errorMsg?.classList.add('hidden');

      const data = Object.fromEntries(new FormData(form));

      try {
        const res = await fetch('/api/contact', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });

        if (res.ok) {
          successMsg?.classList.remove('hidden');
          form.reset();
        } else {
          errorMsg?.classList.remove('hidden');
        }
      } catch {
        errorMsg?.classList.remove('hidden');
      }
    });
  </script>
</BaseLayout>
