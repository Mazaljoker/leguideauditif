---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { Icon } from 'astro-icon/components';

const breadcrumbs = [
  { label: 'Accueil', href: '/' },
  { label: 'À propos' },
];

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'AboutPage',
    name: 'À propos de LeGuideAuditif.fr',
    url: 'https://leguideauditif.fr/a-propos/',
    description: "Le guide indépendant sur l'audition rédigé par Franck-Olivier Chabbat, audioprothésiste DE avec 28 ans d'expérience clinique et 5 ans chez Auzen.com, leader européen de la vente en ligne d'aides auditives.",
    author: {
      '@type': 'Person',
      '@id': 'https://leguideauditif.fr/#author',
      name: 'Franck-Olivier Chabbat',
      givenName: 'Franck-Olivier',
      familyName: 'Chabbat',
      jobTitle: "Audioprothésiste diplômé d'État",
      description: "28 ans d'expérience en audioprothèse — Amplifon, Audika, 18 centres Afflelou, 5 ans Auzen.com, 3 000+ patients appareillés.",
      url: 'https://leguideauditif.fr/a-propos/',
      sameAs: [
        'https://www.linkedin.com/in/franck-olivier-chabbat-/',
        'https://annuaire.sante.fr/web/site-pro/extranet/professionnel/692606494',
        'https://www.facebook.com/leguideauditif/',
        'https://www.instagram.com/leguideauditif/',
        'https://www.linkedin.com/company/leguideauditif/'
      ],
      alumniOf: {
        '@type': 'EducationalOrganization',
        name: 'ISTR Lyon — Institut des Sciences et Techniques de Réadaptation',
        url: 'https://istr.univ-lyon1.fr/'
      },
      hasCredential: [
        {
          '@type': 'EducationalOccupationalCredential',
          credentialCategory: 'degree',
          name: "Diplôme d'État d'audioprothésiste",
          recognizedBy: {
            '@type': 'Organization',
            name: 'Ministère de la Santé'
          }
        }
      ],
      identifier: {
        '@type': 'PropertyValue',
        propertyID: 'ADELI',
        value: '692606494',
        description: 'Numéro ADELI — Répertoire national des professionnels de santé'
      },
      worksFor: {
        '@type': 'Organization',
        name: 'LeGuideAuditif.fr',
        url: 'https://leguideauditif.fr'
      },
      knowsAbout: [
        'audioprothese',
        'appareils auditifs',
        'perte auditive',
        'acouphenes',
        'presbyacousie',
        'commerce en ligne d\'aides auditives',
        'comparaison de puces auditives',
        'marges et tarification en audioprothese'
      ]
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: breadcrumbs.map((item, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      name: item.label,
      ...(item.href && { item: new URL(item.href, 'https://leguideauditif.fr').href }),
    })),
  },
];
---

<BaseLayout
  title="À propos de LeGuideAuditif — Guide santé auditive"
  description="Franck-Olivier Chabbat, audioprothésiste DE, 28 ans d'expérience. Découvrez pourquoi j'ai créé LeGuideAuditif, le guide indépendant sur l'audition."
  schema={schema}
>
  <div class="bg-creme">
    <div class="max-w-[780px] mx-auto px-5">
      <Breadcrumbs items={breadcrumbs} />
    </div>
  </div>

  <!-- Hero section -->
  <section class="bg-creme pt-8 pb-12">
    <div class="max-w-[780px] mx-auto px-5">
      <h1 class="font-sans text-[32px] lg:text-[38px] font-extrabold text-marine leading-tight mb-6">28 ans d'audioprothèse, 5 ans chez Auzen.com : je lève le voile sur les appareils auditifs</h1>
      <p class="text-xl leading-relaxed text-gris-texte mb-4 font-serif">
        Quand on commence à moins bien entendre, on découvre un univers opaque : des devis à 3 000&nbsp;&euro;, du jargon technique incompréhensible, et très peu d'information réellement indépendante. <strong class="text-marine">J'ai passé 28 ans en cabinet et 5 ans chez un leader européen de la vente d'aides auditives en ligne.</strong> Aujourd'hui, je ne vends plus rien. Je vous dis tout.
      </p>
    </div>
  </section>

  <!-- Mon Parcours -->
  <section class="bg-blanc py-12">
    <div class="max-w-[780px] mx-auto px-5">
      <h2 class="font-sans text-2xl font-bold text-marine mb-6">Mon parcours</h2>
      <p class="text-lg leading-relaxed mb-8">
        Ce n'est pas un parcours linéaire, et c'est justement ce qui fait sa valeur. J'ai vu l'audition depuis le fauteuil du patient, depuis le bureau du directeur de centre, et depuis les coulisses d'un géant du e-commerce auditif.
      </p>
      <ol class="space-y-6 mb-6">
        <li class="flex gap-4">
          <span class="w-8 h-8 bg-orange text-white rounded-full flex items-center justify-center font-sans font-bold text-sm shrink-0 mt-0.5">1</span>
          <div>
            <strong class="font-sans text-marine">Formation à l'ISTR Lyon</strong>
            <p class="text-gris-texte text-base mt-1">Diplôme d'État d'audioprothésiste obtenu à l'Institut des Sciences et Techniques de Réadaptation (Université Claude Bernard Lyon 1). Trois ans d'une formation exigeante combinant sciences médicales, acoustique et pratique clinique.</p>
          </div>
        </li>
        <li class="flex gap-4">
          <span class="w-8 h-8 bg-orange text-white rounded-full flex items-center justify-center font-sans font-bold text-sm shrink-0 mt-0.5">2</span>
          <div>
            <strong class="font-sans text-marine">Amplifon (1998-2000) &mdash; les fondamentaux</strong>
            <p class="text-gris-texte text-base mt-1">Mes débuts chez le leader mondial m'ont donné les fondamentaux cliniques et une vision internationale du métier. C'est là que j'ai appris à adapter, pas à vendre.</p>
          </div>
        </li>
        <li class="flex gap-4">
          <span class="w-8 h-8 bg-orange text-white rounded-full flex items-center justify-center font-sans font-bold text-sm shrink-0 mt-0.5">3</span>
          <div>
            <strong class="font-sans text-marine">Audika (2007-2013) &mdash; le réseau français</strong>
            <p class="text-gris-texte text-base mt-1">J'ai vécu de l'intérieur le fonctionnement d'un réseau français de 500+ centres &mdash; avec ses forces et ses limites. Une immersion dans la machine commerciale de l'audioprothèse à la française.</p>
          </div>
        </li>
        <li class="flex gap-4">
          <span class="w-8 h-8 bg-orange text-white rounded-full flex items-center justify-center font-sans font-bold text-sm shrink-0 mt-0.5">4</span>
          <div>
            <strong class="font-sans text-marine">18 centres Alain Afflelou Acousticien &mdash; le terrain</strong>
            <p class="text-gris-texte text-base mt-1">À la tête de 18 centres, j'ai dirigé des équipes, géré des milliers de patients et développé une approche pragmatique de l'appareillage. Plus de 3 000 patients appareillés et suivis sur le long terme. C'est là que j'ai appris l'essentiel : <strong class="text-marine">ce qui compte, ce n'est pas l'appareil le plus cher, c'est celui qui correspond à votre perte auditive, à votre mode de vie et à votre budget.</strong></p>
          </div>
        </li>
        <li class="flex gap-4">
          <span class="w-8 h-8 bg-orange text-white rounded-full flex items-center justify-center font-sans font-bold text-sm shrink-0 mt-0.5">5</span>
          <div>
            <strong class="font-sans text-marine">5 ans chez Auzen.com &mdash; les coulisses de l'industrie</strong>
            <p class="text-gris-texte text-base mt-1">J'ai rejoint <strong class="text-marine">Auzen.com</strong>, l'un des pionniers de la vente d'appareils auditifs en ligne en Europe. Pendant 5 ans, j'ai rédigé une grande partie de leur catalogue technique. J'ai découvert l'envers du décor : les <strong class="text-marine">marges réelles</strong> pratiquées dans l'industrie, les <strong class="text-marine">différences concrètes entre les puces</strong> (Phonak, Signia, Starkey...), les stratégies de positionnement des fabricants, et surtout &mdash; pourquoi le marché reste aussi opaque. Spoiler : cette opacité profite à toute la chaîne, sauf au patient.</p>
          </div>
        </li>
        <li class="flex gap-4">
          <span class="w-8 h-8 bg-orange text-white rounded-full flex items-center justify-center font-sans font-bold text-sm shrink-0 mt-0.5">6</span>
          <div>
            <strong class="font-sans text-marine">Le déclic &mdash; création de LeGuideAuditif.fr</strong>
            <p class="text-gris-texte text-base mt-1">J'ai décidé de quitter la vente directe. Ce parcours 360&deg; &mdash; du cabinet traditionnel aux géants du secteur, de l'enseigne physique au pure player web &mdash; me donne un regard que peu d'audioprothésistes ont. J'ai créé LeGuideAuditif.fr avec un objectif simple : <strong class="text-marine">rendre le pouvoir aux patients</strong>. Je ne vends pas d'appareils. J'offre de l'information technique 100 % transparente, des avis impartiaux sur les modèles, et un annuaire de plus de 7 500 centres auditifs pour vous aider à trouver le bon professionnel, au bon prix, près de chez vous.</p>
          </div>
        </li>
      </ol>
    </div>
  </section>

  <!-- Auteur / E-E-A-T -->
  <section class="bg-creme py-12">
    <div class="max-w-[780px] mx-auto px-5">
      <h2 class="font-sans text-2xl font-bold text-marine mb-6">Qui suis-je ?</h2>
      <div class="bg-blanc border border-gris-clair rounded-2xl p-8 mb-8">
        <div class="flex flex-col sm:flex-row items-start gap-6">
          <img
            src="/images/franck-olivier-chabbat.jpg"
            alt="Franck-Olivier Chabbat, audioprothésiste diplômé d'État"
            width="96"
            height="96"
            class="w-24 h-24 rounded-full object-cover shrink-0"
            loading="eager"
          />
          <div>
            <div class="font-sans text-xl font-bold text-marine mb-1">Franck-Olivier Chabbat</div>
            <div class="font-sans text-base text-orange font-medium mb-3">Audioprothésiste diplômé d'État &mdash; 28 ans d'expérience</div>

            <!-- Badge ADELI -->
            <div class="inline-flex items-center gap-2 bg-creme border border-gris-clair px-4 py-2 rounded-lg text-sm font-sans mb-4">
              <Icon name="lucide:shield-check" class="w-4 h-4 text-orange" aria-hidden="true" />
              <span>N. ADELI : <strong class="text-marine">692606494</strong></span>
            </div>

            <p class="text-base leading-relaxed mb-4">
              Diplômé de l'ISTR Lyon en 1998. Après avoir forgé mon expertise chez les leaders historiques (Amplifon, Audika) et dirigé 18 centres Alain Afflelou Acousticien, j'ai passé 5 ans chez <strong class="text-marine">Auzen.com</strong> entre téléaudiologie et vente en ligne. 28 ans de pratique, 3 000+ patients.
            </p>
            <p class="text-base leading-relaxed mb-4">
              Ce parcours 360&deg; &mdash; du cabinet traditionnel aux géants du secteur, de l'enseigne physique au pure player web &mdash; me donne un regard que peu de professionnels possèdent. Sur LeGuideAuditif.fr, je partage cette connaissance sans filtre : les vraies différences entre les appareils, les pièges à éviter, et les conseils que je donnerais à mes propres parents.
            </p>

            <!-- Réseaux sociaux -->
            <div class="flex flex-wrap items-center gap-3 mt-2">
              <a href="https://www.linkedin.com/in/franck-olivier-chabbat-/" target="_blank" rel="noopener noreferrer"
                 class="inline-flex items-center gap-2 text-orange text-sm font-sans font-medium no-underline hover:underline">
                <Icon name="lucide:linkedin" class="w-4 h-4" aria-hidden="true" />
                LinkedIn perso
              </a>
              <span class="text-gris-clair" aria-hidden="true">|</span>
              <a href="https://www.facebook.com/leguideauditif/" target="_blank" rel="noopener noreferrer"
                 class="inline-flex items-center gap-2 text-orange text-sm font-sans font-medium no-underline hover:underline">
                <Icon name="lucide:facebook" class="w-4 h-4" aria-hidden="true" />
                Facebook
              </a>
              <a href="https://www.instagram.com/leguideauditif/" target="_blank" rel="noopener noreferrer"
                 class="inline-flex items-center gap-2 text-orange text-sm font-sans font-medium no-underline hover:underline">
                <Icon name="lucide:instagram" class="w-4 h-4" aria-hidden="true" />
                Instagram
              </a>
              <a href="https://www.linkedin.com/company/leguideauditif/" target="_blank" rel="noopener noreferrer"
                 class="inline-flex items-center gap-2 text-orange text-sm font-sans font-medium no-underline hover:underline">
                <Icon name="lucide:linkedin" class="w-4 h-4" aria-hidden="true" />
                LinkedIn page
              </a>
            </div>
          </div>
        </div>
      </div>

      <!-- Badge Verifie par un expert -->
      <div class="bg-marine rounded-2xl p-6 mb-8 flex flex-col sm:flex-row items-center gap-5">
        <div class="w-16 h-16 bg-orange/20 rounded-full flex items-center justify-center shrink-0">
          <Icon name="lucide:badge-check" class="w-8 h-8 text-orange" aria-hidden="true" />
        </div>
        <div class="text-center sm:text-left">
          <div class="font-sans text-lg font-bold text-white mb-1">Contenu vérifié par un expert</div>
          <p class="text-white/80 text-sm leading-relaxed">
            Tous les guides et comparatifs publiés sur LeGuideAuditif.fr sont rédigés ou supervisés par Franck-Olivier Chabbat, audioprothésiste DE (ISTR Lyon), ADELI 692606494. Avec 28 ans de pratique clinique &mdash; Amplifon, Audika, 18 centres Afflelou, 5 ans Auzen.com &mdash; chaque article suit un processus de double validation qualité avant publication.
          </p>
        </div>
      </div>

      <!-- Credentials -->
      <h3 class="font-sans text-xl font-bold text-marine mb-4">Parcours et qualifications</h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-8">
        <div class="bg-blanc rounded-xl p-5 border border-gris-clair">
          <Icon name="lucide:graduation-cap" class="w-5 h-5 text-orange mb-2" aria-hidden="true" />
          <div class="font-sans text-sm font-semibold text-orange uppercase tracking-wide mb-2">Formation</div>
          <p class="text-base text-marine">Diplôme d'État d'audioprothésiste &mdash; ISTR Lyon (Université Claude Bernard Lyon 1)</p>
        </div>
        <div class="bg-blanc rounded-xl p-5 border border-gris-clair">
          <Icon name="lucide:calendar-clock" class="w-5 h-5 text-orange mb-2" aria-hidden="true" />
          <div class="font-sans text-sm font-semibold text-orange uppercase tracking-wide mb-2">Expérience</div>
          <p class="text-base text-marine">28 ans &mdash; Amplifon, Audika, Afflelou, Auzen</p>
        </div>
        <div class="bg-blanc rounded-xl p-5 border border-gris-clair">
          <Icon name="lucide:building-2" class="w-5 h-5 text-orange mb-2" aria-hidden="true" />
          <div class="font-sans text-sm font-semibold text-orange uppercase tracking-wide mb-2">Management</div>
          <p class="text-base text-marine">18 centres Alain Afflelou Acousticien dirigés</p>
        </div>
        <div class="bg-blanc rounded-xl p-5 border border-gris-clair">
          <Icon name="lucide:users" class="w-5 h-5 text-orange mb-2" aria-hidden="true" />
          <div class="font-sans text-sm font-semibold text-orange uppercase tracking-wide mb-2">Patients</div>
          <p class="text-base text-marine">3 000+ patients appareillés et suivis</p>
        </div>
        <div class="bg-blanc rounded-xl p-5 border border-gris-clair">
          <Icon name="lucide:globe" class="w-5 h-5 text-orange mb-2" aria-hidden="true" />
          <div class="font-sans text-sm font-semibold text-orange uppercase tracking-wide mb-2">Industrie</div>
          <p class="text-base text-marine">5 ans chez Auzen.com &mdash; téléaudiologie et vente en ligne</p>
        </div>
        <div class="bg-blanc rounded-xl p-5 border border-gris-clair">
          <Icon name="lucide:shield-check" class="w-5 h-5 text-orange mb-2" aria-hidden="true" />
          <div class="font-sans text-sm font-semibold text-orange uppercase tracking-wide mb-2">Enregistrement professionnel</div>
          <p class="text-base text-marine">N. ADELI 692606494 &mdash; Répertoire national des professionnels de santé</p>
        </div>
      </div>
    </div>
  </section>

  <!-- La Mission du Guide Auditif -->
  <section class="bg-blanc py-12">
    <div class="max-w-[780px] mx-auto px-5">
      <h2 class="font-sans text-2xl font-bold text-marine mb-6">La mission du Guide Auditif</h2>
      <p class="text-lg leading-relaxed mb-8">
        Mon objectif est simple : vous donner les clés pour comprendre le marché de l'audition et faire les bons choix, sans dépendre de celui qui vous vend l'appareil.
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        <div class="bg-creme rounded-2xl p-6 border border-gris-clair">
          <div class="w-12 h-12 bg-orange/10 rounded-xl flex items-center justify-center mb-4">
            <Icon name="lucide:book-open" class="w-6 h-6 text-orange" aria-hidden="true" />
          </div>
          <h3 class="font-sans text-lg font-bold text-marine mb-2">Information décryptée</h3>
          <p class="text-base text-gris-texte leading-relaxed">
            Des guides techniques rédigés par un professionnel qui connaît les produits de l'intérieur. Pas du marketing fabricant, pas des fiches recopiées : des <strong class="text-marine">analyses indépendantes</strong> basées sur l'expérience clinique et la connaissance industrielle.
          </p>
        </div>
        <div class="bg-creme rounded-2xl p-6 border border-gris-clair">
          <div class="w-12 h-12 bg-orange/10 rounded-xl flex items-center justify-center mb-4">
            <Icon name="lucide:map-pin" class="w-6 h-6 text-orange" aria-hidden="true" />
          </div>
          <h3 class="font-sans text-lg font-bold text-marine mb-2">Plus de 7 500 centres recensés</h3>
          <p class="text-base text-gris-texte leading-relaxed">
            Une <strong class="text-marine">carte interactive gratuite</strong> recensant plus de 7 500 centres auditifs en France. Pour vous aider à trouver le bon professionnel, au bon prix, près de chez vous.
          </p>
          <a href="/trouver-audioprothesiste/" class="inline-flex items-center gap-2 text-orange hover:underline text-sm font-sans font-medium mt-3 no-underline hover:no-underline">
            Voir la carte
            <Icon name="lucide:arrow-right" class="w-4 h-4" aria-hidden="true" />
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Pourquoi me faire confiance -->
  <section class="bg-creme py-12">
    <div class="max-w-[780px] mx-auto px-5">
      <h2 class="font-sans text-2xl font-bold text-marine mb-6">Pourquoi me faire confiance</h2>
      <div class="space-y-6">
        <div class="flex items-start gap-4">
          <div class="w-10 h-10 bg-orange/10 rounded-lg flex items-center justify-center shrink-0 mt-0.5">
            <Icon name="lucide:shield-check" class="w-5 h-5 text-orange" aria-hidden="true" />
          </div>
          <div>
            <strong class="font-sans text-marine text-lg">Indépendance totale</strong>
            <p class="text-base text-gris-texte leading-relaxed mt-1">Aucun lien capitalistique avec un fabricant d'appareils auditifs ou une enseigne. J'ai <strong class="text-marine">quitté la vente</strong> pour créer ce guide. Mon seul engagement est envers vous, pas envers un catalogue produit.</p>
          </div>
        </div>
        <div class="flex items-start gap-4">
          <div class="w-10 h-10 bg-orange/10 rounded-lg flex items-center justify-center shrink-0 mt-0.5">
            <Icon name="lucide:cpu" class="w-5 h-5 text-orange" aria-hidden="true" />
          </div>
          <div>
            <strong class="font-sans text-marine text-lg">Transparence technique</strong>
            <p class="text-base text-gris-texte leading-relaxed mt-1">Je compare les appareils sur des <strong class="text-marine">critères objectifs</strong> : qualité de la puce, réduction du bruit, connectivité, autonomie, confort. Je connais les différences réelles entre Phonak, Signia, Starkey, ReSound et Oticon &mdash; pas les arguments commerciaux. Je présente toujours les options Classe 1 (reste à charge zéro) et Classe 2.</p>
          </div>
        </div>
        <div class="flex items-start gap-4">
          <div class="w-10 h-10 bg-orange/10 rounded-lg flex items-center justify-center shrink-0 mt-0.5">
            <Icon name="lucide:map-pin" class="w-5 h-5 text-orange" aria-hidden="true" />
          </div>
          <div>
            <strong class="font-sans text-marine text-lg">Proximité</strong>
            <p class="text-base text-gris-texte leading-relaxed mt-1">Un appareil auditif, ça s'essaie en centre. C'est pourquoi je mets à votre disposition un <strong class="text-marine">annuaire gratuit de plus de 7 500 centres auditifs</strong> en France, pour que vous puissiez trouver un professionnel qualifié près de chez vous.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Methodologie editoriale -->
  <section class="bg-blanc py-12">
    <div class="max-w-[780px] mx-auto px-5">
      <h2 class="font-sans text-2xl font-bold text-marine mb-6">Ma méthodologie éditoriale</h2>
      <p class="text-lg leading-relaxed mb-6">
        Chaque guide publié sur LeGuideAuditif.fr suit un processus rigoureux pour garantir la fiabilité de l'information :
      </p>
      <ol class="space-y-4 mb-8">
        <li class="flex gap-4">
          <span class="w-8 h-8 bg-orange text-white rounded-full flex items-center justify-center font-sans font-bold text-sm shrink-0">1</span>
          <div>
            <strong class="font-sans text-marine">Recherche sourcée</strong>
            <p class="text-gris-texte text-base mt-1">Chaque affirmation médicale est fondée sur des sources officielles : HAS, INSERM, OMS, PubMed. Je privilégie les études de moins de 3 ans.</p>
          </div>
        </li>
        <li class="flex gap-4">
          <span class="w-8 h-8 bg-orange text-white rounded-full flex items-center justify-center font-sans font-bold text-sm shrink-0">2</span>
          <div>
            <strong class="font-sans text-marine">Rédaction par un professionnel</strong>
            <p class="text-gris-texte text-base mt-1">Le contenu est rédigé ou supervisé par un audioprothésiste DE, avec une double expertise clinique et industrielle. Le ton est accessible (Flesch FR 60-80) et le vouvoiement systématique.</p>
          </div>
        </li>
        <li class="flex gap-4">
          <span class="w-8 h-8 bg-orange text-white rounded-full flex items-center justify-center font-sans font-bold text-sm shrink-0">3</span>
          <div>
            <strong class="font-sans text-marine">Double validation qualité</strong>
            <p class="text-gris-texte text-base mt-1">Chaque article passe un double contrôle : évaluation de contenu (score minimum 70/100) puis vérification de conformité E-E-A-T (score minimum 80/100).</p>
          </div>
        </li>
        <li class="flex gap-4">
