---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { Icon } from 'astro-icon/components';

const breadcrumbs = [
  { label: 'Accueil', href: '/' },
  { label: 'A propos' },
];

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'AboutPage',
    name: 'A propos de LeGuideAuditif.fr',
    url: 'https://leguideauditif.fr/a-propos/',
    description: "Le guide independant sur l'audition redige par Franck-Olivier Chabbat, audioprothesiste DE avec 28 ans d'experience clinique et 5 ans chez Auzen.com, leader europeen de la vente en ligne d'aides auditives.",
    author: {
      '@type': 'Person',
      '@id': 'https://leguideauditif.fr/#author',
      name: 'Franck-Olivier Chabbat',
      givenName: 'Franck-Olivier',
      familyName: 'Chabbat',
      jobTitle: "Audioprothesiste diplome d'Etat",
      description: "28 ans d'experience en audioprothese, 18 centres diriges, 3 000+ patients appareilles, 5 ans chez Auzen.com — leader europeen de la vente en ligne d'aides auditives.",
      url: 'https://leguideauditif.fr/a-propos/',
      sameAs: [
        'https://www.linkedin.com/in/franck-olivier-chabbat-/'
      ],
      alumniOf: {
        '@type': 'EducationalOrganization',
        name: 'ISTR Lyon — Institut des Sciences et Techniques de Readaptation',
        url: 'https://istr.univ-lyon1.fr/'
      },
      hasCredential: [
        {
          '@type': 'EducationalOccupationalCredential',
          credentialCategory: 'degree',
          name: "Diplome d'Etat d'audioprothesiste",
          recognizedBy: {
            '@type': 'Organization',
            name: 'Ministere de la Sante'
          }
        }
      ],
      identifier: {
        '@type': 'PropertyValue',
        propertyID: 'ADELI',
        value: '692606494',
        description: 'Numero ADELI — Repertoire national des professionnels de sante'
      },
      worksFor: {
        '@type': 'Organization',
        name: 'LeGuideAuditif.fr',
        url: 'https://leguideauditif.fr'
      },
      knowsAbout: [
        'audioprothese',
        'appareils auditifs',
        'perte auditive',
        'acouphenes',
        'presbyacousie',
        'commerce en ligne d\'aides auditives',
        'comparaison de puces auditives',
        'marges et tarification en audioprothese'
      ]
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: breadcrumbs.map((item, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      name: item.label,
      ...(item.href && { item: new URL(item.href, 'https://leguideauditif.fr').href }),
    })),
  },
];
---

<BaseLayout
  title="A propos — LeGuideAuditif.fr"
  description="Franck-Olivier Chabbat, audioprothesiste DE (ISTR Lyon), 28 ans d'experience clinique, 5 ans chez Auzen.com. Decouvrez pourquoi j'ai cree le guide independant sur l'audition."
  schema={schema}
>
  <div class="bg-creme">
    <div class="max-w-[780px] mx-auto px-5">
      <Breadcrumbs items={breadcrumbs} />
    </div>
  </div>

  <!-- Hero section -->
  <section class="bg-creme pt-8 pb-12">
    <div class="max-w-[780px] mx-auto px-5">
      <h1 class="font-sans text-[32px] lg:text-[38px] font-extrabold text-marine leading-tight mb-6">28 ans d'audioprothese, 5 ans chez Auzen.com : je leve le voile sur les appareils auditifs</h1>
      <p class="text-xl leading-relaxed text-gris-texte mb-4 font-serif">
        Quand on commence a moins bien entendre, on decouvre un univers opaque : des devis a 3 000&nbsp;&euro;, du jargon technique incomprehensible, et tres peu d'information reellement independante. <strong class="text-marine">J'ai passe 28 ans en cabinet et 5 ans chez un leader europeen de la vente d'aides auditives en ligne.</strong> Aujourd'hui, je ne vends plus rien. Je vous dis tout.
      </p>
    </div>
  </section>

  <!-- Mon Parcours -->
  <section class="bg-blanc py-12">
    <div class="max-w-[780px] mx-auto px-5">
      <h2 class="font-sans text-2xl font-bold text-marine mb-6">Mon parcours</h2>
      <p class="text-lg leading-relaxed mb-8">
        Ce n'est pas un parcours lineaire, et c'est justement ce qui fait sa valeur. J'ai vu l'audition depuis le fauteuil du patient, depuis le bureau du directeur de centre, et depuis les coulisses d'un geant du e-commerce auditif.
      </p>
      <ol class="space-y-6 mb-6">
        <li class="flex gap-4">
          <span class="w-8 h-8 bg-orange text-white rounded-full flex items-center justify-center font-sans font-bold text-sm shrink-0 mt-0.5">1</span>
          <div>
            <strong class="font-sans text-marine">Formation a l'ISTR Lyon</strong>
            <p class="text-gris-texte text-base mt-1">Diplome d'Etat d'audioprothesiste obtenu a l'Institut des Sciences et Techniques de Readaptation (Universite Claude Bernard Lyon 1). Trois ans d'une formation exigeante combinant sciences medicales, acoustique et pratique clinique.</p>
          </div>
        </li>
        <li class="flex gap-4">
          <span class="w-8 h-8 bg-orange text-white rounded-full flex items-center justify-center font-sans font-bold text-sm shrink-0 mt-0.5">2</span>
          <div>
            <strong class="font-sans text-marine">28 ans de terrain &mdash; 18 centres Alain Afflelou Acousticien</strong>
            <p class="text-gris-texte text-base mt-1">Pendant pres de trois decennies, j'ai dirige 18 centres d'audioprothese. Plus de 3 000 patients appareilles et suivis sur le long terme, de la premiere consultation au renouvellement. C'est la que j'ai appris l'essentiel : <strong class="text-marine">ce qui compte, ce n'est pas l'appareil le plus cher, c'est celui qui correspond a votre perte auditive, a votre mode de vie et a votre budget.</strong></p>
          </div>
        </li>
        <li class="flex gap-4">
          <span class="w-8 h-8 bg-orange text-white rounded-full flex items-center justify-center font-sans font-bold text-sm shrink-0 mt-0.5">3</span>
          <div>
            <strong class="font-sans text-marine">5 ans chez Auzen.com &mdash; les coulisses de l'industrie</strong>
            <p class="text-gris-texte text-base mt-1">J'ai ensuite rejoint <strong class="text-marine">Auzen.com</strong>, l'un des pionniers et leaders de la vente d'appareils auditifs en ligne en Europe. Pendant 5 ans, j'ai redige une grande partie de leur catalogue technique. J'ai decouvert l'envers du decor : les <strong class="text-marine">marges reelles</strong> pratiquees dans l'industrie, les <strong class="text-marine">differences concretes entre les puces</strong> (Phonak, Signia, Starkey...), les strategies de positionnement des fabricants, et surtout &mdash; pourquoi le marche reste aussi opaque. Spoiler : cette opacite profite a toute la chaine, sauf au patient.</p>
          </div>
        </li>
        <li class="flex gap-4">
          <span class="w-8 h-8 bg-orange text-white rounded-full flex items-center justify-center font-sans font-bold text-sm shrink-0 mt-0.5">4</span>
          <div>
            <strong class="font-sans text-marine">Le declic &mdash; creation de LeGuideAuditif.fr</strong>
            <p class="text-gris-texte text-base mt-1">J'ai decide de quitter la vente directe. Pourquoi ? Parce que j'en savais trop pour continuer a me taire. J'ai cree LeGuideAuditif.fr avec un objectif simple : <strong class="text-marine">rendre le pouvoir aux patients</strong>. Je ne vends pas d'appareils. J'offre de l'information technique 100 % transparente, des avis impartiaux sur les modeles, et un annuaire de plus de 7 500 centres auditifs pour vous aider a trouver le bon professionnel, au bon prix, pres de chez vous.</p>
          </div>
        </li>
      </ol>
    </div>
  </section>

  <!-- Auteur / E-E-A-T -->
  <section class="bg-creme py-12">
    <div class="max-w-[780px] mx-auto px-5">
      <h2 class="font-sans text-2xl font-bold text-marine mb-6">Qui suis-je ?</h2>
      <div class="bg-blanc border border-gris-clair rounded-2xl p-8 mb-8">
        <div class="flex flex-col sm:flex-row items-start gap-6">
          <img
            src="/images/franck-olivier-chabbat.jpg"
            alt="Franck-Olivier Chabbat, audioprothesiste diplome d'Etat"
            width="96"
            height="96"
            class="w-24 h-24 rounded-full object-cover shrink-0"
            loading="eager"
          />
          <div>
            <div class="font-sans text-xl font-bold text-marine mb-1">Franck-Olivier Chabbat</div>
            <div class="font-sans text-base text-orange font-medium mb-3">Audioprothesiste diplome d'Etat &mdash; 28 ans de clinique, 5 ans dans l'industrie</div>

            <!-- Badge ADELI -->
            <div class="inline-flex items-center gap-2 bg-creme border border-gris-clair px-4 py-2 rounded-lg text-sm font-sans mb-4">
              <Icon name="lucide:shield-check" class="w-4 h-4 text-orange" aria-hidden="true" />
              <span>N. ADELI : <strong class="text-marine">692606494</strong></span>
            </div>

            <p class="text-base leading-relaxed mb-4">
              Diplome de l'ISTR Lyon (Universite Claude Bernard Lyon 1), j'ai exerce l'audioprothese pendant 28 ans. J'ai dirige 18 centres Alain Afflelou Acousticien et accompagne plus de 3 000 patients dans leur parcours d'appareillage. Puis j'ai passe 5 ans chez <strong class="text-marine">Auzen.com</strong>, ou j'ai redige le catalogue technique et decouvert les coulisses de l'industrie.
            </p>
            <p class="text-base leading-relaxed mb-4">
              Cette double experience &mdash; clinique et industrielle &mdash; me donne une vision que peu de professionnels possedent. Sur LeGuideAuditif.fr, je partage cette connaissance sans filtre : les vraies differences entre les appareils, les pieges a eviter, et les conseils que je donnerais a mes propres parents.
            </p>

            <!-- LinkedIn -->
            <a href="https://www.linkedin.com/in/franck-olivier-chabbat-/" target="_blank" rel="noopener noreferrer"
               class="inline-flex items-center gap-2 text-orange hover:underline text-sm font-sans font-medium mt-2 no-underline hover:no-underline">
              <Icon name="lucide:linkedin" class="w-4 h-4" aria-hidden="true" />
              Voir mon profil LinkedIn
            </a>
          </div>
        </div>
      </div>

      <!-- Badge Verifie par un expert -->
      <div class="bg-marine rounded-2xl p-6 mb-8 flex flex-col sm:flex-row items-center gap-5">
        <div class="w-16 h-16 bg-orange/20 rounded-full flex items-center justify-center shrink-0">
          <Icon name="lucide:badge-check" class="w-8 h-8 text-orange" aria-hidden="true" />
        </div>
        <div class="text-center sm:text-left">
          <div class="font-sans text-lg font-bold text-white mb-1">Contenu verifie par un expert</div>
          <p class="text-white/80 text-sm leading-relaxed">
            Tous les guides et comparatifs publies sur LeGuideAuditif.fr sont rediges ou supervises par Franck-Olivier Chabbat, audioprothesiste DE (ISTR Lyon), ADELI 692606494. Avec 28 ans de pratique clinique et 5 ans d'experience industrielle chez Auzen.com, chaque article suit un processus de double validation qualite avant publication.
          </p>
        </div>
      </div>

      <!-- Credentials -->
      <h3 class="font-sans text-xl font-bold text-marine mb-4">Parcours et qualifications</h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-8">
        <div class="bg-blanc rounded-xl p-5 border border-gris-clair">
          <Icon name="lucide:graduation-cap" class="w-5 h-5 text-orange mb-2" aria-hidden="true" />
          <div class="font-sans text-sm font-semibold text-orange uppercase tracking-wide mb-2">Formation</div>
          <p class="text-base text-marine">Diplome d'Etat d'audioprothesiste &mdash; ISTR Lyon (Universite Claude Bernard Lyon 1)</p>
        </div>
        <div class="bg-blanc rounded-xl p-5 border border-gris-clair">
          <Icon name="lucide:calendar-clock" class="w-5 h-5 text-orange mb-2" aria-hidden="true" />
          <div class="font-sans text-sm font-semibold text-orange uppercase tracking-wide mb-2">Experience clinique</div>
          <p class="text-base text-marine">28 ans de pratique en audioprothese</p>
        </div>
        <div class="bg-blanc rounded-xl p-5 border border-gris-clair">
          <Icon name="lucide:building-2" class="w-5 h-5 text-orange mb-2" aria-hidden="true" />
          <div class="font-sans text-sm font-semibold text-orange uppercase tracking-wide mb-2">Management</div>
          <p class="text-base text-marine">18 centres Alain Afflelou Acousticien diriges</p>
        </div>
        <div class="bg-blanc rounded-xl p-5 border border-gris-clair">
          <Icon name="lucide:users" class="w-5 h-5 text-orange mb-2" aria-hidden="true" />
          <div class="font-sans text-sm font-semibold text-orange uppercase tracking-wide mb-2">Patients</div>
          <p class="text-base text-marine">3 000+ patients appareilles et suivis</p>
        </div>
        <div class="bg-blanc rounded-xl p-5 border border-gris-clair">
          <Icon name="lucide:globe" class="w-5 h-5 text-orange mb-2" aria-hidden="true" />
          <div class="font-sans text-sm font-semibold text-orange uppercase tracking-wide mb-2">Industrie</div>
          <p class="text-base text-marine">5 ans chez Auzen.com &mdash; leader europeen de la vente en ligne d'aides auditives</p>
        </div>
        <div class="bg-blanc rounded-xl p-5 border border-gris-clair">
          <Icon name="lucide:shield-check" class="w-5 h-5 text-orange mb-2" aria-hidden="true" />
          <div class="font-sans text-sm font-semibold text-orange uppercase tracking-wide mb-2">Enregistrement professionnel</div>
          <p class="text-base text-marine">N. ADELI 692606494 &mdash; Repertoire national des professionnels de sante</p>
        </div>
      </div>
    </div>
  </section>

  <!-- La Mission du Guide Auditif -->
  <section class="bg-blanc py-12">
    <div class="max-w-[780px] mx-auto px-5">
      <h2 class="font-sans text-2xl font-bold text-marine mb-6">La mission du Guide Auditif</h2>
      <p class="text-lg leading-relaxed mb-8">
        Mon objectif est simple : vous donner les cles pour comprendre le marche de l'audition et faire les bons choix, sans dependre de celui qui vous vend l'appareil.
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        <div class="bg-creme rounded-2xl p-6 border border-gris-clair">
          <div class="w-12 h-12 bg-orange/10 rounded-xl flex items-center justify-center mb-4">
            <Icon name="lucide:book-open" class="w-6 h-6 text-orange" aria-hidden="true" />
          </div>
          <h3 class="font-sans text-lg font-bold text-marine mb-2">Information decryptee</h3>
          <p class="text-base text-gris-texte leading-relaxed">
            Des guides techniques rediges par un professionnel qui connait les produits de l'interieur. Pas du marketing fabricant, pas des fiches recopiees : des <strong class="text-marine">analyses independantes</strong> basees sur l'experience clinique et la connaissance industrielle.
          </p>
        </div>
        <div class="bg-creme rounded-2xl p-6 border border-gris-clair">
          <div class="w-12 h-12 bg-orange/10 rounded-xl flex items-center justify-center mb-4">
            <Icon name="lucide:map-pin" class="w-6 h-6 text-orange" aria-hidden="true" />
          </div>
          <h3 class="font-sans text-lg font-bold text-marine mb-2">Plus de 7 500 centres recenses</h3>
          <p class="text-base text-gris-texte leading-relaxed">
            Une <strong class="text-marine">carte interactive gratuite</strong> recensant plus de 7 500 centres auditifs en France. Pour vous aider a trouver le bon professionnel, au bon prix, pres de chez vous.
          </p>
          <a href="/trouver-audioprothesiste/" class="inline-flex items-center gap-2 text-orange hover:underline text-sm font-sans font-medium mt-3 no-underline hover:no-underline">
            Voir la carte
            <Icon name="lucide:arrow-right" class="w-4 h-4" aria-hidden="true" />
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Pourquoi me faire confiance -->
  <section class="bg-creme py-12">
    <div class="max-w-[780px] mx-auto px-5">
      <h2 class="font-sans text-2xl font-bold text-marine mb-6">Pourquoi me faire confiance</h2>
      <div class="space-y-6">
        <div class="flex items-start gap-4">
          <div class="w-10 h-10 bg-orange/10 rounded-lg flex items-center justify-center shrink-0 mt-0.5">
            <Icon name="lucide:shield-check" class="w-5 h-5 text-orange" aria-hidden="true" />
          </div>
          <div>
            <strong class="font-sans text-marine text-lg">Independance totale</strong>
            <p class="text-base text-gris-texte leading-relaxed mt-1">Aucun lien capitalistique avec un fabricant d'appareils auditifs ou une enseigne. J'ai <strong class="text-marine">quitte la vente</strong> pour creer ce guide. Mon seul engagement est envers vous, pas envers un catalogue produit.</p>
          </div>
        </div>
        <div class="flex items-start gap-4">
          <div class="w-10 h-10 bg-orange/10 rounded-lg flex items-center justify-center shrink-0 mt-0.5">
            <Icon name="lucide:cpu" class="w-5 h-5 text-orange" aria-hidden="true" />
          </div>
          <div>
            <strong class="font-sans text-marine text-lg">Transparence technique</strong>
            <p class="text-base text-gris-texte leading-relaxed mt-1">Je compare les appareils sur des <strong class="text-marine">criteres objectifs</strong> : qualite de la puce, reduction du bruit, connectivite, autonomie, confort. Je connais les differences reelles entre Phonak, Signia, Starkey, ReSound et Oticon &mdash; pas les arguments commerciaux. Je presente toujours les options Classe 1 (reste a charge zero) et Classe 2.</p>
          </div>
        </div>
        <div class="flex items-start gap-4">
          <div class="w-10 h-10 bg-orange/10 rounded-lg flex items-center justify-center shrink-0 mt-0.5">
            <Icon name="lucide:map-pin" class="w-5 h-5 text-orange" aria-hidden="true" />
          </div>
          <div>
            <strong class="font-sans text-marine text-lg">Proximite</strong>
            <p class="text-base text-gris-texte leading-relaxed mt-1">Un appareil auditif, ca s'essaie en centre. C'est pourquoi je mets a votre disposition un <strong class="text-marine">annuaire gratuit de plus de 7 500 centres auditifs</strong> en France, pour que vous puissiez trouver un professionnel qualifie pres de chez vous.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Methodologie editoriale -->
  <section class="bg-blanc py-12">
    <div class="max-w-[780px] mx-auto px-5">
      <h2 class="font-sans text-2xl font-bold text-marine mb-6">Ma methodologie editoriale</h2>
      <p class="text-lg leading-relaxed mb-6">
        Chaque guide publie sur LeGuideAuditif.fr suit un processus rigoureux pour garantir la fiabilite de l'information :
      </p>
      <ol class="space-y-4 mb-8">
        <li class="flex gap-4">
          <span class="w-8 h-8 bg-orange text-white rounded-full flex items-center justify-center font-sans font-bold text-sm shrink-0">1</span>
          <div>
            <strong class="font-sans text-marine">Recherche sourcee</strong>
            <p class="text-gris-texte text-base mt-1">Chaque affirmation medicale est fondee sur des sources officielles : HAS, INSERM, OMS, PubMed. Je privilegie les etudes de moins de 3 ans.</p>
          </div>
        </li>
        <li class="flex gap-4">
          <span class="w-8 h-8 bg-orange text-white rounded-full flex items-center justify-center font-sans font-bold text-sm shrink-0">2</span>
          <div>
            <strong class="font-sans text-marine">Redaction par un professionnel</strong>
            <p class="text-gris-texte text-base mt-1">Le contenu est redige ou supervise par un audioprothesiste DE, avec une double expertise clinique et industrielle. Le ton est accessible (Flesch FR 60-80) et le vouvoiement systematique.</p>
          </div>
        </li>
        <li class="flex gap-4">
          <span class="w-8 h-8 bg-orange text-white rounded-full flex items-center justify-center font-sans font-bold text-sm shrink-0">3</span>
          <div>
            <strong class="font-sans text-marine">Double validation qualite</strong>
            <p class="text-gris-texte text-base mt-1">Chaque article passe un double controle : evaluation de contenu (score minimum 70/100) puis verification de conformite E-E-A-T (score minimum 80/100).</p>
          </div>
        </li>
        <li class="flex gap-4">
          <span class="w-8 h-8 bg-orange text-white rounded-full flex items-center justify-center font-sans font-bold text-sm shrink-0">4</span>
          <div>
            <strong class="font-sans text-marine">Mise a jour reguliere</strong>
            <p class="text-gris-texte text-base mt-1">Les tarifs, remboursements et recommandations evoluent. Les guides sont revises periodiquement pour rester a jour.</p>
          </div>
        </li>
      </ol>

      <!-- Transparence sur les avis -->
      <h3 class="font-sans text-xl font-bold text-marine mb-4">Comment les avis et comparatifs sont rediges</h3>
      <div class="bg-creme rounded-2xl p-6 border border-gris-clair">
        <ul class="space-y-3 text-base">
          <li class="flex items-start gap-3">
            <span class="text-orange font-bold mt-0.5" aria-hidden="true">&check;</span>
            <span>Chaque appareil est evalue selon des <strong class="text-marine">criteres techniques objectifs</strong> : qualite sonore, reduction du bruit, connectivite, autonomie, confort de port.</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-orange font-bold mt-0.5" aria-hidden="true">&check;</span>
            <span>Les tests s'appuient sur mon <strong class="text-marine">experience clinique</strong> (28 ans, 3 000+ patients) et ma <strong class="text-marine">connaissance industrielle</strong> (5 ans de catalogue technique chez Auzen.com).</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-orange font-bold mt-0.5" aria-hidden="true">&check;</span>
            <span><strong class="text-marine">Aucun fabricant</strong> (Phonak, Signia, ReSound, Oticon, etc.) ne valide ni ne relit les contenus avant publication.</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-orange font-bold mt-0.5" aria-hidden="true">&check;</span>
            <span>Les comparatifs sont <strong class="text-marine">mis a jour</strong> lors de chaque nouvelle generation de produits.</span>
          </li>
        </ul>
      </div>
    </div>
  </section>

  <!-- Transparence affiliation -->
  <section class="bg-creme py-12">
    <div class="max-w-[780px] mx-auto px-5">
      <div class="bg-blanc rounded-2xl p-6 border border-gris-clair">
        <div class="flex items-start gap-4">
          <div class="w-10 h-10 bg-orange/10 rounded-lg flex items-center justify-center shrink-0 mt-0.5">
            <Icon name="lucide:info" class="w-5 h-5 text-orange" aria-hidden="true" />
          </div>
          <div>
            <strong class="font-sans text-marine text-lg">Comment ce site se finance</strong>
            <p class="text-base text-gris-texte leading-relaxed mt-2">
              LeGuideAuditif.fr se finance par des liens affilies. Lorsque vous cliquez sur un lien vers un produit et effectuez un achat, je peux recevoir une commission, <strong class="text-marine">sans cout supplementaire pour vous</strong>. Ce modele me permet de rester independant de tout fabricant. Mes recommandations ne sont jamais influencees par ces commissions : le verdict editorial est redige avant toute consideration commerciale.
            </p>
          </div>
        </div>
      </div>
