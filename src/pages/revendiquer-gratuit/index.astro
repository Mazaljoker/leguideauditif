---
export const prerender = false;

import { Icon } from 'astro-icon/components';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { supabase } from '../../lib/supabase';

const centreSlug = Astro.url.searchParams.get('centre');

let centre = null;
if (centreSlug) {
  const { data } = await supabase
    .from('centres_auditifs')
    .select('slug, nom, adresse, cp, ville, plan, claim_status, siret')
    .eq('slug', centreSlug)
    .single();
  centre = data;
}

if (!centre) {
  return Astro.redirect('/trouver-audioprothesiste/');
}

if (centre.plan !== 'rpps' || centre.claim_status === 'pending') {
  return Astro.redirect(`/centre/${centre.slug}/`);
}

// Lookup RPPS depuis la table rpps_audioprothesistes (par SIRET du centre)
let prefillRpps = '';
if (centre.siret) {
  const { data: rppsData } = await supabase
    .from('rpps_audioprothesistes')
    .select('rpps')
    .eq('siret', centre.siret)
    .limit(1)
    .single();
  if (rppsData?.rpps) prefillRpps = rppsData.rpps;
}

const displayVille = centre.ville || centre.cp;
const pageTitle = `Revendiquer gratuitement ${centre.nom} — LeGuideAuditif`;
const pageDescription = `Vous gérez ${centre.nom} à ${displayVille} ? Revendiquez votre fiche gratuitement pour afficher vos coordonnées et gagner en visibilité.`;

const breadcrumbs = [
  { label: 'Accueil', href: '/' },
  { label: 'Trouver un audioprothésiste', href: '/trouver-audioprothesiste/' },
  { label: centre.nom, href: `/centre/${centre.slug}/` },
  { label: 'Revendiquer' },
];
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <meta slot="head" name="robots" content="noindex" />
  <div class="bg-creme">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <Breadcrumbs items={breadcrumbs} />
    </div>
  </div>

  <section class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

    <h1 class="font-sans text-2xl sm:text-3xl font-bold text-marine mb-2">
      Revendiquez votre fiche gratuitement
    </h1>
    <p class="text-gris-texte font-sans mb-8">
      Complétez le formulaire ci-dessous pour revendiquer la fiche de
      <strong class="text-marine">{centre.nom}</strong> ({centre.adresse}, {centre.cp} {centre.ville}).
    </p>

    {/* Avantages */}
    <div class="rounded-xl border border-gris-clair bg-blanc p-6 mb-8">
      <h2 class="font-sans text-lg font-bold text-marine mb-4">
        Ce que vous debloquez
      </h2>
      <ul class="grid gap-3 sm:grid-cols-2 font-sans text-gris-texte">
        <li class="flex items-start gap-2">
          <Icon name="lucide:check" class="w-5 h-5 text-orange mt-0.5 shrink-0" />
          Telephone affiche en clair
        </li>
        <li class="flex items-start gap-2">
          <Icon name="lucide:check" class="w-5 h-5 text-orange mt-0.5 shrink-0" />
          Horaires d'ouverture affiches
        </li>
        <li class="flex items-start gap-2">
          <Icon name="lucide:check" class="w-5 h-5 text-orange mt-0.5 shrink-0" />
          Spécialités affichées (3 max)
        </li>
        <li class="flex items-start gap-2">
          <Icon name="lucide:check" class="w-5 h-5 text-orange mt-0.5 shrink-0" />
          Marques affichées (3 max)
        </li>
        <li class="flex items-start gap-2">
          <Icon name="lucide:check" class="w-5 h-5 text-orange mt-0.5 shrink-0" />
          Recevez des demandes de patients
        </li>
        <li class="flex items-start gap-2">
          <Icon name="lucide:check" class="w-5 h-5 text-orange mt-0.5 shrink-0" />
          Gratuit, sans engagement
        </li>
      </ul>
    </div>

    {/* Formulaire */}
    <form
      id="claim-form"
      class="rounded-xl border-2 border-orange/20 bg-blanc p-6 sm:p-8"
    >
      <input type="hidden" name="centreSlug" value={centre.slug} />

      <h2 class="font-sans text-lg font-bold text-marine mb-6">
        Vos informations professionnelles
      </h2>

      <div class="grid gap-5 sm:grid-cols-2">
        <div>
          <label for="claim-nom" class="block text-sm font-medium text-marine font-sans mb-1">
            Nom
          </label>
          <input
            id="claim-nom"
            name="nom"
            type="text"
            required
            autocomplete="family-name"
            class="w-full rounded-lg border border-gris-clair px-4 py-3 text-base font-sans focus:border-orange focus:outline-none focus:ring-2 focus:ring-orange/20"
          />
        </div>

        <div>
          <label for="claim-prenom" class="block text-sm font-medium text-marine font-sans mb-1">
            Prénom
          </label>
          <input
            id="claim-prenom"
            name="prenom"
            type="text"
            required
            autocomplete="given-name"
            class="w-full rounded-lg border border-gris-clair px-4 py-3 text-base font-sans focus:border-orange focus:outline-none focus:ring-2 focus:ring-orange/20"
          />
        </div>

        <div>
          <label for="claim-email" class="block text-sm font-medium text-marine font-sans mb-1">
            Email professionnel
          </label>
          <input
            id="claim-email"
            name="email"
            type="email"
            required
            autocomplete="email"
            class="w-full rounded-lg border border-gris-clair px-4 py-3 text-base font-sans focus:border-orange focus:outline-none focus:ring-2 focus:ring-orange/20"
          />
        </div>

        <div>
          <label for="claim-adeli" class="block text-sm font-medium text-marine font-sans mb-1">
            N&deg; RPPS ou SIRET
          </label>
          <input
            id="claim-adeli"
            name="adeli"
            type="text"
            required
            value={prefillRpps}
            placeholder="Ex : 10001234567 ou 123 456 789 00012"
            class="w-full rounded-lg border border-gris-clair px-4 py-3 text-base font-sans focus:border-orange focus:outline-none focus:ring-2 focus:ring-orange/20"
          />
          {prefillRpps && (
            <p class="text-xs text-gris-texte font-sans mt-1">
              RPPS pré-rempli depuis l'annuaire national — vérifiez et corrigez si nécessaire
            </p>
          )}
        </div>
      </div>

      <h2 class="font-sans text-lg font-bold text-marine mt-8 mb-2">
        Informations de votre centre
      </h2>
      <div class="rounded-lg bg-[#E6F1FB] px-4 py-3 mb-5">
        <p class="text-xs text-gris-texte font-sans">{centre.adresse}, {centre.cp} {centre.ville}</p>
      </div>
      <p class="text-sm text-gris-texte font-sans mb-5">
        Ces informations seront affichées sur votre fiche. Vous pourrez les modifier plus tard.
      </p>

      <div class="mb-5">
        <label for="claim-centre-nom" class="block text-sm font-medium text-marine font-sans mb-1">
          Nom de votre centre
        </label>
        <input
          id="claim-centre-nom"
          name="centreNom"
          type="text"
          value={centre.nom}
          required
          class="w-full rounded-lg border border-gris-clair px-4 py-3 text-base font-sans focus:border-orange focus:outline-none focus:ring-2 focus:ring-orange/20"
        />
        <p class="text-xs text-gris-texte font-sans mt-1">Nom INSEE : {centre.nom} — modifiez si votre nom commercial est différent</p>
      </div>

      <div class="grid gap-5 sm:grid-cols-2">
        <div>
          <label for="claim-tel" class="block text-sm font-medium text-marine font-sans mb-1">
            Telephone du centre
          </label>
          <input
            id="claim-tel"
            name="tel"
            type="tel"
            placeholder="04 78 12 34 56"
            class="w-full rounded-lg border border-gris-clair px-4 py-3 text-base font-sans focus:border-orange focus:outline-none focus:ring-2 focus:ring-orange/20"
          />
        </div>

        <div>
          <label for="claim-site-web" class="block text-sm font-medium text-marine font-sans mb-1">
            Site web
          </label>
          <input
            id="claim-site-web"
            name="site_web"
            type="url"
            placeholder="https://www.mon-centre.fr"
            class="w-full rounded-lg border border-gris-clair px-4 py-3 text-base font-sans focus:border-orange focus:outline-none focus:ring-2 focus:ring-orange/20"
          />
        </div>

        <div class="sm:col-span-2">
          <label class="block text-sm font-medium text-marine font-sans mb-2">
            Horaires d'ouverture
          </label>
          <input type="hidden" id="claim-horaires" name="horaires" />
          <div class="grid grid-cols-3 gap-3">
            <div>
              <label for="h-ouverture" class="block text-xs text-gris-texte font-sans mb-1">Ouverture</label>
              <select
                id="h-ouverture"
                class="w-full rounded-lg border border-gris-clair px-3 py-3 text-base font-sans focus:border-orange focus:outline-none focus:ring-2 focus:ring-orange/20 bg-blanc"
              >
                <option value="">--</option>
                <option value="8h">8h</option>
                <option value="8h30">8h30</option>
                <option value="9h" selected>9h</option>
                <option value="9h30">9h30</option>
                <option value="10h">10h</option>
              </select>
            </div>
            <div>
              <label for="h-fermeture" class="block text-xs text-gris-texte font-sans mb-1">Fermeture</label>
              <select
                id="h-fermeture"
                class="w-full rounded-lg border border-gris-clair px-3 py-3 text-base font-sans focus:border-orange focus:outline-none focus:ring-2 focus:ring-orange/20 bg-blanc"
              >
                <option value="">--</option>
                <option value="17h">17h</option>
                <option value="17h30">17h30</option>
                <option value="18h" selected>18h</option>
                <option value="18h30">18h30</option>
                <option value="19h">19h</option>
              </select>
            </div>
            <div>
              <label for="h-samedi" class="block text-xs text-gris-texte font-sans mb-1">Samedi</label>
              <select
                id="h-samedi"
                class="w-full rounded-lg border border-gris-clair px-3 py-3 text-base font-sans focus:border-orange focus:outline-none focus:ring-2 focus:ring-orange/20 bg-blanc"
              >
                <option value="">--</option>
                <option value="Fermé">Fermé</option>
                <option value="9h-12h" selected>9h-12h</option>
                <option value="9h-13h">9h-13h</option>
                <option value="10h-12h">10h-12h</option>
                <option value="Sur RDV">Sur RDV</option>
              </select>
            </div>
          </div>
          <p class="text-xs text-gris-texte font-sans mt-1">Sélectionnez vos horaires en 3 clics</p>
        </div>
      </div>

      <div class="mt-5">
        <label class="block text-sm font-medium text-marine font-sans mb-1">
          Spécialités (3 max)
        </label>
        <div class="flex flex-wrap gap-2" id="specialites-container">
          {[
            'Acouphènes', 'Pédiatrie', 'Implants cochléaires',
            '100% Santé', 'Bilan auditif gratuit', 'Appareillage première fois',
            'Surdité sévère/profonde', 'Protection auditive', 'Audiométrie',
          ].map((s) => (
            <label class="inline-flex items-center gap-1.5 rounded-full border border-gris-clair bg-blanc px-3 py-1.5 text-sm font-sans cursor-pointer hover:border-orange/50 transition-colors has-[:checked]:bg-[#E6F1FB] has-[:checked]:border-[#0C447C]/30 has-[:checked]:text-[#0C447C]">
              <input type="checkbox" name="specialites" value={s} class="sr-only peer" />
              {s}
            </label>
          ))}
        </div>
        <p class="text-xs text-gris-texte font-sans mt-1">Sélectionnez jusqu'à 3 spécialités</p>
      </div>

      <div class="mt-5">
        <label class="block text-sm font-medium text-marine font-sans mb-1">
          Marques proposées (3 max)
        </label>
        <div class="flex flex-wrap gap-2" id="marques-container">
          {[
            'Phonak', 'Oticon', 'Signia', 'ReSound', 'Starkey',
            'Widex', 'Bernafon', 'Unitron', 'Audioservice',
          ].map((m) => (
            <label class="inline-flex items-center gap-1.5 rounded-full border border-gris-clair bg-blanc px-3 py-1.5 text-sm font-sans cursor-pointer hover:border-orange/50 transition-colors has-[:checked]:bg-[#E6F1FB] has-[:checked]:border-[#0C447C]/30 has-[:checked]:text-[#0C447C]">
              <input type="checkbox" name="marques" value={m} class="sr-only peer" />
              {m}
            </label>
          ))}
        </div>
        <p class="text-xs text-gris-texte font-sans mt-1">Sélectionnez jusqu'à 3 marques</p>
      </div>

      <div class="mt-5">
        <label for="claim-apropos" class="block text-sm font-medium text-marine font-sans mb-1">
          Description de votre centre
        </label>
        <textarea
          id="claim-apropos"
          name="a_propos"
          rows="4"
          maxlength="500"
          placeholder="Présentez votre centre en quelques lignes : votre expérience, votre équipe, vos services..."
          class="w-full rounded-lg border border-gris-clair px-4 py-3 text-base font-sans focus:border-orange focus:outline-none focus:ring-2 focus:ring-orange/20 resize-y"
        ></textarea>
        <p class="text-xs text-gris-texte font-sans mt-1">500 caracteres max</p>
      </div>

      <div class="mt-5">
        <label for="claim-photo" class="block text-sm font-medium text-marine font-sans mb-1">
          Photo de votre centre (1 max)
        </label>
        <div
          id="photo-dropzone"
          class="relative rounded-lg border-2 border-dashed border-gris-clair bg-creme/50 p-6 text-center cursor-pointer hover:border-orange/50 transition-colors"
        >
          <input
            id="claim-photo"
            name="photo"
            type="file"
            accept="image/jpeg,image/png,image/webp"
            class="absolute inset-0 w-full h-full opacity-0 cursor-pointer"
          />
          <div id="photo-placeholder">
            <Icon name="lucide:image-plus" class="w-8 h-8 text-gris-texte mx-auto mb-2" />
            <p class="text-sm text-gris-texte font-sans">Cliquez ou glissez une photo ici</p>
            <p class="text-xs text-gris-texte font-sans mt-1">JPG, PNG ou WebP — 5 Mo max</p>
          </div>
          <div id="photo-preview" class="hidden">
            <img id="photo-preview-img" alt="Apercu" class="max-h-40 rounded-lg mx-auto mb-2" />
            <p id="photo-preview-name" class="text-sm text-marine font-sans font-medium"></p>
            <button type="button" id="photo-remove" class="text-xs text-[#A32D2D] font-sans font-medium mt-1 hover:underline">
              Supprimer
            </button>
          </div>
        </div>
      </div>

      <div class="mt-6">
        <label class="flex items-start gap-2 text-sm text-gris-texte font-sans">
          <input type="checkbox" name="rgpd" required class="mt-1" />
          <span>
            J'atteste être le gérant ou un représentant autorisé de cet établissement.
            J'accepte les <a href="/mentions-legales/" class="text-orange underline">conditions générales</a> et la
            <a href="/politique-confidentialite/" class="text-orange underline">politique de confidentialité</a>.
          </span>
        </label>
      </div>

      <div id="claim-error" class="hidden mt-4 rounded-lg border border-red-300 bg-red-50 p-3 text-sm text-red-600 font-sans"></div>

      <div class="mt-6">
        <button
          type="submit"
          id="claim-submit"
          class="w-full sm:w-auto rounded-lg bg-orange px-8 py-3 text-lg font-semibold text-blanc font-sans transition-colors hover:bg-orange-hover focus:outline-none focus:ring-2 focus:ring-orange/50 cursor-pointer disabled:opacity-60"
          style="min-height: 48px;"
        >
          Revendiquer gratuitement
        </button>
      </div>

      <p class="text-xs text-gris-texte font-sans mt-3">
        Aucun paiement requis. Votre demande sera vérifiée sous 24h.
      </p>
    </form>
  </section>

  <script>
    import { readAttribution, getGaClientId, getGaSessionId } from '../../lib/tracking';

    declare global {
      interface Window {
        gtag?: (...args: unknown[]) => void;
      }
    }

    const form = document.getElementById('claim-form') as HTMLFormElement;
    const submitBtn = document.getElementById('claim-submit') as HTMLButtonElement;
    const errorDiv = document.getElementById('claim-error') as HTMLDivElement;

    // --- Photo preview ---
    const photoInput = document.getElementById('claim-photo') as HTMLInputElement;
    const photoPlaceholder = document.getElementById('photo-placeholder') as HTMLDivElement;
    const photoPreview = document.getElementById('photo-preview') as HTMLDivElement;
    const photoPreviewImg = document.getElementById('photo-preview-img') as HTMLImageElement;
    const photoPreviewName = document.getElementById('photo-preview-name') as HTMLParagraphElement;
    const photoRemove = document.getElementById('photo-remove') as HTMLButtonElement;

    photoInput.addEventListener('change', () => {
      const file = photoInput.files?.[0];
      if (!file) return;
      if (file.size > 5 * 1024 * 1024) {
        errorDiv.textContent = 'La photo ne doit pas dépasser 5 Mo.';
        errorDiv.classList.remove('hidden');
        photoInput.value = '';
        return;
      }
      errorDiv.classList.add('hidden');
      const reader = new FileReader();
      reader.onload = (e) => {
        photoPreviewImg.src = e.target?.result as string;
        photoPreviewName.textContent = file.name;
        photoPlaceholder.classList.add('hidden');
        photoPreview.classList.remove('hidden');
      };
      reader.readAsDataURL(file);
    });

    photoRemove.addEventListener('click', () => {
      photoInput.value = '';
      photoPreview.classList.add('hidden');
      photoPlaceholder.classList.remove('hidden');
    });

    // --- Limiter a 3 selections max ---
    function limitCheckboxes(containerId: string, max: number) {
      const container = document.getElementById(containerId);
      if (!container) return;
      container.addEventListener('change', () => {
        const checked = container.querySelectorAll('input[type="checkbox"]:checked');
        const unchecked = container.querySelectorAll('input[type="checkbox"]:not(:checked)');
        if (checked.length >= max) {
          unchecked.forEach((cb) => { (cb as HTMLInputElement).disabled = true; });
        } else {
          unchecked.forEach((cb) => { (cb as HTMLInputElement).disabled = false; });
        }
      });
    }
    limitCheckboxes('specialites-container', 3);
    limitCheckboxes('marques-container', 3);

    // --- Horaires : 3 selects → 1 champ texte ---
    const hOuverture = document.getElementById('h-ouverture') as HTMLSelectElement;
    const hFermeture = document.getElementById('h-fermeture') as HTMLSelectElement;
    const hSamedi = document.getElementById('h-samedi') as HTMLSelectElement;
    const hHidden = document.getElementById('claim-horaires') as HTMLInputElement;

    function updateHoraires() {
      const ouv = hOuverture.value;
      const fer = hFermeture.value;
      const sam = hSamedi.value;
      const parts: string[] = [];
      if (ouv && fer) parts.push(`Lun-Ven ${ouv}-${fer}`);
      if (sam) parts.push(`Sam ${sam}`);
      hHidden.value = parts.join(' | ');
    }
    hOuverture.addEventListener('change', updateHoraires);
    hFermeture.addEventListener('change', updateHoraires);
    hSamedi.addEventListener('change', updateHoraires);
    updateHoraires(); // init avec les defaults

    // --- Submit (FormData pour supporter le fichier photo) ---
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      submitBtn.disabled = true;
      submitBtn.textContent = 'Envoi en cours...';
      errorDiv.classList.add('hidden');

      const formData = new FormData(form);

      // Attribution : UTM capturés au landing + identifiants GA4 côté client.
      // Le serveur utilise ces valeurs pour (1) persister la source et (2) rejouer
      // l'événement via Measurement Protocol — immunisé contre adblock/consent refus.
      const attribution = readAttribution();
      if (attribution) formData.append('attribution', JSON.stringify(attribution));
      const gaClientId = getGaClientId();
      if (gaClientId) formData.append('ga_client_id', gaClientId);
      const gaSessionId = getGaSessionId('G-1GHQCKDVPM');
      if (gaSessionId) formData.append('ga_session_id', gaSessionId);

      // transaction_id partagé client/serveur → dédup dans GA4 (COUNT DISTINCT).
      // crypto.randomUUID est dispo dans tous les navigateurs que supporte Astro 6.
      const transactionId = crypto.randomUUID();
      formData.append('transaction_id', transactionId);

      try {
        const res = await fetch('/api/claim', {
          method: 'POST',
          body: formData,
        });

        const data = await res.json();

        if (!res.ok) {
          throw new Error(data.error || 'Une erreur est survenue.');
        }

        // Event gtag client — capte les users sans adblock avec consent OK.
        // Doublé côté serveur via Measurement Protocol pour couverture 100%.
        // Dédup : même transaction_id sur les deux events → COUNT DISTINCT dans GA4.
        if (typeof window.gtag === 'function') {
          window.gtag('event', 'revendication_success', {
            event_category: 'conversion',
            transaction_id: transactionId,
            event_source: 'client',
            centre_slug: (formData.get('centreSlug') as string) || '',
            utm_source: attribution?.utm_source || '(direct)',
            utm_medium: attribution?.utm_medium || '(none)',
            utm_campaign: attribution?.utm_campaign || '(none)',
          });
        }

        window.location.href = data.redirectUrl;
      } catch (err: unknown) {
        const message = err instanceof Error ? err.message : 'Une erreur est survenue.';
        errorDiv.textContent = message;
        errorDiv.classList.remove('hidden');
        submitBtn.disabled = false;
        submitBtn.textContent = 'Revendiquer gratuitement';
      }
    });
  </script>
</BaseLayout>
