---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { getCollection } from 'astro:content';

const guides = await getCollection('guides');

const breadcrumbs = [
  { label: 'Accueil', href: '/' },
  { label: 'Guides' },
];
const grouped = guides.reduce<Record<string, typeof guides>>((acc, guide) => {
  const cluster = guide.data.cluster;
  if (!acc[cluster]) acc[cluster] = [];
  acc[cluster].push(guide);
  return acc;
}, {});

const clusterLabels: Record<string, string> = {
  'perte-auditive': 'Perte auditive',
  'appareils-auditifs': 'Appareils auditifs',
  'acouphenes': 'Acouphènes',
  'prevention': 'Prévention',
  'remboursement': 'Remboursement',
  'vie-quotidienne': 'Vie quotidienne',
  'audioprothesiste': "L'audioprothésiste",
  'marques': 'Marques et fabricants',
};
---

<BaseLayout
  title="Tous nos guides — LeGuideAuditif.fr"
  description="Retrouvez tous nos guides sur l'audition : perte auditive, appareils, acouphènes, remboursement, prévention et vie quotidienne."
  schema={{
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: breadcrumbs.map((item, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      name: item.label,
      ...(item.href && { item: new URL(item.href, 'https://leguideauditif.fr').href }),
    })),
  }}
>
  <div class="bg-creme">
    <div class="max-w-[1140px] mx-auto px-5">
      <Breadcrumbs items={breadcrumbs} />
    </div>
  </div>
  <section class="bg-creme py-16">
    <div class="max-w-[1140px] mx-auto px-5">
      <h1 class="font-sans text-[38px] font-extrabold text-marine text-center mb-4">Nos guides</h1>
      <p class="text-center text-gris-texte text-lg mb-6 max-w-[600px] mx-auto">
        Tous nos contenus sur la santé auditive, rédigés par un audioprothésiste DE — 28 ans de clinique, 5 ans chez Auzen.com.
      </p>
      <div class="max-w-[700px] mx-auto text-gris-texte text-base leading-relaxed mb-12 space-y-3">
        <p>
          Ces guides sont nés de 28 ans de questions en cabine. "Combien ça coûte vraiment ?" "Est-ce que la mutuelle rembourse ?" "Mon appareil siffle, c'est normal ?" — chaque article répond à une question que mes patients m'ont posée des dizaines de fois. J'écris ce que je dis en consultation, sans jargon inutile, avec les mêmes exemples concrets.
        </p>
        <p>
          Le contenu est organisé par thème : <strong>perte auditive</strong> (comprendre votre audiogramme), <strong>appareils</strong> (choisir le bon type), <strong>remboursement</strong> (100% Santé, mutuelle, renouvellement), <strong>acouphènes</strong>, <strong>prévention</strong> et <strong>vie quotidienne</strong> (téléphone, TV, travail, voyage). Chaque affirmation médicale est sourcée — HAS, INSERM ou études PubMed.
        </p>
      </div>

      {Object.entries(clusterLabels).map(([cluster, label]) => {
        const entries = grouped[cluster];
        if (!entries || entries.length === 0) return null;
        return (
          <div class="mb-12">
            <h2 class="font-sans text-2xl font-bold text-marine mb-6">{label}</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
              {entries.map((guide) => (
                <a
                  href={`/guides/${guide.id}/`}
                  class="bg-blanc rounded-xl p-6 shadow-[0_2px_8px_rgba(27,46,74,0.06)] hover:shadow-lg hover:-translate-y-0.5 transition-all no-underline hover:no-underline"
                >
                  <h3 class="font-sans text-lg font-bold text-marine mb-2">{guide.data.title}</h3>
                  <p class="text-sm text-gris-texte leading-relaxed">{guide.data.metaDescription}</p>
                </a>
              ))}
            </div>
          </div>
        );
      })}
    </div>
  </section>
</BaseLayout>
