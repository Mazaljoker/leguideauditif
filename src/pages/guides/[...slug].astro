---
import { getCollection, render } from 'astro:content';
import GuideLayout from '../../layouts/GuideLayout.astro';
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import {
  buildMedicalWebPageSchema,
  buildPersonSchema,
  buildMedicalOrganizationSchema,
} from '../../utils/schema';

export async function getStaticPaths() {
  const guides = await getCollection('guides');
  return guides.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);
const { title, metaTitle, metaDescription, cluster, author, authorTitle, publishDate, updateDate, readingTime, sources, faq, image, ogImage, useLegacyLayout, quickAnswer } = entry.data;

/* Schemas santé YMYL étendus — tous les clusters sauf vie-quotidienne restent pertinents
   pour MedicalWebPage. remboursement ajouté (100 % Santé, prix appareils = YMYL strict).
   audioprothesiste ajouté (contenu expert médical). */
const healthClusters = [
  'perte-auditive',
  'acouphenes',
  'prevention',
  'appareils-auditifs',
  'remboursement',
  'audioprothesiste',
  'marques',
];

const currentUrl = new URL(Astro.url.pathname, Astro.site).href;
const extraSchemas: Record<string, unknown>[] = [];

/* Person + Organization injectés systématiquement pour renforcer E-E-A-T — unique @id réutilisable. */
extraSchemas.push(buildPersonSchema());
extraSchemas.push(buildMedicalOrganizationSchema());

if (healthClusters.includes(cluster)) {
  extraSchemas.push(
    buildMedicalWebPageSchema({
      title,
      description: metaDescription,
      url: currentUrl,
      lastReviewed: updateDate || publishDate,
    }),
  );
}
---

{useLegacyLayout ? (
  <GuideLayout
    title={title}
    metaTitle={metaTitle}
    metaDescription={metaDescription}
    cluster={cluster}
    author={author}
    authorTitle={authorTitle}
    publishDate={publishDate}
    updateDate={updateDate}
    headings={headings}
    sources={sources}
    faq={faq}
    image={image}
    ogImage={ogImage}
  >
    <Content />
  </GuideLayout>
) : (
  <ArticleLayout
    title={title}
    metaTitle={metaTitle}
    metaDescription={metaDescription}
    cluster={cluster}
    author={author}
    authorTitle={authorTitle}
    publishDate={publishDate}
    updateDate={updateDate}
    readingTime={readingTime}
    headings={headings}
    sources={sources}
    faq={faq}
    image={image}
    ogImage={ogImage}
    extraSchemas={extraSchemas}
    quickAnswer={quickAnswer}
  >
    <Content />
  </ArticleLayout>
)}
