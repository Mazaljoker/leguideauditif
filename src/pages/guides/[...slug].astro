---
import { getCollection, render } from 'astro:content';
import GuideLayout from '../../layouts/GuideLayout.astro';
import ArticleLayout from '../../layouts/ArticleLayout.astro';

export async function getStaticPaths() {
  const guides = await getCollection('guides');
  return guides.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);
const { title, metaDescription, cluster, author, authorTitle, publishDate, updateDate, readingTime, sources, faq, image, ogImage, useLegacyLayout } = entry.data;

/* MedicalWebPage schema pour les guides sante YMYL */
const healthClusters = ['perte-auditive', 'acouphenes', 'prevention'];
const extraSchemas = healthClusters.includes(cluster)
  ? [{
      '@context': 'https://schema.org',
      '@type': 'MedicalWebPage',
      name: title,
      about: { '@type': 'MedicalCondition', name: 'Perte auditive' },
      lastReviewed: (updateDate || publishDate).toISOString(),
      reviewedBy: {
        '@type': 'Person',
        name: 'Franck-Olivier Chabbat',
        jobTitle: "Audioprothesiste diplome d'Etat",
        url: 'https://leguideauditif.fr/auteur/franck-olivier/',
      },
    }]
  : undefined;
---

{useLegacyLayout ? (
  <GuideLayout
    title={title}
    metaDescription={metaDescription}
    cluster={cluster}
    author={author}
    authorTitle={authorTitle}
    publishDate={publishDate}
    updateDate={updateDate}
    headings={headings}
    sources={sources}
    faq={faq}
    image={image}
    ogImage={ogImage}
  >
    <Content />
  </GuideLayout>
) : (
  <ArticleLayout
    title={title}
    metaDescription={metaDescription}
    cluster={cluster}
    author={author}
    authorTitle={authorTitle}
    publishDate={publishDate}
    updateDate={updateDate}
    readingTime={readingTime}
    headings={headings}
    sources={sources}
    faq={faq}
    image={image}
    ogImage={ogImage}
    extraSchemas={extraSchemas}
  >
    <Content />
  </ArticleLayout>
)}
