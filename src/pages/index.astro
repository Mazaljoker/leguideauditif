---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import TrustBar from '../components/TrustBar.astro';
import GuideCard from '../components/GuideCard.astro';
import ComparatifBanner from '../components/ComparatifBanner.astro';
import StatsSection from '../components/StatsSection.astro';
import FaqPreview from '../components/FaqPreview.astro';
import CtaBanner from '../components/CtaBanner.astro';
import HealthDisclaimer from '../components/HealthDisclaimer.astro';

const guides = [
  {
    href: '/guides/remboursement/',
    icon: 'lucide:euro',
    title: 'Prix et remboursement',
    description: "100% Sante, mutuelles, reste a charge zero... Tout comprendre pour ne pas payer plus que necessaire.",
    visualClass: 'bg-gradient-to-br from-[#fff3e0] to-[#ffe0b2]',
    tag: 'Populaire',
  },
  {
    href: '/guides/appareils-auditifs/',
    icon: 'lucide:headphones',
    title: 'Choisir son appareil auditif',
    description: "Contour, intra, invisible, rechargeable... Les criteres qui comptent vraiment pour votre quotidien.",
    visualClass: 'bg-gradient-to-br from-[#e0ecff] to-[#c8d9f5]',
  },
  {
    href: '/guides/perte-auditive/',
    icon: 'lucide:ear',
    title: 'Comprendre la perte auditive',
    description: "Symptomes, causes, types de surdite et quand consulter. Le point de depart pour agir.",
    visualClass: 'bg-gradient-to-br from-[#e8edf5] to-[#d4dce8]',
  },
  {
    href: '/guides/acouphenes/',
    icon: 'lucide:bell-ring',
    title: 'Acouphenes',
    description: "Comprendre ces bruits fantomes, les traitements qui marchent et comment retrouver le calme.",
    visualClass: 'bg-gradient-to-br from-[#fce4ec] to-[#f8bbd0]',
  },
  {
    href: '/guides/prevention/',
    icon: 'lucide:shield-check',
    title: 'Proteger votre audition',
    description: "Bruit au travail, ecouteurs, concerts... Comment preserver votre capital auditif au quotidien.",
    visualClass: 'bg-gradient-to-br from-[#e8f5e9] to-[#c8e6c9]',
  },
  {
    href: '/guides/vie-quotidienne/',
    icon: 'lucide:home',
    title: 'Vivre avec ses appareils',
    description: "Telephone, television, sport, voyage... Tous les conseils pratiques pour votre quotidien.",
    visualClass: 'bg-gradient-to-br from-[#f3e5f5] to-[#e1bee7]',
  },
];

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: 'LeGuideAuditif.fr',
    url: 'https://leguideauditif.fr',
    description: "Le guide independant pour mieux entendre — redige par un audioprothesiste DE",
    founder: {
      '@type': 'Person',
      name: 'Franck-Olivier',
      jobTitle: "Audioprothesiste diplome d'Etat",
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'LeGuideAuditif.fr',
    url: 'https://leguideauditif.fr',
    potentialAction: {
      '@type': 'SearchAction',
      target: 'https://leguideauditif.fr/?s={search_term_string}',
      'query-input': 'required name=search_term_string',
    },
  },
];
---

<BaseLayout
  title="LeGuideAuditif.fr — Le guide independant pour mieux entendre"
  description="Guides clairs sur la perte auditive, appareils, remboursement et acouphenes. Rediges par un audioprothesiste DE independant avec 25 ans d'experience."
  schema={schema}
>
  <Hero />
  <TrustBar />

  <!-- Guides Section -->
  <section class="bg-creme py-18">
    <div class="max-w-[1140px] mx-auto px-5">
      <h2 class="font-sans text-[32px] font-extrabold text-center mb-3">Nos guides pour mieux entendre</h2>
      <p class="text-center text-gris-texte text-lg mb-12 max-w-[600px] mx-auto">
        Chaque guide est redige avec l'expertise de 25 ans de pratique en audioprothese.
      </p>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {guides.map((guide) => (
          <GuideCard {...guide} />
        ))}
      </div>
    </div>
  </section>

  <ComparatifBanner />
  <StatsSection />
  <FaqPreview />
  <CtaBanner />
  <HealthDisclaimer />
</BaseLayout>
