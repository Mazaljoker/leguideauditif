---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import TrustBar from '../components/TrustBar.astro';
import EditorialIntro from '../components/EditorialIntro.astro';
import ParcoursUtilisateur from '../components/ParcoursUtilisateur.astro';
import GuideCard from '../components/GuideCard.astro';
import ZoomSanteSection from '../components/ZoomSanteSection.astro';
import ComparatifBanner from '../components/ComparatifBanner.astro';
import VideoExpert from '../components/VideoExpert.astro';
import StatsSection from '../components/StatsSection.astro';
import Temoignages from '../components/Temoignages.astro';
import MotExpert from '../components/MotExpert.astro';
import FaqPreview from '../components/FaqPreview.astro';
import NewsletterCapture from '../components/NewsletterCapture.astro';
import DerniersArticles from '../components/DerniersArticles.astro';
import CtaBanner from '../components/CtaBanner.astro';
import HealthDisclaimer from '../components/HealthDisclaimer.astro';
import AnnoncesBanner from '../components/annonces/AnnoncesBanner.astro';

const guides = [
  {
    href: '/guides/remboursement/',
    icon: 'lucide:euro',
    title: 'Prix et remboursement',
    description: "Combien vous allez r\u00e9ellement payer en 2026. Le 100% Sant\u00e9 a tout chang\u00e9 \u2014 mais pas forc\u00e9ment comme on vous le pr\u00e9sente.",
    visualClass: 'bg-gradient-to-br from-[#fff3e0] to-[#ffe0b2]',
    image: '/images/blog/remboursement/remboursement.webp',
    tag: 'Populaire',
  },
  {
    href: '/guides/appareils-auditifs/',
    icon: 'lucide:headphones',
    title: 'Choisir son appareil',
    description: "Les vraies diff\u00e9rences entre les mod\u00e8les \u2014 et celles qui ne servent \u00e0 rien. Spoiler : le plus cher n'est pas toujours le mieux adapt\u00e9.",
    visualClass: 'bg-gradient-to-br from-[#e0ecff] to-[#c8d9f5]',
    image: '/images/blog/types/types.webp',
  },
  {
    href: '/guides/perte-auditive/',
    icon: 'lucide:ear',
    title: 'Comprendre sa perte auditive',
    description: "Les signes que la plupart des patients ignorent\u2026 jusqu'au moment o\u00f9 \u00e7a devient un probl\u00e8me. Sympt\u00f4mes, causes, et quand consulter.",
    visualClass: 'bg-gradient-to-br from-[#e8edf5] to-[#d4dce8]',
    image: '/images/blog/symptomes/symptomes.webp',
  },
  {
    href: '/guides/acouphenes/',
    icon: 'lucide:bell-ring',
    title: 'Acouph\u00e8nes',
    description: "Ce qui marche vraiment en 2026 \u2014 et ce que je d\u00e9conseille en pratique. Comprendre ces bruits fant\u00f4mes et retrouver le calme.",
    visualClass: 'bg-gradient-to-br from-[#fce4ec] to-[#f8bbd0]',
    image: '/images/blog/acouphenes/acouphenes.webp',
  },
  {
    href: '/guides/prevention/',
    icon: 'lucide:shield-check',
    title: 'Prot\u00e9ger votre audition',
    description: "Bruit au travail, \u00e9couteurs, concerts\u2026 Les gestes concrets pour pr\u00e9server votre capital auditif. Certains sont simples, d'autres moins \u00e9vidents.",
    visualClass: 'bg-gradient-to-br from-[#e8f5e9] to-[#c8e6c9]',
    image: '/images/blog/prevention/prevention.webp',
  },
  {
    href: '/guides/vie-quotidienne/',
    icon: 'lucide:home',
    title: 'Vivre avec ses appareils',
    description: "T\u00e9l\u00e9phone, bruit de fond, conversations \u00e0 plusieurs\u2026 Les situations qui posent vraiment probl\u00e8me et comment les g\u00e9rer.",
    visualClass: 'bg-gradient-to-br from-[#f3e5f5] to-[#e1bee7]',
    image: '/images/blog/vie-quotidienne/vie-quotidienne.webp',
  },
];

const topBrands = [
  { slug: 'phonak', label: 'Phonak', groupe: 'Sonova' },
  { slug: 'signia', label: 'Signia', groupe: 'WS Audiology' },
  { slug: 'oticon', label: 'Oticon', groupe: 'Demant' },
  { slug: 'resound', label: 'ReSound', groupe: 'GN' },
  { slug: 'widex', label: 'Widex', groupe: 'WS Audiology' },
  { slug: 'starkey', label: 'Starkey', groupe: 'Starkey' },
];

const topVilles = [
  { slug: 'paris', label: 'Paris' },
  { slug: 'lyon', label: 'Lyon' },
  { slug: 'marseille', label: 'Marseille' },
  { slug: 'toulouse', label: 'Toulouse' },
  { slug: 'bordeaux', label: 'Bordeaux' },
  { slug: 'nice', label: 'Nice' },
  { slug: 'nantes', label: 'Nantes' },
  { slug: 'strasbourg', label: 'Strasbourg' },
  { slug: 'montpellier', label: 'Montpellier' },
  { slug: 'lille', label: 'Lille' },
  { slug: 'rennes', label: 'Rennes' },
  { slug: 'toulon', label: 'Toulon' },
];

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'MedicalWebPage',
    name: 'LeGuideAuditif.fr',
    url: 'https://leguideauditif.fr',
    description: "Le guide indépendant pour mieux entendre — rédigé par un audioprothésiste DE avec 28 ans d'expérience clinique et 5 ans chez Auzen.com. Guides, comparatifs et conseils sur la perte auditive, les appareils auditifs et le remboursement 100% Santé.",
    about: {
      '@type': 'MedicalCondition',
      name: 'Perte auditive',
    },
    author: {
      '@type': 'Person',
      name: 'Franck-Olivier',
      jobTitle: "Audioprothésiste diplômé d'État",
      description: "Audioprothésiste DE, 28 ans d'expérience — Amplifon, Audika, 18 centres Afflelou, 5 ans Auzen.com, 3 000+ patients.",
      url: 'https://leguideauditif.fr/a-propos/',
    },
    publisher: {
      '@type': 'Organization',
      name: 'LeGuideAuditif.fr',
      url: 'https://leguideauditif.fr',
    },
    lastReviewed: '2026-04-01',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'LeGuideAuditif.fr',
    url: 'https://leguideauditif.fr',
    potentialAction: {
      '@type': 'SearchAction',
      target: 'https://leguideauditif.fr/?s={search_term_string}',
      'query-input': 'required name=search_term_string',
    },
  },
];
---

<BaseLayout
  title="LeGuideAuditif.fr — Le guide indépendant pour mieux entendre"
  description="Guides sur la perte auditive, appareils auditifs, remboursement 100% Santé et acouphènes. Par un audioprothésiste DE, 28 ans d'expérience."
  schema={schema}
>
  <!-- 1. Hero -->
  <Hero />

  <!-- 2. Trust Bar -->
  <TrustBar />

  <!-- 3. Editorial Introduction -->
  <EditorialIntro />

  <!-- 4. Parcours Utilisateur -->
  <ParcoursUtilisateur />

  <!-- 5. Guides Section -->
  <section class="bg-blanc py-18">
    <div class="max-w-[1140px] mx-auto px-5">
      <h2 class="font-sans text-[32px] font-extrabold text-center mb-3" data-animate>Ce que vous devez savoir avant de d&eacute;cider</h2>
      <p class="text-center text-gris-texte text-lg mb-12 max-w-[600px] mx-auto" data-animate>
        Pas des articles. Des r&eacute;ponses. &Eacute;crites par quelqu'un qui a vu ces situations 3&nbsp;000 fois.
      </p>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {guides.map((guide) => (
          <GuideCard {...guide} />
        ))}
      </div>
    </div>
  </section>

  <!-- 5b. Catalogue Vitrine -->
  <section class="bg-creme py-18">
    <div class="max-w-[1140px] mx-auto px-5">
      <div class="text-center mb-10">
        <span class="inline-block px-4 py-1.5 rounded-full bg-orange/10 text-orange font-sans text-sm font-bold mb-4">Nouveau</span>
        <h2 class="font-sans text-[32px] font-extrabold text-marine mb-3" data-animate>
          Catalogue des aides auditives
        </h2>
        <p class="text-gris-texte text-lg max-w-[640px] mx-auto" data-animate>
          Comparez les appareils auditifs disponibles en France : prix, caractéristiques, Classe 1 ou 2. Un outil gratuit, indépendant, par un audioprothésiste DE.
        </p>
      </div>

      <!-- Stats -->
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-10">
        <div class="bg-blanc rounded-xl p-5 text-center shadow-sm">
          <div class="font-sans text-3xl font-extrabold text-orange">139</div>
          <div class="font-sans text-sm text-gris-texte mt-1">Appareils référencés</div>
        </div>
        <div class="bg-blanc rounded-xl p-5 text-center shadow-sm">
          <div class="font-sans text-3xl font-extrabold text-orange">12</div>
          <div class="font-sans text-sm text-gris-texte mt-1">Marques européennes</div>
        </div>
        <div class="bg-blanc rounded-xl p-5 text-center shadow-sm">
          <div class="font-sans text-3xl font-extrabold text-emerald-600">0€</div>
          <div class="font-sans text-sm text-gris-texte mt-1">Reste à charge Classe 1</div>
        </div>
        <div class="bg-blanc rounded-xl p-5 text-center shadow-sm">
          <div class="font-sans text-3xl font-extrabold text-orange">6</div>
          <div class="font-sans text-sm text-gris-texte mt-1">Types d'appareils</div>
        </div>
      </div>

      <!-- Top marques -->
      <h3 class="font-sans text-lg font-bold text-marine mb-4 text-center">Parcourir par marque</h3>
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-3 mb-8">
        {topBrands.map((brand) => (
          <a
            href={`/catalogue/marques/${brand.slug}/`}
            class="bg-blanc rounded-xl p-4 text-center shadow-sm hover:shadow-md transition-shadow no-underline hover:no-underline group"
          >
            <div class="font-sans text-base font-bold text-marine group-hover:text-orange transition-colors">{brand.label}</div>
            <div class="font-sans text-xs text-gris-texte mt-0.5">{brand.groupe}</div>
          </a>
        ))}
      </div>

      <!-- Liens rapides -->
      <div class="flex flex-wrap justify-center gap-3 mb-8">
        <a href="/catalogue/classe-1/" class="inline-flex items-center gap-2 px-5 py-2.5 bg-emerald-600 text-white font-sans text-sm font-semibold rounded-lg no-underline hover:bg-emerald-700 transition-colors hover:no-underline">
          Classe 1 — 0€ de reste à charge
        </a>
        <a href="/catalogue/types/ric/" class="inline-flex items-center gap-2 px-5 py-2.5 bg-blanc text-marine border border-gris-clair font-sans text-sm font-semibold rounded-lg no-underline hover:border-orange hover:text-orange transition-colors hover:no-underline">
          Contours RIC
        </a>
        <a href="/catalogue/types/iic/" class="inline-flex items-center gap-2 px-5 py-2.5 bg-blanc text-marine border border-gris-clair font-sans text-sm font-semibold rounded-lg no-underline hover:border-orange hover:text-orange transition-colors hover:no-underline">
          Invisibles IIC
        </a>
        <a href="/catalogue/comparer/" class="inline-flex items-center gap-2 px-5 py-2.5 bg-blanc text-marine border border-gris-clair font-sans text-sm font-semibold rounded-lg no-underline hover:border-orange hover:text-orange transition-colors hover:no-underline">
          Comparer des appareils
        </a>
      </div>

      <!-- CTA principal -->
      <div class="text-center">
        <a
          href="/catalogue/"
          class="inline-flex items-center gap-2 px-8 py-3.5 bg-orange text-white font-sans text-lg font-bold rounded-xl no-underline hover:bg-orange-hover transition-colors hover:no-underline"
        >
          Explorer le catalogue complet →
        </a>
      </div>
    </div>
  </section>

  <!-- 5c. Annuaire audioprothésistes (silo SEO) -->
  <section class="bg-blanc py-18">
    <div class="max-w-[1140px] mx-auto px-5">
      <div class="text-center mb-10">
        <h2 class="font-sans text-[32px] font-extrabold text-marine mb-3" data-animate>
          Trouver un audioprothésiste près de chez vous
        </h2>
        <p class="text-gris-texte text-lg max-w-[640px] mx-auto" data-animate>
          7 654 centres auditifs référencés dans 96 départements. Annuaire indépendant, sans publicité, par un audioprothésiste DE.
        </p>
      </div>

      <!-- Grille villes phares -->
      <h3 class="font-sans text-lg font-bold text-marine mb-4 text-center">Les grandes villes</h3>
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-3 mb-8">
        {topVilles.map((ville) => (
          <a
            href={`/audioprothesiste/${ville.slug}/`}
            class="bg-creme rounded-xl px-4 py-3 text-center shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all no-underline hover:no-underline"
          >
            <span class="font-sans text-sm font-semibold text-marine">{ville.label}</span>
          </a>
        ))}
      </div>

      <!-- CTAs -->
      <div class="flex flex-wrap justify-center gap-3">
        <a
          href="/audioprothesiste/"
          class="inline-flex items-center gap-2 px-8 py-3.5 bg-orange text-white font-sans text-lg font-bold rounded-xl no-underline hover:bg-orange-hover transition-colors hover:no-underline"
        >
          Annuaire par département &rarr;
        </a>
        <a
          href="/trouver-audioprothesiste/"
          class="inline-flex items-center gap-2 px-8 py-3.5 bg-blanc text-marine border border-marine font-sans text-lg font-bold rounded-xl no-underline hover:bg-marine hover:text-white transition-colors hover:no-underline"
        >
          Voir la carte interactive
        </a>
      </div>
    </div>
  </section>

  <!-- 6. Zoom 100% Santé -->
  <ZoomSanteSection />

  <!-- 7. Comparatifs -->
  <ComparatifBanner />

  <!-- 8. Vidéo Expert -->
  <VideoExpert />

  <!-- 9. Stats -->
  <StatsSection />

  <!-- 10. Témoignages -->
  <Temoignages />

  <!-- 10b. Petites Annonces Pro -->
  <AnnoncesBanner />

  <!-- 11. Le mot de l'expert -->
  <MotExpert />

  <!-- 12. FAQ -->
  <FaqPreview />

  <!-- 13. Newsletter -->
  <NewsletterCapture />

  <!-- 14. Derniers articles -->
  <DerniersArticles />

  <!-- 15. CTA + Disclaimer -->
  <CtaBanner />
  <HealthDisclaimer />
</BaseLayout>
