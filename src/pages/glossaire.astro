---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';

const breadcrumbs = [
  { label: 'Accueil', href: '/' },
  { label: 'Glossaire' },
];

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: breadcrumbs.map((item, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: item.label,
    ...(item.href && { item: new URL(item.href, 'https://leguideauditif.fr').href }),
  })),
};

const siteUrl = 'https://leguideauditif.fr';

const termes = [
  { terme: 'Acouphène', definition: 'Perception d\'un son (bourdonnement, sifflement) sans source sonore externe. Les acouphènes touchent environ 10 à 15 % de la population adulte et peuvent être temporaires ou chroniques.', lien: '/guides/acouphenes/', lienTexte: 'Comprendre les acouphènes' },
  { terme: 'Acouphénométrie', definition: 'Examen audiologique qui mesure la fréquence et l\'intensité des acouphènes perçus par le patient. Ce test aide l\'audioprothésiste à proposer une prise en charge adaptée.', lien: '/guides/acouphenes/traitement/', lienTexte: 'Traitements des acouphènes' },
  { terme: 'Aide auditive', definition: 'Dispositif médical électronique amplifiant les sons pour compenser une perte auditive. On parle aussi d\'appareil auditif ou de prothèse auditive.', lien: '/guides/appareils-auditifs/', lienTexte: 'Guide des appareils auditifs' },
  { terme: 'Antilarsen', definition: 'Système électronique intégré aux aides auditives qui supprime le sifflement (effet Larsen) provoqué par le retour du son amplifié vers le microphone.', lien: '/guides/appareils-auditifs/premier-appareil/', lienTexte: 'Choisir son premier appareil' },
  { terme: 'Appareillage binaural', definition: 'Équipement des deux oreilles avec des aides auditives. L\'appareillage binaural améliore la localisation des sons et la compréhension dans le bruit.', lien: '/guides/appareils-auditifs/types/', lienTexte: 'Types d\'appareils auditifs' },
  { terme: 'Audiogramme', definition: 'Graphique représentant votre capacité auditive pour chaque fréquence (grave à aiguë). C\'est le résultat de l\'examen audiométrique réalisé par l\'ORL ou l\'audioprothésiste.', lien: '/guides/audiogramme/', lienTexte: 'Lire un audiogramme' },
  { terme: 'Audioprothésiste', definition: 'Professionnel de santé diplômé d\'État spécialisé dans l\'appareillage et le suivi des personnes malentendantes. Il réalise les tests, adapte et règle vos aides auditives.', lien: '/guides/audioprothesiste/', lienTexte: 'Rôle de l\'audioprothésiste' },
  { terme: 'Bobine T (telecoil)', definition: 'Petite antenne intégrée dans certaines aides auditives qui capte les signaux des boucles à induction magnétique. Elle permet d\'entendre directement le son dans les lieux équipés (guichets, salles de spectacle).', lien: '/guides/appareils-auditifs/accessoires/', lienTexte: 'Accessoires pour aides auditives' },
  { terme: 'BTE (contour d\'oreille)', definition: 'Type d\'aide auditive dont le boîtier se place derrière le pavillon de l\'oreille. Le son est conduit vers le conduit auditif par un tube. Robuste et adapté à toutes les pertes auditives.', lien: '/guides/appareils-auditifs/types/', lienTexte: 'Types d\'appareils auditifs' },
  { terme: 'Cellules ciliées', definition: 'Cellules sensorielles situées dans la cochlée (oreille interne) qui transforment les vibrations sonores en signaux nerveux. Leur destruction est irréversible et constitue la principale cause de surdité de perception.', lien: '/guides/perte-auditive/causes/', lienTexte: 'Causes de la perte auditive' },
  { terme: 'CIC (Completely-in-Canal)', definition: 'Aide auditive intra-auriculaire placée entièrement dans le conduit auditif. Très discrète, elle convient aux pertes auditives légères à moyennes.', lien: '/guides/appareils-auditifs/invisible/', lienTexte: 'Appareils auditifs invisibles' },
  { terme: 'Classe 1', definition: 'Catégorie d\'aides auditives dont le prix est plafonné et le reste à charge nul grâce au dispositif 100 % Santé. Ces appareils offrent les fonctionnalités essentielles.', lien: '/guides/appareils-auditifs/classe-1-vs-classe-2/', lienTexte: 'Classe 1 vs Classe 2' },
  { terme: 'Classe 2', definition: 'Catégorie d\'aides auditives à prix libre, offrant des fonctionnalités avancées (rechargeable, Bluetooth, réducteur de bruit supérieur). Le reste à charge dépend de votre mutuelle.', lien: '/guides/appareils-auditifs/classe-1-vs-classe-2/', lienTexte: 'Classe 1 vs Classe 2' },
  { terme: 'Conduction aérienne', definition: 'Transmission du son par le conduit auditif externe, le tympan et les osselets jusqu\'à l\'oreille interne. C\'est la voie normale d\'audition, testée lors de l\'audiogramme avec un casque.', lien: '/guides/audiogramme/', lienTexte: 'Lire un audiogramme' },
  { terme: 'Conduction osseuse', definition: 'Transmission du son directement par les os du crâne jusqu\'à l\'oreille interne, sans passer par le conduit auditif. Testée avec un vibrateur lors de l\'audiogramme pour distinguer surdité de transmission et de perception.', lien: '/guides/audiogramme/', lienTexte: 'Lire un audiogramme' },
  { terme: 'Décibel (dB)', definition: 'Unité de mesure de l\'intensité sonore. Une conversation normale se situe autour de 60 dB. Au-delà de 85 dB d\'exposition prolongée, le risque de lésion auditive augmente significativement.', lien: '/guides/prevention/', lienTexte: 'Prévention auditive' },
  { terme: 'Déshumidificateur', definition: 'Boîtier ou capsule qui absorbe l\'humidité accumulée dans vos aides auditives. Son utilisation quotidienne prolonge la durée de vie de l\'appareil et prévient les pannes.', lien: '/guides/appareils-auditifs/entretien/', lienTexte: 'Entretien des appareils' },
  { terme: 'Dôme', definition: 'Embout souple en silicone placé à l\'extrémité du tube ou du fil de l\'aide auditive. Il existe en différentes tailles (ouvert, semi-ouvert, fermé) selon le degré de perte auditive.', lien: '/guides/appareils-auditifs/adaptation/', lienTexte: 'Adaptation de l\'appareil' },
  { terme: 'Embout', definition: 'Pièce moulée sur mesure en silicone ou résine qui s\'insère dans le conduit auditif. L\'embout sur mesure assure un maintien optimal et réduit le risque d\'effet Larsen pour les pertes auditives moyennes à sévères.', lien: '/guides/appareils-auditifs/adaptation/', lienTexte: 'Adaptation de l\'appareil' },
  { terme: 'Essai 30 jours', definition: 'Période légale d\'essai de 30 jours minimum pendant laquelle vous pouvez tester votre aide auditive en conditions réelles et la restituer sans frais si elle ne vous convient pas.', lien: '/guides/audioprothesiste/premier-rdv/', lienTexte: 'Premier rendez-vous' },
  { terme: 'Filtre anti-cérumen', definition: 'Petit filtre de protection placé à l\'extrémité de l\'aide auditive pour empêcher le cérumen de pénétrer dans le récepteur. À remplacer régulièrement pour maintenir une bonne qualité sonore.', lien: '/guides/appareils-auditifs/entretien/', lienTexte: 'Entretien des appareils' },
  { terme: 'HAS (Haute Autorité de Santé)', definition: 'Institution publique française qui évalue les dispositifs médicaux, émet des recommandations de bonne pratique et définit les conditions de remboursement des aides auditives.', lien: '/guides/remboursement/', lienTexte: 'Guide du remboursement' },
  { terme: 'Hyperacousie', definition: 'Hypersensibilité aux sons d\'intensité normale, qui sont perçus comme désagréables voire douloureux. L\'hyperacousie est souvent associée aux acouphènes.', lien: '/guides/acouphenes/hyperacousie/', lienTexte: 'Comprendre l\'hyperacousie' },
  { terme: 'IIC (Invisible-in-Canal)', definition: 'Aide auditive la plus discrète, insérée profondément dans le conduit auditif. Invisible de l\'extérieur, elle est réservée aux pertes auditives légères à moyennes.', lien: '/guides/appareils-auditifs/invisible/', lienTexte: 'Appareils auditifs invisibles' },
  { terme: 'Implant cochléaire', definition: 'Dispositif médical chirurgicalement implanté qui stimule directement le nerf auditif. Il est proposé aux personnes atteintes de surdité sévère à profonde pour lesquelles les aides auditives classiques ne suffisent plus.', lien: '/guides/perte-auditive/', lienTexte: 'Comprendre la perte auditive' },
  { terme: 'LPPR (Liste des Produits et Prestations Remboursables)', definition: 'Liste officielle de la Sécurité sociale répertoriant les dispositifs médicaux pris en charge, dont les aides auditives. L\'inscription à la LPPR conditionne le remboursement.', lien: '/guides/remboursement/', lienTexte: 'Guide du remboursement' },
  { terme: 'Mesure in vivo', definition: 'Technique de vérification du réglage de l\'aide auditive réalisée avec une sonde placée dans le conduit auditif. Elle mesure le son réel délivré au tympan et permet un ajustement précis et objectif.', lien: '/guides/audioprothesiste/suivi/', lienTexte: 'Suivi audioprothésique' },
  { terme: 'Mutuelle responsable', definition: 'Contrat de complémentaire santé respectant un cahier des charges fixé par la loi, incluant la prise en charge minimale des aides auditives de classe 1 (reste à charge zéro).', lien: '/guides/remboursement/mutuelle/', lienTexte: 'Mutuelle et audition' },
  { terme: 'ORL (Oto-Rhino-Laryngologiste)', definition: 'Médecin spécialiste des pathologies de l\'oreille, du nez et de la gorge. C\'est l\'ORL qui pose le diagnostic de perte auditive et prescrit l\'appareillage.', lien: '/guides/audioprothesiste/orl-vs-audio/', lienTexte: 'ORL vs audioprothésiste' },
  { terme: 'Otoscopie', definition: 'Examen visuel du conduit auditif et du tympan à l\'aide d\'un otoscope. Cet examen permet de vérifier l\'absence de bouchon de cérumen ou de pathologie avant tout appareillage.', lien: '/guides/audioprothesiste/premier-rdv/', lienTexte: 'Premier rendez-vous' },
  { terme: 'Otoemissions acoustiques (OEA)', definition: 'Sons très faibles émis spontanément par les cellules ciliées externes de la cochlée. Leur mesure permet de vérifier le bon fonctionnement de l\'oreille interne, notamment lors du dépistage néonatal.', lien: '/guides/perte-auditive/', lienTexte: 'Comprendre la perte auditive' },
  { terme: 'PCH (Prestation de Compensation du Handicap)', definition: 'Aide financière versée par le département aux personnes en situation de handicap. La PCH peut couvrir une partie du coût des aides auditives et de leurs accessoires.', lien: '/guides/remboursement/aides-financieres/', lienTexte: 'Aides financières' },
  { terme: 'Presbyacousie', definition: 'Perte auditive progressive liée au vieillissement naturel de l\'oreille interne. Elle touche d\'abord les fréquences aiguës et concerne la majorité des personnes après 60 ans.', lien: '/guides/perte-auditive/', lienTexte: 'Comprendre la perte auditive' },
  { terme: 'RIC (Receiver-in-Canal)', definition: 'Type d\'aide auditive dont le récepteur (haut-parleur) est placé directement dans le conduit auditif, relié au boîtier derrière l\'oreille par un fil fin. C\'est le format le plus prescrit aujourd\'hui pour sa discrétion et sa qualité sonore.', lien: '/guides/appareils-auditifs/types/', lienTexte: 'Types d\'appareils auditifs' },
  { terme: 'RQTH (Reconnaissance de la Qualité de Travailleur Handicapé)', definition: 'Statut délivré par la MDPH qui ouvre des droits spécifiques en milieu professionnel. En cas de perte auditive, la RQTH peut faciliter l\'aménagement de poste et l\'accès à des aides complémentaires.', lien: '/guides/remboursement/aides-financieres/', lienTexte: 'Aides financières' },
  { terme: 'Schéma de remboursement', definition: 'Parcours de prise en charge financière d\'une aide auditive : prescription ORL, devis normalisé, accord de la Sécurité sociale, complément mutuelle. Chaque étape conditionne le remboursement.', lien: '/guides/remboursement/', lienTexte: 'Guide du remboursement' },
  { terme: 'Surdité de perception', definition: 'Perte auditive causée par une atteinte de l\'oreille interne (cochlée) ou du nerf auditif. C\'est le type de surdité le plus fréquent chez l\'adulte, souvent lié au vieillissement ou au bruit.', lien: '/guides/perte-auditive/causes/', lienTexte: 'Causes de la perte auditive' },
  { terme: 'Surdité de transmission', definition: 'Perte auditive causée par un obstacle mécanique dans l\'oreille externe ou moyenne (bouchon de cérumen, otite, otospongiose). Elle est souvent traitable médicalement ou chirurgicalement.', lien: '/guides/perte-auditive/causes/', lienTexte: 'Causes de la perte auditive' },
  { terme: 'Téléaudiologie', definition: 'Pratique de l\'audioprothèse à distance grâce aux outils numériques. Elle permet les réglages à distance, le suivi et les téléconsultations, particulièrement utile pour les personnes à mobilité réduite.', lien: '/guides/audioprothesiste/teleaudiologie/', lienTexte: 'Téléaudiologie' },
  { terme: 'TRT (Tinnitus Retraining Therapy)', definition: 'Méthode de rééducation des acouphènes combinant une thérapie sonore (générateur de bruit) et un accompagnement psychologique. L\'objectif est d\'habituer le cerveau à ne plus percevoir l\'acouphène comme gênant.', lien: '/guides/acouphenes/therapie-sonore/', lienTexte: 'Thérapie sonore' },
  { terme: '100 % Santé (audiologie)', definition: 'Réforme entrée en vigueur en 2021 qui garantit un reste à charge nul sur les aides auditives de classe 1 pour les assurés disposant d\'une mutuelle responsable. Le prix est plafonné à 950 euros par oreille.', lien: '/guides/remboursement/100-sante-audition/', lienTexte: '100 % Santé audiologie' },
];

const lettres = [...new Set(termes.map(t => {
  const first = t.terme.charAt(0).toUpperCase();
  return /[0-9]/.test(first) ? '#' : first;
}))];

const termesParLettre = lettres.map(lettre => ({
  lettre,
  items: termes.filter(t => {
    const first = t.terme.charAt(0).toUpperCase();
    const group = /[0-9]/.test(first) ? '#' : first;
    return group === lettre;
  }),
}));

const definedTermSetSchema = {
  '@context': 'https://schema.org',
  '@type': 'DefinedTermSet',
  name: 'Glossaire de l\'audition',
  description: 'Définitions des termes essentiels de l\'audition et des aides auditives.',
  url: `${siteUrl}/glossaire/`,
  hasDefinedTerm: termes.map(t => ({
    '@type': 'DefinedTerm',
    name: t.terme,
    description: t.definition,
    url: `${siteUrl}/glossaire/#${t.terme.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '').replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '')}`,
  })),
};

const schemas = [breadcrumbSchema, definedTermSetSchema];
---

<BaseLayout
  title="Glossaire de l'audition — LeGuideAuditif.fr"
  description="Glossaire complet des termes de l'audition : presbyacousie, acouphènes, audiogramme, contour, RIC, et plus. Définitions claires pour les seniors."
  schema={schemas}
>
  <div class="bg-creme">
    <div class="max-w-[780px] mx-auto px-5">
      <Breadcrumbs items={breadcrumbs} />
    </div>
  </div>
  <section class="bg-creme py-16">
    <div class="max-w-[780px] mx-auto px-5">
      <h1 class="font-sans text-[38px] font-extrabold text-marine mb-8">Glossaire de l'audition</h1>
      <p class="text-lg leading-relaxed text-gris-texte mb-10">
        Vous rencontrez un terme technique que vous ne comprenez pas ? Ce glossaire réunit les définitions essentielles de l'audiologie, des aides auditives et du remboursement. Chaque terme est expliqué simplement, avec un lien vers le guide correspondant pour approfondir.
      </p>

      <!-- Navigation alphabétique -->
      <nav aria-label="Navigation alphabétique du glossaire" class="flex flex-wrap gap-2 mb-12">
        {lettres.map(lettre => (
          <a
            href={`#lettre-${lettre === '#' ? 'num' : lettre.toLowerCase()}`}
            class="inline-flex items-center justify-center w-10 h-10 rounded-md bg-marine text-creme font-sans font-bold text-base hover:bg-orange transition-colors focus:outline-3 focus:outline-orange"
          >
            {lettre}
          </a>
        ))}
      </nav>

      <!-- Définitions par lettre -->
      {termesParLettre.map(({ lettre, items }) => (
        <div id={`lettre-${lettre === '#' ? 'num' : lettre.toLowerCase()}`} class="mb-12 scroll-mt-24">
          <h2 class="font-sans text-2xl font-bold text-marine border-b-2 border-orange pb-2 mb-6">{lettre}</h2>
          <dl class="space-y-6">
            {items.map(item => {
              const ancre = item.terme.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '').replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
              return (
                <div id={ancre} class="scroll-mt-24">
                  <dt class="font-serif text-lg font-bold text-marine mb-1">{item.terme}</dt>
                  <dd class="text-gris-texte leading-relaxed">
                    {item.definition}
                    {item.lien && (
                      <span class="ml-1">
                        &rarr; <a href={item.lien} class="text-orange font-semibold hover:underline focus:outline-3 focus:outline-orange">{item.lienTexte}</a>
                      </span>
                    )}
                  </dd>
                </div>
              );
            })}
          </dl>
        </div>
      ))}

      <!-- Retour en haut -->
      <div class="text-center mt-8 mb-4">
        <a href="#" class="text-orange font-semibold hover:underline focus:outline-3 focus:outline-orange">&uarr; Retour en haut de page</a>
      </div>
    </div>
  </section>
</BaseLayout>
