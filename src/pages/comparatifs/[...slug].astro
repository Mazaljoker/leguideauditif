---
import { getCollection, render } from 'astro:content';
import ComparatifLayout from '../../layouts/ComparatifLayout.astro';

export async function getStaticPaths() {
  const comparatifs = await getCollection('comparatifs');
  return comparatifs.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);
const { title, metaDescription, category, author, authorTitle, publishDate, updateDate, products, faq, image, ogImage } = entry.data;
---

<ComparatifLayout
  title={title}
  metaDescription={metaDescription}
  category={category}
  author={author}
  authorTitle={authorTitle}
  publishDate={publishDate}
  updateDate={updateDate}
  headings={headings}
  products={products}
  faq={faq}
  image={image}
  ogImage={ogImage}
>
  <Content />
</ComparatifLayout>
