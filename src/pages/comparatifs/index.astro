---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { getCollection } from 'astro:content';

const comparatifs = await getCollection('comparatifs');

const breadcrumbs = [
  { label: 'Accueil', href: '/' },
  { label: 'Comparatifs' },
];
---

<BaseLayout
  title="Nos comparatifs indépendants — LeGuideAuditif.fr"
  description="Comparatifs d'appareils auditifs, protections et accessoires. Tests indépendants par un audioprothésiste DE — 28 ans de clinique, 5 ans chez Auzen.com."
  schema={{
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: breadcrumbs.map((item, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      name: item.label,
      ...(item.href && { item: new URL(item.href, 'https://leguideauditif.fr').href }),
    })),
  }}
>
  <div class="bg-creme">
    <div class="max-w-[1140px] mx-auto px-5">
      <Breadcrumbs items={breadcrumbs} />
    </div>
  </div>
  <section class="bg-creme py-16">
    <div class="max-w-[1140px] mx-auto px-5">
      <h1 class="font-sans text-[38px] font-extrabold text-marine text-center mb-4">Nos comparatifs</h1>
      <p class="text-center text-gris-texte text-lg mb-6 max-w-[600px] mx-auto">
        Des comparatifs indépendants pour vous aider à choisir le bon appareil auditif.
      </p>
      <div class="max-w-[700px] mx-auto text-gris-texte text-base leading-relaxed mb-12 space-y-3">
        <p>
          Chaque comparatif est rédigé après essai en cabine ou retour patient documenté. En 28 ans, j'ai appareillé plus de 3 000 personnes — ce qui compte au quotidien, ce n'est pas la fiche technique du fabricant, c'est le confort réel dans le bruit, la tenue de la batterie au bout de 6 mois, la facilité de manipulation pour des doigts arthrosiques.
        </p>
        <p>
          Nos tests couvrent les <a href="/catalogue/" class="text-orange hover:underline">appareils auditifs</a> contour, intra-auriculaire et invisible, mais aussi les accessoires (TV Connector, micro distant) et les protections auditives. Chaque verdict indique si un modèle existe en <a href="/guides/remboursement/100-sante-audition/" class="text-orange hover:underline">classe 1 (reste à charge zéro)</a> ou en classe 2, pour que vous puissiez comparer à budget équivalent.
        </p>
        <p>
          Un doute sur le modèle qui vous conviendrait ? <a href="/devis/" class="text-orange hover:underline">Demandez un devis gratuit</a> — un audioprothésiste diplômé d'État proche de chez vous vous rappelle sous 48h pour un bilan personnalisé.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {comparatifs.map((entry) => (
          <a
            href={`/comparatifs/${entry.id}/`}
            class="bg-blanc rounded-xl p-6 shadow-[0_2px_8px_rgba(27,46,74,0.06)] hover:shadow-lg hover:-translate-y-0.5 transition-all no-underline hover:no-underline"
          >
            <h3 class="font-sans text-lg font-bold text-marine mb-2">{entry.data.title}</h3>
            <p class="text-sm text-gris-texte leading-relaxed">{entry.data.metaDescription}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
