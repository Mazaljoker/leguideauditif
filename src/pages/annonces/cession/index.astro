---
export const prerender = false;

import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import AnnonceListing from '../../../components/annonces/AnnonceListing';

const breadcrumbs = [
  { label: 'Accueil', href: '/' },
  { label: 'Annonces', href: '/annonces/' },
  { label: 'Cession & Installation' },
];

const schema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Cession de centres audioprothèse',
};
---

<BaseLayout
  title="Cession centres audioprothèse — LeGuideAuditif"
  description="Centres à vendre, fonds de commerce, baux à céder. Trouvez votre opportunité dans l'audioprothèse."
  schema={schema}
>
  <div class="max-w-[1140px] mx-auto px-5 py-8">
    <Breadcrumbs items={breadcrumbs} />

    <h1 class="font-sans text-3xl font-extrabold text-marine mb-2">Cession & Installation</h1>
    <p class="text-gris-texte text-lg mb-8 font-sans">
      Centres a vendre, fonds de commerce, patienteles et baux a ceder.
    </p>

    <AnnonceListing client:load categorie="cession" />
  </div>
</BaseLayout>
