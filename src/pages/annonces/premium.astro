---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { Icon } from 'astro-icon/components';

const breadcrumbs = [
  { label: 'Accueil', href: '/' },
  { label: 'Annonces', href: '/annonces/' },
  { label: 'Options premium' },
];
---

<BaseLayout
  title="Options premium annonces — LeGuideAuditif"
  description="Débloquez les contacts, passez en premium, boostez votre annonce. Options payantes pour maximiser la visibilité de vos annonces audioprothèse."
>
  <div class="max-w-[1140px] mx-auto px-5 py-8">
    <Breadcrumbs items={breadcrumbs} />

    <div class="text-center py-16 max-w-2xl mx-auto">
      <Icon name="lucide:clock" class="w-12 h-12 text-orange mx-auto mb-6" />
      <h1 class="font-sans text-3xl sm:text-4xl font-extrabold text-marine mb-4">
        Options premium — bientôt disponibles
      </h1>
      <p class="text-gris-texte text-lg font-sans mb-4 leading-relaxed">
        Les annonces sur LeGuideAuditif sont gratuites.
        Des options de mise en avant seront proposées prochainement
        quand la rubrique sera bien alimentée.
      </p>
      <p class="text-gris-texte text-lg font-sans mb-8 leading-relaxed">
        En attendant, déposez votre annonce gratuitement — c'est 100% gratuit,
        sans limite de durée.
      </p>
      <a
        href="/annonces/deposer/"
        class="inline-flex items-center gap-2 px-8 py-3.5 bg-orange text-white font-sans text-lg font-bold rounded-xl no-underline hover:bg-orange-hover transition-colors hover:no-underline"
        style="min-height: 48px;"
      >
        Déposer une annonce
      </a>
    </div>
  </div>
</BaseLayout>
