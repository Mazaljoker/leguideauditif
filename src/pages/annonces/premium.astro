---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { Icon } from 'astro-icon/components';

const breadcrumbs = [
  { label: 'Accueil', href: '/' },
  { label: 'Annonces', href: '/annonces/' },
  { label: 'Options premium' },
];

const options = [
  {
    name: 'Debloquer les contacts',
    price: '9',
    description: 'Accedez aux coordonnees completes de toutes les personnes interessees par votre annonce.',
    features: ['Nom, email, telephone', 'Message complet', 'Profil professionnel'],
    icon: 'lucide:unlock',
    color: 'border-emerald-400 bg-emerald-50',
    cta: 'Debloquer',
  },
  {
    name: 'Annonce Premium',
    price: '29',
    description: 'Votre annonce se demarque dans les listings avec le badge Premium et une description etendue.',
    features: ['Badge Premium visible', 'Description 5 000 caracteres', 'Photos illimitees', 'Priorite dans les listings'],
    icon: 'lucide:star',
    color: 'border-orange bg-orange/5',
    cta: 'Passer Premium',
    popular: true,
  },
  {
    name: 'Boost 1 semaine',
    price: '9',
    suffix: '/sem.',
    description: 'Votre annonce apparait en premiere position dans sa categorie pendant 7 jours.',
    features: ['Position #1 dans les listings', 'Duree : 7 jours', 'Renouvelable'],
    icon: 'lucide:zap',
    color: 'border-purple-400 bg-purple-50',
    cta: 'Booster',
  },
  {
    name: 'Alerte ciblee',
    price: '19',
    description: 'Envoyez votre annonce directement par email aux audioprothesistes inscrits dans votre zone.',
    features: ['Email direct aux pros de la zone', 'Ciblage par departement', 'Envoi unique'],
    icon: 'lucide:bell-ring',
    color: 'border-blue-400 bg-blue-50',
    cta: 'Envoyer une alerte',
  },
];

const packs = [
  {
    name: 'Pack Cession Standard',
    price: '99',
    description: 'Tout ce qu\'il faut pour vendre votre centre rapidement.',
    features: ['Annonce Premium', 'Contacts debloques', 'Boost 4 semaines', 'Economie de 47 EUR'],
    icon: 'lucide:package',
    color: 'border-marine bg-marine/5',
  },
  {
    name: 'Pack Cession Accompagne',
    price: '349',
    description: 'Accompagnement personnalise par Franck-Olivier pour votre cession.',
    features: ['Tout le Pack Standard', 'Badge "Verifie par LeGuideAuditif"', 'Relecture et optimisation de l\'annonce', 'Conseil personnalise par Franck-Olivier'],
    icon: 'lucide:shield-check',
    color: 'border-orange bg-orange/5',
    popular: true,
  },
];
---

<BaseLayout
  title="Options premium annonces — Boostez votre visibilite | LeGuideAuditif"
  description="Debloquez les contacts, passez en premium, boostez votre annonce. Options payantes pour maximiser la visibilite de vos annonces audioprothese."
>
  <div class="max-w-[1140px] mx-auto px-5 py-8">
    <Breadcrumbs items={breadcrumbs} />

    <div class="text-center mb-12">
      <h1 class="font-sans text-3xl sm:text-4xl font-extrabold text-marine mb-3">
        Boostez votre annonce
      </h1>
      <p class="text-gris-texte text-lg max-w-2xl mx-auto font-sans">
        Votre annonce est gratuite. Ces options vous permettent de maximiser votre visibilite et d'acceder aux coordonnees des professionnels interesses.
      </p>
    </div>

    <!-- Options individuelles -->
    <h2 class="font-sans text-2xl font-extrabold text-marine mb-6">Options a la carte</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5 mb-14">
      {options.map((opt) => (
        <div class={`rounded-xl border-2 p-6 relative ${opt.color}`}>
          {opt.popular && (
            <span class="absolute -top-3 left-1/2 -translate-x-1/2 px-3 py-1 rounded-full bg-orange text-white text-xs font-bold font-sans">
              Populaire
            </span>
          )}
          <Icon name={opt.icon} class="w-8 h-8 text-marine mb-3" />
          <h3 class="font-sans text-lg font-bold text-marine mb-1">{opt.name}</h3>
          <div class="font-sans text-3xl font-extrabold text-orange mb-1">
            {opt.price} EUR
            {opt.suffix && <span class="text-base font-normal text-gris-texte">{opt.suffix}</span>}
          </div>
          <p class="text-sm text-gris-texte font-sans mb-4">{opt.description}</p>
          <ul class="space-y-1.5 mb-4">
            {opt.features.map((f) => (
              <li class="flex items-start gap-2 text-sm font-sans text-marine">
                <Icon name="lucide:check" class="w-4 h-4 text-emerald-600 shrink-0 mt-0.5" />
                {f}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- Packs Cession -->
    <h2 class="font-sans text-2xl font-extrabold text-marine mb-6">Packs Cession</h2>
    <p class="text-gris-texte font-sans mb-6 max-w-2xl">
      Vous vendez votre centre ? Ces packs combinent plusieurs options pour maximiser vos chances de trouver un repreneur.
    </p>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 max-w-3xl mb-14">
      {packs.map((pack) => (
        <div class={`rounded-xl border-2 p-6 relative ${pack.color}`}>
          {pack.popular && (
            <span class="absolute -top-3 left-1/2 -translate-x-1/2 px-3 py-1 rounded-full bg-orange text-white text-xs font-bold font-sans">
              Recommande
            </span>
          )}
          <Icon name={pack.icon} class="w-8 h-8 text-marine mb-3" />
          <h3 class="font-sans text-xl font-bold text-marine mb-1">{pack.name}</h3>
          <div class="font-sans text-3xl font-extrabold text-orange mb-2">
            {pack.price} EUR
          </div>
          <p class="text-sm text-gris-texte font-sans mb-4">{pack.description}</p>
          <ul class="space-y-2">
            {pack.features.map((f) => (
              <li class="flex items-start gap-2 text-sm font-sans text-marine">
                <Icon name="lucide:check" class="w-4 h-4 text-emerald-600 shrink-0 mt-0.5" />
                {f}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- CTA -->
    <div class="text-center bg-creme rounded-2xl p-10">
      <h2 class="font-sans text-2xl font-extrabold text-marine mb-3">Pret a publier ?</h2>
      <p class="text-gris-texte font-sans mb-6">
        Deposez votre annonce gratuitement, puis choisissez vos options depuis votre espace.
      </p>
      <div class="flex flex-col sm:flex-row justify-center gap-4">
        <a
          href="/annonces/deposer/"
          class="inline-flex items-center gap-2 px-8 py-3.5 bg-orange text-white font-sans text-lg font-bold rounded-xl no-underline hover:bg-orange-hover transition-colors hover:no-underline"
        >
          Deposer une annonce
        </a>
        <a
          href="/annonces/mes-annonces/"
          class="inline-flex items-center gap-2 px-8 py-3.5 border-2 border-marine text-marine font-sans text-lg font-bold rounded-xl no-underline hover:bg-marine hover:text-white transition-colors hover:no-underline"
        >
          Mes annonces
        </a>
      </div>
    </div>
  </div>
</BaseLayout>
