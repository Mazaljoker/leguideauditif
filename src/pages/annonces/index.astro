---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import AnnonceCard from '../../components/annonces/AnnonceCard';
import { Icon } from 'astro-icon/components';
import { createServerClient } from '../../lib/supabase';

const supabase = createServerClient();

// Compteurs par categorie
const categories = [
  { key: 'cession', label: 'Cession & Installation', desc: 'Vendre ou reprendre un centre', icon: 'lucide:building-2', color: 'bg-blue-50 border-blue-200 hover:border-blue-400' },
  { key: 'emploi', label: 'Emploi & Recrutement', desc: 'Recruter ou trouver un poste', icon: 'lucide:briefcase', color: 'bg-emerald-50 border-emerald-200 hover:border-emerald-400' },
  { key: 'remplacement', label: 'Remplacement', desc: 'Trouver ou proposer un remplacement', icon: 'lucide:calendar-clock', color: 'bg-purple-50 border-purple-200 hover:border-purple-400' },
  { key: 'materiel', label: 'Matériel professionnel', desc: 'Acheter ou vendre du matériel', icon: 'lucide:wrench', color: 'bg-amber-50 border-amber-200 hover:border-amber-400' },
];

const counts: Record<string, number> = {};
for (const cat of categories) {
  const { count } = await supabase
    .from('annonces')
    .select('*', { count: 'exact', head: true })
    .eq('statut', 'active')
    .eq('categorie', cat.key);
  counts[cat.key] = count ?? 0;
}

// 6 dernieres annonces
const { data: dernieres } = await supabase
  .from('annonces')
  .select('*')
  .eq('statut', 'active')
  .order('created_at', { ascending: false })
  .limit(6);

const breadcrumbs = [
  { label: 'Accueil', href: '/' },
  { label: 'Petites annonces' },
];

const schema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Petites annonces audioprothésistes',
  numberOfItems: Object.values(counts).reduce((a, b) => a + b, 0),
};
---

<BaseLayout
  title="Annonces audioprothésistes — LeGuideAuditif"
  description="Annonces cession de centres, offres d'emploi, remplacements et matériel d'occasion pour audioprothésistes. Publiez gratuitement."
  schema={schema}
>
  <div class="max-w-[1140px] mx-auto px-5 py-8">
    <Breadcrumbs items={breadcrumbs} />

    <div class="text-center mb-10">
      <h1 class="font-sans text-3xl sm:text-4xl font-extrabold text-marine mb-3">Petites annonces pro</h1>
      <p class="text-gris-texte text-lg max-w-2xl mx-auto font-sans">
        L'espace d'echanges entre audioprothesistes : cession de centres, emploi, remplacements et materiel d'occasion.
      </p>
    </div>

    <!-- Categories -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5 mb-14">
      {categories.map((cat) => (
        <a
          href={`/annonces/${cat.key}/`}
          class={`block rounded-xl border-2 p-6 text-center transition-all no-underline hover:no-underline hover:shadow-md ${cat.color}`}
        >
          <Icon name={cat.icon} class="w-10 h-10 mx-auto mb-3 text-marine" />
          <h2 class="font-sans text-lg font-bold text-marine mb-1">{cat.label}</h2>
          <p class="font-sans text-sm text-gris-texte mb-3">{cat.desc}</p>
          <span class="inline-block px-3 py-1 rounded-full bg-white text-sm font-semibold text-marine font-sans">
            {counts[cat.key]} annonce{counts[cat.key] > 1 ? 's' : ''}
          </span>
        </a>
      ))}
    </div>

    <!-- CTA deposer -->
    <div class="text-center mb-14">
      <a
        href="/annonces/deposer/"
        class="inline-flex items-center gap-2 px-8 py-3.5 bg-orange text-white font-sans text-lg font-bold rounded-xl no-underline hover:bg-orange-hover transition-colors hover:no-underline"
      >
        <Icon name="lucide:plus-circle" class="w-5 h-5" />
        Déposer une annonce gratuitement
      </a>
    </div>

    <!-- Dernieres annonces -->
    {dernieres && dernieres.length > 0 && (
      <div>
        <h2 class="font-sans text-2xl font-extrabold text-marine mb-6">Dernieres annonces</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {dernieres.map((annonce: any) => (
            <AnnonceCard client:visible annonce={annonce} />
          ))}
        </div>
      </div>
    )}
  </div>
</BaseLayout>
