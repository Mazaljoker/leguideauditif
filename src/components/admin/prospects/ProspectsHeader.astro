---
// ProspectsHeader.astro — Jalon 2a : header statique.
// Jalon 2c : remplacé par ProspectsHeader.tsx (bouton interactif).

import { Icon } from 'astro-icon/components';
import Button from '../ui/Button.astro';
---

<div class="flex items-end justify-between gap-5 mb-6 flex-wrap">
  <div>
    <h1 class="font-serif text-3xl font-black text-marine mb-1">Prospects</h1>
    <p class="text-sm text-[#6B7A90] font-sans">
      Pipeline commercial — mis à jour en direct depuis Supabase
    </p>
  </div>
  <Button variant="primary" disabled>
    <Icon name="lucide:plus" class="w-4 h-4" />
    Nouveau prospect
  </Button>
</div>
