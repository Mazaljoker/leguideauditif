---
import type { EmailEvent } from '../../types/audiopro-lifecycle';
import { EMAIL_TEMPLATE_LABELS } from '../../types/audiopro-lifecycle';

type EmailStatus = 'sent' | 'delivered' | 'opened' | 'clicked' | 'bounced' | 'complaint';

interface Props {
  events: EmailEvent[];
}
const { events } = Astro.props;

function deriveStatus(ev: EmailEvent): EmailStatus {
  if (ev.complaint_at) return 'complaint';
  if (ev.bounced_at)   return 'bounced';
  if (ev.clicked_at)   return 'clicked';
  if (ev.opened_at)    return 'opened';
  if (ev.delivered_at) return 'delivered';
  return 'sent';
}

function extractClickedUrl(meta: Record<string, unknown> | null): string {
  if (!meta) return '';
  const raw = meta['clicked_url'];
  return typeof raw === 'string' ? raw : '';
}

const STATUS_COLOR: Record<EmailStatus, string> = {
  sent:      'bg-[#F8F5F0] text-[#6B7A90]',
  delivered: 'bg-[#E6F1FB] text-[#0C447C]',
  opened:    'bg-[#E1F5EE] text-[#0F6E56]',
  clicked:   'bg-[#D97B3D] text-white',
  bounced:   'bg-[#FCEBEB] text-[#A32D2D]',
  complaint: 'bg-[#A32D2D] text-white',
};

const STATUS_LABEL: Record<EmailStatus, string> = {
  sent:      'Envoyé',
  delivered: 'Délivré',
  opened:    'Ouvert',
  clicked:   'Cliqué',
  bounced:   'Bounce',
  complaint: 'Spam',
};

const enrichedEvents = events.map((ev) => ({
  ev,
  status: deriveStatus(ev),
  clickedUrl: extractClickedUrl(ev.metadata),
}));
---

{events.length === 0 ? (
  <p class="text-sm text-gris-texte font-sans italic">Aucun email envoyé pour cet audio.</p>
) : (
  <ol class="space-y-3 font-sans">
    {enrichedEvents.map(({ ev, status, clickedUrl }) => (
      <li class="border-l-2 border-[#E4DED3] pl-4 py-1">
        <div class="flex items-start justify-between gap-2">
          <div class="min-w-0">
            <div class="font-medium text-sm text-marine truncate">
              {EMAIL_TEMPLATE_LABELS[ev.template_key] ?? ev.template_key}
            </div>
            <div class="text-xs text-gris-texte">
              {new Date(ev.sent_at).toLocaleString('fr-FR', { day: '2-digit', month: '2-digit', year: 'numeric', hour: '2-digit', minute: '2-digit' })}
              {' · '}
              {ev.trigger}
            </div>
          </div>
          <span class:list={['text-xs px-2 py-0.5 rounded whitespace-nowrap', STATUS_COLOR[status]]}>
            {STATUS_LABEL[status]}
          </span>
        </div>
        {clickedUrl && (
          <div class="text-xs text-gris-texte mt-1 truncate">
            Cliqué : <span class="text-orange">{clickedUrl}</span>
          </div>
        )}
      </li>
    ))}
  </ol>
)}
