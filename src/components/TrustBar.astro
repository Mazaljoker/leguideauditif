---
import { Icon } from 'astro-icon/components';

const items = [
  { icon: 'lucide:microscope', label: 'Sources medicales verifiees (HAS, INSERM)' },
  { icon: 'lucide:shield-check', label: 'Aucun lien avec un fabricant' },
  { icon: 'lucide:calendar', label: 'Contenu mis a jour en 2026' },
  { icon: 'lucide:euro', label: 'Tarifs 100% Sante inclus' },
  { icon: 'lucide:users', label: '3 000+ patients appareilles' },
];
---

<div class="bg-blanc border-b border-gris-clair py-6">
  <div class="max-w-[1140px] mx-auto px-5 flex flex-wrap justify-center gap-8 lg:gap-12">
    {items.map((item) => (
      <div class="flex items-center gap-2.5 font-sans text-[15px] font-medium text-marine">
        <Icon name={item.icon} class="w-6 h-6 text-orange" aria-hidden="true" />
        <span>{item.label}</span>
      </div>
    ))}
  </div>
</div>
