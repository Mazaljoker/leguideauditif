---
import { Icon } from 'astro-icon/components';
import NewsletterForm from './NewsletterForm.tsx';
---

<section class="bg-marine text-white py-18">
  <div class="max-w-[780px] mx-auto px-5 text-center">
    <Icon name="lucide:mail" class="w-10 h-10 text-orange mx-auto mb-4" aria-hidden="true" />
    <h2 class="font-sans text-[28px] lg:text-[32px] font-extrabold mb-3" data-animate>
      Recevez nos conseils audition chaque mois
    </h2>
    <p class="text-lg opacity-85 mb-3 max-w-[560px] mx-auto" data-animate>
      Un email par mois avec nos derniers guides, les évolutions du remboursement et des conseils pratiques. Gratuit, sans engagement.
    </p>
    <p class="text-sm opacity-60 mb-8 flex items-center justify-center gap-2 font-sans" data-animate>
      <Icon name="lucide:file-text" class="w-4 h-4" aria-hidden="true" />
      En bonus : notre checklist gratuite pour votre premier rendez-vous chez l'audioprothésiste
    </p>
    <div class="flex justify-center" data-animate>
      <NewsletterForm client:visible />
    </div>
    <p class="mt-5 text-xs opacity-40 font-sans">
      Vos données restent confidentielles. Désinscription en un clic. Conforme RGPD.
    </p>
  </div>
</section>
