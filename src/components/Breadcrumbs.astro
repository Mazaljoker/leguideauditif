---
interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  items: BreadcrumbItem[];
  includeSchema?: boolean;
}

const { items, includeSchema = true } = Astro.props;

const breadcrumbSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: items.map((item, i) => ({
    "@type": "ListItem",
    position: i + 1,
    name: item.label,
    ...(item.href ? { item: `https://leguideauditif.fr${item.href}` } : {}),
  })),
});
---

<nav class="font-sans text-sm text-gris-texte py-4" aria-label="Fil d'Ariane">
  <ol class="flex flex-wrap items-center gap-1">
    {items.map((item, index) => (
      <li class="flex items-center gap-1">
        {index > 0 && <span aria-hidden="true" class="text-gris-clair">/</span>}
        {item.href ? (
          <a href={item.href} class="hover:text-orange transition-colors">{item.label}</a>
        ) : (
          <span class="text-marine font-medium">{item.label}</span>
        )}
      </li>
    ))}
  </ol>
</nav>
{includeSchema && <script type="application/ld+json" set:html={breadcrumbSchema} />}
