---
// Hero "Réserver un RDV" pour l'espace pro audioprothésiste.
//
// Au-dessus de la ligne de flottaison de chaque dashboard. Photo
// Franck-Olivier à gauche, texte + CTA à droite. La copie est gérée
// en interne via `variant` pour qu'un seul composant serve les 3
// dashboards (revendicateur / premium_solo / reseau) sans que les
// orchestrateurs aient à connaître le wording.

import { Icon } from 'astro-icon/components';
import BookCallButton from './BookCallButton.astro';

export type HeroRDVVariant = 'revendicateur' | 'premium_solo' | 'reseau';

export interface Props {
  variant: HeroRDVVariant;
  prenom: string;
  centreNom: string;
  reseauLabel?: string; // ex "Centre Trocadéro + 2 autres centres"
  prefillName?: string;
  prefillEmail?: string;
  centreId?: string;
  plan?: 'standard' | 'premium' | 'fondateur';
}

const {
  variant,
  prenom,
  centreNom,
  reseauLabel,
  prefillName,
  prefillEmail,
  centreId,
  plan,
} = Astro.props;

interface Copy {
  greeting: string;
  pitchTitle: string;
  pitchBody: string;
  source: string;
}

const copy: Copy = (() => {
  if (variant === 'premium_solo') {
    return {
      greeting: `Votre fiche ${centreNom} est en Premium. Bien joué.`,
      pitchTitle: 'Maintenant, on passe à l\'acquisition active ?',
      pitchBody:
        'Audio DE, 28 ans de terrain. On regarde ensemble ce qui ferait sonner votre téléphone — Pilote, Sérénité, ou un audit avant de lancer la machine. 30 min, sans engagement.',
      source: 'hero-premium-solo',
    };
  }
  if (variant === 'reseau') {
    return {
      greeting: `Votre réseau ${reseauLabel ?? centreNom} est sur LGA.`,
      pitchTitle: 'Parlons déploiement multi-centres — 30 min.',
      pitchBody:
        'Audio DE, 28 ans de terrain, 18 centres dirigés. On regarde la cohérence de votre dispositif d\'acquisition à l\'échelle, dashboard consolidé, pilotage centralisé. Pas de pitch agressif.',
      source: 'hero-reseau',
    };
  }
  return {
    greeting: `Votre fiche ${centreNom} est revendiquée.`,
    pitchTitle: 'Échangeons 30 min — confrère à confrère.',
    pitchBody:
      'Audio DE, 28 ans de terrain, 18 centres dirigés. On regarde votre situation, je vous propose ce qui fonctionne pour des confrères dans votre cas. Pas de pitch agressif.',
    source: 'hero-revendicateur',
  };
})();

const proofLine =
  'Des audios nous font déjà confiance. Téléphone qui sonne, agenda qui se remplit.';
---

<section
  class="mb-8 sm:mb-10 rounded-2xl bg-blanc border border-gris-clair p-5 sm:p-7 lg:p-8 shadow-[0_2px_6px_rgba(27,46,74,0.06)]"
  aria-labelledby="hero-rdv-title"
>
  <div class="flex flex-col md:flex-row md:items-center gap-6 md:gap-8">
    <div class="shrink-0 flex justify-center md:justify-start">
      <img
        src="/images/franck-olivier-chabbat.webp"
        alt="Franck-Olivier Chabbat, audioprothésiste DE, fondateur de LeGuideAuditif"
        width="240"
        height="240"
        loading="eager"
        decoding="async"
        class="w-40 h-40 md:w-60 md:h-60 rounded-2xl object-cover shadow-lg"
      />
    </div>

    <div class="flex-1 min-w-0">
      <p class="font-sans text-base sm:text-lg text-marine mb-1">
        Bonjour <strong>{prenom}</strong>,
      </p>
      <p class="font-sans text-sm sm:text-base text-gris-texte mb-4">
        {copy.greeting}
      </p>

      <h2
        id="hero-rdv-title"
        class="font-sans text-xl sm:text-2xl lg:text-3xl font-bold text-marine leading-tight mb-3"
      >
        {copy.pitchTitle}
      </h2>

      <p class="font-sans text-base text-marine leading-relaxed mb-3">
        {copy.pitchBody}
      </p>

      <p class="font-sans text-sm sm:text-base text-gris-texte italic mb-6">
        {proofLine}
      </p>

      <div class="flex flex-col sm:flex-row sm:items-center gap-3">
        <BookCallButton
          source={copy.source}
          variant="primary"
          size="lg"
          prefillName={prefillName}
          prefillEmail={prefillEmail}
          centreId={centreId}
          plan={plan}
        />
        <p class="text-xs sm:text-sm font-sans text-gris-texte inline-flex items-center gap-1.5">
          <Icon name="lucide:calendar-clock" class="w-4 h-4" aria-hidden="true" />
          3 créneaux disponibles cette semaine
        </p>
      </div>
    </div>
  </div>
</section>
