---
// Bandeau "feature Premium-locked" partagé entre les pages internes
// de l'espace pro qui ne sont accessibles qu'aux comptes Premium
// (Actualités, Cas patients). Mutualise les deux versions
// précédemment dupliquées dans actualites.astro et cas-patients.astro.
//
// Présente deux CTAs côte à côte :
//   1. "Passer Premium" en orange (self-service vers /revendiquer/)
//   2. "Ou en parler avec Franck-Olivier" en ghost marine (RDV)
//
// `lockedSource` alimente l'UTM Calendly (locked-actualites,
// locked-cas-patients...).

import { Icon } from 'astro-icon/components';
import BookCallButton from './BookCallButton.astro';

export interface Props {
  title: string;
  body: string;
  centreSlug: string;
  lockedSource: string;
  prefillName?: string;
  prefillEmail?: string;
  centreId?: string;
}

const { title, body, centreSlug, lockedSource, prefillName, prefillEmail, centreId } = Astro.props;
---

<section
  class="rounded-xl border-2 border-orange/30 bg-orange/5 p-6 mb-8"
  aria-labelledby="premium-locked-title"
>
  <div class="flex flex-col md:flex-row md:items-center gap-4 mb-4">
    <Icon name="lucide:crown" class="w-8 h-8 text-orange shrink-0" aria-hidden="true" />
    <div class="flex-1 min-w-0">
      <h2 id="premium-locked-title" class="font-sans font-bold text-marine mb-1">
        {title}
      </h2>
      <p class="text-sm font-sans text-gris-texte">
        {body}
      </p>
    </div>
  </div>

  <div class="flex flex-col sm:flex-row gap-3 sm:items-center">
    <a
      href={`/revendiquer/?centre=${centreSlug}`}
      class="inline-flex items-center justify-center gap-2 rounded-lg bg-orange px-5 py-3 text-sm font-sans font-semibold text-blanc hover:bg-orange-hover transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-orange/60 focus-visible:ring-offset-2"
      style="min-height: 44px;"
    >
      Passer Premium
    </a>

    <BookCallButton
      source={lockedSource}
      variant="ghost"
      size="md"
      label="Ou en parler avec Franck-Olivier"
      iconRight={false}
      prefillName={prefillName}
      prefillEmail={prefillEmail}
      centreId={centreId}
      plan="standard"
    />
  </div>
</section>
