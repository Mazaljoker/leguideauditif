---
// Quick Access footer : liens rapides sous chaque dashboard.
// Contenu spécifique à chaque état (revendicateur / premium / reseau) :
// le parent passe la liste de liens à rendre.

export interface QuickLink {
  label: string;
  href: string;
}

export interface Props {
  links: QuickLink[];
  label?: string;
}

const { links, label = 'Accès rapide' } = Astro.props;
---

<nav
  class="mt-12 pt-5 border-t border-gris-clair flex flex-wrap items-center gap-x-6 gap-y-2"
  aria-label="Accès rapide"
>
  <span class="text-sm font-sans font-semibold text-gris-texte">{label}</span>
  {links.map((l) => (
    <a
      href={l.href}
      class="text-sm font-sans text-marine hover:text-orange hover:underline transition-colors py-1"
    >
      {l.label}
    </a>
  ))}
</nav>
