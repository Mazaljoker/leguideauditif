---
// Accordéon de complétude fiche pour les dashboards. Replié par défaut.
// Le titre est dynamique : "Votre fiche est complète à {pct}% — {n}
// étapes restantes pour mieux ranker". Sur le mockup brief, ce bloc
// vit en bas du dashboard, jamais en hero.
//
// Reprend la liste de TodoItem alimentée par l'orchestrateur. Si tout
// est complété (100%), on affiche un état "fiche complète" sobre.

import { Icon } from 'astro-icon/components';
import CompletudeBar from './CompletudeBar.astro';
import type { TodoItem } from '../revendicateur/CompletudeTodo.astro';

export interface Props {
  items: TodoItem[];
}

const { items } = Astro.props;
const doneCount = items.filter((i) => i.done).length;
const total = items.length;
const remaining = total - doneCount;
const pct = total > 0 ? Math.round((doneCount / total) * 100) : 0;

const summaryTitle =
  remaining === 0
    ? 'Votre fiche est complète à 100% — tout est OK'
    : `Votre fiche est complète à ${pct}% — ${remaining} ${
        remaining === 1 ? 'étape restante' : 'étapes restantes'
      } pour mieux ranker`;
---

<details class="mb-10 rounded-xl bg-blanc border border-gris-clair shadow-[0_1px_3px_rgba(27,46,74,0.06)] group">
  <summary class="cursor-pointer list-none [&::-webkit-details-marker]:hidden flex flex-col sm:flex-row sm:items-center gap-3 sm:gap-4 p-5 sm:p-6 rounded-xl focus:outline-none focus-visible:ring-2 focus-visible:ring-orange/60 hover:bg-creme/40 transition-colors">
    <span
      class="w-10 h-10 rounded-full bg-marine/10 text-marine flex items-center justify-center shrink-0"
      aria-hidden="true"
    >
      <Icon name="lucide:list-checks" class="w-5 h-5" />
    </span>
    <div class="flex-1 min-w-0">
      <h2 class="font-sans text-base sm:text-lg font-bold text-marine leading-snug">
        {summaryTitle}
      </h2>
      <p class="text-xs sm:text-sm text-gris-texte font-sans mt-0.5">
        Cliquez pour voir les détails
      </p>
    </div>
    <Icon
      name="lucide:chevron-down"
      class="w-5 h-5 text-gris-texte transition-transform group-open:rotate-180 shrink-0"
      aria-hidden="true"
    />
  </summary>

  <div class="px-5 sm:px-6 pb-6 pt-1">
    <div class="mb-5">
      <CompletudeBar done={doneCount} total={total} />
    </div>

    <ul class="divide-y divide-[#F3F4F6]">
      {items.map((it) => (
        <li class="flex items-center gap-3 py-3 sm:py-3.5">
          <span
            class:list={[
              'w-5 h-5 rounded-full border-2 flex items-center justify-center shrink-0',
              it.done ? 'bg-[#059669] border-[#059669] text-blanc' : 'border-gris-clair',
            ]}
            aria-hidden="true"
          >
            {it.done && <Icon name="lucide:check" class="w-3 h-3" />}
          </span>
          <span
            class:list={[
              'flex-1 text-sm sm:text-base font-sans',
              it.done ? 'line-through text-[#9CA3AF]' : 'text-marine',
            ]}
          >
            {it.label}
          </span>
          {!it.done && it.href && (
            <a
              href={it.href}
              class="inline-flex items-center gap-1 text-sm font-sans font-semibold text-orange hover:underline shrink-0 py-1"
              style="min-height: 44px;"
            >
              {it.ctaLabel ?? 'Ajouter'}
              <Icon name="lucide:arrow-right" class="w-3.5 h-3.5" />
            </a>
          )}
        </li>
      ))}
    </ul>
  </div>
</details>
