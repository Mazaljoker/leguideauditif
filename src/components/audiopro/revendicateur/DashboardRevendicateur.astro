---
// Orchestrateur du dashboard "Revendicateur" — version RDV-funnel.
//
// Architecture cible (brief refonte espace pro 2026-04-25) :
//   1. Hero RDV (photo Franck + pitch confrère + CTA Calendly)
//   2. 4 cards problème (Acquisition, Conversion, Charge mentale, Base patient)
//   3. Activité de la fiche (3 KPIs : vues, demandes, position locked)
//   4. Complétion fiche (accordéon replié)
//   5. Leviers d'acquisition (3 cards reformulées avec CTA RDV)
//   6. Plan B self-service (Fondateur 19€ + Premium 39€)
//
// Self-service reste accessible mais déprioritisé visuellement —
// l'objectif business est la prise de RDV avec Franck-Olivier.

import { Icon } from 'astro-icon/components';
import HeroRDV from '../shared/HeroRDV.astro';
import ProblemCardsGrid from '../shared/ProblemCardsGrid.astro';
import CompletudeAccordion from '../shared/CompletudeAccordion.astro';
import PlanBSelfService from '../shared/PlanBSelfService.astro';
import SectionHeader from '../shared/SectionHeader.astro';
import KPICard from '../shared/KPICard.astro';
import KPICardLocked from '../shared/KPICardLocked.astro';
import QuickAccess from '../shared/QuickAccess.astro';
import LeviersTeaser from './LeviersTeaser.astro';
import type { TodoItem } from './CompletudeTodo.astro';
import type { CentreData } from '../../../types/centre';

export interface Props {
  prenom: string;
  nomFamille?: string;
  centre: CentreData;
  viewCount30j: number;
  leadCount30j: number;
  claimedDaysAgo: number;
  prefillEmail?: string;
}

const { prenom, nomFamille, centre, viewCount30j, leadCount30j, claimedDaysAgo, prefillEmail } =
  Astro.props;

const ficheHref = '/audioprothesiste-pro/fiche/';

const items: TodoItem[] = [
  { label: 'Revendiquer votre fiche', done: true },
  {
    label: 'Informations de contact (téléphone, email, site)',
    done: Boolean(centre.tel && centre.email),
    href: ficheHref,
    ctaLabel: 'Compléter',
  },
  {
    label: 'Horaires d\'ouverture',
    done: Boolean(centre.horaires),
    href: ficheHref,
    ctaLabel: 'Renseigner',
  },
  {
    label: 'Numéro RPPS renseigné',
    done: Boolean(centre.rpps),
    href: ficheHref,
    ctaLabel: 'Renseigner',
  },
  {
    label: 'Ajouter votre photo de profil',
    done: Boolean(centre.photo_url),
    href: ficheHref,
    ctaLabel: 'Ajouter',
  },
  {
    label: 'Photos de votre cabine (min. 3)',
    done: false,
    href: ficheHref,
    ctaLabel: 'Ajouter',
  },
  {
    label: 'Vos spécialités et marques proposées',
    done: centre.specialites.length > 0 && centre.marques.length > 0,
    href: ficheHref,
    ctaLabel: 'Renseigner',
  },
  {
    label: 'Bio courte (parcours, approche)',
    done: Boolean(centre.a_propos),
    href: ficheHref,
    ctaLabel: 'Rédiger',
  },
];

const claimedLabel =
  claimedDaysAgo === 0
    ? 'aujourd\'hui'
    : claimedDaysAgo === 1
      ? 'hier'
      : `il y a ${claimedDaysAgo} jours`;

const prefillName = nomFamille ? `${prenom} ${nomFamille}`.trim() : prenom;
---

<HeroRDV
  variant="revendicateur"
  prenom={prenom}
  centreNom={centre.nom}
  prefillName={prefillName}
  prefillEmail={prefillEmail}
  centreId={centre.id}
  plan="standard"
/>

<ProblemCardsGrid
  variant="revendicateur"
  prefillName={prefillName}
  prefillEmail={prefillEmail}
  centreId={centre.id}
  plan="standard"
/>

<SectionHeader title="Votre activité" subtitle={`30 derniers jours · fiche revendiquée ${claimedLabel}`} />

<div class="grid grid-cols-1 gap-4 sm:gap-5 sm:grid-cols-2 lg:grid-cols-3 mb-10">
  <KPICard
    label="VUES DE VOTRE FICHE"
    value={viewCount30j.toLocaleString('fr-FR')}
    desc="vues depuis la revendication"
    footer="Site lancé le 14 avril 2026 · J+10"
    footerTone="muted"
  />
  <KPICard
    label="DEMANDES PATIENTS"
    value={leadCount30j.toLocaleString('fr-FR')}
    desc="reçues via LGA ce mois"
    footer="Vos fiches remontent mieux en Premium"
    footerTone="muted"
  />
  <KPICardLocked
    label="POSITION DANS VOTRE ZONE"
    value="— / 34"
    desc="Analyse de ranking zone"
  />
</div>

<CompletudeAccordion items={items} />

<SectionHeader
  title="Leviers d'acquisition"
  subtitle="Disponibles en Premium ou via accompagnement Pilote"
/>

<LeviersTeaser
  prefillName={prefillName}
  prefillEmail={prefillEmail}
  centreId={centre.id}
/>

<aside
  id="upsell"
  class="mb-6 rounded-xl bg-gradient-to-br from-marine to-marine-light p-5 sm:p-6 text-blanc shadow-[0_4px_12px_rgba(27,46,74,0.15)]"
>
  <div class="flex flex-col sm:flex-row sm:items-center gap-4">
    <div class="w-12 h-12 rounded-full bg-orange/20 text-orange flex items-center justify-center shrink-0">
      <Icon name="lucide:sparkles" class="w-6 h-6" aria-hidden="true" />
    </div>
    <div class="flex-1 min-w-0">
      <p class="font-sans text-base sm:text-lg font-bold mb-1">
        Voyez concrètement ce que Premium permet
      </p>
      <p class="text-sm font-sans text-blanc/85 leading-snug">
        Fiche démo complète avec bio audio, 2 appareils phares, parcours patient, actualités, cas patients anonymisés et FAQ locale.
      </p>
    </div>
    <a
      href="/centre/le-guide-auditif-demo-premium-franck-olivier/"
      target="_blank"
      rel="noopener"
      class="inline-flex items-center justify-center gap-2 rounded-lg bg-orange text-blanc font-sans font-bold text-sm px-5 py-3 hover:bg-orange-hover transition-colors shrink-0"
      style="min-height: 44px;"
    >
      Voir une fiche Premium
      <Icon name="lucide:external-link" class="w-4 h-4" />
    </a>
  </div>
</aside>

<PlanBSelfService centreSlug={centre.slug} />

<QuickAccess
  links={[
    { label: 'Ma fiche', href: '/audioprothesiste-pro/fiche/' },
    { label: 'Mes demandes', href: '/audioprothesiste-pro/leads/' },
    { label: 'Mon compte', href: '/audioprothesiste-pro/compte/' },
    { label: 'Support', href: 'mailto:contact@leguideauditif.fr' },
  ]}
/>
