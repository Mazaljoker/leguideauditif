---
// Todo list de complétude fiche pour le dashboard Revendicateur.
// Les 8 items reproduisent fidèlement le mockup :
//   1-4 : pré-coché par définition (revendication validée, contact, horaires, RPPS)
//   5-8 : à compléter (photo, photos cabine, spécialités, bio)
//
// Le parent passe un objet `items` avec l'état done/doing de chaque ligne
// + les hrefs de chaque CTA (vers /audioprothesiste-pro/fiche/ en général).

import { Icon } from 'astro-icon/components';
import CompletudeBar from '../shared/CompletudeBar.astro';

export interface TodoItem {
  label: string;
  done: boolean;
  href?: string;
  ctaLabel?: string;
}

export interface Props {
  items: TodoItem[];
}

const { items } = Astro.props;
const doneCount = items.filter((i) => i.done).length;
---

<section class="rounded-xl bg-blanc border border-gris-clair p-5 sm:p-7 mb-8 shadow-[0_1px_3px_rgba(27,46,74,0.06)]">
  <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-3 mb-5">
    <h2 class="font-sans text-base sm:text-lg font-bold text-marine leading-snug">
      Complétez votre fiche pour apparaître plus haut dans les recherches
    </h2>
  </div>

  <div class="mb-5">
    <CompletudeBar done={doneCount} total={items.length} />
  </div>

  <ul class="divide-y divide-[#F3F4F6]">
    {items.map((it) => (
      <li class="flex items-center gap-3 py-3 sm:py-3.5">
        <span
          class:list={[
            'w-5 h-5 rounded-full border-2 flex items-center justify-center shrink-0',
            it.done ? 'bg-[#059669] border-[#059669] text-blanc' : 'border-gris-clair',
          ]}
          aria-hidden="true"
        >
          {it.done && <Icon name="lucide:check" class="w-3 h-3" />}
        </span>
        <span class:list={[
          'flex-1 text-sm sm:text-base font-sans',
          it.done ? 'line-through text-[#9CA3AF]' : 'text-marine',
        ]}>
          {it.label}
        </span>
        {!it.done && it.href && (
          <a
            href={it.href}
            class="inline-flex items-center gap-1 text-sm font-sans font-semibold text-orange hover:underline shrink-0 py-1"
            style="min-height: 44px;"
          >
            {it.ctaLabel ?? 'Ajouter'}
            <Icon name="lucide:arrow-right" class="w-3.5 h-3.5" />
          </a>
        )}
      </li>
    ))}
  </ul>
</section>
