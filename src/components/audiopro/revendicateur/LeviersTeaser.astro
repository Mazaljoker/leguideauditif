---
// Teaser des 3 leviers d'acquisition (Ads, Leads, nPosts) lockés pour les
// comptes gratuits. Opacité réduite au repos pour signaler le cadenas ;
// le hover restore l'opacité pleine (le mockup fait déjà ça).
//
// Cliquer un teaser ramène vers l'upsell Premium (pas vers une page
// intermédiaire — un revendicateur curieux = conversion chaude).

import { Icon } from 'astro-icon/components';

const leviers = [
  {
    iconName: 'lucide:megaphone',
    title: 'Campagnes Google Ads',
    body: 'Landing LGA co-brandée et gestion de vos campagnes pour attirer des patients sur votre zone.',
  },
  {
    iconName: 'lucide:target',
    title: 'Leads qualifiés',
    body: 'Recevez des demandes patients exclusives sur votre code postal. Paiement à la performance.',
  },
  {
    iconName: 'lucide:smartphone',
    title: 'Réseaux sociaux (nPosts)',
    body: 'Publiez automatiquement sur Facebook, Instagram et Google Business Profile.',
  },
];

const upsellHref = '#upsell';
---

<div class="grid grid-cols-1 gap-4 sm:gap-5 sm:grid-cols-2 lg:grid-cols-3 mb-8">
  {leviers.map((l) => (
    <a
      href={upsellHref}
      class="block rounded-xl bg-blanc border border-gris-clair p-5 sm:p-6 opacity-75 hover:opacity-100 transition-opacity shadow-[0_1px_3px_rgba(27,46,74,0.06)]"
    >
      <div class="w-10 h-10 rounded-full bg-[#F3F4F6] text-gris-texte flex items-center justify-center mb-3">
        <Icon name={l.iconName} class="w-5 h-5" />
      </div>
      <h3 class="font-sans text-base font-bold text-marine mb-1.5">{l.title}</h3>
      <p class="text-sm font-sans text-gris-texte leading-snug mb-4 min-h-[50px]">
        {l.body}
      </p>
      <span class="inline-flex items-center gap-1.5 rounded-md bg-[#F3F4F6] text-marine text-[11px] font-sans font-bold px-3 py-1.5">
        <Icon name="lucide:lock" class="w-3 h-3" />
        Premium requis
      </span>
    </a>
  ))}
</div>
