---
// Navigation latérale (desktop) / topbar scrollable (mobile) pour
// /audioprothesiste-pro/. Pattern inspiré de AdminNav.astro. Les
// entrées "Bientôt" restent présentes visuellement mais désactivées
// — l'utilisateur voit toute la carte fonctionnelle à venir.

import { Icon } from 'astro-icon/components';

export interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;

interface NavLink {
  href: string;
  label: string;
  icon: string;
  soon?: boolean;
}

const links: NavLink[] = [
  { href: '/audioprothesiste-pro/', label: 'Tableau de bord', icon: 'lucide:layout-dashboard' },
  { href: '/audioprothesiste-pro/fiche/', label: 'Ma fiche', icon: 'lucide:pen-line' },
  { href: '/audioprothesiste-pro/leads/', label: 'Mes demandes', icon: 'lucide:inbox' },
  { href: '/audioprothesiste-pro/annonces/', label: 'Mes annonces', icon: 'lucide:megaphone' },
  { href: '/audioprothesiste-pro/abonnement/', label: 'Abonnement', icon: 'lucide:credit-card' },
  { href: '/audioprothesiste-pro/compte/', label: 'Compte', icon: 'lucide:user' },
];

function isActive(linkHref: string, path: string): boolean {
  if (linkHref === '/audioprothesiste-pro/') {
    return path === '/audioprothesiste-pro' || path === '/audioprothesiste-pro/';
  }
  return path === linkHref || path.startsWith(linkHref);
}
---

<nav aria-label="Navigation espace pro" class="audiopro-nav">
  {/* Sur mobile : barre compacte d'icônes (44x44 chacun) + tooltip via title.
     Sur desktop lg+ : sidebar verticale icône + libellé + label Bientôt. */}
  <ul
    class="flex lg:flex-col gap-1 lg:gap-1 justify-between lg:justify-start overflow-x-auto lg:overflow-visible"
    role="list"
  >
    {links.map((link) => {
      const active = isActive(link.href, currentPath);
      const baseClass = 'group inline-flex items-center justify-center lg:justify-start gap-3 rounded-lg text-sm font-sans transition-colors focus:outline-none focus:ring-2 focus:ring-orange/50 relative';
      const mobileSize = 'w-11 h-11 lg:w-auto lg:h-auto lg:px-4 lg:py-3';
      const stateClass = link.soon
        ? 'text-gris-texte/60 cursor-not-allowed bg-blanc/60'
        : active
          ? 'bg-marine text-blanc font-semibold'
          : 'text-marine hover:bg-blanc hover:text-orange font-medium';

      return (
        <li class="flex-shrink-0 lg:flex-shrink">
          {link.soon ? (
            <span
              class:list={[baseClass, mobileSize, stateClass, 'lg:w-full']}
              aria-disabled="true"
              aria-label={`${link.label} — bientôt disponible`}
              title={`${link.label} — bientôt disponible`}
            >
              <Icon name={link.icon} class="w-5 h-5 shrink-0 lg:w-4 lg:h-4" />
              <span class="hidden lg:block flex-1">{link.label}</span>
              <span class="hidden lg:inline text-[11px] font-semibold uppercase tracking-wide text-orange/80">Bientôt</span>
            </span>
          ) : (
            <a
              href={link.href}
              class:list={[baseClass, mobileSize, stateClass, 'lg:w-full']}
              aria-label={link.label}
              title={link.label}
              aria-current={active ? 'page' : undefined}
            >
              <Icon name={link.icon} class="w-5 h-5 shrink-0 lg:w-4 lg:h-4" />
              <span class="hidden lg:block flex-1">{link.label}</span>
            </a>
          )}
        </li>
      );
    })}
  </ul>
</nav>
