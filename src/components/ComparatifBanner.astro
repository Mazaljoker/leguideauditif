---
import { Icon } from 'astro-icon/components';

const miniCards = [
  { icon: 'lucide:trophy', label: 'Meilleur appareil auditif 2026', href: '/comparatifs/meilleur-appareil-auditif-2026/' },
  { icon: 'lucide:euro', label: 'Meilleur appareil Classe 1 (reste a charge 0\u20AC)', href: '/comparatifs/meilleur-appareil-classe-1/' },
  { icon: 'lucide:swords', label: 'Phonak vs Signia vs ReSound', href: '/comparatifs/phonak-vs-signia-vs-resound/' },
  { icon: 'lucide:eye', label: 'Meilleur appareil invisible', href: '/comparatifs/meilleur-intra-auriculaire/' },
];
---

<section class="bg-creme py-16">
  <div class="max-w-[1140px] mx-auto px-5">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <!-- Left: Image + Text -->
      <div data-animate>
        <img
          src="/images/homepage/comparatif-appareils.webp"
          alt="Trois appareils auditifs modernes compares"
          width="500"
          height="300"
          loading="lazy"
          decoding="async"
          class="rounded-2xl shadow-[0_4px_16px_rgba(27,46,74,0.1)] mb-6 w-full h-auto"
        />
        <h2 class="font-sans text-[32px] font-extrabold mb-4 text-marine">
          Nos comparatifs<br /><span class="text-orange">independants</span>
        </h2>
        <p class="text-[17px] text-gris-texte mb-4">
          Nous testons et comparons les appareils auditifs des grandes marques avec un seul objectif : vous aider a trouver celui qui correspond a votre situation et a votre budget.
        </p>
        <p class="text-[17px] text-gris-texte mb-7">
          Chaque comparatif est base sur des criteres objectifs : nombre de canaux, reduction de bruit, connectivite, autonomie, confort et rapport qualite-prix. Nous incluons systematiquement des appareils Classe 1 (100% Sante) et Classe 2 pour vous offrir une vision complete.
        </p>
        <a
          href="/comparatifs/meilleur-appareil-auditif-2026/"
          class="inline-flex items-center gap-2 px-6 py-3 bg-orange text-white font-sans text-base font-semibold rounded-lg hover:bg-orange-hover transition-colors no-underline hover:no-underline"
        >
          Voir tous les comparatifs &rarr;
        </a>
      </div>

      <!-- Right: Mini cards -->
      <div class="flex flex-col gap-3" data-animate>
        {miniCards.map((card) => (
          <a
            href={card.href}
            class="bg-blanc border border-gris-clair rounded-xl px-5 py-4 flex items-center gap-3.5 font-sans text-[15px] font-medium hover:shadow-[0_4px_12px_rgba(27,46,74,0.08)] transition-shadow no-underline text-marine hover:no-underline"
          >
            <Icon name={card.icon} class="w-6 h-6 text-orange" aria-hidden="true" />
            <span>{card.label}</span>
            <span class="ml-auto text-gris-texte/50">&rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </div>
</section>
