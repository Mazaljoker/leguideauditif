---
import { Icon } from 'astro-icon/components';
---

<section class="relative overflow-hidden bg-gradient-to-br from-marine to-marine-light text-white py-20 pb-24">
  <!-- Decorative circle -->
  <div class="absolute -right-24 -top-24 w-[500px] h-[500px] bg-[radial-gradient(circle,rgba(217,123,61,0.15)_0%,transparent_70%)] rounded-full" aria-hidden="true"></div>

  <div class="max-w-[1140px] mx-auto px-5 relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-[1.1fr_0.9fr] gap-12 items-center">
      <!-- Left: Text -->
      <div>
        <h1 class="font-sans text-[32px] lg:text-[42px] font-extrabold leading-[1.15] mb-6">
          La plupart de mes patients ont fait<br />
          <span class="text-orange">la m&ecirc;me erreur.</span>
        </h1>
        <p class="text-[18px] leading-relaxed opacity-90 mb-4">
          Ils ont attendu. 5 ans. Parfois 10.
        </p>
        <p class="text-[17px] leading-relaxed opacity-85 mb-4">
          Pas parce que la perte auditive n'&eacute;tait pas l&agrave;.
          Parce qu'ils ne comprenaient pas ce qu'on leur disait.
          Devis &agrave; 3&nbsp;000&euro;, jargon technique, discours commercial.
        </p>
        <p class="text-[17px] leading-relaxed opacity-90 mb-4 font-medium">
          Je vais &ecirc;tre direct&nbsp;: ce n'est pas votre faute.
        </p>
        <p class="text-[17px] leading-relaxed opacity-85 mb-8">
          Apr&egrave;s 28 ans en cabinet et 5 ans dans l'industrie, j'ai vu comment ce march&eacute;
          fonctionne vraiment. Aujourd'hui, je ne vends plus rien. Je vous explique simplement
          ce que je dirais &agrave; mes proches.
        </p>
        <div class="flex flex-wrap gap-4">
          <a
            href="/guides/remboursement/"
            class="inline-flex items-center gap-2 px-6 py-3 bg-orange text-white font-sans text-base font-semibold rounded-lg hover:bg-orange-hover transition-colors no-underline hover:no-underline"
          >
            Voir les erreurs &agrave; &eacute;viter &rarr;
          </a>
          <a
            href="/comparatifs/meilleur-appareil-auditif-2026/"
            class="inline-flex items-center gap-2 px-6 py-3 bg-transparent text-white font-sans text-base font-semibold rounded-lg border-2 border-white/40 hover:bg-white/10 transition-colors no-underline hover:no-underline"
          >
            Voir le comparatif 2026
          </a>
        </div>
      </div>

      <!-- Right: Hero Image -->
      <div class="relative hidden lg:block">
        <picture>
          <source srcset="/images/homepage/hero-senior-audition-mobile.webp" media="(max-width: 767px)" width="400" height="300" />
          <img
            src="/images/homepage/hero-senior-audition.webp"
            alt="Senior souriant portant un appareil auditif discret"
            width="600"
            height="500"
            loading="eager"
            fetchpriority="high"
            decoding="async"
            class="rounded-2xl shadow-[0_8px_32px_rgba(0,0,0,0.3)] w-full h-auto"
          />
        </picture>
        <!-- Floating trust badge -->
        <div class="absolute -bottom-4 -left-4 bg-white text-marine rounded-xl px-5 py-3 shadow-[0_4px_16px_rgba(0,0,0,0.15)] font-sans text-sm font-semibold flex items-center gap-2">
          <Icon name="lucide:shield-check" class="w-5 h-5 text-orange" aria-hidden="true" />
          <span>100% ind&eacute;pendant</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Wave separator -->
  <div class="absolute bottom-0 left-0 w-full" aria-hidden="true">
    <svg viewBox="0 0 1440 60" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none" class="w-full h-[40px] lg:h-[60px]">
      <path d="M0 60V20C240 0 480 0 720 20C960 40 1200 40 1440 20V60H0Z" fill="#FFFFFF" />
    </svg>
  </div>
</section>
