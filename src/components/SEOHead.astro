---
interface Props {
  title: string;
  description: string;
  image?: string;
  canonicalURL?: string;
  type?: 'website' | 'article';
  publishedTime?: string;
  modifiedTime?: string;
  author?: string;
}

const {
  title,
  description,
  image = '/images/og-default.jpg',
  canonicalURL,
  type = 'website',
  publishedTime,
  modifiedTime,
  author,
} = Astro.props;

const fullImageUrl = image.startsWith('http') ? image : new URL(image, Astro.site).href;
---

<!-- Supplementary SEO meta tags for article pages -->
{type === 'article' && (
  <>
    <meta property="article:author" content={author || 'Franck-Olivier'} />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
  </>
)}