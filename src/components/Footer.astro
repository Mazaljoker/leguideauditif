---
import { Icon } from 'astro-icon/components';

const sections = [
  {
    id: 'sante',
    title: 'Santé auditive',
    links: [
      { href: '/guides/perte-auditive/', label: 'Perte auditive' },
      { href: '/guides/acouphenes/', label: 'Acouphènes' },
      { href: '/guides/perte-auditive/presbyacousie/', label: 'Presbyacousie' },
      { href: '/outils/analyse-audiogramme/', label: 'Analyser mon audiogramme' },
      { href: '/guides/prevention/', label: 'Prévention' },
    ],
  },
  {
    id: 'prix',
    title: 'Prix & comparatifs',
    links: [
      { href: '/guides/remboursement/100-sante-audition/', label: '100% Santé — remboursement' },
      { href: '/comparatifs/meilleur-appareil-auditif-2026/', label: 'Comparatif 2026' },
      { href: '/catalogue/', label: 'Catalogue appareils' },
      { href: '/guides/remboursement/', label: 'Prix & remboursement' },
      { href: '/guides/appareils-auditifs/', label: 'Appareils auditifs' },
    ],
  },
  {
    id: 'lesite',
    title: 'Le site & expertise',
    links: [
      { href: '/auteur/franck-olivier/', label: 'L\u2019auteur — Franck-Olivier' },
      { href: '/a-propos/', label: 'À propos' },
      { href: '/contact/', label: 'Contact' },
      { href: '/faq/', label: 'FAQ' },
      { href: '/glossaire/', label: 'Glossaire' },
    ],
  },
  {
    id: 'pro',
    title: 'Audioprothésistes',
    links: [
      { href: '/audioprothesiste-pro/', label: 'Espace pro' },
      { href: '/annonces/', label: 'Petites annonces' },
      { href: '/revendiquer-gratuit/', label: 'Revendiquer ma fiche' },
      { href: '/connexion-pro/', label: 'Me connecter' },
    ],
  },
];

// Annuaire local tier-2 : 20 grandes villes ≥100k habitants non présentes dans la
// grille tier-1 de la home (/index.astro ligne 82). Chaque lien pointe vers la page
// ville correspondante du silo /audioprothesiste/[slug]/.
const villesTier2 = [
  { slug: 'grenoble', label: 'Grenoble' },
  { slug: 'le-havre', label: 'Le Havre' },
  { slug: 'reims', label: 'Reims' },
  { slug: 'saint-etienne', label: 'Saint-Étienne' },
  { slug: 'tours', label: 'Tours' },
  { slug: 'angers', label: 'Angers' },
  { slug: 'nimes', label: 'Nîmes' },
  { slug: 'le-mans', label: 'Le Mans' },
  { slug: 'aix-en-provence', label: 'Aix-en-Provence' },
  { slug: 'brest', label: 'Brest' },
  { slug: 'clermont-ferrand', label: 'Clermont-Ferrand' },
  { slug: 'dijon', label: 'Dijon' },
  { slug: 'limoges', label: 'Limoges' },
  { slug: 'villeurbanne', label: 'Villeurbanne' },
  { slug: 'besancon', label: 'Besançon' },
  { slug: 'orleans', label: 'Orléans' },
  { slug: 'metz', label: 'Metz' },
  { slug: 'mulhouse', label: 'Mulhouse' },
  { slug: 'rouen', label: 'Rouen' },
  { slug: 'caen', label: 'Caen' },
];

const year = new Date().getFullYear();
---

<!-- Zone CTA -->
<section class="bg-orange/10 py-10">
  <div class="max-w-[1140px] mx-auto px-5 text-center">
    <p class="font-sans text-xl font-bold text-marine mb-2">
      Vous cherchez un audioprothésiste ?
    </p>
    <p class="font-sans text-gris-texte mb-6">
      7 146 professionnels référencés sur notre carte interactive
    </p>
    <a
      href="/trouver-audioprothesiste/"
      class="inline-flex items-center gap-2 px-8 py-4 bg-orange text-white font-sans text-[16px] font-semibold rounded-md hover:bg-orange-hover transition-colors no-underline hover:no-underline min-h-[48px]"
    >
      Consulter la carte
    </a>
  </div>
</section>

<!-- Footer principal -->
<footer class="bg-marine text-white pt-14 pb-8">
  <div class="max-w-[1140px] mx-auto px-5">

    <!-- Bloc identité + 4 colonnes (santé / prix / site / audioprothésistes) -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-10 mb-10">

      <!-- Bloc identité -->
      <div>
        <div class="font-sans font-extrabold text-xl leading-tight mb-3">
          LeGuideAuditif
          <small class="block font-normal text-xs text-white/50 mt-1">Le guide indépendant pour mieux entendre</small>
        </div>
        <p class="text-[15px] opacity-80 leading-relaxed mb-4">
          Rédigé par
          <a href="/auteur/franck-olivier/" class="text-white underline hover:text-orange hover:no-underline">Franck-Olivier Chabbat</a>,
          audioprothésiste diplômé d'État.
        </p>
        <nav aria-label="Réseaux sociaux" class="flex items-center gap-3">
          <a href="https://www.facebook.com/leguideauditif/" target="_blank" rel="noopener noreferrer"
             class="flex items-center justify-center w-11 h-11 rounded-lg opacity-80 hover:opacity-100 hover:text-orange transition-colors"
             aria-label="Facebook">
            <Icon name="lucide:facebook" class="w-5 h-5" aria-hidden="true" />
          </a>
          <a href="https://www.instagram.com/leguideauditif/" target="_blank" rel="noopener noreferrer"
             class="flex items-center justify-center w-11 h-11 rounded-lg opacity-80 hover:opacity-100 hover:text-orange transition-colors"
             aria-label="Instagram">
            <Icon name="lucide:instagram" class="w-5 h-5" aria-hidden="true" />
          </a>
          <a href="https://www.linkedin.com/company/leguideauditif/" target="_blank" rel="noopener noreferrer"
             class="flex items-center justify-center w-11 h-11 rounded-lg opacity-80 hover:opacity-100 hover:text-orange transition-colors"
             aria-label="LinkedIn">
            <Icon name="lucide:linkedin" class="w-5 h-5" aria-hidden="true" />
          </a>
          <!-- GMB à ajouter après vérification -->
        </nav>
      </div>

      <!-- 3 colonnes de liens -->
      {sections.map((section) => (
        <div class="footer-accordion">
          {/* Titre desktop (toujours visible) */}
          <p class="hidden lg:block font-sans text-sm font-bold uppercase tracking-widest mb-4 opacity-60">
            {section.title}
          </p>

          {/* Bouton accordéon mobile */}
          <button
            class="lg:hidden w-full flex items-center justify-between py-3 min-h-[48px] border-b border-white/10"
            aria-expanded="false"
            aria-controls={`footer-${section.id}`}
          >
            <span class="font-sans text-sm font-bold uppercase tracking-widest opacity-60">
              {section.title}
            </span>
            <Icon
              name="lucide:chevron-down"
              class="w-5 h-5 opacity-60 transition-transform duration-200 motion-reduce:transition-none accordion-icon"
            />
          </button>

          {/* Liens (accordéon mobile, toujours visible desktop) */}
          <div
            id={`footer-${section.id}`}
            class="grid grid-rows-[0fr] lg:grid-rows-[1fr] transition-[grid-template-rows] duration-200 motion-reduce:transition-none"
          >
            <div class="overflow-hidden">
              {section.links.map((link) => (
                <a
                  href={link.href}
                  class="flex items-center min-h-[48px] text-white opacity-80 text-[16px] py-2 font-sans no-underline hover:opacity-100 hover:text-orange hover:no-underline"
                >
                  {link.label}
                </a>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Annuaire local tier-2 — distribution link equity sur 20 grandes villes -->
    <div class="border-t border-white/10 pt-6 pb-8 mb-2">
      <p class="font-sans text-sm font-bold uppercase tracking-widest mb-3 opacity-60">
        Trouver un audioprothésiste
      </p>
      <nav aria-label="Annuaire local par ville" class="font-sans text-[15px] leading-relaxed">
        {villesTier2.map((ville, i) => (
          <>
            <a
              href={`/audioprothesiste/${ville.slug}/`}
              class="text-white opacity-80 hover:opacity-100 hover:text-orange no-underline hover:no-underline"
            >
              {ville.label}
            </a>
            {i < villesTier2.length - 1 && <span class="opacity-30 mx-2" aria-hidden="true">·</span>}
          </>
        ))}
      </nav>
      <p class="mt-4">
        <a
          href="/audioprothesiste/"
          class="inline-flex items-center gap-1 font-sans text-sm text-orange hover:underline no-underline"
        >
          Voir tous les départements
          <Icon name="lucide:arrow-right" class="w-4 h-4" aria-hidden="true" />
        </a>
      </p>
    </div>

    <!-- Barre légale -->
    <div class="border-t border-white/10 pt-6 flex flex-col sm:flex-row justify-between items-center font-sans text-[13px] opacity-50 gap-4">
      <span>&copy; {year} LeGuideAuditif.fr — Tous droits réservés</span>
      <nav aria-label="Liens légaux" class="flex flex-wrap justify-center gap-2 sm:gap-4">
        <a href="/mentions-legales/" class="text-white hover:text-orange no-underline hover:no-underline">Mentions légales</a>
        <span aria-hidden="true">|</span>
        <a href="/cgu/" class="text-white hover:text-orange no-underline hover:no-underline">CGU</a>
        <span aria-hidden="true">|</span>
        <a href="/politique-confidentialite/" class="text-white hover:text-orange no-underline hover:no-underline">Confidentialité</a>
      </nav>
      <span class="hidden sm:inline">Contenu vérifié par un audioprothésiste DE</span>
    </div>
  </div>
</footer>

<script>
  // --- Accordéon footer mobile ---
  document.querySelectorAll('.footer-accordion button').forEach((btn) => {
    btn.addEventListener('click', () => {
      const expanded = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!expanded));

      const controlsId = btn.getAttribute('aria-controls');
      if (!controlsId) return;
      const target = document.getElementById(controlsId);
      if (!target) return;

      target.classList.toggle('grid-rows-[0fr]', expanded);
      target.classList.toggle('grid-rows-[1fr]', !expanded);

      // Rotation du chevron
      const icon = btn.querySelector('.accordion-icon');
      icon?.classList.toggle('rotate-180', !expanded);
    });
  });
</script>
