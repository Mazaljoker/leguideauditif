---
import { Icon } from 'astro-icon/components';

interface Props {
  name?: string;
  title?: string;
}

const { name = 'Franck-Olivier', title = "Audioprothesiste diplome d'Etat, 28 ans d'experience" } = Astro.props;
---

<aside class="bg-blanc border border-gris-clair rounded-2xl p-6 my-8 flex flex-col sm:flex-row items-start gap-5" aria-label="A propos de l'auteur">
  <img
    src="/images/franck-olivier-chabbat.jpg"
    alt="Franck-Olivier Chabbat, audioprothesiste diplome d'Etat"
    width="64"
    height="64"
    class="w-16 h-16 rounded-full object-cover shrink-0"
    loading="lazy"
  />
  <div>
    <a href="/a-propos/" class="font-sans text-lg font-bold text-marine hover:text-orange mb-1 no-underline block">{name}</a>
    <div class="font-sans text-sm text-gris-texte mb-3">{title}</div>
    <div class="flex flex-wrap gap-2">
      <span class="inline-flex items-center gap-1 bg-creme px-3 py-1 rounded-full font-sans text-xs font-medium text-marine">
        <Icon name="lucide:graduation-cap" class="w-3.5 h-3.5" aria-hidden="true" /> Diplome d'Etat
      </span>
      <span class="inline-flex items-center gap-1 bg-creme px-3 py-1 rounded-full font-sans text-xs font-medium text-marine">
        <Icon name="lucide:building-2" class="w-3.5 h-3.5" aria-hidden="true" /> 18 centres diriges
      </span>
      <span class="inline-flex items-center gap-1 bg-creme px-3 py-1 rounded-full font-sans text-xs font-medium text-marine">
        <Icon name="lucide:users" class="w-3.5 h-3.5" aria-hidden="true" /> 3000+ patients
      </span>
      <span class="inline-flex items-center gap-1 bg-creme px-3 py-1 rounded-full font-sans text-xs font-medium text-marine">
        <Icon name="lucide:shield-check" class="w-3.5 h-3.5" aria-hidden="true" /> ADELI 692606494
      </span>
    </div>
    <p class="text-sm text-gris-texte mt-3 leading-relaxed">
      Audioprothesiste independant, Franck-Olivier a dirige 18 centres Alain Afflelou Acousticien et adapte plus de 3 000 patients. Il partage son expertise pour vous aider a mieux entendre.
    </p>
  </div>
</aside>
