---
import { Icon } from 'astro-icon/components';

interface Props {
  name?: string;
  title?: string;
}

const { name = 'Franck-Olivier', title = "Audioprothesiste DE, 28 ans d'experience" } = Astro.props;
---

<aside class="bg-blanc border border-gris-clair rounded-2xl p-6 my-8 flex flex-col sm:flex-row items-start gap-5" aria-label="A propos de l'auteur">
  <img
    src="/images/franck-olivier-chabbat.jpg"
    alt="Franck-Olivier Chabbat, audioprothesiste diplome d'Etat"
    width="64"
    height="64"
    class="w-16 h-16 rounded-full object-cover shrink-0"
    loading="lazy"
  />
  <div>
    <a href="/auteur/franck-olivier/" class="font-sans text-lg font-bold text-marine hover:text-orange mb-1 no-underline block">{name}</a>
    <div class="font-sans text-sm text-gris-texte mb-3">{title}</div>
    <div class="font-sans text-xs text-gris-texte mb-3">
      Diplome d'Etat &middot; Amplifon &middot; Audika &middot; 18 centres Afflelou &middot; Auzen.com &middot; 3000+ patients &middot; ADELI 692606494
    </div>
    <p class="text-sm text-gris-texte leading-relaxed">
      Apres avoir forge son expertise chez les leaders historiques (Amplifon, Audika) et dirige 18 centres Alain Afflelou Acousticien, Franck-Olivier a passe 5 ans chez Auzen.com entre teleaudiologie et vente en ligne. Il met ce parcours unique au service de votre audition, sans langue de bois.
    </p>
  </div>
</aside>
