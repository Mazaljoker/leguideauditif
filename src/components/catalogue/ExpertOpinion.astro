---
/**
 * ExpertOpinion — Encadré "L'avis de Franck-Olivier" (E-E-A-T)
 */
interface Props {
  noteExpert?: number;
  descriptionExpert?: string;
  descriptionCourte?: string;
  idealPour?: string;
  pointsForts?: string[];
  pointsFaibles?: string[];
  author?: string;
  authorTitle?: string;
}

const {
  noteExpert,
  descriptionExpert,
  descriptionCourte,
  idealPour,
  pointsForts = [],
  pointsFaibles = [],
  author = "Franck-Olivier",
  authorTitle = "Audioprothesiste DE — 28 ans d'experience",
} = Astro.props;

const hasContent = descriptionExpert || descriptionCourte || pointsForts.length > 0;
---

{hasContent && (
  <section class="expert-opinion" aria-labelledby="expert-title">
    <div class="expert-opinion__header">
      <div class="expert-opinion__author">
        <div class="expert-opinion__avatar" aria-hidden="true">FO</div>
        <div>
          <strong>{author}</strong>
          <span>{authorTitle}</span>
        </div>
      </div>
      {noteExpert && (
        <div class="expert-opinion__note">
          <span class="expert-opinion__score">{noteExpert}</span>
          <span class="expert-opinion__max">/10</span>
        </div>
      )}
    </div>

    <h2 id="expert-title">L'avis de l'expert</h2>

    {(descriptionExpert || descriptionCourte) && (
      <div class="expert-opinion__text">
        <p>{descriptionExpert || descriptionCourte}</p>
      </div>
    )}

    {idealPour && (
      <div class="expert-opinion__ideal">
        <strong>Idéal pour :</strong> {idealPour}
      </div>
    )}

    {pointsForts.length > 0 && (
      <div class="expert-opinion__pros">
        <h3>Points forts</h3>
        <ul>
          {pointsForts.map((p) => <li>{p}</li>)}
        </ul>
      </div>
    )}

    {pointsFaibles.length > 0 && (
      <div class="expert-opinion__cons">
        <h3>Points faibles</h3>
        <ul>
          {pointsFaibles.map((p) => <li>{p}</li>)}
        </ul>
      </div>
    )}
  </section>
)}

<style>
  .expert-opinion {
    background: var(--color-cream);
    border: 2px solid var(--color-navy);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }
  .expert-opinion__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-4);
  }
  .expert-opinion__author {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }
  .expert-opinion__avatar {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: var(--color-navy);
    color: var(--color-white);
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: var(--text-sm);
  }
  .expert-opinion__author strong {
    display: block;
    color: var(--color-navy);
    font-size: var(--text-base);
  }
  .expert-opinion__author span {
    font-size: var(--text-sm);
    color: var(--color-gray-500);
  }
  .expert-opinion__note {
    text-align: center;
  }
  .expert-opinion__score {
    font-family: var(--font-heading);
    font-size: var(--text-4xl);
    font-weight: 700;
    color: var(--color-orange);
    line-height: 1;
  }
  .expert-opinion__max {
    font-size: var(--text-sm);
    color: var(--color-gray-500);
  }
  .expert-opinion h2 {
    font-size: var(--text-2xl);
    color: var(--color-navy);
    margin: 0;
  }
  .expert-opinion__text p {
    font-size: var(--text-base);
    line-height: 1.7;
    color: var(--color-navy);
  }
  .expert-opinion__ideal {
    background: var(--color-white);
    padding: var(--space-3) var(--space-4);
    border-radius: var(--radius-md);
    font-size: var(--text-sm);
    border-left: 4px solid var(--color-orange);
  }
  .expert-opinion__pros, .expert-opinion__cons {
    padding: var(--space-4);
    border-radius: var(--radius-md);
  }
  .expert-opinion__pros {
    background: #F0FDF4;
    border-left: 4px solid var(--color-green);
  }
  .expert-opinion__cons {
    background: #FEF2F2;
    border-left: 4px solid var(--color-red);
  }
  .expert-opinion__pros h3, .expert-opinion__cons h3 {
    font-size: var(--text-sm);
    font-family: var(--font-body);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: var(--space-2);
  }
  .expert-opinion__pros h3 { color: #166534; }
  .expert-opinion__cons h3 { color: #991B1B; }
  ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }
  li {
    font-size: var(--text-sm);
    padding-left: 1.5em;
    position: relative;
  }
  .expert-opinion__pros li::before {
    content: "✓";
    position: absolute;
    left: 0;
    color: var(--color-green);
    font-weight: 700;
  }
  .expert-opinion__cons li::before {
    content: "✗";
    position: absolute;
    left: 0;
    color: var(--color-red);
    font-weight: 700;
  }
</style>