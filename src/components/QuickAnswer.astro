---
import { Icon } from 'astro-icon/components';

interface QuickAnswerData {
  title?: string;
  items: Array<{ strong: string; text: string }>;
  conclusion?: string;
}

interface Props {
  /** Objet structuré depuis le frontmatter (pattern recommandé). */
  data?: QuickAnswerData;
  /** Titre alternatif si usage manuel via slot (rétrocompat). */
  title?: string;
}

const { data, title } = Astro.props;

// Mode structuré (data) OU mode slot manuel. Priorité au data si fourni.
const resolvedTitle = data?.title ?? title ?? 'La réponse en 30 secondes';
---

<aside
  class="not-prose my-8 p-6 bg-orange/10 border-l-4 border-orange rounded-r-xl shadow-sm"
  aria-label="Réponse directe à la question"
>
  <h3 class="flex items-center gap-2 font-sans text-lg font-bold text-marine mb-4">
    <Icon name="lucide:zap" class="w-5 h-5 text-orange shrink-0" aria-hidden="true" />
    {resolvedTitle}
  </h3>

  <div class="font-sans text-marine text-[15px] md:text-base leading-relaxed space-y-3">
    {data ? (
      <>
        <ul class="list-disc pl-5 space-y-2">
          {data.items.map((item) => (
            <li><strong>{item.strong}</strong> : {item.text}</li>
          ))}
        </ul>
        {data.conclusion && <p class="font-medium">{data.conclusion}</p>}
      </>
    ) : (
      <div class="[&_ul]:list-disc [&_ul]:pl-5 [&_ul]:space-y-2 [&_p]:font-medium">
        <slot />
      </div>
    )}
  </div>
</aside>
