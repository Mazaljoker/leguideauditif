---
import { Icon } from 'astro-icon/components';
import type { CentreData } from '../../types/centre';

interface Props {
  centre: CentreData;
}

const { centre } = Astro.props;
const plan = centre.plan;

// Nom de l'audioprothesiste
const audioName = plan === 'rpps'
  ? (centre.audio_prenom && centre.audio_nom
      ? `${centre.audio_prenom} ${centre.audio_nom}`
      : null)
  : centre.claimed_by_name || null;

const hasPhoto = !!centre.photo_url;
---

<header class="mb-8">
  {/* --- Photo grande pour claimed/premium avec image --- */}
  {hasPhoto && (plan === 'claimed' || plan === 'premium') && (
    <div class="mb-5 rounded-xl overflow-hidden" style="max-height: 400px;">
      <img
        src={centre.photo_url}
        alt={`Photo du centre ${centre.nom}`}
        class="w-full object-cover"
        style="max-height: 400px;"
        loading="lazy"
        width="800"
        height="400"
      />
    </div>
  )}

  <div class="flex items-start gap-4 mb-4">
    {/* Photo miniature / Placeholder (seulement si pas de grande photo) */}
    {plan === 'rpps' ? (
      <div class="w-16 h-16 rounded-lg bg-[#F1EFE8] border-2 border-dashed border-[#D3D1C7] flex flex-col items-center justify-center shrink-0">
        <Icon name="lucide:image" class="w-5 h-5 text-[#B4B2A9]" />
        <span class="text-[8px] text-[#B4B2A9] mt-0.5 font-sans">Pas de photo</span>
      </div>
    ) : !hasPhoto ? (
      <div class="w-16 h-16 rounded-lg bg-[#E6F1FB] border-2 border-[#B3D4F0] flex flex-col items-center justify-center shrink-0">
        <Icon name="lucide:image" class="w-5 h-5 text-[#6BA3D6]" />
        <span class="text-[8px] text-[#6BA3D6] mt-0.5 font-sans">Ajouter</span>
      </div>
    ) : null}

    <div class="min-w-0">
      {/* Nom du centre */}
      <div class="flex flex-wrap items-center gap-2 mb-2">
        <h1 class="font-sans text-[22px] font-medium text-marine leading-tight">
          {centre.nom}
        </h1>

        {/* Badge rpps */}
        {plan === 'rpps' && (
          <span class="inline-flex items-center gap-1 rounded-full bg-[#FCEBEB] px-2.5 py-0.5 text-[11px] font-medium text-[#791F1F] font-sans">
            <Icon name="lucide:x" class="w-3 h-3" />
            Non revendiqu&eacute;e
          </span>
        )}

        {/* Badge claimed — bleu + favicon LGA */}
        {plan === 'claimed' && (
          <span class="inline-flex items-center gap-1.5 rounded-full bg-[#E6F1FB] border border-[#B3D4F0] px-3 py-1 text-[11px] font-semibold text-[#0C447C] font-sans">
            <img src="/favicon.png" alt="" class="w-3.5 h-3.5" />
            Fiche v&eacute;rifi&eacute;e
          </span>
        )}

        {/* Badge premium — orange + favicon LGA */}
        {plan === 'premium' && (
          <span class="inline-flex items-center gap-1.5 rounded-full bg-orange px-3 py-1 text-[11px] font-semibold text-blanc font-sans shadow-sm">
            <img src="/favicon.png" alt="" class="w-3.5 h-3.5 brightness-0 invert" />
            <Icon name="lucide:star" class="w-3 h-3 fill-current" />
            Recommand&eacute; LeGuideAuditif
          </span>
        )}
      </div>

      {/* Adresse */}
      <div class="flex items-start gap-1.5 text-sm text-gris-texte font-sans mb-2">
        <Icon name="lucide:map-pin" class="w-4 h-4 mt-0.5 shrink-0 text-marine/50" />
        <span>{centre.adresse}, {centre.cp} {centre.ville}</span>
      </div>

      {/* Audioprothesiste */}
      {audioName && (
        <div class="flex items-center gap-2">
          {plan === 'premium' ? (
            <div class="w-6 h-6 rounded-full bg-marine flex items-center justify-center shrink-0">
              <Icon name="lucide:user" class="w-3.5 h-3.5 text-blanc" />
            </div>
          ) : (
            <Icon name="lucide:user" class="w-3.5 h-3.5 text-gris-texte shrink-0" />
          )}
          <div>
            <span class="text-[13px] font-medium text-marine font-sans">
              {audioName}, audioproth&eacute;siste DE
            </span>
            {plan === 'rpps' && (
              <span class="text-[11px] text-[#B4B2A9] font-sans ml-2">Source : RPPS</span>
            )}
          </div>
        </div>
      )}
    </div>
  </div>
</header>
