---
import { Icon } from 'astro-icon/components';
---

<aside class="rounded-xl border border-gris-clair bg-blanc p-5 mt-8 font-sans" aria-label="Offres premium">
  <p class="text-marine font-semibold text-sm mb-1">Boostez votre visibilite</p>
  <p class="text-gris-texte text-sm mb-3">
    Badge "Centre verifie", position prioritaire dans l'annuaire, leads patients directs.
  </p>
  <a
    href="/offres/"
    class="inline-flex items-center gap-1.5 text-sm font-semibold text-orange hover:underline"
  >
    Decouvrir nos offres
    <Icon name="lucide:arrow-right" class="w-4 h-4" />
  </a>
</aside>
