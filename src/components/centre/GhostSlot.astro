---
import { Icon } from 'astro-icon/components';

interface Props {
  iconName: string;
  label: string;
  placeholder: string;
}

const { iconName, label, placeholder } = Astro.props;
---

<div class="relative rounded-lg bg-gray-100/60 p-4 overflow-hidden">
  {/* Contenu fantome flou */}
  <div class="opacity-30 blur-[1px] select-none pointer-events-none" aria-hidden="true">
    <div class="flex items-center gap-3">
      <div class="flex items-center justify-center w-11 h-11 rounded-full bg-gray-200">
        <Icon name={iconName} class="w-5 h-5 text-gray-400" />
      </div>
      <div>
        <p class="text-sm text-gray-400 font-sans">{label}</p>
        <p class="font-semibold text-gray-400 font-sans">{placeholder}</p>
      </div>
    </div>
  </div>

  {/* Overlay cadenas */}
  <div class="absolute inset-0 flex items-center justify-center bg-white/20">
    <div class="flex items-center gap-2 rounded-full bg-white/90 px-4 py-2 shadow-sm">
      <Icon name="lucide:lock" class="w-4 h-4 text-gris-texte" />
      <span class="text-sm font-medium text-gris-texte font-sans">Disponible en fiche premium</span>
    </div>
  </div>
</div>
