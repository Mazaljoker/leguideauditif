---
interface Props {
  percentage: number;
}

const { percentage } = Astro.props;
---

<div class="rounded-xl border border-gris-clair bg-blanc p-5 mb-6">
  <div class="flex items-center justify-between mb-2">
    <p class="text-sm font-semibold text-marine font-sans">Fiche complete a {percentage}%</p>
    <span class="text-xs text-gris-texte font-sans">{percentage}/100</span>
  </div>
  <div class="w-full h-3 rounded-full bg-gray-200 overflow-hidden">
    <div
      class="h-full rounded-full bg-orange transition-all"
      style={`width: ${percentage}%`}
      role="progressbar"
      aria-valuenow={percentage}
      aria-valuemin={0}
      aria-valuemax={100}
      aria-label={`Fiche complete a ${percentage} pourcent`}
    ></div>
  </div>
  <p class="text-xs text-gris-texte font-sans mt-2">
    Completez votre fiche pour apparaitre en priorite dans les resultats
  </p>
</div>
