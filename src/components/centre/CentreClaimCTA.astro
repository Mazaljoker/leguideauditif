---
import { Icon } from 'astro-icon/components';

interface Props {
  slug: string;
  audioPrenom?: string | null;
}

const { slug, audioPrenom } = Astro.props;
const title = audioPrenom
  ? `${audioPrenom}, c'est votre centre ?`
  : "C'est votre centre ?";
---

<section class="rounded-xl bg-marine p-5 sm:p-6 mb-6" aria-label="Revendiquer cette fiche">
  <div class="flex items-start gap-4 mb-5">
    <div class="w-10 h-10 rounded-full bg-orange flex items-center justify-center shrink-0">
      <Icon name="lucide:shield" class="w-5 h-5 text-blanc" />
    </div>
    <div>
      <h2 class="font-sans text-[15px] font-medium text-blanc leading-snug">
        {title}
      </h2>
      <p class="text-[13px] text-[#9DB5CC] font-sans mt-1">
        Completez votre fiche en 2 minutes. C'est gratuit.
      </p>
    </div>
  </div>

  <div class="grid grid-cols-2 gap-x-4 gap-y-2 mb-5">
    {[
      'Telephone affiche en clair',
      'Horaires d\'ouverture affiches',
      'Specialites affichees (3 max)',
      'Marques affichees (3 max)',
      'Recevez des demandes de patients',
      'Gratuit, sans engagement',
    ].map((item) => (
      <div class="flex items-center gap-2">
        <Icon name="lucide:check" class="w-4 h-4 text-[#5DCAA5] shrink-0" />
        <span class="text-xs text-[#9DB5CC] font-sans">{item}</span>
      </div>
    ))}
  </div>

  <a
    href={`/revendiquer-gratuit/?centre=${slug}`}
    class="flex items-center justify-center gap-2 w-full rounded-lg bg-orange px-5 py-3 text-sm font-medium text-blanc font-sans transition-colors hover:bg-orange/90 focus:outline-none focus:ring-2 focus:ring-orange/50"
    style="min-height: 44px;"
  >
    Completer ma fiche gratuitement
    <Icon name="lucide:arrow-right" class="w-4 h-4" />
  </a>
</section>
