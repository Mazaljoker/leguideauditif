---
// Appareils phares recommandés par l'audioprothésiste (1-6 entrées),
// chargés depuis la table centre_appareils_phares.
//
// Affichage : cards avec marque + modèle + classe + type + verdict.
// Le block est rendu uniquement si l'audio a renseigné au moins 1 appareil
// — c'est un bloc de contenu riche, pas une section marketing.

import { Icon } from 'astro-icon/components';
import { supabase } from '../../../lib/supabase';
import type { CentreData } from '../../../types/centre';

export interface Props {
  centre: CentreData;
}

const { centre } = Astro.props;

interface AppareilPhareRow {
  id: string;
  marque: string;
  modele: string;
  classe: '1' | '2' | 'tous';
  type_appareil: string;
  verdict_audio: string;
  ordre: number;
}

const { data } = await supabase
  .from('centre_appareils_phares')
  .select('id, marque, modele, classe, type_appareil, verdict_audio, ordre')
  .eq('centre_id', centre.id)
  .order('ordre', { ascending: true });

const appareils = (data ?? []) as AppareilPhareRow[];
const audioFullName = centre.audio_prenom && centre.audio_nom
  ? `${centre.audio_prenom} ${centre.audio_nom}`
  : centre.claimed_by_name || 'votre audioprothésiste';
---

{appareils.length > 0 && (
  <section
    class="rounded-xl bg-blanc border border-gris-clair p-5 sm:p-7 mb-8"
    aria-labelledby="appareils-phares-title"
  >
    <div class="flex items-center gap-3 mb-5">
      <div class="w-10 h-10 rounded-full bg-orange/10 text-orange flex items-center justify-center shrink-0">
        <Icon name="lucide:package" class="w-5 h-5" />
      </div>
      <div>
        <h2 id="appareils-phares-title" class="font-sans text-xl sm:text-2xl font-bold text-marine">
          Appareils recommandés par {audioFullName}
        </h2>
        <p class="text-sm text-gris-texte font-sans mt-0.5">Sélection professionnelle avec verdict personnalisé</p>
      </div>
    </div>

    <ul class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      {appareils.map((a) => (
        <li class="rounded-lg border border-gris-clair bg-creme/40 p-5">
          <div class="flex flex-wrap items-center gap-2 mb-2">
            <h3 class="font-sans font-bold text-marine text-base sm:text-lg">
              {a.marque} <span class="font-normal">{a.modele}</span>
            </h3>
          </div>
          <div class="flex flex-wrap gap-1.5 mb-3">
            <span class:list={[
              'inline-flex items-center rounded-full px-2 py-0.5 text-[11px] font-sans font-bold uppercase tracking-wide',
              a.classe === '1' ? 'bg-[#D1FAE5] text-[#059669]' : a.classe === '2' ? 'bg-orange/10 text-orange' : 'bg-marine/10 text-marine',
            ]}>
              {a.classe === '1' ? 'Classe 1' : a.classe === '2' ? 'Classe 2' : 'Classe 1 & 2'}
            </span>
            <span class="inline-flex items-center rounded-full bg-gris-clair text-marine px-2 py-0.5 text-[11px] font-sans font-bold uppercase tracking-wide">
              {a.type_appareil}
            </span>
          </div>
          <blockquote class="text-sm font-serif text-marine leading-relaxed italic border-l-2 border-orange pl-3">
            « {a.verdict_audio} »
          </blockquote>
        </li>
      ))}
    </ul>

    <p class="text-xs text-gris-texte font-sans mt-4 pt-4 border-t border-gris-clair">
      <Icon name="lucide:info" class="inline w-3.5 h-3.5" /> Ces recommandations sont personnelles et basées sur l'expérience de l'audioprothésiste. Un bilan auditif en cabine est nécessaire pour déterminer l'appareil adapté à votre profil.
    </p>
  </section>
)}
