---
// Appareils recommandés par l'audioprothésiste.
// Chaque entrée référence un produit du catalogue LGA via produit_slug
// -> affiche prix + classe + specs clés + lien vers la fiche produit
// /catalogue/appareils/{slug}/.
//
// Fallback gracieux si produit_slug absent ou non trouvé dans le catalogue :
// on affiche marque + modele + verdict sans prix ni lien (rare, transition).

import { Icon } from 'astro-icon/components';
import { getCollection } from 'astro:content';
import { supabase } from '../../../lib/supabase';
import type { CentreData } from '../../../types/centre';

export interface Props {
  centre: CentreData;
}

const { centre } = Astro.props;

interface AppareilPhareRow {
  id: string;
  marque: string;
  modele: string;
  classe: '1' | '2' | 'tous';
  type_appareil: string;
  verdict_audio: string;
  produit_slug: string | null;
  ordre: number;
}

const { data } = await supabase
  .from('centre_appareils_phares')
  .select('id, marque, modele, classe, type_appareil, verdict_audio, produit_slug, ordre')
  .eq('centre_id', centre.id)
  .order('ordre', { ascending: true });

const appareils = (data ?? []) as AppareilPhareRow[];

// Préchargement du catalogue pour résoudre les produit_slug
const catalogue = await getCollection('catalogueAppareils');
const catalogueBySlug = new Map(catalogue.map((p) => [p.id.replace(/\.json$/, ''), p]));

interface Enriched {
  db: AppareilPhareRow;
  produit: ReturnType<typeof catalogueBySlug.get>;
}

const enrichedList: Enriched[] = appareils.map((db) => ({
  db,
  produit: db.produit_slug ? catalogueBySlug.get(db.produit_slug) : undefined,
}));

const audioFullName = centre.audio_prenom && centre.audio_nom
  ? `${centre.audio_prenom} ${centre.audio_nom}`
  : centre.claimed_by_name || 'votre audioprothésiste';

function fmtPrix(p: (typeof catalogue)[number]['data']['prix']): string | null {
  if (!p?.eur) return null;
  const { min, max, unitaire } = p.eur;
  if (min && max) return `${min}-${max} € / oreille`;
  if (unitaire) return `${unitaire} € / oreille`;
  return null;
}
---

{enrichedList.length > 0 && (
  <section
    class="rounded-xl bg-blanc border border-gris-clair p-5 sm:p-7 mb-8"
    aria-labelledby="appareils-phares-title"
  >
    <div class="flex items-center gap-3 mb-5">
      <div class="w-10 h-10 rounded-full bg-orange/10 text-orange flex items-center justify-center shrink-0">
        <Icon name="lucide:package" class="w-5 h-5" />
      </div>
      <div>
        <h2 id="appareils-phares-title" class="font-sans text-xl sm:text-2xl font-bold text-marine">
          Appareils recommandés par {audioFullName}
        </h2>
        <p class="text-sm text-gris-texte font-sans mt-0.5">Sélection professionnelle avec fiche produit détaillée</p>
      </div>
    </div>

    <ul class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      {enrichedList.map(({ db, produit }) => {
        const href = produit ? `/catalogue/appareils/${produit.id.replace(/\.json$/, '')}/` : null;
        const prix = produit ? fmtPrix(produit.data.prix) : null;
        const marqueLabel = produit?.data.marqueLabel ?? db.marque;
        const modele = produit?.data.modele ?? db.modele;
        const classeDb = db.classe === 'tous' ? (produit?.data.classe ?? '2') : db.classe;
        const formeType = produit?.data.formeType ?? db.type_appareil;
        const autonomie = produit?.data.specs?.autonomie;
        const bluetooth = produit?.data.connectivite?.bluetooth;

        const Wrapper = href ? 'a' : 'div';
        return (
          <li>
            <Wrapper
              {...(href ? { href, class: 'block group' } : { class: 'block' })}
            >
              <article class="rounded-lg border border-gris-clair bg-creme/40 p-5 h-full transition-colors group-hover:border-orange/50">
                <div class="flex items-start justify-between gap-2 mb-2">
                  <h3 class="font-sans font-bold text-marine text-base sm:text-lg leading-tight">
                    <span class="text-orange">{marqueLabel}</span> {modele}
                  </h3>
                  {produit?.data.noteExpert !== undefined && (
                    <span class="inline-flex items-center gap-1 rounded-full bg-marine/10 text-marine px-2 py-0.5 text-[11px] font-sans font-bold">
                      <Icon name="lucide:star" class="w-3 h-3" />
                      {produit.data.noteExpert}/10
                    </span>
                  )}
                </div>

                <div class="flex flex-wrap gap-1.5 mb-3">
                  <span class:list={[
                    'inline-flex items-center rounded-full px-2 py-0.5 text-[11px] font-sans font-bold uppercase tracking-wide',
                    classeDb === '1' ? 'bg-[#D1FAE5] text-[#059669]' : 'bg-orange/10 text-orange',
                  ]}>
                    Classe {classeDb}
                  </span>
                  <span class="inline-flex items-center rounded-full bg-gris-clair text-marine px-2 py-0.5 text-[11px] font-sans font-bold uppercase tracking-wide">
                    {formeType}
                  </span>
                  {produit?.data.fonctionnalites?.rechargeable && (
                    <span class="inline-flex items-center gap-1 rounded-full bg-marine/10 text-marine px-2 py-0.5 text-[11px] font-sans font-semibold">
                      <Icon name="lucide:battery-charging" class="w-3 h-3" />
                      Rechargeable
                    </span>
                  )}
                  {produit?.data.connectivite?.auracast && (
                    <span class="inline-flex items-center rounded-full bg-marine/10 text-marine px-2 py-0.5 text-[11px] font-sans font-semibold">
                      Auracast
                    </span>
                  )}
                </div>

                <blockquote class="text-sm font-serif text-marine leading-relaxed italic border-l-2 border-orange pl-3 mb-3">
                  « {db.verdict_audio} »
                </blockquote>

                {produit && (
                  <dl class="grid grid-cols-2 gap-2 text-xs font-sans mb-3 pt-3 border-t border-gris-clair">
                    {prix && (
                      <div>
                        <dt class="text-gris-texte uppercase tracking-wide font-semibold">Prix indicatif</dt>
                        <dd class="text-marine font-bold mt-0.5">{prix}</dd>
                      </div>
                    )}
                    {autonomie && (
                      <div>
                        <dt class="text-gris-texte uppercase tracking-wide font-semibold">Autonomie</dt>
                        <dd class="text-marine font-bold mt-0.5">{autonomie} h</dd>
                      </div>
                    )}
                    {bluetooth && (
                      <div class="col-span-2">
                        <dt class="text-gris-texte uppercase tracking-wide font-semibold">Bluetooth</dt>
                        <dd class="text-marine font-bold mt-0.5">{bluetooth}</dd>
                      </div>
                    )}
                  </dl>
                )}

                {href && (
                  <p class="inline-flex items-center gap-1.5 text-sm font-sans font-semibold text-orange group-hover:underline">
                    Voir la fiche produit complète
                    <Icon name="lucide:arrow-right" class="w-3.5 h-3.5" />
                  </p>
                )}
              </article>
            </Wrapper>
          </li>
        );
      })}
    </ul>

    <p class="text-xs text-gris-texte font-sans mt-4 pt-4 border-t border-gris-clair">
      <Icon name="lucide:info" class="inline w-3.5 h-3.5" /> Ces recommandations sont personnelles et basées sur l'expérience de l'audioprothésiste. Un bilan auditif en cabine est nécessaire pour déterminer l'appareil adapté à votre profil.
    </p>
  </section>
)}
