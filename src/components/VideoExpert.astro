---
import { Icon } from 'astro-icon/components';
---

<section class="bg-blanc py-18">
  <div class="max-w-[1140px] mx-auto px-5">
    <div class="grid grid-cols-1 lg:grid-cols-[1fr_1.2fr] gap-12 items-center">
      <!-- Left: Text + credentials -->
      <div data-animate>
        <div class="inline-flex items-center gap-2 bg-orange/10 border border-orange/20 px-4 py-1.5 rounded-full font-sans text-sm font-medium text-orange mb-5">
          <Icon name="lucide:video" class="w-4 h-4" aria-hidden="true" />
          Video expert
        </div>
        <h2 class="font-sans text-[28px] lg:text-[32px] font-extrabold text-marine mb-5">
          Franck-Olivier vous explique
        </h2>
        <p class="text-gris-texte text-base leading-relaxed mb-5">
          En tant qu'audioprothesiste DE avec 28 ans d'experience clinique et 5 ans chez Auzen.com, je reponds en video aux
          questions les plus frequentes sur la perte auditive, le choix d'un appareil et le remboursement.
          Des explications claires, sans jargon &mdash; avec la connaissance de l'interieur.
        </p>
        <div class="flex items-center gap-3 mb-5">
          <img
            src="/images/franck-olivier-chabbat.jpg"
            alt="Franck-Olivier Chabbat, audioprothesiste diplome d'Etat"
            width="48"
            height="48"
            class="w-12 h-12 rounded-full object-cover"
            loading="lazy"
          />
          <div>
            <div class="font-sans text-base font-bold text-marine">Franck-Olivier</div>
            <div class="font-sans text-sm text-gris-texte">Audioprothesiste DE &mdash; 28 ans de clinique, 5 ans chez Auzen.com</div>
          </div>
        </div>
      </div>

      <!-- Right: Video player -->
      <div class="relative" data-animate>
        <div class="video-container relative rounded-2xl overflow-hidden shadow-[0_8px_32px_rgba(27,46,74,0.15)] aspect-video bg-marine">
          <!-- Thumbnail poster -->
          <img
            src="/images/homepage/video-thumbnail.webp"
            alt="Video presentation par Franck-Olivier, audioprothesiste"
            width="640"
            height="360"
            loading="lazy"
            decoding="async"
            class="video-poster w-full h-full object-cover absolute inset-0 z-10"
          />
          <!-- Play button overlay -->
          <button
            class="video-play-btn absolute inset-0 z-20 flex items-center justify-center bg-marine/30 hover:bg-marine/20 transition-colors group cursor-pointer"
            aria-label="Lire la video : presentation par Franck-Olivier"
          >
            <div class="w-20 h-20 bg-orange rounded-full flex items-center justify-center shadow-[0_4px_16px_rgba(217,123,61,0.4)] group-hover:scale-110 transition-transform">
              <svg class="w-8 h-8 text-white ml-1" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M8 5v14l11-7z" />
              </svg>
            </div>
          </button>
          <!-- Actual video (hidden until play) -->
          <video
            class="video-player w-full h-full object-cover"
            preload="none"
            playsinline
            controls
            poster="/images/homepage/video-thumbnail.webp"
          >
            <source src="/videos/homepage/expert-presentation.mp4" type="video/mp4" />
            Votre navigateur ne supporte pas la lecture video.
          </video>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const playBtn = document.querySelector('.video-play-btn');
  const poster = document.querySelector('.video-poster');
  const video = document.querySelector('.video-player') as HTMLVideoElement | null;

  playBtn?.addEventListener('click', () => {
    if (!video) return;
    playBtn.classList.add('hidden');
    poster?.classList.add('hidden');
    video.play();
  });
</script>
