---
/* ArticleCTA — Bloc CTA lead gen, fond marine, contraste fort */
import { Icon } from 'astro-icon/components';

interface Props {
  title: string;
  description: string;
  buttonText: string;
  buttonUrl: string;
}

const { title, description, buttonText, buttonUrl } = Astro.props;
---

<aside class="article-cta" aria-label="Appel a l'action">
  <div class="article-cta__badge">
    <Icon name="lucide:ear" size={24} aria-hidden="true" />
  </div>
  <h3 class="article-cta__title">{title}</h3>
  <p class="article-cta__desc">{description}</p>
  <a href={buttonUrl} class="article-cta__button">
    {buttonText} &rarr;
  </a>
  <p class="article-cta__reassurance">Gratuit &middot; Sans engagement &middot; Reponse sous 48h</p>
</aside>

<style>
  .article-cta {
    background: linear-gradient(145deg, #1B2E4A 0%, #243B5C 60%, #2C4A6E 100%);
    border-radius: 20px;
    padding: 40px 32px 36px;
    text-align: center;
    margin: 48px 0;
    position: relative;
    overflow: hidden;
  }

  /* Motif decoratif subtil */
  .article-cta::before {
    content: '';
    position: absolute;
    top: -40px;
    right: -40px;
    width: 160px;
    height: 160px;
    border-radius: 50%;
    background: rgba(217, 123, 61, 0.08);
  }

  .article-cta__badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border-radius: 14px;
    background: rgba(217, 123, 61, 0.2);
    color: #D97B3D;
    margin-bottom: 16px;
  }

  .article-cta__title {
    font-family: Inter, sans-serif;
    font-size: 22px;
    font-weight: 800;
    color: #fff;
    margin: 0 0 8px;
    line-height: 1.3;
  }

  .article-cta__desc {
    font-family: Inter, sans-serif;
    font-size: 16px;
    line-height: 1.6;
    color: #CBD5E1;
    margin: 0 auto 28px;
    max-width: 420px;
  }

  a.article-cta__button {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: #D97B3D;
    color: #fff;
    border: none;
    border-radius: 12px;
    padding: 16px 36px;
    font-family: Inter, sans-serif;
    font-size: 17px;
    font-weight: 700;
    text-decoration: none;
    box-shadow: 0 4px 20px rgba(217, 123, 61, 0.35);
    transition: background 0.2s ease, transform 0.15s ease, box-shadow 0.2s ease;
    min-height: 52px;
    letter-spacing: 0.01em;
  }

  a.article-cta__button:hover {
    background: #c46a2e;
    color: #fff;
    text-decoration: none;
    transform: translateY(-1px);
    box-shadow: 0 6px 24px rgba(217, 123, 61, 0.45);
  }

  a.article-cta__button:focus-visible {
    outline: 3px solid rgba(217, 123, 61, 0.5);
    outline-offset: 3px;
  }

  .article-cta__reassurance {
    font-family: Inter, sans-serif;
    font-size: 12px;
    color: rgba(255, 255, 255, 0.45);
    margin: 14px 0 0;
    letter-spacing: 0.02em;
  }

  @media (max-width: 640px) {
    .article-cta {
      padding: 32px 20px 28px;
    }
    .article-cta__title {
      font-size: 19px;
    }
    .article-cta__desc {
      font-size: 15px;
    }
    a.article-cta__button {
      font-size: 15px;
      padding: 14px 28px;
      width: 100%;
      justify-content: center;
    }
  }
</style>
