---
/* ProductCard — Fiche produit pour comparatifs */
import { Icon } from 'astro-icon/components';

interface Props {
  name: string;
  image?: string;
  score?: number;
  category?: string;
  priceRange: string;
  pros: string[];
  cons: string[];
  ctaUrl?: string;
}

const { name, image, score, category, priceRange, pros, cons, ctaUrl } = Astro.props;
---

<div class="product-card">
  {image && (
    <div class="product-card__image">
      <img src={image} alt={name} loading="lazy" width="280" height="180" />
    </div>
  )}

  <div class="product-card__body">
    <div class="product-card__header">
      <h3 class="product-card__name">{name}</h3>
      {score && (
        <div class="product-card__score">
          <span class="product-card__score-value">{score}</span>
          <span class="product-card__score-label">/10</span>
        </div>
      )}
    </div>

    {category && (
      <span class="product-card__category">{category}</span>
    )}

    <div class="product-card__price">
      <Icon name="lucide:tag" size={16} aria-hidden="true" />
      <span>{priceRange}</span>
    </div>

    <div class="product-card__lists">
      {pros.length > 0 && (
        <div class="product-card__pros">
          {pros.map((pro) => (
            <div class="product-card__list-item product-card__list-item--pro">
              <Icon name="lucide:check" size={16} aria-hidden="true" />
              <span>{pro}</span>
            </div>
          ))}
        </div>
      )}
      {cons.length > 0 && (
        <div class="product-card__cons">
          {cons.map((con) => (
            <div class="product-card__list-item product-card__list-item--con">
              <Icon name="lucide:x" size={16} aria-hidden="true" />
              <span>{con}</span>
            </div>
          ))}
        </div>
      )}
    </div>

    {ctaUrl && (
      <a href={ctaUrl} class="product-card__cta" rel="sponsored noopener" target="_blank">
        Voir le prix &rarr;
      </a>
    )}
  </div>
</div>

<style>
  .product-card {
    background: var(--article-card, #fff);
    border: 1px solid var(--article-border, #E8E4DF);
    border-radius: 16px;
    overflow: hidden;
    margin: 24px 0;
  }

  .product-card__image {
    width: 100%;
    overflow: hidden;
    background: var(--article-sommaire-bg, #F5F3EF);
  }

  .product-card__image img {
    width: 100%;
    height: 180px;
    object-fit: contain;
    display: block;
  }

  .product-card__body {
    padding: 24px;
  }

  .product-card__header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 12px;
    margin-bottom: 8px;
  }

  .product-card__name {
    font-family: var(--font-heading, Georgia, serif);
    font-size: 20px;
    font-weight: 700;
    color: var(--article-navy, #1B3A5C);
    margin: 0;
    line-height: 1.3;
  }

  .product-card__score {
    display: flex;
    align-items: baseline;
    gap: 2px;
    flex-shrink: 0;
    padding: 4px 12px;
    background: var(--article-green-bg, #EEFBF3);
    border-radius: 8px;
  }

  .product-card__score-value {
    font-family: var(--font-heading, Georgia, serif);
    font-size: 22px;
    font-weight: 700;
    color: var(--article-green, #2D7A4F);
  }

  .product-card__score-label {
    font-size: 13px;
    color: var(--article-green, #2D7A4F);
  }

  .product-card__category {
    display: inline-block;
    padding: 3px 10px;
    background: var(--article-navy-light, #EDF2F7);
    border-radius: 6px;
    font-size: 12px;
    font-weight: 600;
    color: var(--article-navy, #1B3A5C);
    letter-spacing: 0.03em;
    margin-bottom: 12px;
  }

  .product-card__price {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 15px;
    font-weight: 600;
    color: var(--article-accent, #C66A32);
    margin-bottom: 16px;
  }

  .product-card__lists {
    display: flex;
    flex-direction: column;
    gap: 16px;
    margin-bottom: 20px;
  }

  .product-card__list-item {
    display: flex;
    align-items: flex-start;
    gap: 8px;
    font-size: 14px;
    line-height: 1.5;
    color: var(--article-text, #2D2A26);
    margin-bottom: 6px;
  }

  .product-card__list-item--pro {
    color: var(--article-green, #2D7A4F);
  }

  .product-card__list-item--pro span {
    color: var(--article-text, #2D2A26);
  }

  .product-card__list-item--con {
    color: var(--article-urgent, #B8392E);
  }

  .product-card__list-item--con span {
    color: var(--article-text, #2D2A26);
  }

  .product-card__cta {
    display: inline-block;
    padding: 10px 24px;
    background: var(--article-accent, #C66A32);
    color: #fff;
    border-radius: 10px;
    font-size: 14px;
    font-weight: 700;
    text-decoration: none;
    min-height: 44px;
    min-width: 44px;
    line-height: 24px;
    transition: background 0.2s ease;
  }

  .product-card__cta:hover {
    background: var(--article-accent-hover, #A8552A);
    text-decoration: none;
  }
</style>
