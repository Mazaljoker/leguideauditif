{
  "name": "lga-site",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "prebuild": "node scripts/copy-tarteaucitron.mjs",
    "predev": "node scripts/copy-tarteaucitron.mjs",
    "build": "astro build && npx pagefind --site dist/client && cp -r dist/client/pagefind .vercel/output/static/pagefind",
    "preview": "astro preview",
    "astro": "astro",
    "test:e2e:seed": "node scripts/seed-test-centre.mjs",
    "test:e2e": "npm run test:e2e:seed && playwright test --grep-invert=@full",
    "test:e2e:full": "npm run test:e2e:seed && playwright test",
    "test:e2e:ui": "npm run test:e2e:seed && playwright test --ui"
  },
  "dependencies": {
    "@astrojs/mdx": "^5.0.3",
    "@astrojs/react": "^5.0.3",
    "@astrojs/sitemap": "^3.7.2",
    "@astrojs/vercel": "^10.0.4",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@iconify-json/lucide": "^1.2.101",
    "@supabase/supabase-js": "^2.102.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/leaflet": "^1.9.21",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vercel/og": "^0.11.1",
    "astro": "^6.1.4",
    "astro-icon": "^1.1.5",
    "leaflet": "^1.9.4",
    "papaparse": "^5.5.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-leaflet": "^5.0.0",
    "resend": "^6.10.0",
    "stripe": "^22.0.0",
    "tailwindcss": "^4.2.2",
    "tarteaucitronjs": "^1.32.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "dotenv": "^17.4.2",
    "pagefind": "^1.5.0"
  },
  "overrides": {
    "vite": "^7"
  }
}
