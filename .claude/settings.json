{
  "env": {
    "MAX_THINKING_TOKENS": "10000",
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "70"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [{ "type": "command", "command": "bash .claude/hooks/block-no-verify.sh" }],
        "description": "Block --no-verify pour proteger les hooks pre-commit"
      },
      {
        "matcher": "Edit|Write",
        "hooks": [{ "type": "command", "command": "bash .claude/hooks/suggest-compact.sh" }],
        "description": "Suggerer compaction tous les 15 edits"
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [{ "type": "command", "command": "bash .claude/hooks/block-env-edit.sh" }],
        "description": "Block writes to .env, secrets, and detect hardcoded tokens"
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [{ "type": "command", "command": "bash .claude/hooks/auto-format.sh", "timeout": 15 }],
        "description": "Auto-format avec Prettier apres edits"
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [{ "type": "command", "command": "bash .claude/hooks/file-size-warn.sh" }],
        "description": "Warn when file exceeds 200 lines"
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [{ "type": "command", "command": "bash .claude/hooks/block-any-type.sh" }],
        "description": "Detect TypeScript any — use explicit interfaces"
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [{ "type": "command", "command": "bash .claude/hooks/stop-build-check.sh", "timeout": 60 }],
        "description": "Run npm run build avant de terminer"
      },
      {
        "matcher": "*",
        "hooks": [{ "type": "command", "command": "bash .claude/hooks/session-end-memory.sh", "timeout": 10 }],
        "description": "Save session summary to .claude/memory/session-log.md"
      },
      {
        "matcher": "*",
        "hooks": [{ "type": "command", "command": "bash .claude/hooks/check-harness-coherence.sh" }],
        "description": "Verify harness internal consistency"
      }
    ]
  }
}
