{
  "env": {
    "MAX_THINKING_TOKENS": "10000",
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "70"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [{ "type": "command", "command": "bash .claude/hooks/block-no-verify.sh" }],
        "description": "Block --no-verify pour proteger les hooks pre-commit"
      },
      {
        "matcher": "Edit|Write",
        "hooks": [{ "type": "command", "command": "bash .claude/hooks/suggest-compact.sh" }],
        "description": "Suggerer compaction tous les 15 edits"
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [{ "type": "command", "command": "bash .claude/hooks/auto-format.sh", "timeout": 15 }],
        "description": "Auto-format avec Prettier apres edits"
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [{ "type": "command", "command": "bash .claude/hooks/stop-build-check.sh", "timeout": 60 }],
        "description": "Run npm run build avant de terminer"
      }
    ]
  }
}
