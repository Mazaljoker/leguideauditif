# ======================================================================
# Fichier .env.test — Stripe en mode TEST pour Playwright @full
# ======================================================================
#
# COMMENT L'UTILISER :
# 1. Copie ce fichier en .env.test : cp .env.test.example .env.test
# 2. Remplis les valeurs depuis https://dashboard.stripe.com/test/apikeys
# 3. Cree les prices equivalents en mode test (39eur/mois, 390eur/an)
# 4. Lance : stripe listen --forward-to localhost:4321/api/webhook
#    (la commande affichera whsec_... a copier dans STRIPE_WEBHOOK_SECRET)
# 5. npm run test:e2e:full
#
# .env.test n'est PAS commite (.gitignore). .env.test.example est un template.
# ======================================================================

# Stripe TEST mode — recupere sur dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_REMPLACE_MOI

# Webhook secret en mode test — generer avec `stripe listen --forward-to localhost:4321/api/webhook`
# ou creer un endpoint webhook dans dashboard.stripe.com/test/webhooks
STRIPE_WEBHOOK_SECRET=whsec_test_REMPLACE_MOI

# Prices TEST mode — creer a l'identique des prices live :
# - Fiche premium mensuel 39 EUR
# - Fiche premium annuel 390 EUR
STRIPE_PRICE_ID=price_test_monthly_REMPLACE_MOI
STRIPE_PRICE_ID_ANNUAL=price_test_annual_REMPLACE_MOI

# (Optionnel) Prices annonces test mode — non utilises par la suite claim/premium
# STRIPE_PRICE_UNLOCK_CONTACTS=price_test_REMPLACE_MOI
# STRIPE_PRICE_PREMIUM_ANNONCE=price_test_REMPLACE_MOI
# STRIPE_PRICE_BOOST_SEMAINE=price_test_REMPLACE_MOI
# STRIPE_PRICE_ALERTE_CIBLEE=price_test_REMPLACE_MOI
# STRIPE_PRICE_PACK_CESSION=price_test_REMPLACE_MOI
# STRIPE_PRICE_PACK_CESSION_ACCOMP=price_test_REMPLACE_MOI
