---
/**
 * Page d'entrée catalogue — /catalogue/
 * 6 parcours "par besoin" + accès rapide listing/marques
 */
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/catalogue/Breadcrumbs.astro";
import ProductCard from "../../components/catalogue/ProductCard.astro";
import LeadCTA from "../../components/catalogue/LeadCTA.astro";

const allAppareils = await getCollection("catalogue-appareils");
const enAvant = allAppareils
  .filter((a) => a.data.enAvant && a.data.actif !== false)
  .sort((a, b) => (b.data.noteExpert || 0) - (a.data.noteExpert || 0))
  .slice(0, 6);

const totalAppareils = allAppareils.filter((a) => a.data.actif !== false).length;
const marques = await getCollection("marques");

const besoins = [
  {
    icon: "🔇",
    title: "Première aide auditive",
    desc: "Vous découvrez l'appareillage ? Trouvez l'appareil qui correspond à votre perte auditive et votre mode de vie.",
    href: "/catalogue/appareils/?premier=1",
  },
  {
    icon: "🔄",
    title: "Renouvellement",
    desc: "Vos appareils ont plus de 4 ans ? Découvrez les dernières technologies et comparez avec votre équipement actuel.",
    href: "/catalogue/appareils/",
  },
  {
    icon: "👁️",
    title: "Discrétion maximale",
    desc: "Vous recherchez un appareil invisible ? Découvrez les intra-auriculaires et les RIC les plus compacts.",
    href: "/catalogue/appareils/?forme=invisible,intra",
  },
  {
    icon: "📱",
    title: "Connecté et Bluetooth",
    desc: "Téléphone, TV, musique en streaming directement dans vos aides auditives.",
    href: "/catalogue/appareils/?bluetooth=1",
  },
  {
    icon: "💰",
    title: "100% Santé (RAC 0€)",
    desc: "Des aides auditives de qualité, intégralement remboursées avec une mutuelle responsable.",
    href: "/catalogue/appareils/?classe=1",
  },
  {
    icon: "🔊",
    title: "Acouphènes",
    desc: "Certaines aides auditives intègrent un générateur de bruit pour soulager les acouphènes.",
    href: "/catalogue/appareils/?acouphenes=1",
  },
];
---

<BaseLayout
  title="Catalogue Aides Auditives — Guide Expert Indépendant"
  description={`Comparez ${totalAppareils} aides auditives de ${marques.length} marques. Guide rédigé par un audioprothésiste DE avec 25 ans d'expérience. Devis gratuit.`}
>
  <div class="container">
    <Breadcrumbs items={[
      { label: "Accueil", href: "/" },
      { label: "Catalogue" },
    ]} />

    <!-- Hero -->
    <header class="catalogue-hero">
      <h1>Trouvez l'aide auditive qui vous convient</h1>
      <p>
        {totalAppareils} appareils de {marques.length} marques, testés et comparés par un audioprothésiste diplômé d'État
        avec 25 ans d'expérience.
      </p>
      <div class="catalogue-hero__actions">
        <a href="/catalogue/appareils/" class="btn btn--primary">Voir tous les appareils</a>
        <a href="/devis/" class="btn btn--outline">Demander un devis gratuit</a>
      </div>
    </header>

    <!-- Parcours par besoin -->
    <section class="besoins" aria-labelledby="besoins-title">
      <h2 id="besoins-title">Quel est votre besoin ?</h2>
      <div class="besoins__grid">
        {besoins.map((b) => (
          <a href={b.href} class="besoin-card">
            <span class="besoin-card__icon" aria-hidden="true">{b.icon}</span>
            <h3>{b.title}</h3>
            <p>{b.desc}</p>
          </a>
        ))}
      </div>
    </section>

    <!-- Appareils en avant -->
    {enAvant.length > 0 && (
      <section class="featured" aria-labelledby="featured-title">
        <h2 id="featured-title">Nos recommandations</h2>
        <p class="featured__subtitle">Sélection de notre audioprothésiste expert</p>
        <div class="featured__grid">
          {enAvant.map((appareil) => (
            <ProductCard
              slug={appareil.data.slug}
              nom={appareil.data.nom}
              marque={appareil.data.marque}
              forme={appareil.data.forme}
              classe={appareil.data.classe}
              noteExpert={appareil.data.noteExpert}
              prixFourchette={appareil.data.prixFourchette}
              prixMin={appareil.data.prixMin}
              prixMax={appareil.data.prixMax}
              bluetooth={appareil.data.bluetooth}
              rechargeable={appareil.data.rechargeable}
              imageUrl={appareil.data.imageUrl}
              descriptionCourte={appareil.data.descriptionCourte}
              enAvant={true}
            />
          ))}
        </div>
        <div class="featured__more">
          <a href="/catalogue/appareils/" class="btn btn--secondary">Voir les {totalAppareils} appareils →</a>
        </div>
      </section>
    )}

    <!-- Marques -->
    <section class="brands-section" aria-labelledby="brands-title">
      <h2 id="brands-title">Les marques du catalogue</h2>
      <div class="brands-row">
        {marques.sort((a, b) => a.data.nom.localeCompare(b.data.nom)).map((m) => (
          <a href={`/catalogue/marques/${m.data.slug}/`} class="brand-pill">
            {m.data.nom}
          </a>
        ))}
      </div>
      <div class="brands-section__more">
        <a href="/catalogue/marques/">Voir toutes les marques →</a>
      </div>
    </section>

    <LeadCTA />
  </div>
</BaseLayout>

<style>
  .catalogue-hero {
    text-align: center;
    padding: var(--space-12) 0 var(--space-8);
    max-width: var(--max-width-narrow);
    margin-inline: auto;
  }
  .catalogue-hero h1 {
    font-size: var(--text-4xl);
    margin-bottom: var(--space-4);
  }
  .catalogue-hero p {
    font-size: var(--text-lg);
    color: var(--color-gray-700);
    line-height: 1.6;
    margin-bottom: var(--space-6);
  }
  .catalogue-hero__actions {
    display: flex;
    gap: var(--space-3);
    justify-content: center;
    flex-wrap: wrap;
  }

  /* Besoins */
  .besoins {
    padding: var(--space-12) 0;
  }
  .besoins h2 {
    font-size: var(--text-2xl);
    text-align: center;
    margin-bottom: var(--space-8);
  }
  .besoins__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: var(--space-4);
  }
  .besoin-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding: var(--space-6);
    background: var(--color-cream);
    border: 1px solid var(--color-gray-200);
    border-radius: var(--radius-lg);
    text-decoration: none;
    color: inherit;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .besoin-card:hover {
    border-color: var(--color-orange);
    box-shadow: var(--shadow-md);
  }
  .besoin-card__icon {
    font-size: var(--text-3xl);
  }
  .besoin-card h3 {
    font-size: var(--text-lg);
    color: var(--color-navy);
    margin: 0;
  }
  .besoin-card p {
    font-size: var(--text-sm);
    color: var(--color-gray-700);
    line-height: 1.5;
  }

  /* Featured */
  .featured {
    padding: var(--space-12) 0;
    border-top: 2px solid var(--color-gray-200);
  }
  .featured h2 {
    font-size: var(--text-2xl);
    text-align: center;
    margin-bottom: var(--space-1);
  }
  .featured__subtitle {
    text-align: center;
    color: var(--color-gray-500);
    font-size: var(--text-sm);
    margin-bottom: var(--space-8);
  }
  .featured__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--space-6);
  }
  .featured__more {
    text-align: center;
    margin-top: var(--space-8);
  }

  /* Marques */
  .brands-section {
    padding: var(--space-12) 0;
    border-top: 2px solid var(--color-gray-200);
  }
  .brands-section h2 {
    font-size: var(--text-2xl);
    text-align: center;
    margin-bottom: var(--space-6);
  }
  .brands-row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    justify-content: center;
  }
  .brand-pill {
    display: inline-block;
    padding: var(--space-2) var(--space-4);
    background: var(--color-white);
    border: 1px solid var(--color-gray-200);
    border-radius: var(--radius-full);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-navy);
    text-decoration: none;
    transition: all 0.2s;
  }
  .brand-pill:hover {
    background: var(--color-navy);
    color: var(--color-white);
    border-color: var(--color-navy);
  }
  .brands-section__more {
    text-align: center;
    margin-top: var(--space-4);
    font-size: var(--text-sm);
  }
</style>