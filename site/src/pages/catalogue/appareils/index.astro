---
/**
 * Listing Appareils Auditifs — /catalogue/appareils/
 * Grille filtrable de tous les appareils du catalogue
 */
import { getCollection } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../../components/catalogue/Breadcrumbs.astro";
import ProductCard from "../../../components/catalogue/ProductCard.astro";
import LeadCTA from "../../../components/catalogue/LeadCTA.astro";

const allAppareils = await getCollection("catalogue-appareils");
const appareils = allAppareils
  .filter((a) => a.data.actif !== false)
  .sort((a, b) => {
    // En avant d'abord, puis par note expert décroissante
    if (a.data.enAvant && !b.data.enAvant) return -1;
    if (!a.data.enAvant && b.data.enAvant) return 1;
    return (b.data.noteExpert || 0) - (a.data.noteExpert || 0);
  });

// Extraire les valeurs uniques pour les filtres
const marques = [...new Set(appareils.map((a) => a.data.marque))].sort();
const formes = [...new Set(appareils.map((a) => a.data.forme))];

const formeLabels: Record<string, string> = {
  ric: "RIC (micro-contour)",
  contour: "Contour d'oreille",
  intra: "Intra-auriculaire",
  invisible: "Invisible (CIC/IIC)",
};

const schemaMarkup = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "Catalogue d'aides auditives",
  description: "Comparez les aides auditives des plus grandes marques. Guide expert indépendant par un audioprothésiste DE.",
  url: "https://leguideauditif.fr/catalogue/appareils/",
  numberOfItems: appareils.length,
});
---

<BaseLayout
  title="Catalogue Aides Auditives — Comparez les Appareils"
  description={`Comparez ${appareils.length} aides auditives des plus grandes marques. Filtrez par forme, classe, prix. Guide expert par un audioprothésiste DE.`}
  schemaMarkup={schemaMarkup}
>
  <div class="container">
    <Breadcrumbs items={[
      { label: "Accueil", href: "/" },
      { label: "Catalogue", href: "/catalogue/" },
      { label: "Aides auditives" },
    ]} />

    <header class="listing-header">
      <h1>Aides auditives : le catalogue expert</h1>
      <p>{appareils.length} appareils comparés par un audioprothésiste diplômé d'État</p>
    </header>

    <!-- Filtres -->
    <div class="listing-layout">
      <aside class="filters" aria-label="Filtres">
        <h2 class="filters__title">Filtrer par</h2>

        <fieldset class="filters__group">
          <legend>Marque</legend>
          {marques.map((m) => (
            <label class="filters__option">
              <input type="checkbox" value={m} data-filter="marque" />
              <span>{m.charAt(0).toUpperCase() + m.slice(1)}</span>
              <span class="filters__count">({appareils.filter((a) => a.data.marque === m).length})</span>
            </label>
          ))}
        </fieldset>

        <fieldset class="filters__group">
          <legend>Forme</legend>
          {formes.map((f) => (
            <label class="filters__option">
              <input type="checkbox" value={f} data-filter="forme" />
              <span>{formeLabels[f] || f}</span>
            </label>
          ))}
        </fieldset>

        <fieldset class="filters__group">
          <legend>Classe</legend>
          <label class="filters__option">
            <input type="checkbox" value="1" data-filter="classe" />
            <span>Classe 1 (100% Santé)</span>
          </label>
          <label class="filters__option">
            <input type="checkbox" value="2" data-filter="classe" />
            <span>Classe 2</span>
          </label>
        </fieldset>

        <fieldset class="filters__group">
          <legend>Fonctionnalités</legend>
          <label class="filters__option">
            <input type="checkbox" value="bluetooth" data-filter="feature" />
            <span>Bluetooth</span>
          </label>
          <label class="filters__option">
            <input type="checkbox" value="rechargeable" data-filter="feature" />
            <span>Rechargeable</span>
          </label>
          <label class="filters__option">
            <input type="checkbox" value="masqueurAcouphenes" data-filter="feature" />
            <span>Masqueur d'acouphènes</span>
          </label>
        </fieldset>
      </aside>

      <!-- Grille produits -->
      <div class="products">
        <div class="products__grid" id="product-grid">
          {appareils.map((appareil) => (
            <div
              class="products__item"
              data-marque={appareil.data.marque}
              data-forme={appareil.data.forme}
              data-classe={appareil.data.classe}
              data-bluetooth={appareil.data.bluetooth}
              data-rechargeable={appareil.data.rechargeable}
              data-masqueuracouphenes={appareil.data.masqueurAcouphenes}
            >
              <ProductCard
                slug={appareil.data.slug}
                nom={appareil.data.nom}
                marque={appareil.data.marque}
                forme={appareil.data.forme}
                classe={appareil.data.classe}
                noteExpert={appareil.data.noteExpert}
                prixFourchette={appareil.data.prixFourchette}
                prixMin={appareil.data.prixMin}
                prixMax={appareil.data.prixMax}
                bluetooth={appareil.data.bluetooth}
                rechargeable={appareil.data.rechargeable}
                imageUrl={appareil.data.imageUrl}
                descriptionCourte={appareil.data.descriptionCourte}
                enAvant={appareil.data.enAvant}
              />
            </div>
          ))}
        </div>
        <p class="products__empty" id="no-results" hidden>
          Aucun appareil ne correspond à vos critères. Essayez de modifier vos filtres.
        </p>
      </div>
    </div>

    <LeadCTA />
  </div>
</BaseLayout>

<!-- Filtrage côté client (vanilla JS, pas de framework) -->
<script>
  document.addEventListener("DOMContentLoaded", () => {
    const checkboxes = document.querySelectorAll<HTMLInputElement>("[data-filter]");
    const items = document.querySelectorAll<HTMLElement>(".products__item");
    const noResults = document.getElementById("no-results");

    function applyFilters() {
      const filters: Record<string, string[]> = {};
      checkboxes.forEach((cb) => {
        if (cb.checked) {
          const key = cb.dataset.filter!;
          if (!filters[key]) filters[key] = [];
          filters[key].push(cb.value);
        }
      });

      let visible = 0;
      items.forEach((item) => {
        let show = true;

        if (filters.marque?.length) {
          show = show && filters.marque.includes(item.dataset.marque || "");
        }
        if (filters.forme?.length) {
          show = show && filters.forme.includes(item.dataset.forme || "");
        }
        if (filters.classe?.length) {
          show = show && filters.classe.includes(item.dataset.classe || "");
        }
        if (filters.feature?.length) {
          for (const feat of filters.feature) {
            const val = item.dataset[feat.toLowerCase()] || item.dataset[feat];
            show = show && val === "true";
          }
        }

        item.style.display = show ? "" : "none";
        if (show) visible++;
      });

      if (noResults) noResults.hidden = visible > 0;
    }

    checkboxes.forEach((cb) => cb.addEventListener("change", applyFilters));
  });
</script>

<style>
  .listing-header {
    text-align: center;
    padding: var(--space-8) 0 var(--space-6);
  }
  .listing-header h1 {
    font-size: var(--text-3xl);
    margin-bottom: var(--space-2);
  }
  .listing-header p {
    font-size: var(--text-lg);
    color: var(--color-gray-500);
  }

  .listing-layout {
    display: grid;
    grid-template-columns: 260px 1fr;
    gap: var(--space-8);
    padding-bottom: var(--space-12);
  }

  /* Filtres */
  .filters {
    position: sticky;
    top: 80px;
    align-self: start;
    background: var(--color-white);
    border: 1px solid var(--color-gray-200);
    border-radius: var(--radius-lg);
    padding: var(--space-4);
    max-height: calc(100vh - 100px);
    overflow-y: auto;
  }
  .filters__title {
    font-size: var(--text-lg);
    margin-bottom: var(--space-4);
  }
  .filters__group {
    border: none;
    margin-bottom: var(--space-4);
    padding: 0;
  }
  .filters__group legend {
    font-weight: 700;
    font-size: var(--text-sm);
    color: var(--color-navy);
    margin-bottom: var(--space-2);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .filters__option {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    cursor: pointer;
    padding: var(--space-1) 0;
    font-size: var(--text-sm);
  }
  .filters__option input[type="checkbox"] {
    accent-color: var(--color-orange);
    width: 16px;
    height: 16px;
  }
  .filters__count {
    color: var(--color-gray-500);
    font-size: var(--text-xs);
    margin-left: auto;
  }

  /* Grille produits */
  .products__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--space-6);
  }
  .products__empty {
    text-align: center;
    padding: var(--space-12);
    color: var(--color-gray-500);
    font-size: var(--text-lg);
  }

  @media (max-width: 768px) {
    .listing-layout {
      grid-template-columns: 1fr;
    }
    .filters {
      position: static;
      max-height: none;
    }
  }
</style>