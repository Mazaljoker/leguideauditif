---
/**
 * Fiche Appareil Auditif — /catalogue/appareils/[slug]/
 * Page produit complète : specs, avis expert, prix, CTA lead gen
 * Schema.org Product + Review (E-E-A-T / YMYL)
 */
import { getCollection } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../../components/catalogue/Breadcrumbs.astro";
import ProductSpecs from "../../../components/catalogue/ProductSpecs.astro";
import ExpertOpinion from "../../../components/catalogue/ExpertOpinion.astro";
import PriceDisclaimer from "../../../components/catalogue/PriceDisclaimer.astro";
import LeadCTA from "../../../components/catalogue/LeadCTA.astro";
import HealthDisclaimer from "../../../components/catalogue/HealthDisclaimer.astro";

export async function getStaticPaths() {
  const appareils = await getCollection("catalogue-appareils");
  return appareils
    .filter((a) => a.data.actif !== false)
    .map((appareil) => ({
      params: { slug: appareil.data.slug },
      props: { appareil: appareil.data },
    }));
}

const { appareil } = Astro.props;

const marqueLabel = appareil.marque.charAt(0).toUpperCase() + appareil.marque.slice(1);
const fullName = `${marqueLabel} ${appareil.nom}`;

// Schema.org Product + Review
const schemaMarkup = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Product",
  name: fullName,
  description: appareil.descriptionCourte || appareil.metaDescription || `Aide auditive ${fullName}`,
  brand: { "@type": "Brand", name: marqueLabel },
  category: "Aide auditive",
  ...(appareil.imageUrl ? { image: appareil.imageUrl } : {}),
  ...(appareil.prixMin || appareil.prixMax
    ? {
        offers: {
          "@type": "AggregateOffer",
          priceCurrency: "EUR",
          ...(appareil.prixMin ? { lowPrice: String(appareil.prixMin) } : {}),
          ...(appareil.prixMax ? { highPrice: String(appareil.prixMax) } : {}),
          offerCount: "1",
          availability: "https://schema.org/InStoreOnly",
          seller: {
            "@type": "LocalBusiness",
            name: "Audioprothésiste agréé",
          },
        },
      }
    : {}),
  ...(appareil.noteExpert
    ? {
        review: {
          "@type": "Review",
          author: {
            "@type": "Person",
            name: appareil.author || "Franck-Olivier",
            jobTitle: appareil.authorTitle || "Audioprothésiste DE",
          },
          reviewRating: {
            "@type": "Rating",
            ratingValue: String(appareil.noteExpert),
            bestRating: "10",
            worstRating: "0",
          },
          reviewBody: appareil.descriptionCourte || `Avis expert sur ${fullName}`,
        },
      }
    : {}),
});

const formeLabels: Record<string, string> = {
  ric: "RIC",
  contour: "Contour",
  intra: "Intra",
  invisible: "Invisible",
};
---

<BaseLayout
  title={appareil.title || `${fullName} : Avis d'Expert, Caractéristiques et Prix`}
  description={appareil.metaDescription || `Test complet du ${fullName} par un audioprothésiste DE. Caractéristiques, prix indicatifs et avis professionnel.`}
  schemaMarkup={schemaMarkup}
>
  <article class="container product-page">
    <Breadcrumbs items={[
      { label: "Accueil", href: "/" },
      { label: "Catalogue", href: "/catalogue/" },
      { label: "Aides auditives", href: "/catalogue/appareils/" },
      { label: fullName },
    ]} />

    <!-- ── Hero produit ──────────────────────────────────────── -->
    <header class="product-hero">
      <div class="product-hero__image">
        {appareil.imageUrl ? (
          <img src={appareil.imageUrl} alt={fullName} width="480" height="360" />
        ) : (
          <div class="product-hero__placeholder">
            <span>{marqueLabel}</span>
            <span>{appareil.nom}</span>
          </div>
        )}
      </div>

      <div class="product-hero__info">
        <div class="product-hero__badges">
          <span class={`badge badge--${appareil.forme}`}>{formeLabels[appareil.forme] || appareil.forme}</span>
          <span class={`badge badge--classe${appareil.classe}`}>Classe {appareil.classe}</span>
          {appareil.bluetooth && <span class="badge" style="background:#EFF6FF;color:#1D4ED8;">Bluetooth</span>}
          {appareil.rechargeable && <span class="badge" style="background:#F0FDF4;color:#166534;">Rechargeable</span>}
          {appareil.ip && <span class="badge" style="background:#F5F3FF;color:#6B21A8;">{appareil.ip}</span>}
        </div>

        <p class="product-hero__brand">{marqueLabel}</p>
        <h1 class="product-hero__title">{appareil.nom}</h1>

        {appareil.noteExpert && (
          <div class="product-hero__rating">
            <span class="product-hero__score">{appareil.noteExpert}</span>
            <span class="product-hero__score-max">/10</span>
            <span class="product-hero__score-label">Note expert</span>
          </div>
        )}

        {appareil.descriptionCourte && (
          <p class="product-hero__desc">{appareil.descriptionCourte}</p>
        )}

        <div class="product-hero__cta">
          <a href="/devis/" class="btn btn--primary">Demander un devis gratuit</a>
          <a href="#avis-expert" class="btn btn--outline">Lire l'avis expert</a>
        </div>
      </div>
    </header>

    <!-- ── Contenu principal 2 colonnes ──────────────────────── -->
    <div class="product-content">
      <div class="product-content__main">
        <!-- Spécifications -->
        <ProductSpecs
          forme={appareil.forme}
          classe={appareil.classe}
          bluetooth={appareil.bluetooth}
          rechargeable={appareil.rechargeable}
          masqueurAcouphenes={appareil.masqueurAcouphenes}
          ip={appareil.ip}
          canaux={appareil.canaux}
          batterie={appareil.batterie}
          puissanceSortie={appareil.puissanceSortie}
          gainMax={appareil.gainMax}
          garantieAnnees={appareil.garantieAnnees}
          niveaux={appareil.niveaux}
          niveauTechno={appareil.niveauTechno}
          telecommande={appareil.telecommande}
          synchronisationBinaurale={appareil.synchronisationBinaurale}
        />

        <!-- Avis expert -->
        <div id="avis-expert">
          <ExpertOpinion
            noteExpert={appareil.noteExpert}
            descriptionExpert={appareil.descriptionExpert}
            descriptionCourte={appareil.descriptionCourte}
            idealPour={appareil.idealPour}
            pointsForts={appareil.pointsForts}
            pointsFaibles={appareil.pointsFaibles}
            author={appareil.author}
            authorTitle={appareil.authorTitle}
          />
        </div>

        <!-- CTA inline -->
        <LeadCTA appareilNom={fullName} variant="inline" />

        <!-- Disclaimer santé -->
        <HealthDisclaimer />
      </div>

      <!-- Sidebar -->
      <aside class="product-content__sidebar">
        <!-- Prix -->
        <PriceDisclaimer
          prixMin={appareil.prixMin}
          prixMax={appareil.prixMax}
          prixFourchette={appareil.prixFourchette}
          classe={appareil.classe}
          remboursementSecu={appareil.remboursementSecu}
        />

        <!-- CTA sidebar -->
        <LeadCTA appareilNom={fullName} variant="sidebar" />

        <!-- Niveaux disponibles -->
        {appareil.niveaux && appareil.niveaux.length > 0 && (
          <div class="sidebar-card">
            <h3>Niveaux disponibles</h3>
            <ul>
              {appareil.niveaux.map((n: string) => <li>{n}</li>)}
            </ul>
          </div>
        )}

        <!-- Lien marque -->
        <div class="sidebar-card">
          <h3>En savoir plus</h3>
          <a href={`/catalogue/marques/${appareil.marque}/`} class="sidebar-card__link">
            Tous les appareils {marqueLabel} →
          </a>
        </div>
      </aside>
    </div>

    <!-- CTA final pleine largeur -->
    <LeadCTA />

    <!-- Mise à jour -->
    <p class="product-page__updated">
      Dernière mise à jour : {appareil.dateMiseAJour || appareil.dateAjout}
    </p>
  </article>
</BaseLayout>

<style>
  .product-page {
    padding-bottom: var(--space-12);
  }

  /* Hero */
  .product-hero {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-8);
    padding: var(--space-6) 0 var(--space-8);
    align-items: start;
  }
  .product-hero__image {
    background: var(--color-cream);
    border-radius: var(--radius-lg);
    aspect-ratio: 4/3;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .product-hero__image img {
    object-fit: contain;
    width: 100%;
    height: 100%;
    padding: var(--space-6);
  }
  .product-hero__placeholder {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-heading);
    color: var(--color-gray-300);
  }
  .product-hero__placeholder span:first-child {
    font-size: var(--text-xl);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
  .product-hero__placeholder span:last-child {
    font-size: var(--text-3xl);
    font-weight: 700;
    color: var(--color-navy);
  }
  .product-hero__info {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  .product-hero__badges {
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
  }
  .product-hero__brand {
    font-size: var(--text-sm);
    color: var(--color-gray-500);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-weight: 600;
  }
  .product-hero__title {
    font-size: var(--text-4xl);
    line-height: 1.1;
    margin: 0;
  }
  .product-hero__rating {
    display: flex;
    align-items: baseline;
    gap: var(--space-1);
  }
  .product-hero__score {
    font-family: var(--font-heading);
    font-size: var(--text-3xl);
    font-weight: 700;
    color: var(--color-orange);
  }
  .product-hero__score-max {
    font-size: var(--text-lg);
    color: var(--color-gray-500);
  }
  .product-hero__score-label {
    font-size: var(--text-sm);
    color: var(--color-gray-500);
    margin-left: var(--space-2);
  }
  .product-hero__desc {
    font-size: var(--text-base);
    line-height: 1.7;
    color: var(--color-gray-700);
  }
  .product-hero__cta {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
    margin-top: var(--space-2);
  }

  /* Contenu 2 colonnes */
  .product-content {
    display: grid;
    grid-template-columns: 1fr 340px;
    gap: var(--space-8);
    padding: var(--space-8) 0;
  }
  .product-content__main {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }
  .product-content__sidebar {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    position: sticky;
    top: 80px;
    align-self: start;
  }

  /* Sidebar cards */
  .sidebar-card {
    background: var(--color-white);
    border: 1px solid var(--color-gray-200);
    border-radius: var(--radius-lg);
    padding: var(--space-4);
  }
  .sidebar-card h3 {
    font-size: var(--text-sm);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-navy);
    margin-bottom: var(--space-3);
    font-family: var(--font-body);
  }
  .sidebar-card ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }
  .sidebar-card li {
    font-size: var(--text-sm);
    padding: var(--space-1) 0;
    border-bottom: 1px solid var(--color-gray-100);
  }
  .sidebar-card li:last-child {
    border-bottom: none;
  }
  .sidebar-card__link {
    font-size: var(--text-sm);
    font-weight: 600;
  }

  .product-page__updated {
    text-align: center;
    font-size: var(--text-xs);
    color: var(--color-gray-500);
    padding-top: var(--space-6);
  }

  @media (max-width: 968px) {
    .product-hero { grid-template-columns: 1fr; }
    .product-content { grid-template-columns: 1fr; }
    .product-content__sidebar { position: static; }
  }
</style>