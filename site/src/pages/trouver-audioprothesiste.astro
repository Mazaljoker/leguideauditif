---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Trouver un audioprothesiste — LeGuideAuditif.fr"
  description="Trouvez un audioprothesiste qualifie pres de chez vous pour un bilan auditif gratuit et sans engagement."
>
  <section class="bg-creme py-16">
    <div class="max-w-[780px] mx-auto px-5">
      <h1 class="font-sans text-[38px] font-extrabold text-marine mb-8">Trouver un audioprothesiste</h1>
      <p class="text-lg leading-relaxed mb-6">
        Un bilan auditif complet est la premiere etape pour mieux entendre. Trouvez un audioprothesiste diplome d'Etat pres de chez vous.
      </p>
      <div class="bg-blanc rounded-2xl p-8 shadow-[0_2px_12px_rgba(27,46,74,0.06)]">
        <p class="text-center text-gris-texte font-sans">
          Outil de recherche a venir — en attendant, vous pouvez consulter l'annuaire des audioprothesistes sur ameli.fr.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
