---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Glossaire de l'audition — LeGuideAuditif.fr"
  description="Glossaire complet des termes de l'audition : presbyacousie, acouphenes, audiogramme, contour, RIC, et plus."
>
  <section class="bg-creme py-16">
    <div class="max-w-[780px] mx-auto px-5">
      <h1 class="font-sans text-[38px] font-extrabold text-marine mb-8">Glossaire de l'audition</h1>
      <p class="text-lg leading-relaxed mb-8">
        Les termes essentiels pour comprendre l'audition et les appareils auditifs, expliques simplement.
      </p>
      <p class="text-gris-texte font-sans">Contenu a venir.</p>
    </div>
  </section>
</BaseLayout>
