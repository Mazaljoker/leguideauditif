---
/**
 * Accueil — LeGuideAuditif.fr
 * Page d'entrée du site avec accès au catalogue
 */
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import ProductCard from "../components/catalogue/ProductCard.astro";
import LeadCTA from "../components/catalogue/LeadCTA.astro";
import HealthDisclaimer from "../components/catalogue/HealthDisclaimer.astro";

const allAppareils = await getCollection("catalogue-appareils");
const enAvant = allAppareils
  .filter((a) => a.data.enAvant && a.data.actif !== false)
  .sort((a, b) => (b.data.noteExpert || 0) - (a.data.noteExpert || 0))
  .slice(0, 3);

const totalAppareils = allAppareils.filter((a) => a.data.actif !== false).length;
const marques = await getCollection("marques");

const schemaMarkup = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "LeGuideAuditif.fr",
  url: "https://leguideauditif.fr",
  description: "Guide expert indépendant sur les aides auditives. Comparez les appareils, consultez les avis d'un audioprothésiste DE.",
  author: {
    "@type": "Person",
    name: "Franck-Olivier",
    jobTitle: "Audioprothésiste DE",
  },
});
---

<BaseLayout
  title="Guide Expert Indépendant sur les Aides Auditives"
  description={`LeGuideAuditif.fr — Comparez ${totalAppareils} aides auditives de ${marques.length} marques. Avis d'expert par un audioprothésiste DE avec 25 ans d'expérience.`}
  schemaMarkup={schemaMarkup}
>
  <!-- Hero principal -->
  <section class="hero">
    <div class="container hero__inner">
      <h1>Le guide expert<br/>de vos aides auditives</h1>
      <p class="hero__subtitle">
        Comparez {totalAppareils} appareils de {marques.length} marques, testés et analysés
        par un audioprothésiste diplômé d'État avec 25 ans d'expérience.
      </p>
      <div class="hero__actions">
        <a href="/catalogue/" class="btn btn--primary">Explorer le catalogue</a>
        <a href="/devis/" class="btn btn--outline hero__btn-outline">Devis gratuit</a>
      </div>
      <p class="hero__trust">
        Indépendant · Aucun lien commercial avec les fabricants · Conseils d'expert
      </p>
    </div>
  </section>

  <!-- Appareils recommandés -->
  {enAvant.length > 0 && (
    <section class="container section-featured">
      <h2>Appareils recommandés par notre expert</h2>
      <div class="featured-grid">
        {enAvant.map((appareil) => (
          <ProductCard
            slug={appareil.data.slug}
            nom={appareil.data.nom}
            marque={appareil.data.marque}
            forme={appareil.data.forme}
            classe={appareil.data.classe}
            noteExpert={appareil.data.noteExpert}
            prixFourchette={appareil.data.prixFourchette}
            prixMin={appareil.data.prixMin}
            prixMax={appareil.data.prixMax}
            bluetooth={appareil.data.bluetooth}
            rechargeable={appareil.data.rechargeable}
            descriptionCourte={appareil.data.descriptionCourte}
            enAvant={true}
          />
        ))}
      </div>
      <div class="section-more">
        <a href="/catalogue/appareils/" class="btn btn--secondary">Voir tous les appareils →</a>
      </div>
    </section>
  )}

  <!-- Qui suis-je (E-E-A-T) -->
  <section class="author-section">
    <div class="container author-section__inner">
      <div class="author-section__avatar">FO</div>
      <div class="author-section__content">
        <h2>Votre guide : Franck-Olivier</h2>
        <p class="author-section__title">Audioprothésiste diplômé d'État — 25 ans d'expérience</p>
        <p>
          Fort de plus de 25 années de pratique en audioprothèse, dont 18 ans à la tête
          de centres Alain Afflelou Acousticien, je mets mon expertise au service de votre
          information. Ce guide est 100% indépendant : je ne vends aucun appareil ici et
          n'ai aucun lien commercial avec les fabricants.
        </p>
        <p>
          Mon objectif : vous donner les clés pour choisir en toute connaissance de cause,
          puis vous orienter vers un audioprothésiste compétent près de chez vous.
        </p>
      </div>
    </div>
  </section>

  <div class="container">
    <LeadCTA />
    <div style="margin-top: var(--space-6);">
      <HealthDisclaimer />
    </div>
  </div>
</BaseLayout>

<style>
  /* Hero */
  .hero {
    background: linear-gradient(135deg, var(--color-navy) 0%, var(--color-navy-dark) 100%);
    color: var(--color-white);
    padding: var(--space-16) 0;
    text-align: center;
  }
  .hero__inner {
    max-width: var(--max-width-narrow);
  }
  .hero h1 {
    font-size: clamp(2rem, 5vw, 3.5rem);
    color: var(--color-white);
    line-height: 1.15;
    margin-bottom: var(--space-4);
  }
  .hero__subtitle {
    font-size: var(--text-lg);
    color: var(--color-gray-300);
    line-height: 1.6;
    margin-bottom: var(--space-6);
  }
  .hero__actions {
    display: flex;
    gap: var(--space-3);
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: var(--space-4);
  }
  .hero__btn-outline {
    border-color: var(--color-white);
    color: var(--color-white);
  }
  .hero__btn-outline:hover {
    background: var(--color-white);
    color: var(--color-navy);
  }
  .hero__trust {
    font-size: var(--text-xs);
    color: var(--color-gray-500);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  /* Featured */
  .section-featured {
    padding: var(--space-12) 0;
  }
  .section-featured h2 {
    font-size: var(--text-2xl);
    text-align: center;
    margin-bottom: var(--space-8);
  }
  .featured-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: var(--space-6);
  }
  .section-more {
    text-align: center;
    margin-top: var(--space-8);
  }

  /* Auteur (E-E-A-T) */
  .author-section {
    background: var(--color-cream);
    padding: var(--space-12) 0;
  }
  .author-section__inner {
    display: flex;
    gap: var(--space-8);
    align-items: start;
  }
  .author-section__avatar {
    width: 80px;
    height: 80px;
    flex-shrink: 0;
    border-radius: 50%;
    background: var(--color-navy);
    color: var(--color-white);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: var(--text-2xl);
    font-weight: 700;
  }
  .author-section__content h2 {
    font-size: var(--text-2xl);
    margin-bottom: var(--space-1);
  }
  .author-section__title {
    font-size: var(--text-sm);
    color: var(--color-orange);
    font-weight: 600;
    margin-bottom: var(--space-4);
  }
  .author-section__content p {
    line-height: 1.7;
    color: var(--color-gray-700);
    margin-bottom: var(--space-3);
  }

  @media (max-width: 768px) {
    .author-section__inner { flex-direction: column; align-items: center; text-align: center; }
  }
</style>