---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact — LeGuideAuditif.fr"
  description="Contactez l'equipe de LeGuideAuditif.fr pour toute question sur nos guides, partenariats ou demande de renseignements."
>
  <section class="bg-creme py-16">
    <div class="max-w-[780px] mx-auto px-5">
      <h1 class="font-sans text-[38px] font-extrabold text-marine mb-8">Nous contacter</h1>
      <p class="text-lg leading-relaxed mb-6">
        Vous avez une question sur nos guides ? Vous souhaitez proposer un partenariat ? N'hesitez pas a nous ecrire.
      </p>
      <p class="text-lg leading-relaxed">
        Email : <a href="mailto:contact@leguideauditif.fr" class="text-orange font-semibold">contact@leguideauditif.fr</a>
      </p>
    </div>
  </section>
</BaseLayout>
