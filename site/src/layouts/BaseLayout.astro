---
/**
 * BaseLayout — Layout principal de LeGuideAuditif.fr
 * Palette : bleu marine #1B2E4A, crème #F8F5F0, orange #D97B3D, blanc #FFFFFF
 */
interface Props {
  title: string;
  description?: string;
  canonicalUrl?: string;
  ogImage?: string;
  schemaMarkup?: string;
}

const {
  title,
  description = "LeGuideAuditif.fr — Guide expert indépendant sur les aides auditives. Comparez les appareils, consultez les avis d'un audioprothésiste DE.",
  canonicalUrl,
  ogImage,
  schemaMarkup,
} = Astro.props;

const siteTitle = `${title} | LeGuideAuditif.fr`;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{siteTitle}</title>
    <meta name="description" content={description} />

    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}

    <!-- Open Graph -->
    <meta property="og:title" content={siteTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="fr_FR" />
    {ogImage && <meta property="og:image" content={ogImage} />}

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />

    <!-- Schema.org -->
    {schemaMarkup && <script type="application/ld+json" set:html={schemaMarkup} />}

    <style>
      @import "../styles/global.css";
    </style>
  </head>
  <body>
    <!-- ── Header ────────────────────────────────────────────── -->
    <header class="site-header">
      <div class="container site-header__inner">
        <a href="/" class="site-header__logo">
          <strong>LeGuideAuditif</strong><span>.fr</span>
        </a>
        <nav class="site-header__nav" aria-label="Navigation principale">
          <a href="/catalogue/">Catalogue</a>
          <a href="/catalogue/appareils/">Appareils</a>
          <a href="/catalogue/marques/">Marques</a>
          <a href="/devis/" class="btn btn--primary btn--sm">Devis gratuit</a>
        </nav>
      </div>
    </header>

    <!-- ── Main ──────────────────────────────────────────────── -->
    <main>
      <slot />
    </main>

    <!-- ── Footer ────────────────────────────────────────────── -->
    <footer class="site-footer">
      <div class="container site-footer__inner">
        <div class="site-footer__col">
          <strong>LeGuideAuditif.fr</strong>
          <p>Guide expert indépendant sur les aides auditives.<br/>
          Rédigé par un audioprothésiste DE avec 25 ans d'expérience.</p>
        </div>
        <div class="site-footer__col">
          <h4>Catalogue</h4>
          <a href="/catalogue/appareils/">Aides auditives</a>
          <a href="/catalogue/marques/">Marques</a>
          <a href="/devis/">Devis gratuit</a>
        </div>
        <div class="site-footer__col">
          <h4>Informations</h4>
          <a href="/mentions-legales/">Mentions légales</a>
          <a href="/politique-confidentialite/">Politique de confidentialité</a>
          <a href="/contact/">Contact</a>
        </div>
        <div class="site-footer__disclaimer">
          <p>Les prix indiqués sur ce site sont fournis à titre informatif et ne constituent pas une offre commerciale.
          La délivrance d'aides auditives est un acte médical réservé aux audioprothésistes diplômés d'État (article L. 4361-1 du Code de la santé publique).</p>
          <p>&copy; {new Date().getFullYear()} LeGuideAuditif.fr — Tous droits réservés</p>
        </div>
      </div>
    </footer>

    <style>
      /* Header */
      .site-header {
        background: var(--color-navy);
        color: var(--color-white);
        padding: var(--space-4) 0;
        position: sticky;
        top: 0;
        z-index: 100;
      }
      .site-header__inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: var(--space-4);
      }
      .site-header__logo {
        color: var(--color-white);
        font-size: var(--text-xl);
        text-decoration: none;
      }
      .site-header__logo span {
        color: var(--color-orange);
      }
      .site-header__nav {
        display: flex;
        align-items: center;
        gap: var(--space-6);
      }
      .site-header__nav a {
        color: var(--color-cream);
        font-size: var(--text-sm);
        font-weight: 500;
      }
      .site-header__nav a:hover {
        color: var(--color-white);
      }
      .btn--sm {
        padding: var(--space-2) var(--space-4);
        font-size: var(--text-sm);
      }

      /* Footer */
      .site-footer {
        background: var(--color-navy-dark);
        color: var(--color-gray-300);
        padding: var(--space-12) 0 var(--space-8);
        margin-top: var(--space-16);
      }
      .site-footer__inner {
        display: grid;
        grid-template-columns: 2fr 1fr 1fr;
        gap: var(--space-8);
      }
      .site-footer__col {
        display: flex;
        flex-direction: column;
        gap: var(--space-2);
      }
      .site-footer__col strong {
        color: var(--color-white);
        font-size: var(--text-lg);
      }
      .site-footer__col h4 {
        color: var(--color-orange);
        font-size: var(--text-sm);
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-bottom: var(--space-2);
      }
      .site-footer__col a {
        color: var(--color-gray-300);
        font-size: var(--text-sm);
      }
      .site-footer__col a:hover {
        color: var(--color-white);
      }
      .site-footer__disclaimer {
        grid-column: 1 / -1;
        border-top: 1px solid rgba(255,255,255,0.1);
        padding-top: var(--space-6);
        font-size: var(--text-xs);
        color: var(--color-gray-500);
      }

      @media (max-width: 768px) {
        .site-header__inner { flex-direction: column; gap: var(--space-2); }
        .site-header__nav { flex-wrap: wrap; gap: var(--space-3); }
        .site-footer__inner { grid-template-columns: 1fr; }
      }
    </style>
  </body>
</html>