---
const navLinks = [
  { href: '/guides/perte-auditive/', label: 'Perte auditive' },
  { href: '/guides/appareils-auditifs/', label: 'Appareils' },
  { href: '/guides/acouphenes/', label: 'Acouphenes' },
  { href: '/guides/remboursement/', label: 'Prix & remboursement' },
  { href: '/comparatifs/meilleur-appareil-auditif-2026/', label: 'Comparatifs' },
];
---

<!-- Top Bar -->
<div class="bg-marine text-white py-2 text-center font-sans text-[13px] tracking-wide">
  <span class="opacity-80">Guide independant redige par un audioprothesiste diplome d'Etat — 25 ans d'experience</span>
</div>

<!-- Header -->
<header class="bg-blanc border-b border-gris-clair sticky top-0 z-50 shadow-[0_2px_12px_rgba(27,46,74,0.06)]">
  <div class="max-w-[1140px] mx-auto px-5 flex items-center justify-between py-4">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-3 no-underline hover:no-underline">
      <div class="w-11 h-11 bg-marine rounded-xl flex items-center justify-center text-[22px]" aria-hidden="true">
        &#x1F442;
      </div>
      <div class="font-sans font-extrabold text-xl text-marine leading-tight">
        LeGuideAuditif
        <small class="block font-normal text-xs text-gris-texte tracking-wide">Le guide independant pour mieux entendre</small>
      </div>
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden lg:flex items-center gap-7" aria-label="Navigation principale">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="text-marine font-sans text-[15px] font-medium no-underline py-1.5 border-b-2 border-transparent hover:text-orange hover:border-orange transition-all duration-200 hover:no-underline"
        >
          {link.label}
        </a>
      ))}
      <a
        href="/trouver-audioprothesiste/"
        class="inline-flex items-center gap-2 px-5 py-2.5 bg-orange text-white font-sans text-sm font-semibold rounded-md hover:bg-orange-hover transition-colors no-underline hover:no-underline"
      >
        Trouver un audio
      </a>
    </nav>

    <!-- Mobile Menu Button -->
    <button
      class="lg:hidden flex flex-col gap-1.5 p-2"
      aria-label="Ouvrir le menu"
      id="mobile-menu-btn"
    >
      <span class="block w-6 h-0.5 bg-marine"></span>
      <span class="block w-6 h-0.5 bg-marine"></span>
      <span class="block w-6 h-0.5 bg-marine"></span>
    </button>
  </div>

  <!-- Mobile Nav -->
  <nav
    id="mobile-menu"
    class="hidden lg:hidden border-t border-gris-clair bg-blanc px-5 pb-4"
    aria-label="Navigation mobile"
  >
    {navLinks.map((link) => (
      <a
        href={link.href}
        class="block py-3 text-marine font-sans text-base font-medium border-b border-gris-clair no-underline hover:text-orange"
      >
        {link.label}
      </a>
    ))}
    <a
      href="/trouver-audioprothesiste/"
      class="mt-3 block text-center px-5 py-3 bg-orange text-white font-sans font-semibold rounded-md no-underline hover:bg-orange-hover"
    >
      Trouver un audioprothesiste
    </a>
  </nav>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    const expanded = menu?.classList.toggle('hidden');
    btn.setAttribute('aria-expanded', String(!expanded));
  });
</script>
