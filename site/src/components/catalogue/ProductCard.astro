---
/**
 * ProductCard — Card produit pour le listing catalogue
 * Affiche : nom, marque, forme, classe, note, prix, CTA
 */
interface Props {
  slug: string;
  nom: string;
  marque: string;
  forme: string;
  classe: string;
  noteExpert?: number;
  prixFourchette?: string;
  prixMin?: number | null;
  prixMax?: number | null;
  bluetooth?: boolean;
  rechargeable?: boolean;
  imageUrl?: string;
  descriptionCourte?: string;
  enAvant?: boolean;
}

const {
  slug,
  nom,
  marque,
  forme,
  classe,
  noteExpert,
  prixFourchette,
  prixMin,
  prixMax,
  bluetooth = false,
  rechargeable = false,
  imageUrl,
  descriptionCourte,
  enAvant = false,
} = Astro.props;

const marqueLabel = marque.charAt(0).toUpperCase() + marque.slice(1);
const formeLabels: Record<string, string> = {
  ric: "RIC",
  contour: "Contour",
  intra: "Intra",
  invisible: "Invisible",
};
const prixDisplay = prixFourchette || (prixMin && prixMax ? `${prixMin.toLocaleString("fr-FR")} € – ${prixMax.toLocaleString("fr-FR")} €` : null);
---

<article class:list={["product-card", { "product-card--featured": enAvant }]}>
  <a href={`/catalogue/appareils/${slug}/`} class="product-card__link">
    <div class="product-card__image">
      {imageUrl ? (
        <img src={imageUrl} alt={`${marqueLabel} ${nom}`} loading="lazy" width="280" height="200" />
      ) : (
        <div class="product-card__placeholder">
          <span>{marqueLabel}</span>
        </div>
      )}
      {enAvant && <span class="product-card__badge-featured">Recommandé</span>}
    </div>

    <div class="product-card__body">
      <div class="product-card__badges">
        <span class={`badge badge--${forme}`}>{formeLabels[forme] || forme}</span>
        <span class={`badge badge--classe${classe}`}>Classe {classe}</span>
      </div>

      <h3 class="product-card__title">
        <span class="product-card__brand">{marqueLabel}</span> {nom}
      </h3>

      {descriptionCourte && (
        <p class="product-card__desc">{descriptionCourte.slice(0, 120)}{descriptionCourte.length > 120 ? "..." : ""}</p>
      )}

      <div class="product-card__features">
        {bluetooth && <span class="product-card__feat">Bluetooth</span>}
        {rechargeable && <span class="product-card__feat">Rechargeable</span>}
      </div>

      <div class="product-card__footer">
        {noteExpert && (
          <div class="note-expert">
            <span class="note-expert__value">{noteExpert}</span>
            <span class="note-expert__max">/10</span>
          </div>
        )}
        {prixDisplay && (
          <div class="product-card__price">{prixDisplay}</div>
        )}
      </div>
    </div>
  </a>
</article>

<style>
  .product-card {
    background: var(--color-white);
    border: 1px solid var(--color-gray-200);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: box-shadow 0.2s, transform 0.2s;
  }
  .product-card:hover {
    box-shadow: var(--shadow-lg);
    transform: translateY(-2px);
  }
  .product-card--featured {
    border-color: var(--color-orange);
    border-width: 2px;
  }
  .product-card__link {
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    height: 100%;
  }
  .product-card__image {
    position: relative;
    background: var(--color-cream);
    aspect-ratio: 4/3;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .product-card__image img {
    object-fit: contain;
    width: 100%;
    height: 100%;
    padding: var(--space-4);
  }
  .product-card__placeholder {
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
    color: var(--color-gray-300);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
  .product-card__badge-featured {
    position: absolute;
    top: var(--space-3);
    left: var(--space-3);
    background: var(--color-orange);
    color: var(--color-white);
    font-size: var(--text-xs);
    font-weight: 700;
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-full);
    text-transform: uppercase;
  }
  .product-card__body {
    padding: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    flex: 1;
  }
  .product-card__badges {
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
  }
  .product-card__title {
    font-family: var(--font-heading);
    font-size: var(--text-lg);
    color: var(--color-navy);
    line-height: 1.3;
  }
  .product-card__brand {
    color: var(--color-gray-500);
    font-weight: 400;
    font-size: var(--text-sm);
    display: block;
  }
  .product-card__desc {
    font-size: var(--text-sm);
    color: var(--color-gray-700);
    line-height: 1.5;
  }
  .product-card__features {
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
  }
  .product-card__feat {
    font-size: var(--text-xs);
    background: var(--color-gray-100);
    color: var(--color-gray-700);
    padding: 2px var(--space-2);
    border-radius: var(--radius-sm);
  }
  .product-card__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: auto;
    padding-top: var(--space-3);
    border-top: 1px solid var(--color-gray-100);
  }
  .product-card__price {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-navy);
  }
</style>